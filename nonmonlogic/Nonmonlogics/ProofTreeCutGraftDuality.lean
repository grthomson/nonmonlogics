    ProofTheoreticHopfThreeMainGoalsCompleted base ↔
      ProofTheoreticHopfMainResult base := by
  constructor
  · intro h
    exact
      ⟨ck_cut_graft_duality_marquee base,
        nonmonotonic_weakening_grafting_marquee base,
        (proofTheoreticHopf_completed_iff_og_primitive_antipode_formula
          (base := base)).1 h⟩
  · intro h
    exact
      (proofTheoreticHopf_completed_iff_og_primitive_antipode_formula
        (base := base)).2 h.2.2

