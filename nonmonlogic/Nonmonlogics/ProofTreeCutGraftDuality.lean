import Nonmonlogics.ProofTreeHopf
import Nonmonlogics.DerivableHypersequent
import Nonmonlogics.GrossmanLarssonOudomGuinCoalgebra
import Nonmonlogics.GrossmanLarssonOudomGuinHopfRigidity

open Syntax

/-!
# Cut/graft interface for proof-tree hypersequents

This file records the proof-theoretic bridge between the two algebraic
operations that now coexist in the development.

* The Hopf-algebra multiplication on `HypersequentAlgebra K` is external
  juxtaposition of proof-labelled hypersequents, i.e. forest union.
* Matching-leaf grafting is the internal proof-composition operation.  It is
  the operation whose stable quotient satisfies the pre-Lie identity.
* The coproduct is the admissible-cut tensor splitting.  The coefficient-level
  duality problem is to compare those cuts with matching-leaf grafting
  reconstructions.

The point is not to hide the remaining work.  The named targets at the end are
the precise local coefficient statements we should attack next.
-/

noncomputable section

namespace QuotientConnected
namespace HypersequentRoute
namespace CutGraftDuality

attribute [local instance] QuotientConnected.CoproductSupport.stableUEATensor_ring
attribute [local instance] QuotientConnected.CoproductSupport.stableUEATensor_algebra

/-! ## Carrier bookkeeping -/

/--
The completed CK-style Hopf algebra currently lives on finite linear
combinations of hypersequents, i.e. finite forests of proof-tree labels.
-/
abbrev AmbientForestHopfCarrier (K : Type) [CommRing K] :=
  ProofTreeHopfCarrier K

/--
The grafting/pre-Lie side starts on the free linear carrier generated by single
proof trees.
-/
abbrev AmbientGraftingCarrier :=
  PreLieCarrier

/--
The proof-theoretic grafting carrier over a material base is not all raw
proof-tree syntax: it is the linear span/submodule generated by genuinely
derivable proof trees.
-/
abbrev ProofTheoreticGraftingCarrier (base : BaseRel) :=
  DerivablePreLieCarrier base

/--
The proof-theoretic hypersequent carrier over a material base is the subtype
of hypersequents all of whose proof-tree components are genuinely derivable.
-/
abbrev ProofTheoreticHypersequentCarrier (base : BaseRel) :=
  DerivableProofHypersequent base

@[simp]
theorem ambientForestHopfCarrier_eq_hypersequentAlgebra
    (K : Type) [CommRing K] :
    AmbientForestHopfCarrier K = HypersequentAlgebra K := rfl

@[simp]
theorem ambientGraftingCarrier_eq_preLieCarrier :
    AmbientGraftingCarrier = PreLieCarrier := rfl

/--
The forest Hopf carrier and the grafting carrier are not definitionally the
same carrier: forests are generated by hypersequents, while grafting is
generated by individual proof trees.

The duality problem should therefore be phrased through comparison maps and
support/coefficient theorems, not by pretending the two sides already share a
single carrier.
-/
def CarrierBridgeTarget : Prop :=
  ∃ toForest : AmbientGraftingCarrier →ₗ[ℤ] AmbientForestHopfCarrier ℤ,
    ∀ t : PTree, toForest (treeGen t) = treeMonomial ℤ t

theorem primitiveToHypersequentAlgebra_is_carrier_bridge :
    CarrierBridgeTarget := by
  exact ⟨primitiveToHypersequentAlgebra,
    primitiveToHypersequentAlgebra_treeGen⟩

/-! ## The two Hopf sides we ultimately want to compare -/

/--
The completed CK/forest side: this is the Hopf algebra already built in
`ProofTreeHopf.lean`.

Its product is external hypersequent/forest juxtaposition; its coproduct is
the normalized admissible-cut coproduct.
-/
abbrev CompletedForestHopfSide (K : Type) [CommRing K] :=
  HopfAlgebra K (ProofTreeHopfCarrier K)

/-- The completed CK/forest Hopf side exists. -/
theorem completed_forest_hopf_side_exists
    (K : Type) [CommRing K]
    [LeftDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    [RightDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))] :
    Nonempty (CompletedForestHopfSide K) := by
  exact proofTreeHopfAlgebra_exists K

/--
The primitive stable quotient generated by the constrained grafting/pre-Lie
story.  This is the Lie/pre-Lie carrier before adjoining a unit.
-/
abbrev GraftingPrimitiveHopfCarrier :=
  PreLieDifferenceStableQuotient

/--
The UEA carrier for the Oudom-Guin side.

This is where the grafting/pre-Lie route should become an honest Hopf algebra:
the unit, counit, primitive coproduct, and antipode live naturally in the UEA,
not on the bare pre-Lie quotient alone.
-/
abbrev GraftingUEAHopfCarrier :=
  preLieDifferenceStableQuotientUEA

/--
The carrier-correct OG coalgebra side already isolated in
`GrossmanLarssonOudomGuinCoalgebra.lean`.

This is weaker than the full Hopf side: it records the UEA carrier, primitive
coproduct/counit, coalgebra axioms, and GL/OG intertwining equation.
-/
def OudomGuinGraftingCoalgebraSide : Prop :=
  ∃ _H : QuotientConnected.CoproductSupport.OudomGuinUEAHopfCarrierTarget,
    True

/-- The OG/grafting coalgebra carrier target exists in the current development. -/
theorem oudomGuin_grafting_coalgebra_side_exists :
    OudomGuinGraftingCoalgebraSide := by
  simpa [OudomGuinGraftingCoalgebraSide] using
    QuotientConnected.CoproductSupport.oudomGuinUEAHopfCarrierTarget_exists

/--
The missing OG/grafting Hopf side.

This is intentionally stated as a target, not smuggled in as already proved.
It asks for the full UEA Hopf package: carrier-correct primitive coproduct,
bialgebra multiplicativity, and antipode cancellation.
-/
def OudomGuinGraftingHopfSide : Prop :=
  ∃ _H : QuotientConnected.CoproductSupport.OudomGuinUEAHopfAlgebraTarget,
    True

/--
Tree generators embed into the OG UEA through the stable quotient exactly as
expected.

This is the generator-level bridge from proof trees to the grafting/OG Hopf
carrier.
-/
theorem og_uea_tree_generator_bridge (t : PTree) :
    QuotientConnected.CoproductSupport.stableUEACanonicalIota
        (mkPreLieDifferenceStableQuotient (treeGen t)) =
      stableUEA_treeGen t := by
  exact QuotientConnected.CoproductSupport.stableUEACanonicalIota_treeGen t

/--
The stable grafting quotient carries Mathlib's official `RightPreLieRing`
structure.

The multiplication in this typeclass instance is the opposite of the direct
grafting product, because Mathlib's right-pre-Lie convention makes the
associator symmetric in the last two arguments.
-/
noncomputable def graftingPrimitiveMathlibRightPreLieRing :
    RightPreLieRing GraftingPrimitiveHopfCarrier := by
  letI : Mul GraftingPrimitiveHopfCarrier :=
    ⟨preLieDifferenceStableQuotientOppMul⟩
  letI : NonUnitalNonAssocRing GraftingPrimitiveHopfCarrier := {
    mul := preLieDifferenceStableQuotientOppMul
    left_distrib := preLieDifferenceStableQuotientOppMul_left_distrib
    right_distrib := preLieDifferenceStableQuotientOppMul_right_distrib
    zero_mul := preLieDifferenceStableQuotientOppMul_zero_left
    mul_zero := preLieDifferenceStableQuotientOppMul_zero_right
  }
  exact {
    assoc_symm' := preLieDifferenceStableQuotientOppMul_assoc_symm
  }

/-- The official Mathlib right-pre-Lie multiplication is exactly opposite grafting. -/
theorem graftingPrimitiveMathlibRightPreLieRing_mul
    (a b : GraftingPrimitiveHopfCarrier) :
    letI : RightPreLieRing GraftingPrimitiveHopfCarrier :=
      graftingPrimitiveMathlibRightPreLieRing
    a * b = preLieDifferenceStableQuotientOppMul a b := by
  rfl

/-- The stable grafting quotient has the induced Mathlib Lie ring. -/
noncomputable def graftingPrimitiveMathlibLieRing :
    LieRing GraftingPrimitiveHopfCarrier :=
  preLieDifferenceStableQuotientLieRing

/-- The OG carrier is literally Mathlib's universal enveloping algebra. -/
theorem graftingUEA_is_mathlib_universalEnveloping :
    letI : LieRing GraftingPrimitiveHopfCarrier :=
      graftingPrimitiveMathlibLieRing
    GraftingUEAHopfCarrier =
      UniversalEnvelopingAlgebra ℤ GraftingPrimitiveHopfCarrier := by
  rfl

/-- The stable UEA insertion is Mathlib's canonical UEA map `ι`. -/
theorem graftingUEA_iota_is_mathlib_iota :
    letI : LieRing GraftingPrimitiveHopfCarrier :=
      graftingPrimitiveMathlibLieRing
    preLieDifferenceStableQuotientUEA_ι =
      UniversalEnvelopingAlgebra.ι ℤ
        (L := GraftingPrimitiveHopfCarrier) := by
  rfl

/--
The Lie primitive operation induced by grafting on the stable quotient.

This is the antisymmetrization of the descended GL/pre-Lie grafting product.
It is the operation that the OG universal enveloping algebra is meant to
envelop.
-/
noncomputable def stableGraftingLieBracket
    (a b : GraftingPrimitiveHopfCarrier) :
    GraftingPrimitiveHopfCarrier :=
  preLieDifferenceStableQuotientMul a b -
    preLieDifferenceStableQuotientMul b a

/--
The Lie bracket convention used by the Mathlib/OG interface.

Because the available theorem is a right-pre-Lie law, Mathlib's
`RightPreLieRing` instance uses the opposite multiplication.  This bracket is
therefore the commutator of the opposite grafting product.
-/
noncomputable def stableOudomGuinLieBracket
    (a b : GraftingPrimitiveHopfCarrier) :
    GraftingPrimitiveHopfCarrier :=
  preLieDifferenceStableQuotientOppMul a b -
    preLieDifferenceStableQuotientOppMul b a

/--
The precise Mathlib interface for the grafting/Oudom-Guin side.

This says the pre-Lie, Lie, and UEA objects used by the proof-tree
construction are not parallel hand-rolled notions: they are actual instances
of the Mathlib hierarchy.
-/
structure MathlibOudomGuinGraftingInterface : Prop where
  rightPreLie_ring :
    ∃ _inst : RightPreLieRing GraftingPrimitiveHopfCarrier, True
  rightPreLie_mul_is_opposite_grafting :
    ∀ a b : GraftingPrimitiveHopfCarrier,
      letI : RightPreLieRing GraftingPrimitiveHopfCarrier :=
        graftingPrimitiveMathlibRightPreLieRing
      a * b = preLieDifferenceStableQuotientOppMul a b
  lie_ring :
    ∃ _inst : LieRing GraftingPrimitiveHopfCarrier, True
  lie_bracket_is_og_grafting_commutator :
    ∀ a b : GraftingPrimitiveHopfCarrier,
      letI : LieRing GraftingPrimitiveHopfCarrier :=
        graftingPrimitiveMathlibLieRing
      stableOudomGuinLieBracket a b = ⁅a, b⁆
  uea_is_mathlib_universal_enveloping :
    letI : LieRing GraftingPrimitiveHopfCarrier :=
      graftingPrimitiveMathlibLieRing
    GraftingUEAHopfCarrier =
      UniversalEnvelopingAlgebra ℤ GraftingPrimitiveHopfCarrier
  uea_iota_is_mathlib_iota :
    letI : LieRing GraftingPrimitiveHopfCarrier :=
      graftingPrimitiveMathlibLieRing
    preLieDifferenceStableQuotientUEA_ι =
      UniversalEnvelopingAlgebra.ι ℤ
        (L := GraftingPrimitiveHopfCarrier)

/--
The proved grafting/pre-Lie input for the Oudom-Guin side.

This is the algebraic content already established before the full Hopf target:
the GL product is constrained matching-leaf grafting, it descends to the
stable quotient, and the descended product satisfies the pre-Lie identity.
-/
structure OudomGuinGraftingPreLieSide : Prop where
  product_descends_grafting :
    ∀ a b : AmbientGraftingCarrier,
      preLieDifferenceStableQuotientMul
          (mkPreLieDifferenceStableQuotient a)
          (mkPreLieDifferenceStableQuotient b) =
        mkPreLieDifferenceStableQuotient (graftPreLie a b)
  preLie_identity :
    ∀ a b c : GraftingPrimitiveHopfCarrier,
      preLieDifferenceStableQuotientAssociator a b c =
        preLieDifferenceStableQuotientAssociator b a c
  mathlib_rightPreLie_ring :
    ∃ _inst : RightPreLieRing GraftingPrimitiveHopfCarrier, True
  mathlib_lie_ring :
    ∃ _inst : LieRing GraftingPrimitiveHopfCarrier, True
  mathlib_interface :
    MathlibOudomGuinGraftingInterface
  uea_carrier_is_stable_enveloping :
    GraftingUEAHopfCarrier = preLieDifferenceStableQuotientUEA
  tree_generator_bridge :
    ∀ t : PTree,
      QuotientConnected.CoproductSupport.stableUEACanonicalIota
          (mkPreLieDifferenceStableQuotient (treeGen t)) =
        stableUEA_treeGen t

/-- The current development already proves the grafting/pre-Lie input. -/
theorem oudomGuin_grafting_preLie_side_exists :
    OudomGuinGraftingPreLieSide where
  product_descends_grafting := by
    intro a b
    exact preLieDifferenceStableQuotientMul_mk a b
  preLie_identity := by
    intro a b c
    exact proofTreeSpine_stable_quotient_preLie_identity a b c
  mathlib_rightPreLie_ring :=
    ⟨graftingPrimitiveMathlibRightPreLieRing, trivial⟩
  mathlib_lie_ring :=
    preLieDifferenceStableQuotient_admitsMathlibLieRing
  mathlib_interface := by
    refine
      { rightPreLie_ring := ?_
        rightPreLie_mul_is_opposite_grafting := ?_
        lie_ring := ?_
        lie_bracket_is_og_grafting_commutator := ?_
        uea_is_mathlib_universal_enveloping := ?_
        uea_iota_is_mathlib_iota := ?_ }
    · exact ⟨graftingPrimitiveMathlibRightPreLieRing, trivial⟩
    · intro a b
      exact graftingPrimitiveMathlibRightPreLieRing_mul a b
    · exact ⟨graftingPrimitiveMathlibLieRing, trivial⟩
    · intro a b
      letI : LieRing GraftingPrimitiveHopfCarrier :=
        graftingPrimitiveMathlibLieRing
      change
        stableOudomGuinLieBracket a b =
          preLieDifferenceStableQuotientOppMul a b -
            preLieDifferenceStableQuotientOppMul b a
      rfl
    · exact graftingUEA_is_mathlib_universalEnveloping
    · exact graftingUEA_iota_is_mathlib_iota
  uea_carrier_is_stable_enveloping := rfl
  tree_generator_bridge :=
    og_uea_tree_generator_bridge

/-- The grafting/Oudom-Guin side is an actual Mathlib pre-Lie/Lie/UEA interface. -/
theorem oudomGuin_grafting_mathlib_interface :
    MathlibOudomGuinGraftingInterface :=
  oudomGuin_grafting_preLie_side_exists.mathlib_interface

/-- The grafting/Oudom-Guin primitive carrier has an official Mathlib right-pre-Lie ring. -/
theorem oudomGuin_grafting_official_rightPreLie_ring :
    ∃ _inst : RightPreLieRing GraftingPrimitiveHopfCarrier, True :=
  oudomGuin_grafting_mathlib_interface.rightPreLie_ring

/-- The grafting/Oudom-Guin primitive carrier has the induced official Mathlib Lie ring. -/
theorem oudomGuin_grafting_official_lie_ring :
    ∃ _inst : LieRing GraftingPrimitiveHopfCarrier, True :=
  oudomGuin_grafting_mathlib_interface.lie_ring

/-! ## Direct base-indexed UEA on derivable proof trees -/

/--
The primitive Lie carrier we actually want for the proof-theoretic Hopf
algebra over a material base.

Unlike the ambient stable quotient, this carrier is generated from
`DerivableTree base`: the only primitive generators are classes of genuine
NMMS proof trees over the given base consequence relation.
-/
abbrev DerivablePrimitiveLieCarrier (base : BaseRel) :=
  QuotientConnected.CoproductSupport.DerivablePreLieStableQuotient base

/--
The direct Oudom-Guin UEA over the derivable proof-tree quotient for `base`.

This is the intended algebraic home of the grafting product when we claim to
be studying a Hopf algebra of nonmonotonic derivations rather than a Hopf
algebra of arbitrary decorated rooted trees.
-/
noncomputable abbrev DerivableUEA
    (base : BaseRel) [LieRing (DerivablePrimitiveLieCarrier base)] :=
  UniversalEnvelopingAlgebra ℤ (DerivablePrimitiveLieCarrier base)

/-- The canonical Lie insertion into the direct derivable UEA. -/
noncomputable abbrev derivableUEAι
    (base : BaseRel) [LieRing (DerivablePrimitiveLieCarrier base)] :
    DerivablePrimitiveLieCarrier base →ₗ⁅ℤ⁆ DerivableUEA base :=
  UniversalEnvelopingAlgebra.ι ℤ
    (L := DerivablePrimitiveLieCarrier base)

/-- The UEA generator associated to a derivable proof tree. -/
noncomputable def derivableUEATreeGen
    {base : BaseRel} [LieRing (DerivablePrimitiveLieCarrier base)]
    {t : PTree} (ht : DerivableTree base t) :
    DerivableUEA base :=
  derivableUEAι base
    (QuotientConnected.CoproductSupport.derivableStableTreeGen ht)

/-- The direct UEA generator associated to an actual NMMS derivation. -/
noncomputable def derivableUEAOfDerivation
    {base : BaseRel} [LieRing (DerivablePrimitiveLieCarrier base)]
    {s : MultiSequent} (d : NMMS base s) :
    DerivableUEA base :=
  derivableUEATreeGen (derivableTree_of_derivation d)

/-- Scalar multiplication by integers is a tower over itself on the direct UEA. -/
instance derivableUEA_int_int_isScalarTower
    (base : BaseRel) [LieRing (DerivablePrimitiveLieCarrier base)] :
    IsScalarTower ℤ ℤ (DerivableUEA base) :=
  @IsScalarTower.left ℤ (DerivableUEA base) inferInstance inferInstance

/-- The tensor square of the direct derivable UEA. -/
noncomputable abbrev DerivableUEATensor
    (base : BaseRel) [LieRing (DerivablePrimitiveLieCarrier base)] :=
  TensorProduct ℤ (DerivableUEA base) (DerivableUEA base)

instance derivableUEATensor_smulCommClass
    (base : BaseRel) [LieRing (DerivablePrimitiveLieCarrier base)] :
    SMulCommClass ℤ (DerivableUEA base) (DerivableUEA base) :=
  Algebra.to_smulCommClass
    (R := ℤ) (A := DerivableUEA base)

instance derivableUEATensor_isScalarTower
    (base : BaseRel) [LieRing (DerivablePrimitiveLieCarrier base)] :
    IsScalarTower ℤ (DerivableUEA base) (DerivableUEA base) :=
  IsScalarTower.right
    (R := ℤ) (A := DerivableUEA base)

noncomputable instance derivableUEATensor_ring
    (base : BaseRel) [LieRing (DerivablePrimitiveLieCarrier base)] :
    Ring (DerivableUEATensor base) :=
  Algebra.TensorProduct.instRing
    (R := ℤ)
    (A := DerivableUEA base)
    (B := DerivableUEA base)

noncomputable instance derivableUEATensor_algebra
    (base : BaseRel) [LieRing (DerivablePrimitiveLieCarrier base)] :
    Algebra ℤ (DerivableUEATensor base) :=
  Algebra.TensorProduct.instAlgebra
    (R := ℤ)
    (A := DerivableUEA base)
    (B := DerivableUEA base)

noncomputable instance derivableUEATensor_rightDistribClass
    (base : BaseRel) [LieRing (DerivablePrimitiveLieCarrier base)] :
    RightDistribClass (DerivableUEATensor base) where
  right_distrib := by
    intro a b c
    exact Distrib.right_distrib a b c

noncomputable instance derivableUEATensor_leftDistribClass
    (base : BaseRel) [LieRing (DerivablePrimitiveLieCarrier base)] :
    LeftDistribClass (DerivableUEATensor base) where
  left_distrib := by
    intro a b c
    exact Distrib.left_distrib a b c

noncomputable instance derivableUEATensor_lieRing
    (base : BaseRel) [LieRing (DerivablePrimitiveLieCarrier base)] :
    LieRing (DerivableUEATensor base) :=
  LieRing.ofAssociativeRing

noncomputable instance derivableUEATensor_lieAlgebra
    (base : BaseRel) [LieRing (DerivablePrimitiveLieCarrier base)] :
    LieAlgebra ℤ (DerivableUEATensor base) :=
  LieAlgebra.ofAssociativeAlgebra

/--
Elementary tensor multiplication in the direct derivable UEA tensor square.
This is the local algebraic calculation needed for the primitive OG
comultiplication.
-/
theorem derivableUEATensor_tmul_mul_tmul
    (base : BaseRel) [LieRing (DerivablePrimitiveLieCarrier base)]
    (a b c d : DerivableUEA base) :
    TensorProduct.tmul ℤ a b * TensorProduct.tmul ℤ c d =
      TensorProduct.tmul ℤ (a * c) (b * d) := by
  exact @Algebra.TensorProduct.tmul_mul_tmul
    ℤ (DerivableUEA base) (DerivableUEA base)
    inferInstance inferInstance inferInstance
    (derivableUEATensor_smulCommClass base)
    (derivableUEATensor_isScalarTower base)
    inferInstance inferInstance
    (derivableUEATensor_smulCommClass base)
    (derivableUEATensor_isScalarTower base)
    a c b d

/-- The primitive tensor formula on the direct derivable UEA. -/
noncomputable def derivableUEAPrimitiveTensor
    (base : BaseRel) [LieRing (DerivablePrimitiveLieCarrier base)]
    (q : DerivablePrimitiveLieCarrier base) :
    DerivableUEATensor base :=
  TensorProduct.tmul ℤ (derivableUEAι base q) 1 +
    TensorProduct.tmul ℤ 1 (derivableUEAι base q)

/--
Primitive tensors in the direct derivable UEA are closed under commutator.

This is the direct, base-indexed analogue of the ambient OG calculation.
-/
theorem derivableUEATensor_primitive_bracket
    (base : BaseRel) [LieRing (DerivablePrimitiveLieCarrier base)]
    (x y : DerivableUEA base) :
    Bracket.bracket
      (TensorProduct.tmul ℤ x (1 : DerivableUEA base) +
        TensorProduct.tmul ℤ (1 : DerivableUEA base) x)
      (TensorProduct.tmul ℤ y (1 : DerivableUEA base) +
        TensorProduct.tmul ℤ (1 : DerivableUEA base) y) =
      TensorProduct.tmul ℤ (Bracket.bracket x y)
        (1 : DerivableUEA base) +
        TensorProduct.tmul ℤ (1 : DerivableUEA base)
          (Bracket.bracket x y) := by
  rw [LieRing.of_associative_ring_bracket,
    LieRing.of_associative_ring_bracket]
  rw [add_mul, mul_add, mul_add, add_mul, mul_add, mul_add]
  rw [derivableUEATensor_tmul_mul_tmul base x 1 y 1,
    derivableUEATensor_tmul_mul_tmul base x 1 1 y,
    derivableUEATensor_tmul_mul_tmul base 1 x y 1,
    derivableUEATensor_tmul_mul_tmul base 1 x 1 y,
    derivableUEATensor_tmul_mul_tmul base y 1 x 1,
    derivableUEATensor_tmul_mul_tmul base y 1 1 x,
    derivableUEATensor_tmul_mul_tmul base 1 y x 1,
    derivableUEATensor_tmul_mul_tmul base 1 y 1 x]
  simp only [one_mul, mul_one, sub_eq_add_neg]
  rw [TensorProduct.add_tmul, TensorProduct.tmul_add]
  simp only [TensorProduct.neg_tmul, TensorProduct.tmul_neg]
  abel

/--
The direct primitive tensor map is a Lie morphism from the derivable
primitive carrier to the tensor square of its own UEA.
-/
theorem derivableUEAPrimitiveTensor_map_lie
    (base : BaseRel) [LieRing (DerivablePrimitiveLieCarrier base)]
    (q r : DerivablePrimitiveLieCarrier base) :
    derivableUEAPrimitiveTensor base ⁅q, r⁆ =
      ⁅derivableUEAPrimitiveTensor base q,
        derivableUEAPrimitiveTensor base r⁆ := by
  rw [derivableUEAPrimitiveTensor, derivableUEAPrimitiveTensor,
    derivableUEAPrimitiveTensor]
  rw [LieHom.map_lie (derivableUEAι base) q r]
  exact (derivableUEATensor_primitive_bracket base
    (derivableUEAι base q) (derivableUEAι base r)).symm

/-! ### Direct pre-Lie descent on the derivable stable quotient -/

/-- The restricted stable relation is preserved by grafting on the right. -/
theorem derivableGraftPreLie_right_preserves_stableRelation
    {base : BaseRel} {a b : DerivablePreLieCarrier base}
    (ha :
      a ∈ QuotientConnected.CoproductSupport.derivablePreLieStableRelation base) :
    derivableGraftPreLie base a b ∈
      QuotientConnected.CoproductSupport.derivablePreLieStableRelation base := by
  have ha' : (a : PreLieCarrier) ∈ preLieDifferenceStableSubmodule := by
    simpa [QuotientConnected.CoproductSupport.derivablePreLieStableRelation]
      using ha
  change
    (derivableGraftPreLie base a b : PreLieCarrier) ∈
      preLieDifferenceStableSubmodule
  simpa [derivableGraftPreLie_apply_val] using
    graftPreLie_right_preserves_preLieDifferenceStableSubmodule
      (a := (a : PreLieCarrier)) (b := (b : PreLieCarrier)) ha'

/-- The restricted stable relation is preserved by grafting on the left. -/
theorem derivableGraftPreLie_left_preserves_stableRelation
    {base : BaseRel} {a b : DerivablePreLieCarrier base}
    (hb :
      b ∈ QuotientConnected.CoproductSupport.derivablePreLieStableRelation base) :
    derivableGraftPreLie base a b ∈
      QuotientConnected.CoproductSupport.derivablePreLieStableRelation base := by
  have hb' : (b : PreLieCarrier) ∈ preLieDifferenceStableSubmodule := by
    simpa [QuotientConnected.CoproductSupport.derivablePreLieStableRelation]
      using hb
  change
    (derivableGraftPreLie base a b : PreLieCarrier) ∈
      preLieDifferenceStableSubmodule
  simpa [derivableGraftPreLie_apply_val] using
    graftPreLie_left_preserves_preLieDifferenceStableSubmodule
      (a := (a : PreLieCarrier)) (b := (b : PreLieCarrier)) hb'

/--
The restricted grafting product, viewed in the derivable stable quotient.
-/
noncomputable def derivableGraftPreLieModStableQuotient
    (base : BaseRel) :
    DerivablePreLieCarrier base →ₗ[ℤ]
      DerivablePreLieCarrier base →ₗ[ℤ]
        DerivablePrimitiveLieCarrier base where
  toFun := fun a =>
    (QuotientConnected.CoproductSupport.mkDerivablePreLieStableQuotient
        base).comp
      (derivableGraftPreLie base a)
  map_add' := by
    intro a₁ a₂
    apply LinearMap.ext
    intro b
    simp [LinearMap.comp_apply, LinearMap.map_add]
  map_smul' := by
    intro n a
    apply LinearMap.ext
    intro b
    change
      QuotientConnected.CoproductSupport.mkDerivablePreLieStableQuotient
          base ((derivableGraftPreLie base (n • a)) b) =
        (n •
          (QuotientConnected.CoproductSupport.mkDerivablePreLieStableQuotient
              base).comp (derivableGraftPreLie base a)) b
    calc
      QuotientConnected.CoproductSupport.mkDerivablePreLieStableQuotient
          base ((derivableGraftPreLie base (n • a)) b)
          =
          QuotientConnected.CoproductSupport.mkDerivablePreLieStableQuotient
            base (((n • derivableGraftPreLie base a) b)) := by
              rw [LinearMap.map_smul]
      _ = n •
          QuotientConnected.CoproductSupport.mkDerivablePreLieStableQuotient
            base ((derivableGraftPreLie base a) b) := by
            rw [LinearMap.smul_apply, LinearMap.map_smul]
      _ =
          (n •
            (QuotientConnected.CoproductSupport.mkDerivablePreLieStableQuotient
              base).comp (derivableGraftPreLie base a)) b := by
            rfl

/-- The stable relation is in the kernel of quotient-valued grafting. -/
theorem derivableStableRelation_le_ker_graftPreLieModStableQuotient
    (base : BaseRel) :
    QuotientConnected.CoproductSupport.derivablePreLieStableRelation base ≤
      (derivableGraftPreLieModStableQuotient base).ker := by
  intro a ha
  rw [LinearMap.mem_ker]
  ext b
  exact
    (Submodule.Quotient.mk_eq_zero
      (QuotientConnected.CoproductSupport.derivablePreLieStableRelation
        base)).2
      (derivableGraftPreLie_right_preserves_stableRelation
        (base := base) (a := a) (b := b) ha)

/-- The stable relation is in the kernel of flipped quotient-valued grafting. -/
theorem derivableStableRelation_le_ker_graftPreLieModStableQuotient_flip
    (base : BaseRel) :
    QuotientConnected.CoproductSupport.derivablePreLieStableRelation base ≤
      (derivableGraftPreLieModStableQuotient base).flip.ker := by
  intro b hb
  rw [LinearMap.mem_ker]
  ext a
  exact
    (Submodule.Quotient.mk_eq_zero
      (QuotientConnected.CoproductSupport.derivablePreLieStableRelation
        base)).2
      (derivableGraftPreLie_left_preserves_stableRelation
        (base := base) (a := a) (b := b) hb)

/--
Constrained derivable grafting descends to the base-indexed stable quotient.
-/
noncomputable def derivableStableQuotientMul
    (base : BaseRel) :
    DerivablePrimitiveLieCarrier base →ₗ[ℤ]
      DerivablePrimitiveLieCarrier base →ₗ[ℤ]
        DerivablePrimitiveLieCarrier base :=
  (derivableGraftPreLieModStableQuotient base).liftQ₂
    (QuotientConnected.CoproductSupport.derivablePreLieStableRelation base)
    (QuotientConnected.CoproductSupport.derivablePreLieStableRelation base)
    (derivableStableRelation_le_ker_graftPreLieModStableQuotient base)
    (derivableStableRelation_le_ker_graftPreLieModStableQuotient_flip base)

@[simp]
theorem derivableStableQuotientMul_mk
    {base : BaseRel}
    (a b : DerivablePreLieCarrier base) :
    derivableStableQuotientMul base
        (Submodule.Quotient.mk a)
        (Submodule.Quotient.mk b) =
      QuotientConnected.CoproductSupport.mkDerivablePreLieStableQuotient
        base (derivableGraftPreLie base a b) := by
  rfl

/-- The associator of the descended derivable quotient product. -/
noncomputable def derivableStableQuotientAssociator
    (base : BaseRel)
    (a b c : DerivablePrimitiveLieCarrier base) :
    DerivablePrimitiveLieCarrier base :=
  derivableStableQuotientMul base
      (derivableStableQuotientMul base a b) c -
    derivableStableQuotientMul base a
      (derivableStableQuotientMul base b c)

@[simp]
theorem derivableStableQuotientAssociator_mk
    {base : BaseRel}
    (a b c : DerivablePreLieCarrier base) :
    derivableStableQuotientAssociator base
      (Submodule.Quotient.mk a)
      (Submodule.Quotient.mk b)
      (Submodule.Quotient.mk c)
    =
    QuotientConnected.CoproductSupport.mkDerivablePreLieStableQuotient
      base (derivableGraftAssociator base a b c) := by
  unfold derivableStableQuotientAssociator derivableGraftAssociator
  rw [derivableStableQuotientMul_mk,
    derivableStableQuotientMul_mk]
  change
    derivableStableQuotientMul base
        (Submodule.Quotient.mk (derivableGraftPreLie base a b))
        (Submodule.Quotient.mk c) -
      derivableStableQuotientMul base
        (Submodule.Quotient.mk a)
        (Submodule.Quotient.mk (derivableGraftPreLie base b c))
    =
      QuotientConnected.CoproductSupport.mkDerivablePreLieStableQuotient
        base
        (derivableGraftPreLie base (derivableGraftPreLie base a b) c -
          derivableGraftPreLie base a (derivableGraftPreLie base b c))
  rw [derivableStableQuotientMul_mk, derivableStableQuotientMul_mk]
  exact
    (LinearMap.map_sub
      (QuotientConnected.CoproductSupport.mkDerivablePreLieStableQuotient
        base)
      (((derivableGraftPreLie base)
          (((derivableGraftPreLie base) a) b)) c)
      (((derivableGraftPreLie base) a)
          (((derivableGraftPreLie base) b) c))).symm

/--
Equality in the ambient stable quotient reflects equality in the derivable
stable quotient for representatives from the derivable submodule.
-/
theorem mkDerivableStableQuotient_eq_of_ambient_eq
    {base : BaseRel}
    {a b : DerivablePreLieCarrier base}
    (h :
      mkPreLieDifferenceStableQuotient (a : PreLieCarrier) =
        mkPreLieDifferenceStableQuotient (b : PreLieCarrier)) :
    QuotientConnected.CoproductSupport.mkDerivablePreLieStableQuotient
        base a =
      QuotientConnected.CoproductSupport.mkDerivablePreLieStableQuotient
        base b := by
  have hmem :
      (a : PreLieCarrier) - (b : PreLieCarrier) ∈
        preLieDifferenceStableSubmodule :=
    (Submodule.Quotient.eq preLieDifferenceStableSubmodule).1 h
  exact
    (Submodule.Quotient.eq
      (QuotientConnected.CoproductSupport.derivablePreLieStableRelation
        base)).2
      (by
        change
          ((a - b : DerivablePreLieCarrier base) : PreLieCarrier) ∈
            preLieDifferenceStableSubmodule
        simpa using hmem)

/--
The descended derivable quotient product satisfies the same pre-Lie associator
symmetry as the ambient stable quotient.
-/
theorem derivableStableQuotientAssociator_swap_left
    (base : BaseRel)
    (a b c : DerivablePrimitiveLieCarrier base) :
    derivableStableQuotientAssociator base a b c =
      derivableStableQuotientAssociator base b a c := by
  refine Quotient.inductionOn₃' a b c ?_
  intro a₀ b₀ c₀
  change
    derivableStableQuotientAssociator base
        (Submodule.Quotient.mk a₀)
        (Submodule.Quotient.mk b₀)
        (Submodule.Quotient.mk c₀) =
      derivableStableQuotientAssociator base
        (Submodule.Quotient.mk b₀)
        (Submodule.Quotient.mk a₀)
        (Submodule.Quotient.mk c₀)
  rw [derivableStableQuotientAssociator_mk,
    derivableStableQuotientAssociator_mk]
  apply mkDerivableStableQuotient_eq_of_ambient_eq
  simpa [stableProjectedAssociator, derivableGraftAssociator_val] using
    stableProjectedAssociator_swap_left_everywhere
      (a₀ : PreLieCarrier) (b₀ : PreLieCarrier) (c₀ : PreLieCarrier)

/-- Opposite multiplication for Mathlib's right-pre-Lie convention. -/
noncomputable def derivableStableQuotientOppMul
    (base : BaseRel)
    (a b : DerivablePrimitiveLieCarrier base) :
    DerivablePrimitiveLieCarrier base :=
  derivableStableQuotientMul base b a

@[simp]
theorem derivableStableQuotientOppMul_zero_left
    (base : BaseRel) (a : DerivablePrimitiveLieCarrier base) :
    derivableStableQuotientOppMul base 0 a = 0 := by
  change derivableStableQuotientMul base a 0 = 0
  simpa using LinearMap.map_zero (derivableStableQuotientMul base a)

@[simp]
theorem derivableStableQuotientOppMul_zero_right
    (base : BaseRel) (a : DerivablePrimitiveLieCarrier base) :
    derivableStableQuotientOppMul base a 0 = 0 := by
  change derivableStableQuotientMul base 0 a = 0
  exact LinearMap.congr_fun
    (LinearMap.map_zero (derivableStableQuotientMul base)) a

theorem derivableStableQuotientOppMul_left_distrib
    (base : BaseRel)
    (a b c : DerivablePrimitiveLieCarrier base) :
    derivableStableQuotientOppMul base a (b + c) =
      derivableStableQuotientOppMul base a b +
        derivableStableQuotientOppMul base a c := by
  change derivableStableQuotientMul base (b + c) a =
    derivableStableQuotientMul base b a +
      derivableStableQuotientMul base c a
  simpa using
    LinearMap.congr_fun
      (LinearMap.map_add (derivableStableQuotientMul base) b c) a

theorem derivableStableQuotientOppMul_right_distrib
    (base : BaseRel)
    (a b c : DerivablePrimitiveLieCarrier base) :
    derivableStableQuotientOppMul base (a + b) c =
      derivableStableQuotientOppMul base a c +
        derivableStableQuotientOppMul base b c := by
  change derivableStableQuotientMul base c (a + b) =
    derivableStableQuotientMul base c a +
      derivableStableQuotientMul base c b
  simpa using
    LinearMap.map_add (derivableStableQuotientMul base c) a b

theorem derivableStableQuotientOppMul_assoc_symm
    (base : BaseRel)
    (a b c : DerivablePrimitiveLieCarrier base) :
    derivableStableQuotientOppMul base
        (derivableStableQuotientOppMul base a b) c -
      derivableStableQuotientOppMul base a
        (derivableStableQuotientOppMul base b c) =
    derivableStableQuotientOppMul base
        (derivableStableQuotientOppMul base a c) b -
      derivableStableQuotientOppMul base a
        (derivableStableQuotientOppMul base c b) := by
  let m := derivableStableQuotientMul base
  have h0 :
      m (m c b) a - m c (m b a) =
        m (m b c) a - m b (m c a) := by
    simpa [derivableStableQuotientAssociator, m] using
      derivableStableQuotientAssociator_swap_left base c b a
  have hneg := congrArg Neg.neg h0
  change
    m c (m b a) - m (m c b) a =
      m b (m c a) - m (m b c) a
  simpa only [neg_sub] using hneg

/-- The derivable stable quotient carries Mathlib's right-pre-Lie ring. -/
noncomputable def derivableStableQuotientRightPreLieRing
    (base : BaseRel) :
    RightPreLieRing (DerivablePrimitiveLieCarrier base) := by
  letI : Mul (DerivablePrimitiveLieCarrier base) :=
    ⟨derivableStableQuotientOppMul base⟩
  letI : NonUnitalNonAssocRing (DerivablePrimitiveLieCarrier base) := {
    toAddCommGroup := Submodule.Quotient.addCommGroup
      (QuotientConnected.CoproductSupport.derivablePreLieStableRelation
        base)
    mul := derivableStableQuotientOppMul base
    left_distrib := derivableStableQuotientOppMul_left_distrib base
    right_distrib := derivableStableQuotientOppMul_right_distrib base
    zero_mul := derivableStableQuotientOppMul_zero_left base
    mul_zero := derivableStableQuotientOppMul_zero_right base
  }
  exact {
    assoc_symm' := derivableStableQuotientOppMul_assoc_symm base
  }

/--
The derivable stable quotient has the Lie ring induced by constrained
derivable grafting.
-/
noncomputable def derivableStableQuotientLieRing
    (base : BaseRel) :
    LieRing (DerivablePrimitiveLieCarrier base) := by
  letI : RightPreLieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientRightPreLieRing base
  exact LieAdmissibleRing.instLieRing

/-- Linear primitive tensor map for the direct derivable UEA. -/
noncomputable def derivableUEAPrimitiveTensorLinearDirect
    (base : BaseRel) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    DerivablePrimitiveLieCarrier base →ₗ[ℤ] DerivableUEATensor base := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  exact
    ((TensorProduct.mk ℤ (DerivableUEA base) (DerivableUEA base)).flip
        (1 : DerivableUEA base)).comp
        (derivableUEAι base).toLinearMap +
      ((TensorProduct.mk ℤ (DerivableUEA base) (DerivableUEA base))
        (1 : DerivableUEA base)).comp
        (derivableUEAι base).toLinearMap

@[simp]
theorem derivableUEAPrimitiveTensorLinearDirect_apply
    (base : BaseRel) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    ∀ q : DerivablePrimitiveLieCarrier base,
      derivableUEAPrimitiveTensorLinearDirect base q =
        derivableUEAPrimitiveTensor base q := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  intro q
  rfl

/-- The direct primitive tensor formula is a Lie morphism. -/
noncomputable def derivableUEAPrimitiveComulLieHomDirect
    (base : BaseRel) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    DerivablePrimitiveLieCarrier base →ₗ⁅ℤ⁆ DerivableUEATensor base := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  exact {
    derivableUEAPrimitiveTensorLinearDirect base with
    map_lie' := by
      intro q r
      simpa using derivableUEAPrimitiveTensor_map_lie base q r
  }

/--
Input needed to complete the direct base-indexed OG construction.

This is the remaining genuine closure theorem in mathematical form: the
derivable stable quotient must carry a Lie ring whose primitive tensor formula
is a Lie morphism.  Once this is supplied, the UEA comultiplication follows
formally from Mathlib's universal property.
-/
structure DirectDerivableUEAPrimitiveLieMorphismInput
    (base : BaseRel) :
    Type where
  lieRing : LieRing (DerivablePrimitiveLieCarrier base)
  primitiveLieHom :
    letI : LieRing (DerivablePrimitiveLieCarrier base) := lieRing
    DerivablePrimitiveLieCarrier base →ₗ⁅ℤ⁆ DerivableUEATensor base
  primitiveLieHom_formula :
    letI : LieRing (DerivablePrimitiveLieCarrier base) := lieRing
    ∀ q : DerivablePrimitiveLieCarrier base,
      primitiveLieHom q =
        TensorProduct.tmul ℤ (derivableUEAι base q) 1 +
          TensorProduct.tmul ℤ 1 (derivableUEAι base q)

/--
The direct OG comultiplication produced from a proof-theoretic Lie-morphism
input.  This algebra homomorphism lives on the UEA of the derivable stable
quotient for `base`.
-/
noncomputable def DirectDerivableUEAPrimitiveLieMorphismInput.comulAlgHom
    {base : BaseRel}
    (H : DirectDerivableUEAPrimitiveLieMorphismInput base) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) := H.lieRing
    DerivableUEA base →ₐ[ℤ] DerivableUEATensor base :=
  by
    letI : LieRing (DerivablePrimitiveLieCarrier base) := H.lieRing
    exact UniversalEnvelopingAlgebra.lift ℤ H.primitiveLieHom

/-- The UEA lift has the primitive formula on direct derivable UEA generators. -/
theorem DirectDerivableUEAPrimitiveLieMorphismInput.comulAlgHom_ι_formula
    {base : BaseRel}
    (H : DirectDerivableUEAPrimitiveLieMorphismInput base) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) := H.lieRing
    ∀ q : DerivablePrimitiveLieCarrier base,
      H.comulAlgHom (derivableUEAι base q) =
        TensorProduct.tmul ℤ (derivableUEAι base q) 1 +
          TensorProduct.tmul ℤ 1 (derivableUEAι base q) := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) := H.lieRing
  intro q
  have hlift :
      H.comulAlgHom (derivableUEAι base q) =
        H.primitiveLieHom q := by
    dsimp [DirectDerivableUEAPrimitiveLieMorphismInput.comulAlgHom,
      derivableUEAι]
    exact UniversalEnvelopingAlgebra.lift_ι_apply
      ℤ H.primitiveLieHom q
  rw [hlift]
  exact H.primitiveLieHom_formula q

/--
Direct primitive formula for a genuinely derivable proof tree, conditional only
on the missing direct Lie-morphism input.
-/
theorem DirectDerivableUEAPrimitiveLieMorphismInput.comulAlgHom_treeGen_formula
    {base : BaseRel}
    (H : DirectDerivableUEAPrimitiveLieMorphismInput base)
    {t : PTree} (ht : DerivableTree base t) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) := H.lieRing
    H.comulAlgHom (derivableUEATreeGen ht) =
      TensorProduct.tmul ℤ (derivableUEATreeGen ht) 1 +
        TensorProduct.tmul ℤ 1 (derivableUEATreeGen ht) := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) := H.lieRing
  simpa [derivableUEATreeGen] using
    H.comulAlgHom_ι_formula
      (QuotientConnected.CoproductSupport.derivableStableTreeGen ht)

/--
Direct primitive formula for an actual NMMS derivation.

This is now the precise first main theorem target: once constrained derivable
grafting gives the direct quotient its compatible Lie morphism, the OG
coproduct is an algebra homomorphism on the UEA generated by actual NMMS
derivations and has the expected primitive value on every derivation.
-/
theorem DirectDerivableUEAPrimitiveLieMorphismInput.comulAlgHom_derivation_formula
    {base : BaseRel}
    (H : DirectDerivableUEAPrimitiveLieMorphismInput base)
    {s : MultiSequent} (d : NMMS base s) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) := H.lieRing
    H.comulAlgHom (derivableUEAOfDerivation d) =
      TensorProduct.tmul ℤ (derivableUEAOfDerivation d) 1 +
        TensorProduct.tmul ℤ 1 (derivableUEAOfDerivation d) := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) := H.lieRing
  simpa [derivableUEAOfDerivation] using
    H.comulAlgHom_treeGen_formula (derivableTree_of_derivation d)

/--
The pre-Lie route supplies the direct Lie-morphism input for every material
base: the carrier is the derivable stable quotient, the Lie bracket is induced
by constrained grafting, and the primitive tensor formula is the Lie morphism.
-/
noncomputable def directDerivableUEAPrimitiveLieMorphismInput
    (base : BaseRel) :
    DirectDerivableUEAPrimitiveLieMorphismInput base where
  lieRing := derivableStableQuotientLieRing base
  primitiveLieHom := by
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    exact derivableUEAPrimitiveComulLieHomDirect base
  primitiveLieHom_formula := by
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    intro q
    change
      derivableUEAPrimitiveComulLieHomDirect base q =
        derivableUEAPrimitiveTensor base q
    exact derivableUEAPrimitiveTensorLinearDirect_apply base q

/--
The direct OG coproduct on the UEA generated by derivable proof trees over
`base`.
-/
noncomputable def directDerivableUEAComulAlgHom
    (base : BaseRel) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    DerivableUEA base →ₐ[ℤ] DerivableUEATensor base :=
  (directDerivableUEAPrimitiveLieMorphismInput base).comulAlgHom

/-- Direct primitive formula on every derivable primitive quotient class. -/
theorem directDerivableUEAComulAlgHom_ι_formula
    (base : BaseRel) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    ∀ q : DerivablePrimitiveLieCarrier base,
      directDerivableUEAComulAlgHom base (derivableUEAι base q) =
        TensorProduct.tmul ℤ (derivableUEAι base q) 1 +
          TensorProduct.tmul ℤ 1 (derivableUEAι base q) := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  intro q
  exact
    (directDerivableUEAPrimitiveLieMorphismInput base).comulAlgHom_ι_formula
      q

/--
The direct primitive coproduct is uniquely determined by its restriction to
the derivable primitive Lie carrier.
-/
theorem directDerivableUEAComulAlgHom_unique
    (base : BaseRel) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    ∀ Phi : DerivableUEA base →ₐ[ℤ] DerivableUEATensor base,
      (∀ q : DerivablePrimitiveLieCarrier base,
        Phi (derivableUEAι base q) =
          TensorProduct.tmul ℤ (derivableUEAι base q) 1 +
            TensorProduct.tmul ℤ 1 (derivableUEAι base q)) →
      Phi = directDerivableUEAComulAlgHom base := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  intro Phi hPhi
  refine
    (UniversalEnvelopingAlgebra.lift_unique
      (R := ℤ)
      (f := derivableUEAPrimitiveComulLieHomDirect base)
      Phi).1 ?_
  funext q
  change Phi (derivableUEAι base q) =
    derivableUEAPrimitiveComulLieHomDirect base q
  rw [hPhi q]
  change
    TensorProduct.tmul ℤ (derivableUEAι base q) 1 +
      TensorProduct.tmul ℤ 1 (derivableUEAι base q) =
        derivableUEAPrimitiveTensor base q
  rfl

/--
Existence and uniqueness of the direct primitive coproduct on the UEA of
derivable proof trees.
-/
theorem directDerivableUEAComulAlgHom_exists_unique
    (base : BaseRel) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    ∃! Phi : DerivableUEA base →ₐ[ℤ] DerivableUEATensor base,
      ∀ q : DerivablePrimitiveLieCarrier base,
        Phi (derivableUEAι base q) =
          TensorProduct.tmul ℤ (derivableUEAι base q) 1 +
            TensorProduct.tmul ℤ 1 (derivableUEAι base q) := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  refine
    ⟨directDerivableUEAComulAlgHom base,
      directDerivableUEAComulAlgHom_ι_formula base, ?_⟩
  intro Phi hPhi
  exact directDerivableUEAComulAlgHom_unique base Phi hPhi

/-- Direct primitive formula for every derivable proof tree. -/
theorem directDerivableUEAComulAlgHom_treeGen_formula
    {base : BaseRel} {t : PTree} (ht : DerivableTree base t) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    directDerivableUEAComulAlgHom base (derivableUEATreeGen ht) =
      TensorProduct.tmul ℤ (derivableUEATreeGen ht) 1 +
        TensorProduct.tmul ℤ 1 (derivableUEATreeGen ht) := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  exact
    (directDerivableUEAPrimitiveLieMorphismInput base).comulAlgHom_treeGen_formula
      ht

/--
Direct primitive formula for every actual NMMS derivation.

This is the first fully direct OG-side theorem: the algebra map lives on
`DerivableUEA base`, whose primitive carrier is the derivable stable quotient
over the same material consequence relation.
-/
theorem directDerivableUEAComulAlgHom_derivation_formula
    {base : BaseRel} {s : MultiSequent} (d : NMMS base s) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    directDerivableUEAComulAlgHom base (derivableUEAOfDerivation d) =
      TensorProduct.tmul ℤ (derivableUEAOfDerivation d) 1 +
        TensorProduct.tmul ℤ 1 (derivableUEAOfDerivation d) := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  exact
    (directDerivableUEAPrimitiveLieMorphismInput base).comulAlgHom_derivation_formula
      d

/-! ### Direct OG counit on the derivable UEA -/

/--
The direct OG counit on the UEA generated by derivable proof trees.

It is induced by the zero Lie morphism out of the derivable primitive carrier,
so every primitive proof-tree class has counit zero while the UEA unit has
counit one.
-/
noncomputable def directDerivableUEACounitAlgHom
    (base : BaseRel) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    DerivableUEA base →ₐ[ℤ] ℤ := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  exact UniversalEnvelopingAlgebra.lift ℤ
    (0 : DerivablePrimitiveLieCarrier base →ₗ⁅ℤ⁆ ℤ)

/-- The direct counit kills inserted derivable primitive classes. -/
@[simp]
theorem directDerivableUEACounitAlgHom_ι_formula
    (base : BaseRel)
    (q : DerivablePrimitiveLieCarrier base) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    directDerivableUEACounitAlgHom base (derivableUEAι base q) = 0 := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  change
    ((UniversalEnvelopingAlgebra.lift ℤ)
        (0 : DerivablePrimitiveLieCarrier base →ₗ⁅ℤ⁆ ℤ))
      ((UniversalEnvelopingAlgebra.ι ℤ) q) = 0
  exact
    UniversalEnvelopingAlgebra.lift_ι_apply ℤ
      (0 : DerivablePrimitiveLieCarrier base →ₗ⁅ℤ⁆ ℤ) q

/-- The direct counit kills every derivable proof-tree generator. -/
@[simp]
theorem directDerivableUEACounitAlgHom_treeGen_formula
    {base : BaseRel} {t : PTree}
    (ht : DerivableTree base t) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    directDerivableUEACounitAlgHom base (derivableUEATreeGen ht) = 0 := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  simp [derivableUEATreeGen]

/-- The direct counit kills every actual NMMS derivation generator. -/
@[simp]
theorem directDerivableUEACounitAlgHom_derivation_formula
    {base : BaseRel} {s : MultiSequent}
    (d : NMMS base s) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    directDerivableUEACounitAlgHom base (derivableUEAOfDerivation d) = 0 := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  simp [derivableUEAOfDerivation]

/-- The direct counit sends the empty product/unit to one. -/
@[simp]
theorem directDerivableUEACounitAlgHom_one
    (base : BaseRel) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    directDerivableUEACounitAlgHom base (1 : DerivableUEA base) = 1 := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  exact (directDerivableUEACounitAlgHom base).map_one

/-- The direct counit is multiplicative. -/
@[simp]
theorem directDerivableUEACounitAlgHom_mul
    (base : BaseRel) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    ∀ a b : DerivableUEA base,
      directDerivableUEACounitAlgHom base (a * b) =
        directDerivableUEACounitAlgHom base a *
          directDerivableUEACounitAlgHom base b := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  intro a b
  exact (directDerivableUEACounitAlgHom base).map_mul a b

/--
The direct counit is uniquely determined by killing every derivable primitive
generator.
-/
theorem directDerivableUEACounitAlgHom_unique
    (base : BaseRel) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    ∀ epsilon : DerivableUEA base →ₐ[ℤ] ℤ,
      (∀ q : DerivablePrimitiveLieCarrier base,
        epsilon (derivableUEAι base q) = 0) →
      epsilon = directDerivableUEACounitAlgHom base := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  intro epsilon hepsilon
  refine
    (UniversalEnvelopingAlgebra.lift_unique
      (R := ℤ)
      (f := (0 : DerivablePrimitiveLieCarrier base →ₗ⁅ℤ⁆ ℤ))
      epsilon).1 ?_
  funext q
  change epsilon (derivableUEAι base q) =
    (0 : DerivablePrimitiveLieCarrier base →ₗ⁅ℤ⁆ ℤ) q
  exact hepsilon q

/-- Existence and uniqueness of the direct UEA counit. -/
theorem directDerivableUEACounitAlgHom_exists_unique
    (base : BaseRel) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    ∃! epsilon : DerivableUEA base →ₐ[ℤ] ℤ,
      ∀ q : DerivablePrimitiveLieCarrier base,
        epsilon (derivableUEAι base q) = 0 := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  refine
    ⟨directDerivableUEACounitAlgHom base,
      directDerivableUEACounitAlgHom_ι_formula base, ?_⟩
  intro epsilon hepsilon
  exact directDerivableUEACounitAlgHom_unique base epsilon hepsilon

/--
The direct OG generator theorem on actual NMMS derivations: derivation
generators are primitive for the coproduct and killed by the counit.
-/
theorem directDerivableUEA_OG_derivation_generator_formula
    {base : BaseRel} {s : MultiSequent}
    (d : NMMS base s) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    directDerivableUEAComulAlgHom base (derivableUEAOfDerivation d) =
        TensorProduct.tmul ℤ (derivableUEAOfDerivation d) 1 +
          TensorProduct.tmul ℤ 1 (derivableUEAOfDerivation d) ∧
      directDerivableUEACounitAlgHom base (derivableUEAOfDerivation d) = 0 := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  exact
    ⟨directDerivableUEAComulAlgHom_derivation_formula d,
      directDerivableUEACounitAlgHom_derivation_formula d⟩

/-! ### Direct coalgebra laws from primitive proof-tree generators -/

/--
The local coalgebra equations at a single element of the direct derivable UEA.

This is stated as a pointwise condition because the present theorem is about
the proof-theoretic generators: primitive quotient classes, derivable proof
trees, and actual NMMS derivations.  The full algebra-level bialgebra laws are
the later global target.
-/
def DirectDerivableUEACoalgebraLawsAt
    (base : BaseRel)
    (x : @DerivableUEA base (derivableStableQuotientLieRing base)) : Prop :=
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  (TensorProduct.assoc ℤ
      (DerivableUEA base)
      (DerivableUEA base)
      (DerivableUEA base)).toLinearMap
      (((directDerivableUEAComulAlgHom base).toLinearMap.rTensor
        (DerivableUEA base))
        ((directDerivableUEAComulAlgHom base).toLinearMap x)) =
    ((directDerivableUEAComulAlgHom base).toLinearMap.lTensor
      (DerivableUEA base))
      ((directDerivableUEAComulAlgHom base).toLinearMap x) ∧
    ((directDerivableUEACounitAlgHom base).toLinearMap.rTensor
        (DerivableUEA base))
        ((directDerivableUEAComulAlgHom base).toLinearMap x) =
      TensorProduct.tmul ℤ (1 : ℤ) x ∧
    ((directDerivableUEACounitAlgHom base).toLinearMap.lTensor
        (DerivableUEA base))
        ((directDerivableUEAComulAlgHom base).toLinearMap x) =
      TensorProduct.tmul ℤ x (1 : ℤ)

/--
Coassociativity holds at every element whose coproduct is primitive.

Proof-theoretically, this says: once a derivation-class generator splits as
`x ⊗ 1 + 1 ⊗ x`, splitting it again on either side exposes the same
threefold tensor of proof data.
-/
theorem directDerivableUEAComul_coassoc_of_primitive_formula
    (base : BaseRel) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    ∀ x : DerivableUEA base,
      (directDerivableUEAComulAlgHom base).toLinearMap x =
          TensorProduct.tmul ℤ x 1 + TensorProduct.tmul ℤ 1 x →
      (TensorProduct.assoc ℤ
          (DerivableUEA base)
          (DerivableUEA base)
          (DerivableUEA base)).toLinearMap
          (((directDerivableUEAComulAlgHom base).toLinearMap.rTensor
            (DerivableUEA base))
            ((directDerivableUEAComulAlgHom base).toLinearMap x)) =
        ((directDerivableUEAComulAlgHom base).toLinearMap.lTensor
          (DerivableUEA base))
          ((directDerivableUEAComulAlgHom base).toLinearMap x) := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  intro x hΔ
  rw [hΔ]
  have hR :
      ((directDerivableUEAComulAlgHom base).toLinearMap.rTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ x 1 + TensorProduct.tmul ℤ 1 x) =
        ((directDerivableUEAComulAlgHom base).toLinearMap.rTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ x 1) +
        ((directDerivableUEAComulAlgHom base).toLinearMap.rTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ 1 x) :=
    ((directDerivableUEAComulAlgHom base).toLinearMap.rTensor
      (DerivableUEA base)).map_add _ _
  have hL :
      ((directDerivableUEAComulAlgHom base).toLinearMap.lTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ x 1 + TensorProduct.tmul ℤ 1 x) =
        ((directDerivableUEAComulAlgHom base).toLinearMap.lTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ x 1) +
        ((directDerivableUEAComulAlgHom base).toLinearMap.lTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ 1 x) :=
    ((directDerivableUEAComulAlgHom base).toLinearMap.lTensor
      (DerivableUEA base)).map_add _ _
  calc
    (TensorProduct.assoc ℤ
        (DerivableUEA base)
        (DerivableUEA base)
        (DerivableUEA base)).toLinearMap
        (((directDerivableUEAComulAlgHom base).toLinearMap.rTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ x 1 + TensorProduct.tmul ℤ 1 x))
        =
        (TensorProduct.assoc ℤ
          (DerivableUEA base)
          (DerivableUEA base)
          (DerivableUEA base)).toLinearMap
          (((directDerivableUEAComulAlgHom base).toLinearMap.rTensor
            (DerivableUEA base))
            (TensorProduct.tmul ℤ x 1) +
          ((directDerivableUEAComulAlgHom base).toLinearMap.rTensor
            (DerivableUEA base))
            (TensorProduct.tmul ℤ 1 x)) := by
          exact congrArg
            (fun z =>
              (TensorProduct.assoc ℤ
                (DerivableUEA base)
                (DerivableUEA base)
                (DerivableUEA base)).toLinearMap z) hR
    _ =
        (TensorProduct.assoc ℤ
          (DerivableUEA base)
          (DerivableUEA base)
          (DerivableUEA base)).toLinearMap
          (((directDerivableUEAComulAlgHom base).toLinearMap.rTensor
            (DerivableUEA base))
            (TensorProduct.tmul ℤ x 1)) +
        (TensorProduct.assoc ℤ
          (DerivableUEA base)
          (DerivableUEA base)
          (DerivableUEA base)).toLinearMap
          (((directDerivableUEAComulAlgHom base).toLinearMap.rTensor
            (DerivableUEA base))
            (TensorProduct.tmul ℤ 1 x)) := by
          exact
            ((TensorProduct.assoc ℤ
              (DerivableUEA base)
              (DerivableUEA base)
              (DerivableUEA base)).toLinearMap).map_add _ _
    _ =
        ((directDerivableUEAComulAlgHom base).toLinearMap.lTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ x 1) +
        ((directDerivableUEAComulAlgHom base).toLinearMap.lTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ 1 x) := by
          rw [LinearMap.rTensor_tmul, LinearMap.rTensor_tmul,
            LinearMap.lTensor_tmul, LinearMap.lTensor_tmul]
          have hΔone :
              (directDerivableUEAComulAlgHom base).toLinearMap
                  (1 : DerivableUEA base) =
                (1 : DerivableUEATensor base) := by
            exact (directDerivableUEAComulAlgHom base).map_one
          simp only [hΔ, hΔone, Algebra.TensorProduct.one_def]
          change
            (TensorProduct.assoc ℤ
              (DerivableUEA base)
              (DerivableUEA base)
              (DerivableUEA base))
              ((x ⊗ₜ[ℤ] (1 : DerivableUEA base) +
                  (1 : DerivableUEA base) ⊗ₜ[ℤ] x) ⊗ₜ[ℤ]
                (1 : DerivableUEA base)) +
              (TensorProduct.assoc ℤ
                (DerivableUEA base)
                (DerivableUEA base)
                (DerivableUEA base))
                (((1 : DerivableUEA base) ⊗ₜ[ℤ]
                  (1 : DerivableUEA base)) ⊗ₜ[ℤ] x) =
            x ⊗ₜ[ℤ]
                ((1 : DerivableUEA base) ⊗ₜ[ℤ]
                  (1 : DerivableUEA base)) +
              (1 : DerivableUEA base) ⊗ₜ[ℤ]
                (x ⊗ₜ[ℤ] (1 : DerivableUEA base) +
                  (1 : DerivableUEA base) ⊗ₜ[ℤ] x)
          have hAssocSum :
              (TensorProduct.assoc ℤ
                (DerivableUEA base)
                (DerivableUEA base)
                (DerivableUEA base))
                ((x ⊗ₜ[ℤ] (1 : DerivableUEA base) +
                    (1 : DerivableUEA base) ⊗ₜ[ℤ] x) ⊗ₜ[ℤ]
                  (1 : DerivableUEA base)) =
              x ⊗ₜ[ℤ]
                  ((1 : DerivableUEA base) ⊗ₜ[ℤ]
                    (1 : DerivableUEA base)) +
                (1 : DerivableUEA base) ⊗ₜ[ℤ]
                  (x ⊗ₜ[ℤ] (1 : DerivableUEA base)) := by
            calc
              (TensorProduct.assoc ℤ
                (DerivableUEA base)
                (DerivableUEA base)
                (DerivableUEA base))
                ((x ⊗ₜ[ℤ] (1 : DerivableUEA base) +
                    (1 : DerivableUEA base) ⊗ₜ[ℤ] x) ⊗ₜ[ℤ]
                  (1 : DerivableUEA base))
                  =
                  (TensorProduct.assoc ℤ
                    (DerivableUEA base)
                    (DerivableUEA base)
                    (DerivableUEA base))
                    ((x ⊗ₜ[ℤ] (1 : DerivableUEA base)) ⊗ₜ[ℤ]
                      (1 : DerivableUEA base) +
                    ((1 : DerivableUEA base) ⊗ₜ[ℤ] x) ⊗ₜ[ℤ]
                      (1 : DerivableUEA base)) := by
                    exact congrArg
                      (fun z =>
                        (TensorProduct.assoc ℤ
                          (DerivableUEA base)
                          (DerivableUEA base)
                          (DerivableUEA base)) z)
                      (TensorProduct.add_tmul
                        (x ⊗ₜ[ℤ] (1 : DerivableUEA base))
                        ((1 : DerivableUEA base) ⊗ₜ[ℤ] x)
                        (1 : DerivableUEA base))
              _ =
                  (TensorProduct.assoc ℤ
                    (DerivableUEA base)
                    (DerivableUEA base)
                    (DerivableUEA base))
                    ((x ⊗ₜ[ℤ] (1 : DerivableUEA base)) ⊗ₜ[ℤ]
                      (1 : DerivableUEA base)) +
                  (TensorProduct.assoc ℤ
                    (DerivableUEA base)
                    (DerivableUEA base)
                    (DerivableUEA base))
                    (((1 : DerivableUEA base) ⊗ₜ[ℤ] x) ⊗ₜ[ℤ]
                      (1 : DerivableUEA base)) := by
                    exact
                      ((TensorProduct.assoc ℤ
                        (DerivableUEA base)
                        (DerivableUEA base)
                        (DerivableUEA base)).toLinearMap).map_add _ _
              _ =
                  x ⊗ₜ[ℤ]
                      ((1 : DerivableUEA base) ⊗ₜ[ℤ]
                        (1 : DerivableUEA base)) +
                    (1 : DerivableUEA base) ⊗ₜ[ℤ]
                      (x ⊗ₜ[ℤ] (1 : DerivableUEA base)) := by
                    rfl
          have hTensorRight :
              (1 : DerivableUEA base) ⊗ₜ[ℤ]
                  (x ⊗ₜ[ℤ] (1 : DerivableUEA base) +
                    (1 : DerivableUEA base) ⊗ₜ[ℤ] x) =
                (1 : DerivableUEA base) ⊗ₜ[ℤ]
                    (x ⊗ₜ[ℤ] (1 : DerivableUEA base)) +
                  (1 : DerivableUEA base) ⊗ₜ[ℤ]
                    ((1 : DerivableUEA base) ⊗ₜ[ℤ] x) := by
            exact TensorProduct.tmul_add
              (1 : DerivableUEA base)
              (x ⊗ₜ[ℤ] (1 : DerivableUEA base))
              ((1 : DerivableUEA base) ⊗ₜ[ℤ] x)
          rw [hAssocSum, hTensorRight]
          simp
          abel
    _ =
        ((directDerivableUEAComulAlgHom base).toLinearMap.lTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ x 1 + TensorProduct.tmul ℤ 1 x) := by
          exact hL.symm

/-- The right counit law follows from the primitive formula and zero counit. -/
theorem directDerivableUEAComul_rightCounit_of_primitive_formula
    (base : BaseRel) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    ∀ x : DerivableUEA base,
      (directDerivableUEAComulAlgHom base).toLinearMap x =
          TensorProduct.tmul ℤ x 1 + TensorProduct.tmul ℤ 1 x →
      (directDerivableUEACounitAlgHom base).toLinearMap x = 0 →
      ((directDerivableUEACounitAlgHom base).toLinearMap.rTensor
          (DerivableUEA base))
          ((directDerivableUEAComulAlgHom base).toLinearMap x) =
        TensorProduct.tmul ℤ (1 : ℤ) x := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  intro x hΔ hε
  rw [hΔ]
  have hR :
      ((directDerivableUEACounitAlgHom base).toLinearMap.rTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ x 1 + TensorProduct.tmul ℤ 1 x) =
        ((directDerivableUEACounitAlgHom base).toLinearMap.rTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ x 1) +
        ((directDerivableUEACounitAlgHom base).toLinearMap.rTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ 1 x) :=
    ((directDerivableUEACounitAlgHom base).toLinearMap.rTensor
      (DerivableUEA base)).map_add _ _
  calc
    ((directDerivableUEACounitAlgHom base).toLinearMap.rTensor
        (DerivableUEA base))
        (TensorProduct.tmul ℤ x 1 + TensorProduct.tmul ℤ 1 x)
        =
        ((directDerivableUEACounitAlgHom base).toLinearMap.rTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ x 1) +
        ((directDerivableUEACounitAlgHom base).toLinearMap.rTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ 1 x) := hR
    _ = TensorProduct.tmul ℤ (1 : ℤ) x := by
      rw [LinearMap.rTensor_tmul, LinearMap.rTensor_tmul]
      rw [hε]
      simp

/-- The left counit law follows from the primitive formula and zero counit. -/
theorem directDerivableUEAComul_leftCounit_of_primitive_formula
    (base : BaseRel) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    ∀ x : DerivableUEA base,
      (directDerivableUEAComulAlgHom base).toLinearMap x =
          TensorProduct.tmul ℤ x 1 + TensorProduct.tmul ℤ 1 x →
      (directDerivableUEACounitAlgHom base).toLinearMap x = 0 →
      ((directDerivableUEACounitAlgHom base).toLinearMap.lTensor
          (DerivableUEA base))
          ((directDerivableUEAComulAlgHom base).toLinearMap x) =
        TensorProduct.tmul ℤ x (1 : ℤ) := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  intro x hΔ hε
  rw [hΔ]
  have hL :
      ((directDerivableUEACounitAlgHom base).toLinearMap.lTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ x 1 + TensorProduct.tmul ℤ 1 x) =
        ((directDerivableUEACounitAlgHom base).toLinearMap.lTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ x 1) +
        ((directDerivableUEACounitAlgHom base).toLinearMap.lTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ 1 x) :=
    ((directDerivableUEACounitAlgHom base).toLinearMap.lTensor
      (DerivableUEA base)).map_add _ _
  calc
    ((directDerivableUEACounitAlgHom base).toLinearMap.lTensor
        (DerivableUEA base))
        (TensorProduct.tmul ℤ x 1 + TensorProduct.tmul ℤ 1 x)
        =
        ((directDerivableUEACounitAlgHom base).toLinearMap.lTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ x 1) +
        ((directDerivableUEACounitAlgHom base).toLinearMap.lTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ 1 x) := hL
    _ = TensorProduct.tmul ℤ x (1 : ℤ) := by
      rw [LinearMap.lTensor_tmul, LinearMap.lTensor_tmul]
      rw [hε]
      simp

/--
Every primitive, counit-zero element satisfies the local coalgebra laws.

This is the reusable algebraic lemma behind the proof-theoretic generator
statements below.
-/
theorem directDerivableUEA_coalgebra_laws_of_primitive
    (base : BaseRel) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    ∀ x : DerivableUEA base,
      (directDerivableUEAComulAlgHom base).toLinearMap x =
          TensorProduct.tmul ℤ x 1 + TensorProduct.tmul ℤ 1 x →
      (directDerivableUEACounitAlgHom base).toLinearMap x = 0 →
      DirectDerivableUEACoalgebraLawsAt base x := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  intro x hΔ hε
  exact
    ⟨directDerivableUEAComul_coassoc_of_primitive_formula base x hΔ,
      directDerivableUEAComul_rightCounit_of_primitive_formula base x hΔ hε,
      directDerivableUEAComul_leftCounit_of_primitive_formula base x hΔ hε⟩

/-- The local coalgebra laws hold for every primitive quotient class. -/
theorem directDerivableUEA_OG_primitive_quotient_coalgebra_laws
    (base : BaseRel)
    (q : DerivablePrimitiveLieCarrier base) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    DirectDerivableUEACoalgebraLawsAt base (derivableUEAι base q) := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  exact
    directDerivableUEA_coalgebra_laws_of_primitive base
      (derivableUEAι base q)
      (directDerivableUEAComulAlgHom_ι_formula base q)
      (directDerivableUEACounitAlgHom_ι_formula base q)

/-- The local coalgebra laws hold for every derivable proof-tree generator. -/
theorem directDerivableUEA_OG_tree_generator_coalgebra_laws
    {base : BaseRel} {t : PTree}
    (ht : DerivableTree base t) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    DirectDerivableUEACoalgebraLawsAt base (derivableUEATreeGen ht) := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  exact
    directDerivableUEA_coalgebra_laws_of_primitive base
      (derivableUEATreeGen ht)
      (directDerivableUEAComulAlgHom_treeGen_formula ht)
      (directDerivableUEACounitAlgHom_treeGen_formula ht)

/-! ### Direct coalgebra laws on actual derivation generators -/

/--
The direct OG coproduct is coassociative on every actual NMMS derivation
generator.

This is the generator-level coalgebra law for the proof-theoretic carrier:
the element is not an arbitrary decorated tree, but the UEA class coming from
`NMMS.toTree d`.
-/
theorem directDerivableUEAComul_coassoc_derivation_formula
    {base : BaseRel} {s : MultiSequent}
    (d : NMMS base s) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    (TensorProduct.assoc ℤ
        (DerivableUEA base)
        (DerivableUEA base)
        (DerivableUEA base)).toLinearMap
        (((directDerivableUEAComulAlgHom base).toLinearMap.rTensor
          (DerivableUEA base))
          ((directDerivableUEAComulAlgHom base).toLinearMap
            (derivableUEAOfDerivation d))) =
      ((directDerivableUEAComulAlgHom base).toLinearMap.lTensor
        (DerivableUEA base))
        ((directDerivableUEAComulAlgHom base).toLinearMap
          (derivableUEAOfDerivation d)) := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  have hΔ :
      (directDerivableUEAComulAlgHom base).toLinearMap
          (derivableUEAOfDerivation d) =
        TensorProduct.tmul ℤ (derivableUEAOfDerivation d) 1 +
          TensorProduct.tmul ℤ 1 (derivableUEAOfDerivation d) :=
    directDerivableUEAComulAlgHom_derivation_formula d
  rw [hΔ]
  have hR :
      ((directDerivableUEAComulAlgHom base).toLinearMap.rTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ (derivableUEAOfDerivation d) 1 +
            TensorProduct.tmul ℤ 1 (derivableUEAOfDerivation d)) =
        ((directDerivableUEAComulAlgHom base).toLinearMap.rTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ (derivableUEAOfDerivation d) 1) +
        ((directDerivableUEAComulAlgHom base).toLinearMap.rTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ 1 (derivableUEAOfDerivation d)) :=
    ((directDerivableUEAComulAlgHom base).toLinearMap.rTensor
      (DerivableUEA base)).map_add _ _
  have hL :
      ((directDerivableUEAComulAlgHom base).toLinearMap.lTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ (derivableUEAOfDerivation d) 1 +
            TensorProduct.tmul ℤ 1 (derivableUEAOfDerivation d)) =
        ((directDerivableUEAComulAlgHom base).toLinearMap.lTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ (derivableUEAOfDerivation d) 1) +
        ((directDerivableUEAComulAlgHom base).toLinearMap.lTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ 1 (derivableUEAOfDerivation d)) :=
    ((directDerivableUEAComulAlgHom base).toLinearMap.lTensor
      (DerivableUEA base)).map_add _ _
  calc
    (TensorProduct.assoc ℤ
        (DerivableUEA base)
        (DerivableUEA base)
        (DerivableUEA base)).toLinearMap
        (((directDerivableUEAComulAlgHom base).toLinearMap.rTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ (derivableUEAOfDerivation d) 1 +
            TensorProduct.tmul ℤ 1 (derivableUEAOfDerivation d)))
        =
        (TensorProduct.assoc ℤ
          (DerivableUEA base)
          (DerivableUEA base)
          (DerivableUEA base)).toLinearMap
          (((directDerivableUEAComulAlgHom base).toLinearMap.rTensor
            (DerivableUEA base))
            (TensorProduct.tmul ℤ (derivableUEAOfDerivation d) 1) +
          ((directDerivableUEAComulAlgHom base).toLinearMap.rTensor
            (DerivableUEA base))
            (TensorProduct.tmul ℤ 1 (derivableUEAOfDerivation d))) := by
          exact congrArg
            (fun z =>
              (TensorProduct.assoc ℤ
                (DerivableUEA base)
                (DerivableUEA base)
                (DerivableUEA base)).toLinearMap z) hR
    _ =
        (TensorProduct.assoc ℤ
          (DerivableUEA base)
          (DerivableUEA base)
          (DerivableUEA base)).toLinearMap
          (((directDerivableUEAComulAlgHom base).toLinearMap.rTensor
            (DerivableUEA base))
            (TensorProduct.tmul ℤ (derivableUEAOfDerivation d) 1)) +
        (TensorProduct.assoc ℤ
          (DerivableUEA base)
          (DerivableUEA base)
          (DerivableUEA base)).toLinearMap
          (((directDerivableUEAComulAlgHom base).toLinearMap.rTensor
            (DerivableUEA base))
            (TensorProduct.tmul ℤ 1 (derivableUEAOfDerivation d))) := by
          exact
            ((TensorProduct.assoc ℤ
              (DerivableUEA base)
              (DerivableUEA base)
              (DerivableUEA base)).toLinearMap).map_add _ _
    _ =
        ((directDerivableUEAComulAlgHom base).toLinearMap.lTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ (derivableUEAOfDerivation d) 1) +
        ((directDerivableUEAComulAlgHom base).toLinearMap.lTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ 1 (derivableUEAOfDerivation d)) := by
          rw [LinearMap.rTensor_tmul, LinearMap.rTensor_tmul,
            LinearMap.lTensor_tmul, LinearMap.lTensor_tmul]
          have hΔone :
              (directDerivableUEAComulAlgHom base).toLinearMap
                  (1 : DerivableUEA base) =
                (1 : DerivableUEATensor base) := by
            exact (directDerivableUEAComulAlgHom base).map_one
          simp only [hΔ, hΔone, Algebra.TensorProduct.one_def]
          let x : DerivableUEA base := derivableUEAOfDerivation d
          change
            (TensorProduct.assoc ℤ
              (DerivableUEA base)
              (DerivableUEA base)
              (DerivableUEA base))
              ((x ⊗ₜ[ℤ] (1 : DerivableUEA base) +
                  (1 : DerivableUEA base) ⊗ₜ[ℤ] x) ⊗ₜ[ℤ]
                (1 : DerivableUEA base)) +
              (TensorProduct.assoc ℤ
                (DerivableUEA base)
                (DerivableUEA base)
                (DerivableUEA base))
                (((1 : DerivableUEA base) ⊗ₜ[ℤ]
                  (1 : DerivableUEA base)) ⊗ₜ[ℤ] x) =
            x ⊗ₜ[ℤ]
                ((1 : DerivableUEA base) ⊗ₜ[ℤ]
                  (1 : DerivableUEA base)) +
              (1 : DerivableUEA base) ⊗ₜ[ℤ]
                (x ⊗ₜ[ℤ] (1 : DerivableUEA base) +
                  (1 : DerivableUEA base) ⊗ₜ[ℤ] x)
          have hAssocSum :
              (TensorProduct.assoc ℤ
                (DerivableUEA base)
                (DerivableUEA base)
                (DerivableUEA base))
                ((x ⊗ₜ[ℤ] (1 : DerivableUEA base) +
                    (1 : DerivableUEA base) ⊗ₜ[ℤ] x) ⊗ₜ[ℤ]
                  (1 : DerivableUEA base)) =
              x ⊗ₜ[ℤ]
                  ((1 : DerivableUEA base) ⊗ₜ[ℤ]
                    (1 : DerivableUEA base)) +
                (1 : DerivableUEA base) ⊗ₜ[ℤ]
                  (x ⊗ₜ[ℤ] (1 : DerivableUEA base)) := by
            calc
              (TensorProduct.assoc ℤ
                (DerivableUEA base)
                (DerivableUEA base)
                (DerivableUEA base))
                ((x ⊗ₜ[ℤ] (1 : DerivableUEA base) +
                    (1 : DerivableUEA base) ⊗ₜ[ℤ] x) ⊗ₜ[ℤ]
                  (1 : DerivableUEA base))
                  =
                  (TensorProduct.assoc ℤ
                    (DerivableUEA base)
                    (DerivableUEA base)
                    (DerivableUEA base))
                    ((x ⊗ₜ[ℤ] (1 : DerivableUEA base)) ⊗ₜ[ℤ]
                      (1 : DerivableUEA base) +
                    ((1 : DerivableUEA base) ⊗ₜ[ℤ] x) ⊗ₜ[ℤ]
                      (1 : DerivableUEA base)) := by
                    exact congrArg
                      (fun z =>
                        (TensorProduct.assoc ℤ
                          (DerivableUEA base)
                          (DerivableUEA base)
                          (DerivableUEA base)) z)
                      (TensorProduct.add_tmul
                        (x ⊗ₜ[ℤ] (1 : DerivableUEA base))
                        ((1 : DerivableUEA base) ⊗ₜ[ℤ] x)
                        (1 : DerivableUEA base))
              _ =
                  (TensorProduct.assoc ℤ
                    (DerivableUEA base)
                    (DerivableUEA base)
                    (DerivableUEA base))
                    ((x ⊗ₜ[ℤ] (1 : DerivableUEA base)) ⊗ₜ[ℤ]
                      (1 : DerivableUEA base)) +
                  (TensorProduct.assoc ℤ
                    (DerivableUEA base)
                    (DerivableUEA base)
                    (DerivableUEA base))
                    (((1 : DerivableUEA base) ⊗ₜ[ℤ] x) ⊗ₜ[ℤ]
                      (1 : DerivableUEA base)) := by
                    exact
                      ((TensorProduct.assoc ℤ
                        (DerivableUEA base)
                        (DerivableUEA base)
                        (DerivableUEA base)).toLinearMap).map_add _ _
              _ =
                  x ⊗ₜ[ℤ]
                      ((1 : DerivableUEA base) ⊗ₜ[ℤ]
                        (1 : DerivableUEA base)) +
                    (1 : DerivableUEA base) ⊗ₜ[ℤ]
                      (x ⊗ₜ[ℤ] (1 : DerivableUEA base)) := by
                    rfl
          have hTensorRight :
              (1 : DerivableUEA base) ⊗ₜ[ℤ]
                  (x ⊗ₜ[ℤ] (1 : DerivableUEA base) +
                    (1 : DerivableUEA base) ⊗ₜ[ℤ] x) =
                (1 : DerivableUEA base) ⊗ₜ[ℤ]
                    (x ⊗ₜ[ℤ] (1 : DerivableUEA base)) +
                  (1 : DerivableUEA base) ⊗ₜ[ℤ]
                    ((1 : DerivableUEA base) ⊗ₜ[ℤ] x) := by
            exact TensorProduct.tmul_add
              (1 : DerivableUEA base)
              (x ⊗ₜ[ℤ] (1 : DerivableUEA base))
              ((1 : DerivableUEA base) ⊗ₜ[ℤ] x)
          rw [hAssocSum, hTensorRight]
          simp
          abel
    _ =
        ((directDerivableUEAComulAlgHom base).toLinearMap.lTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ (derivableUEAOfDerivation d) 1 +
            TensorProduct.tmul ℤ 1 (derivableUEAOfDerivation d)) := by
          exact hL.symm

/--
The right counit law holds on every actual NMMS derivation generator.

After decomposing a primitive derivation generator, applying the counit to
the extracted left component leaves the original derivation generator in the
right tensor position.
-/
theorem directDerivableUEAComul_rightCounit_derivation_formula
    {base : BaseRel} {s : MultiSequent}
    (d : NMMS base s) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    ((directDerivableUEACounitAlgHom base).toLinearMap.rTensor
        (DerivableUEA base))
        ((directDerivableUEAComulAlgHom base).toLinearMap
          (derivableUEAOfDerivation d)) =
      TensorProduct.tmul ℤ (1 : ℤ) (derivableUEAOfDerivation d) := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  have hΔ :
      (directDerivableUEAComulAlgHom base).toLinearMap
          (derivableUEAOfDerivation d) =
        TensorProduct.tmul ℤ (derivableUEAOfDerivation d) 1 +
          TensorProduct.tmul ℤ 1 (derivableUEAOfDerivation d) :=
    directDerivableUEAComulAlgHom_derivation_formula d
  have hε :
      (directDerivableUEACounitAlgHom base).toLinearMap
          (derivableUEAOfDerivation d) = 0 :=
    directDerivableUEACounitAlgHom_derivation_formula d
  rw [hΔ]
  have hR :
      ((directDerivableUEACounitAlgHom base).toLinearMap.rTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ (derivableUEAOfDerivation d) 1 +
            TensorProduct.tmul ℤ 1 (derivableUEAOfDerivation d)) =
        ((directDerivableUEACounitAlgHom base).toLinearMap.rTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ (derivableUEAOfDerivation d) 1) +
        ((directDerivableUEACounitAlgHom base).toLinearMap.rTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ 1 (derivableUEAOfDerivation d)) :=
    ((directDerivableUEACounitAlgHom base).toLinearMap.rTensor
      (DerivableUEA base)).map_add _ _
  calc
    ((directDerivableUEACounitAlgHom base).toLinearMap.rTensor
        (DerivableUEA base))
        (TensorProduct.tmul ℤ (derivableUEAOfDerivation d) 1 +
          TensorProduct.tmul ℤ 1 (derivableUEAOfDerivation d))
        =
        ((directDerivableUEACounitAlgHom base).toLinearMap.rTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ (derivableUEAOfDerivation d) 1) +
        ((directDerivableUEACounitAlgHom base).toLinearMap.rTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ 1 (derivableUEAOfDerivation d)) := hR
    _ = TensorProduct.tmul ℤ (1 : ℤ) (derivableUEAOfDerivation d) := by
      rw [LinearMap.rTensor_tmul, LinearMap.rTensor_tmul]
      rw [hε]
      simp

/--
The left counit law holds on every actual NMMS derivation generator.

After decomposing a primitive derivation generator, applying the counit to
the extracted right component leaves the original derivation generator in the
left tensor position.
-/
theorem directDerivableUEAComul_leftCounit_derivation_formula
    {base : BaseRel} {s : MultiSequent}
    (d : NMMS base s) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    ((directDerivableUEACounitAlgHom base).toLinearMap.lTensor
        (DerivableUEA base))
        ((directDerivableUEAComulAlgHom base).toLinearMap
          (derivableUEAOfDerivation d)) =
      TensorProduct.tmul ℤ (derivableUEAOfDerivation d) (1 : ℤ) := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  have hΔ :
      (directDerivableUEAComulAlgHom base).toLinearMap
          (derivableUEAOfDerivation d) =
        TensorProduct.tmul ℤ (derivableUEAOfDerivation d) 1 +
          TensorProduct.tmul ℤ 1 (derivableUEAOfDerivation d) :=
    directDerivableUEAComulAlgHom_derivation_formula d
  have hε :
      (directDerivableUEACounitAlgHom base).toLinearMap
          (derivableUEAOfDerivation d) = 0 :=
    directDerivableUEACounitAlgHom_derivation_formula d
  rw [hΔ]
  have hL :
      ((directDerivableUEACounitAlgHom base).toLinearMap.lTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ (derivableUEAOfDerivation d) 1 +
            TensorProduct.tmul ℤ 1 (derivableUEAOfDerivation d)) =
        ((directDerivableUEACounitAlgHom base).toLinearMap.lTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ (derivableUEAOfDerivation d) 1) +
        ((directDerivableUEACounitAlgHom base).toLinearMap.lTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ 1 (derivableUEAOfDerivation d)) :=
    ((directDerivableUEACounitAlgHom base).toLinearMap.lTensor
      (DerivableUEA base)).map_add _ _
  calc
    ((directDerivableUEACounitAlgHom base).toLinearMap.lTensor
        (DerivableUEA base))
        (TensorProduct.tmul ℤ (derivableUEAOfDerivation d) 1 +
          TensorProduct.tmul ℤ 1 (derivableUEAOfDerivation d))
        =
        ((directDerivableUEACounitAlgHom base).toLinearMap.lTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ (derivableUEAOfDerivation d) 1) +
        ((directDerivableUEACounitAlgHom base).toLinearMap.lTensor
          (DerivableUEA base))
          (TensorProduct.tmul ℤ 1 (derivableUEAOfDerivation d)) := hL
    _ = TensorProduct.tmul ℤ (derivableUEAOfDerivation d) (1 : ℤ) := by
      rw [LinearMap.lTensor_tmul, LinearMap.lTensor_tmul]
      rw [hε]
      simp

/--
Consolidated generator-level coalgebra laws for the direct proof-theoretic
OG coproduct on actual NMMS derivations.
-/
theorem directDerivableUEA_OG_derivation_generator_coalgebra_laws
    {base : BaseRel} {s : MultiSequent}
    (d : NMMS base s) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    (TensorProduct.assoc ℤ
        (DerivableUEA base)
        (DerivableUEA base)
        (DerivableUEA base)).toLinearMap
        (((directDerivableUEAComulAlgHom base).toLinearMap.rTensor
          (DerivableUEA base))
          ((directDerivableUEAComulAlgHom base).toLinearMap
            (derivableUEAOfDerivation d))) =
      ((directDerivableUEAComulAlgHom base).toLinearMap.lTensor
        (DerivableUEA base))
        ((directDerivableUEAComulAlgHom base).toLinearMap
          (derivableUEAOfDerivation d)) ∧
      ((directDerivableUEACounitAlgHom base).toLinearMap.rTensor
          (DerivableUEA base))
          ((directDerivableUEAComulAlgHom base).toLinearMap
            (derivableUEAOfDerivation d)) =
        TensorProduct.tmul ℤ (1 : ℤ) (derivableUEAOfDerivation d) ∧
      ((directDerivableUEACounitAlgHom base).toLinearMap.lTensor
          (DerivableUEA base))
          ((directDerivableUEAComulAlgHom base).toLinearMap
            (derivableUEAOfDerivation d)) =
        TensorProduct.tmul ℤ (derivableUEAOfDerivation d) (1 : ℤ) := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  exact
    ⟨directDerivableUEAComul_coassoc_derivation_formula d,
      directDerivableUEAComul_rightCounit_derivation_formula d,
      directDerivableUEAComul_leftCounit_derivation_formula d⟩

/-! ### Comparison from the direct derivable UEA to the ambient OG UEA -/

/--
The canonical quotient map from the derivable stable quotient to the ambient
stable quotient respects the descended grafting products.
-/
theorem derivableStableQuotientToStableQuotient_mul
    {base : BaseRel}
    (a b : DerivablePrimitiveLieCarrier base) :
    QuotientConnected.CoproductSupport.derivableStableQuotientToStableQuotient
        base (derivableStableQuotientMul base a b) =
      preLieDifferenceStableQuotientMul
        (QuotientConnected.CoproductSupport.derivableStableQuotientToStableQuotient
          base a)
        (QuotientConnected.CoproductSupport.derivableStableQuotientToStableQuotient
          base b) := by
  refine Quotient.inductionOn₂' a b ?_
  intro a₀ b₀
  change
    QuotientConnected.CoproductSupport.derivableStableQuotientToStableQuotient
        base
        (derivableStableQuotientMul base
          (Submodule.Quotient.mk a₀)
          (Submodule.Quotient.mk b₀)) =
      preLieDifferenceStableQuotientMul
        (QuotientConnected.CoproductSupport.derivableStableQuotientToStableQuotient
          base (Submodule.Quotient.mk a₀))
        (QuotientConnected.CoproductSupport.derivableStableQuotientToStableQuotient
          base (Submodule.Quotient.mk b₀))
  rw [derivableStableQuotientMul_mk]
  change
    mkPreLieDifferenceStableQuotient
        (graftPreLie (a₀ : PreLieCarrier) (b₀ : PreLieCarrier)) =
      preLieDifferenceStableQuotientMul
        (mkPreLieDifferenceStableQuotient (a₀ : PreLieCarrier))
        (mkPreLieDifferenceStableQuotient (b₀ : PreLieCarrier))
  exact
    (preLieDifferenceStableQuotientMul_mk
      (a₀ : PreLieCarrier) (b₀ : PreLieCarrier)).symm

/-- Product compatibility in Mathlib's opposite/pre-Lie convention. -/
theorem derivableStableQuotientToStableQuotient_oppMul
    {base : BaseRel}
    (a b : DerivablePrimitiveLieCarrier base) :
    QuotientConnected.CoproductSupport.derivableStableQuotientToStableQuotient
        base (derivableStableQuotientOppMul base a b) =
      preLieDifferenceStableQuotientOppMul
        (QuotientConnected.CoproductSupport.derivableStableQuotientToStableQuotient
          base a)
        (QuotientConnected.CoproductSupport.derivableStableQuotientToStableQuotient
          base b) := by
  exact derivableStableQuotientToStableQuotient_mul b a

/-- The direct OG/pre-Lie bracket is the Mathlib Lie bracket. -/
theorem derivableStableOudomGuinLieBracket_eq_lie
    {base : BaseRel}
    (a b : DerivablePrimitiveLieCarrier base) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    derivableStableQuotientOppMul base a b -
      derivableStableQuotientOppMul base b a = ⁅a, b⁆ := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  change
    derivableStableQuotientOppMul base a b -
      derivableStableQuotientOppMul base b a =
        derivableStableQuotientOppMul base a b -
          derivableStableQuotientOppMul base b a
  rfl

/--
The canonical map from the direct derivable stable quotient to the ambient
stable quotient is a Lie morphism.
-/
noncomputable def derivableStableQuotientToStableLieHom
    (base : BaseRel) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    letI : LieRing GraftingPrimitiveHopfCarrier :=
      graftingPrimitiveMathlibLieRing
    DerivablePrimitiveLieCarrier base →ₗ⁅ℤ⁆ GraftingPrimitiveHopfCarrier := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  letI : LieRing GraftingPrimitiveHopfCarrier :=
    graftingPrimitiveMathlibLieRing
  exact {
    QuotientConnected.CoproductSupport.derivableStableQuotientToStableQuotient
      base with
    map_lie' := by
      intro a b
      rw [← derivableStableOudomGuinLieBracket_eq_lie a b]
      change
        QuotientConnected.CoproductSupport.derivableStableQuotientToStableQuotient
            base
            (derivableStableQuotientOppMul base a b -
              derivableStableQuotientOppMul base b a) =
          preLieDifferenceStableQuotientOppMul
            (QuotientConnected.CoproductSupport.derivableStableQuotientToStableQuotient
              base a)
            (QuotientConnected.CoproductSupport.derivableStableQuotientToStableQuotient
              base b) -
          preLieDifferenceStableQuotientOppMul
            (QuotientConnected.CoproductSupport.derivableStableQuotientToStableQuotient
              base b)
            (QuotientConnected.CoproductSupport.derivableStableQuotientToStableQuotient
              base a)
      rw [LinearMap.map_sub,
        derivableStableQuotientToStableQuotient_oppMul,
        derivableStableQuotientToStableQuotient_oppMul]
  }

/--
The canonical algebra map from the direct derivable UEA into the ambient OG
UEA.
-/
noncomputable def directDerivableUEAToAmbientUEA
    (base : BaseRel) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    DerivableUEA base →ₐ[ℤ] GraftingUEAHopfCarrier := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  letI : LieRing GraftingPrimitiveHopfCarrier :=
    graftingPrimitiveMathlibLieRing
  exact UniversalEnvelopingAlgebra.lift ℤ
    (preLieDifferenceStableQuotientUEA_ι.comp
      (derivableStableQuotientToStableLieHom base))

/-- The direct-to-ambient UEA map sends derivable generators to ambient generators. -/
theorem directDerivableUEAToAmbientUEA_ι_formula
    (base : BaseRel)
    (q : DerivablePrimitiveLieCarrier base) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    directDerivableUEAToAmbientUEA base (derivableUEAι base q) =
      preLieDifferenceStableQuotientUEA_ι
        (QuotientConnected.CoproductSupport.derivableStableQuotientToStableQuotient
          base q) := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  letI : LieRing GraftingPrimitiveHopfCarrier :=
    graftingPrimitiveMathlibLieRing
  dsimp [directDerivableUEAToAmbientUEA, derivableUEAι]
  change
    ((UniversalEnvelopingAlgebra.lift ℤ)
        (preLieDifferenceStableQuotientUEA_ι.comp
          (derivableStableQuotientToStableLieHom base)))
      ((UniversalEnvelopingAlgebra.ι ℤ) q) =
        (preLieDifferenceStableQuotientUEA_ι.comp
          (derivableStableQuotientToStableLieHom base)) q
  exact
    UniversalEnvelopingAlgebra.lift_ι_apply ℤ
      (preLieDifferenceStableQuotientUEA_ι.comp
        (derivableStableQuotientToStableLieHom base)) q

/-- On derivable tree generators, direct-to-ambient UEA comparison is the old stable insertion. -/
theorem directDerivableUEAToAmbientUEA_treeGen_formula
    {base : BaseRel} {t : PTree}
    (ht : DerivableTree base t) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    directDerivableUEAToAmbientUEA base (derivableUEATreeGen ht) =
      QuotientConnected.CoproductSupport.derivableStableUEAIota
        base (QuotientConnected.CoproductSupport.derivableStableTreeGen ht) := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  simpa [derivableUEATreeGen,
    QuotientConnected.CoproductSupport.derivableStableUEAIota] using
    directDerivableUEAToAmbientUEA_ι_formula base
      (QuotientConnected.CoproductSupport.derivableStableTreeGen ht)

/--
On actual NMMS derivations, the direct UEA generator maps to the ambient stable
UEA generator of the same proof tree.
-/
theorem directDerivableUEAToAmbientUEA_derivation_formula
    {base : BaseRel} {s : MultiSequent}
    (d : NMMS base s) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    directDerivableUEAToAmbientUEA base (derivableUEAOfDerivation d) =
      stableUEA_treeGen (NMMS.toTree d) := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  simpa [derivableUEAOfDerivation] using
    directDerivableUEAToAmbientUEA_treeGen_formula
      (derivableTree_of_derivation d)

/--
The tensor square map induced by the direct-to-ambient UEA comparison.
-/
noncomputable def directDerivableUEATensorToAmbientTensor
    (base : BaseRel) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    DerivableUEATensor base →ₗ[ℤ] stableUEATensor := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  exact TensorProduct.map
    (directDerivableUEAToAmbientUEA base).toLinearMap
    (directDerivableUEAToAmbientUEA base).toLinearMap

@[simp]
theorem directDerivableUEATensorToAmbientTensor_tmul_formula
    (base : BaseRel) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    ∀ x y : DerivableUEA base,
      directDerivableUEATensorToAmbientTensor base (TensorProduct.tmul ℤ x y) =
        TensorProduct.tmul ℤ
          (directDerivableUEAToAmbientUEA base x)
          (directDerivableUEAToAmbientUEA base y) := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  intro x y
  change
    (TensorProduct.map
        (directDerivableUEAToAmbientUEA base).toLinearMap
        (directDerivableUEAToAmbientUEA base).toLinearMap)
      (TensorProduct.tmul ℤ x y) =
        TensorProduct.tmul ℤ
          (directDerivableUEAToAmbientUEA base x)
          (directDerivableUEAToAmbientUEA base y)
  exact TensorProduct.map_tmul
    (directDerivableUEAToAmbientUEA base).toLinearMap
    (directDerivableUEAToAmbientUEA base).toLinearMap x y

/--
The direct OG coproduct agrees with the ambient OG coproduct on actual NMMS
derivation generators, after applying the canonical direct-to-ambient tensor
map.
-/
theorem directDerivableUEAComul_toAmbient_derivation_formula
    {base : BaseRel} {s : MultiSequent}
    (d : NMMS base s) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    directDerivableUEATensorToAmbientTensor base
        (directDerivableUEAComulAlgHom base (derivableUEAOfDerivation d)) =
      QuotientConnected.CoproductSupport.stableUEA_OGPrimitiveCanonicalComulAlgHom
        (directDerivableUEAToAmbientUEA base (derivableUEAOfDerivation d)) := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  calc
    directDerivableUEATensorToAmbientTensor base
        (directDerivableUEAComulAlgHom base (derivableUEAOfDerivation d))
        =
        directDerivableUEATensorToAmbientTensor base
          (TensorProduct.tmul ℤ (derivableUEAOfDerivation d) 1 +
            TensorProduct.tmul ℤ 1 (derivableUEAOfDerivation d)) := by
          rw [directDerivableUEAComulAlgHom_derivation_formula d]
    _ =
        TensorProduct.tmul ℤ (stableUEA_treeGen (NMMS.toTree d)) 1 +
          TensorProduct.tmul ℤ 1 (stableUEA_treeGen (NMMS.toTree d)) := by
          rw [map_add,
            directDerivableUEATensorToAmbientTensor_tmul_formula base,
            directDerivableUEATensorToAmbientTensor_tmul_formula base,
            directDerivableUEAToAmbientUEA_derivation_formula d]
          simp
    _ =
        QuotientConnected.CoproductSupport.stableUEA_OGPrimitiveCanonicalComulAlgHom
          (stableUEA_treeGen (NMMS.toTree d)) := by
          exact
            (QuotientConnected.CoproductSupport.stableUEA_OGPrimitiveCanonicalComulAlgHom_treeGen_formula
              (NMMS.toTree d)).symm
    _ =
        QuotientConnected.CoproductSupport.stableUEA_OGPrimitiveCanonicalComulAlgHom
          (directDerivableUEAToAmbientUEA base (derivableUEAOfDerivation d)) := by
          rw [directDerivableUEAToAmbientUEA_derivation_formula d]

/--
The direct counit agrees with the ambient canonical UEA counit on actual NMMS
derivation generators.
-/
theorem directDerivableUEACounit_toAmbient_derivation_formula
    {base : BaseRel} {s : MultiSequent}
    (d : NMMS base s) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    stableUEA_counitAlgHom
        (directDerivableUEAToAmbientUEA base (derivableUEAOfDerivation d)) =
      directDerivableUEACounitAlgHom base (derivableUEAOfDerivation d) := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  simp [directDerivableUEAToAmbientUEA_derivation_formula d]

/--
Direct and ambient OG structures coincide on the primitive data of actual
NMMS derivation generators.
-/
theorem directDerivableUEA_OG_derivation_generator_ambient_comparison
    {base : BaseRel} {s : MultiSequent}
    (d : NMMS base s) :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    directDerivableUEATensorToAmbientTensor base
        (directDerivableUEAComulAlgHom base (derivableUEAOfDerivation d)) =
        QuotientConnected.CoproductSupport.stableUEA_OGPrimitiveCanonicalComulAlgHom
          (directDerivableUEAToAmbientUEA base (derivableUEAOfDerivation d)) ∧
      stableUEA_counitAlgHom
          (directDerivableUEAToAmbientUEA base (derivableUEAOfDerivation d)) =
        directDerivableUEACounitAlgHom base (derivableUEAOfDerivation d) := by
  letI : LieRing (DerivablePrimitiveLieCarrier base) :=
    derivableStableQuotientLieRing base
  exact
    ⟨directDerivableUEAComul_toAmbient_derivation_formula d,
      directDerivableUEACounit_toAmbient_derivation_formula d⟩

/--
The direct proof-theoretic Oudom-Guin theorem over a material base.

This is the first consolidated theorem package on the intended carrier:
`DerivableUEA base`, the UEA of the derivable stable quotient generated by
actual proof trees over the nonmonotonic base relation.
-/
structure DirectDerivableUEAOudomGuinPrimitiveTheorem
    (base : BaseRel) : Prop where
  coproduct_exists_unique :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    ∃! Phi : DerivableUEA base →ₐ[ℤ] DerivableUEATensor base,
      ∀ q : DerivablePrimitiveLieCarrier base,
        Phi (derivableUEAι base q) =
          TensorProduct.tmul ℤ (derivableUEAι base q) 1 +
            TensorProduct.tmul ℤ 1 (derivableUEAι base q)
  counit_exists_unique :
    letI : LieRing (DerivablePrimitiveLieCarrier base) :=
      derivableStableQuotientLieRing base
    ∃! epsilon : DerivableUEA base →ₐ[ℤ] ℤ,
      ∀ q : DerivablePrimitiveLieCarrier base,
        epsilon (derivableUEAι base q) = 0
  primitive_quotient_coalgebra_laws :
    ∀ q : DerivablePrimitiveLieCarrier base,
      letI : LieRing (DerivablePrimitiveLieCarrier base) :=
        derivableStableQuotientLieRing base
      DirectDerivableUEACoalgebraLawsAt base (derivableUEAι base q)
  derivable_tree_coalgebra_laws :
    ∀ {t : PTree} (ht : DerivableTree base t),
      letI : LieRing (DerivablePrimitiveLieCarrier base) :=
        derivableStableQuotientLieRing base
      DirectDerivableUEACoalgebraLawsAt base (derivableUEATreeGen ht)
  nmms_derivation_generators :
    ∀ {s : MultiSequent} (d : NMMS base s),
      letI : LieRing (DerivablePrimitiveLieCarrier base) :=
        derivableStableQuotientLieRing base
      directDerivableUEAComulAlgHom base (derivableUEAOfDerivation d) =
          TensorProduct.tmul ℤ (derivableUEAOfDerivation d) 1 +
            TensorProduct.tmul ℤ 1 (derivableUEAOfDerivation d) ∧
        directDerivableUEACounitAlgHom base (derivableUEAOfDerivation d) = 0
  nmms_derivation_coalgebra_laws :
    ∀ {s : MultiSequent} (d : NMMS base s),
      letI : LieRing (DerivablePrimitiveLieCarrier base) :=
        derivableStableQuotientLieRing base
      (TensorProduct.assoc ℤ
          (DerivableUEA base)
          (DerivableUEA base)
          (DerivableUEA base)).toLinearMap
          (((directDerivableUEAComulAlgHom base).toLinearMap.rTensor
            (DerivableUEA base))
            ((directDerivableUEAComulAlgHom base).toLinearMap
              (derivableUEAOfDerivation d))) =
        ((directDerivableUEAComulAlgHom base).toLinearMap.lTensor
          (DerivableUEA base))
          ((directDerivableUEAComulAlgHom base).toLinearMap
            (derivableUEAOfDerivation d)) ∧
        ((directDerivableUEACounitAlgHom base).toLinearMap.rTensor
            (DerivableUEA base))
            ((directDerivableUEAComulAlgHom base).toLinearMap
              (derivableUEAOfDerivation d)) =
          TensorProduct.tmul ℤ (1 : ℤ) (derivableUEAOfDerivation d) ∧
        ((directDerivableUEACounitAlgHom base).toLinearMap.lTensor
            (DerivableUEA base))
            ((directDerivableUEAComulAlgHom base).toLinearMap
              (derivableUEAOfDerivation d)) =
          TensorProduct.tmul ℤ (derivableUEAOfDerivation d) (1 : ℤ)
  ambient_comparison_on_nmms_derivations :
    ∀ {s : MultiSequent} (d : NMMS base s),
      letI : LieRing (DerivablePrimitiveLieCarrier base) :=
        derivableStableQuotientLieRing base
      directDerivableUEATensorToAmbientTensor base
          (directDerivableUEAComulAlgHom base (derivableUEAOfDerivation d)) =
          QuotientConnected.CoproductSupport.stableUEA_OGPrimitiveCanonicalComulAlgHom
            (directDerivableUEAToAmbientUEA base (derivableUEAOfDerivation d)) ∧
        stableUEA_counitAlgHom
            (directDerivableUEAToAmbientUEA base (derivableUEAOfDerivation d)) =
          directDerivableUEACounitAlgHom base (derivableUEAOfDerivation d)

/--
The direct proof-theoretic Oudom-Guin primitive theorem holds for every
material base relation.
-/
theorem directDerivableUEA_oudomGuin_primitive_theorem
    (base : BaseRel) :
    DirectDerivableUEAOudomGuinPrimitiveTheorem base where
  coproduct_exists_unique :=
    directDerivableUEAComulAlgHom_exists_unique base
  counit_exists_unique :=
    directDerivableUEACounitAlgHom_exists_unique base
  primitive_quotient_coalgebra_laws := by
    intro q
    exact directDerivableUEA_OG_primitive_quotient_coalgebra_laws base q
  derivable_tree_coalgebra_laws := by
    intro t ht
    exact directDerivableUEA_OG_tree_generator_coalgebra_laws ht
  nmms_derivation_generators := by
    intro s d
    exact directDerivableUEA_OG_derivation_generator_formula d
  nmms_derivation_coalgebra_laws := by
    intro s d
    exact directDerivableUEA_OG_derivation_generator_coalgebra_laws d
  ambient_comparison_on_nmms_derivations := by
    intro s d
    exact directDerivableUEA_OG_derivation_generator_ambient_comparison d

/--
The OG/Mathlib Lie-bracket convention is the negative of the direct grafting
commutator.  This records the right-pre-Lie/opposite-product convention
explicitly.
-/
theorem stableOudomGuinLieBracket_eq_neg_stableGraftingLieBracket
    (a b : GraftingPrimitiveHopfCarrier) :
    stableOudomGuinLieBracket a b =
      -stableGraftingLieBracket a b := by
  unfold stableOudomGuinLieBracket stableGraftingLieBracket
    preLieDifferenceStableQuotientOppMul
  abel

/--
The OG-convention bracket is the Lie bracket coming from Mathlib's
right-pre-Lie instance on the stable quotient.
-/
theorem stableOudomGuinLieBracket_eq_lie
    (a b : GraftingPrimitiveHopfCarrier) :
    letI : LieRing PreLieDifferenceStableQuotient :=
      preLieDifferenceStableQuotientLieRing
    stableOudomGuinLieBracket a b = ⁅a, b⁆ := by
  letI : LieRing PreLieDifferenceStableQuotient :=
    preLieDifferenceStableQuotientLieRing
  change
    stableOudomGuinLieBracket a b =
      preLieDifferenceStableQuotientOppMul a b -
        preLieDifferenceStableQuotientOppMul b a
  rfl

/--
On proof-tree generators, the stable grafting Lie bracket is exactly the
antisymmetrized constrained grafting product.
-/
theorem stableGraftingLieBracket_treeGen
    (x y : PTree) :
    stableGraftingLieBracket
        (mkPreLieDifferenceStableQuotient (treeGen x))
        (mkPreLieDifferenceStableQuotient (treeGen y)) =
      mkPreLieDifferenceStableQuotient
          (graftPreLie (treeGen x) (treeGen y)) -
        mkPreLieDifferenceStableQuotient
          (graftPreLie (treeGen y) (treeGen x)) := by
  unfold stableGraftingLieBracket
  change
    (preLieDifferenceStableQuotientMul
        (Submodule.Quotient.mk (treeGen x)))
        (Submodule.Quotient.mk (treeGen y)) -
      (preLieDifferenceStableQuotientMul
        (Submodule.Quotient.mk (treeGen y)))
        (Submodule.Quotient.mk (treeGen x)) =
        mkPreLieDifferenceStableQuotient
          (graftPreLie (treeGen x) (treeGen y)) -
        mkPreLieDifferenceStableQuotient
          (graftPreLie (treeGen y) (treeGen x))
  rw [preLieDifferenceStableQuotientMul_mk,
    preLieDifferenceStableQuotientMul_mk]

/--
On proof-tree generators, the OG-convention Lie bracket is the
opposite-order antisymmetrized constrained grafting product.
-/
theorem stableOudomGuinLieBracket_treeGen
    (x y : PTree) :
    stableOudomGuinLieBracket
        (mkPreLieDifferenceStableQuotient (treeGen x))
        (mkPreLieDifferenceStableQuotient (treeGen y)) =
      mkPreLieDifferenceStableQuotient
          (graftPreLie (treeGen y) (treeGen x)) -
        mkPreLieDifferenceStableQuotient
          (graftPreLie (treeGen x) (treeGen y)) := by
  unfold stableOudomGuinLieBracket preLieDifferenceStableQuotientOppMul
    mkPreLieDifferenceStableQuotient
  change
    (preLieDifferenceStableQuotientMul
        (Submodule.Quotient.mk (treeGen y)))
        (Submodule.Quotient.mk (treeGen x)) -
      (preLieDifferenceStableQuotientMul
        (Submodule.Quotient.mk (treeGen x)))
        (Submodule.Quotient.mk (treeGen y)) =
        mkPreLieDifferenceStableQuotient
          (graftPreLie (treeGen y) (treeGen x)) -
        mkPreLieDifferenceStableQuotient
          (graftPreLie (treeGen x) (treeGen y))
  rw [preLieDifferenceStableQuotientMul_mk,
    preLieDifferenceStableQuotientMul_mk]

/--
The UEA image of the stable grafting Lie bracket on generators.

This keeps the OG side visibly tied to grafting even before the full Hopf
witness is supplied.
-/
theorem stableUEA_graftingLieBracket_treeGen
    (x y : PTree) :
    preLieDifferenceStableQuotientUEA_ι
        (stableGraftingLieBracket
          (mkPreLieDifferenceStableQuotient (treeGen x))
          (mkPreLieDifferenceStableQuotient (treeGen y))) =
      preLieDifferenceStableQuotientUEA_ι
          (mkPreLieDifferenceStableQuotient
            (graftPreLie (treeGen x) (treeGen y))) -
        preLieDifferenceStableQuotientUEA_ι
          (mkPreLieDifferenceStableQuotient
            (graftPreLie (treeGen y) (treeGen x))) := by
  letI : LieRing PreLieDifferenceStableQuotient :=
    preLieDifferenceStableQuotientLieRing
  rw [stableGraftingLieBracket_treeGen]
  exact preLieDifferenceStableQuotientUEA_ι.toLinearMap.map_sub _ _

/--
UEA image of the OG-convention Lie bracket on proof-tree generators.

This is the same grafting commutator with the right-pre-Lie/opposite-product
order made explicit.
-/
theorem stableUEA_oudomGuinLieBracket_treeGen
    (x y : PTree) :
    preLieDifferenceStableQuotientUEA_ι
        (stableOudomGuinLieBracket
          (mkPreLieDifferenceStableQuotient (treeGen x))
          (mkPreLieDifferenceStableQuotient (treeGen y))) =
      preLieDifferenceStableQuotientUEA_ι
          (mkPreLieDifferenceStableQuotient
            (graftPreLie (treeGen y) (treeGen x))) -
        preLieDifferenceStableQuotientUEA_ι
          (mkPreLieDifferenceStableQuotient
            (graftPreLie (treeGen x) (treeGen y))) := by
  letI : LieRing PreLieDifferenceStableQuotient :=
    preLieDifferenceStableQuotientLieRing
  rw [stableOudomGuinLieBracket_treeGen]
  exact preLieDifferenceStableQuotientUEA_ι.toLinearMap.map_sub _ _

/--
In the stable UEA, the inserted OG grafting Lie bracket is represented by the
associative commutator of the inserted primitive classes.
-/
theorem stableUEA_oudomGuinLieBracket_eq_commutator
    (a b : GraftingPrimitiveHopfCarrier) :
    preLieDifferenceStableQuotientUEA_ι
        (stableOudomGuinLieBracket a b) =
      preLieDifferenceStableQuotientUEA_ι a *
          preLieDifferenceStableQuotientUEA_ι b -
        preLieDifferenceStableQuotientUEA_ι b *
          preLieDifferenceStableQuotientUEA_ι a := by
  letI : LieRing PreLieDifferenceStableQuotient :=
    preLieDifferenceStableQuotientLieRing
  rw [stableOudomGuinLieBracket_eq_lie]
  have h := preLieDifferenceStableQuotientUEA_ι.map_lie a b
  rwa [Ring.lie_def] at h

/--
Generator-level commutator form of the OG grafting bracket in the stable UEA.
-/
theorem stableUEA_oudomGuinLieBracket_treeGen_eq_commutator
    (x y : PTree) :
    preLieDifferenceStableQuotientUEA_ι
        (stableOudomGuinLieBracket
          (mkPreLieDifferenceStableQuotient (treeGen x))
          (mkPreLieDifferenceStableQuotient (treeGen y))) =
      stableUEA_treeGen x * stableUEA_treeGen y -
        stableUEA_treeGen y * stableUEA_treeGen x := by
  rw [stableUEA_oudomGuinLieBracket_eq_commutator]
  simp [stableUEA_treeGen_eq_ι]

/--
Current OG-side status before the final Hopf witness.

The pre-Lie/grafting input and the carrier-correct coalgebra side are both
available.  The remaining construction is the full UEA Hopf target.
-/
theorem oudomGuin_grafting_preLie_and_coalgebra_status :
    OudomGuinGraftingPreLieSide ∧ OudomGuinGraftingCoalgebraSide := by
  exact ⟨oudomGuin_grafting_preLie_side_exists,
    oudomGuin_grafting_coalgebra_side_exists⟩

/--
A concrete witness form for the OG/grafting Hopf side.

This unpacks the target into the proof-theoretically meaningful Hopf facts:
primitive coproduct on proof-tree generators, multiplicativity on the UEA,
and antipode cancellation.
-/
structure OudomGuinGraftingHopfWitness where
  target : QuotientConnected.CoproductSupport.OudomGuinUEAHopfAlgebraTarget
  primitive_treeGen :
    ∀ x : PTree,
      target.carrier.DeltaOG (stableUEA_treeGen x) =
        TensorProduct.tmul ℤ (stableUEA_treeGen x) 1 +
          TensorProduct.tmul ℤ 1 (stableUEA_treeGen x)
  coproduct_mul :
    ∀ a b : preLieDifferenceStableQuotientUEA,
      target.carrier.DeltaOG (a * b) =
        target.carrier.DeltaOG a * target.carrier.DeltaOG b
  counit_mul :
    ∀ a b : preLieDifferenceStableQuotientUEA,
      target.carrier.epsilonOG (a * b) =
        target.carrier.epsilonOG a * target.carrier.epsilonOG b
  antipode_treeGen :
    ∀ x : PTree,
      target.hopf.antipode (stableUEA_treeGen x) =
        -stableUEA_treeGen x
  antipode_left_cancellation :
    ∀ a : preLieDifferenceStableQuotientUEA,
      target.hopf.mulTensor
          ((LinearMap.rTensor preLieDifferenceStableQuotientUEA
              target.hopf.antipode)
            (target.carrier.DeltaOG a)) =
        target.hopf.unitLinear (target.carrier.epsilonOG a)
  antipode_right_cancellation :
    ∀ a : preLieDifferenceStableQuotientUEA,
      target.hopf.mulTensor
          ((LinearMap.lTensor preLieDifferenceStableQuotientUEA
              target.hopf.antipode)
            (target.carrier.DeltaOG a)) =
        target.hopf.unitLinear (target.carrier.epsilonOG a)

/--
An explicit carrier-correct OG Hopf target supplies the concrete witness used
by the rest of this file.
-/
def oudomGuin_grafting_hopf_witness_of_target
    (H : QuotientConnected.CoproductSupport.OudomGuinUEAHopfAlgebraTarget) :
    OudomGuinGraftingHopfWitness where
  target := H
  primitive_treeGen := by
    intro x
    exact H.primitive_treeGen x
  coproduct_mul := by
    intro a b
    exact H.DeltaOG_mul a b
  counit_mul := by
    intro a b
    exact H.epsilonOG_mul a b
  antipode_treeGen := by
    intro x
    exact H.antipode_treeGen x
  antipode_left_cancellation := by
    intro a
    exact H.antipode_left_cancellation a
  antipode_right_cancellation := by
    intro a
    exact H.antipode_right_cancellation a

/-- An explicit carrier-correct OG Hopf target supplies the OG Hopf side. -/
theorem oudomGuin_grafting_hopf_side_of_target
    (H : QuotientConnected.CoproductSupport.OudomGuinUEAHopfAlgebraTarget) :
    OudomGuinGraftingHopfSide := by
  exact ⟨H, trivial⟩

/-- An explicit carrier-correct OG Hopf target supplies the witness package. -/
theorem oudomGuin_grafting_hopf_witness_exists_of_target
    (H : QuotientConnected.CoproductSupport.OudomGuinUEAHopfAlgebraTarget) :
    Nonempty OudomGuinGraftingHopfWitness := by
  exact ⟨oudomGuin_grafting_hopf_witness_of_target H⟩

/--
The concrete OG Hopf witness is equivalent to the carrier-correct OG UEA Hopf
target.  This is useful because the witness is the proof-theoretic package
used in this file, while the target is the algebraic construction obligation
in the coalgebra/UEA file.
-/
theorem oudomGuin_grafting_hopf_witness_iff_og_target :
    Nonempty OudomGuinGraftingHopfWitness ↔
      ∃ _H : QuotientConnected.CoproductSupport.OudomGuinUEAHopfAlgebraTarget,
        True := by
  constructor
  · intro h
    cases h with
    | intro W =>
        exact ⟨W.target, trivial⟩
  · intro h
    rcases h with ⟨H, -⟩
    exact oudomGuin_grafting_hopf_witness_exists_of_target H

/--
The abstract OG Hopf-side target is equivalent to this concrete witness
package.
-/
theorem oudomGuin_grafting_hopf_side_iff_nonempty_witness :
    OudomGuinGraftingHopfSide ↔
      Nonempty OudomGuinGraftingHopfWitness := by
  constructor
  · rintro ⟨H, -⟩
    exact oudomGuin_grafting_hopf_witness_exists_of_target H
  · rintro ⟨W⟩
    exact ⟨W.target, trivial⟩

/--
The honest Mathlib version of the missing OG Hopf side: a `HopfAlgebra` on the
stable UEA carrier itself.

The existing custom target remains useful for proof-tree formulas and
intertwining statements, but the external algebraic standard we should aim at
is this Mathlib class.
-/
abbrev MathlibOudomGuinHopfSide :=
  HopfAlgebra ℤ preLieDifferenceStableQuotientUEA

/-- The Mathlib OG Hopf-side existence target. -/
def MathlibOudomGuinHopfSideExists : Prop :=
  Nonempty MathlibOudomGuinHopfSide

/-- Any actual Mathlib Hopf instance on the stable UEA supplies the Mathlib-side target. -/
theorem mathlib_oudomGuin_hopf_side_exists_of_instance
    [HopfAlgebra ℤ preLieDifferenceStableQuotientUEA] :
    MathlibOudomGuinHopfSideExists := by
  exact ⟨inferInstance⟩

/--
A Mathlib-facing OG Hopf witness.

This is deliberately stated with Mathlib's `HopfAlgebra`, `Bialgebra`, and
`Coalgebra` operations, rather than the older custom `StableUEAHopfData`.
The extra fields are the proof-tree-specific facts that Mathlib will not know
by itself: the UEA generators are primitive, the counit kills them, and the
antipode negates them.
-/
structure MathlibOudomGuinHopfWitness where
  hopf : MathlibOudomGuinHopfSide
  primitive_treeGen :
    letI : MathlibOudomGuinHopfSide := hopf
    letI : HopfAlgebraStruct ℤ preLieDifferenceStableQuotientUEA :=
      HopfAlgebra.toHopfAlgebraStruct
    letI : Bialgebra ℤ preLieDifferenceStableQuotientUEA :=
      HopfAlgebraStruct.toBialgebra
    letI : Algebra ℤ preLieDifferenceStableQuotientUEA :=
      Bialgebra.toAlgebra
    letI : Module ℤ preLieDifferenceStableQuotientUEA := Algebra.toModule
    letI : Coalgebra ℤ preLieDifferenceStableQuotientUEA :=
      Bialgebra.toCoalgebra (R := ℤ)
        (A := preLieDifferenceStableQuotientUEA)
    ∀ x : PTree,
      Coalgebra.comul (R := ℤ) (A := preLieDifferenceStableQuotientUEA)
          (stableUEA_treeGen x) =
        TensorProduct.tmul ℤ (stableUEA_treeGen x)
            (1 : preLieDifferenceStableQuotientUEA) +
          TensorProduct.tmul ℤ (1 : preLieDifferenceStableQuotientUEA)
            (stableUEA_treeGen x)
  counit_treeGen :
    letI : MathlibOudomGuinHopfSide := hopf
    letI : HopfAlgebraStruct ℤ preLieDifferenceStableQuotientUEA :=
      HopfAlgebra.toHopfAlgebraStruct
    letI : Bialgebra ℤ preLieDifferenceStableQuotientUEA :=
      HopfAlgebraStruct.toBialgebra
    letI : Algebra ℤ preLieDifferenceStableQuotientUEA :=
      Bialgebra.toAlgebra
    letI : Module ℤ preLieDifferenceStableQuotientUEA := Algebra.toModule
    letI : Coalgebra ℤ preLieDifferenceStableQuotientUEA :=
      Bialgebra.toCoalgebra (R := ℤ)
        (A := preLieDifferenceStableQuotientUEA)
    ∀ x : PTree,
      Coalgebra.counit (R := ℤ) (A := preLieDifferenceStableQuotientUEA)
          (stableUEA_treeGen x) = 0
  antipode_treeGen :
    letI : MathlibOudomGuinHopfSide := hopf
    ∀ x : PTree,
      HopfAlgebra.antipode ℤ (stableUEA_treeGen x) =
        -stableUEA_treeGen x

