  · intro h
    rcases h with ⟨W⟩
    exact og_primitive_antipode_formula_data_of_og_target W.target

/--
Full Hopf-form characterization of completion.

This packages the primitive bialgebra formulas together with the antipode:
generator negation and both convolution cancellation equations.  It is the
most explicit algebraic statement of the OG side currently available.
-/
theorem proofTheoreticHopf_completed_iff_og_primitive_antipode_formula
    {base : BaseRel}
    [LeftDistribClass
      (TensorProduct ℤ (HypersequentAlgebra ℤ) (HypersequentAlgebra ℤ))]
    [RightDistribClass
      (TensorProduct ℤ (HypersequentAlgebra ℤ) (HypersequentAlgebra ℤ))] :
    ProofTheoreticHopfThreeMainGoalsCompleted base ↔
      OGPrimitiveAntipodeFormulaData := by
  constructor
  · intro h
    rcases
      (proofTheoreticHopf_threeMainGoals_completed_iff_og_target
        (base := base)).1 h with
      ⟨H, -⟩
    have hcanon := canonical_og_hopf_data_of_og_target H
    have hprim := CanonicalOudomGuinHopfData.bialgebra_treeGen_formula hcanon
    exact
      ⟨H.carrier, H.hopf, hcanon, hprim.1, hprim.2,
        H.antipode_treeGen, H.antipode_left_cancellation,
        H.antipode_right_cancellation⟩
  · intro h
    rcases h with ⟨carrier, hopf, hcanon, -⟩
    exact
      proofTheoreticHopf_threeMainGoals_completed_of_canonical_og_hopf_data
        (base := base) ⟨carrier, hopf, hcanon⟩

/--
Headline proof-theoretic Hopf result, stated without hiding the proof theory.

The main package consists of:

* CK admissible-cut/graft reconstruction duality;
* nonmonotonic weakening/grafting diagnostics for internal and external
  structural behavior;
* OG primitive-antipode Hopf data generated by proof-tree grafting.

The theorem says this explicit proof-theoretic/algebraic package is equivalent
to the completed three-goal theorem.
-/
def ProofTheoreticHopfMainResult
    (base : BaseRel) : Prop :=
  CutGraftDualityMarqueeTarget
      base CKGraftReconstructionMultiplicity ∧
    NonmonotonicWeakeningGraftingMarquee base ∧
    OGPrimitiveAntipodeFormulaData

