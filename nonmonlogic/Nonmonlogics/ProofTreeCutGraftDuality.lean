      True := by
  rcases h with ⟨carrier, hopf, hcanon, -⟩
  refine
    (QuotientConnected.CoproductSupport.oudomGuinUEAHopfAlgebraTarget_exists_iff_compatible_hopf_data).2
      ?_
  exact
    ⟨carrier, hopf,
      compatible_og_hopf_data_of_canonical_og_hopf_data hcanon⟩

