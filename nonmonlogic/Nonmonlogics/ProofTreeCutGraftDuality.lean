/--
Named OG primitive-antipode data.

This is the algebraic content of the grafting/OG Hopf side in the language of
proof-tree generators: primitive coproduct, zero counit, antipode negating
generators, and the two Hopf convolution cancellation equations.
-/
def OGPrimitiveAntipodeFormulaData : Prop :=
  ∃ (carrier :
      QuotientConnected.CoproductSupport.OudomGuinUEAHopfCarrierTarget)
    (hopf : QuotientConnected.StableUEAHopfData),
    CanonicalOudomGuinHopfData carrier hopf ∧
      (∀ x : PTree,
        hopf.bialgebra.comul (stableUEA_treeGen x) =
          TensorProduct.tmul ℤ (stableUEA_treeGen x) 1 +
            TensorProduct.tmul ℤ 1 (stableUEA_treeGen x)) ∧
      (∀ x : PTree,
        hopf.bialgebra.counit (stableUEA_treeGen x) = 0) ∧
      (∀ x : PTree,
        hopf.antipode (stableUEA_treeGen x) =
          -stableUEA_treeGen x) ∧
      (∀ a : preLieDifferenceStableQuotientUEA,
        hopf.mulTensor
            ((LinearMap.rTensor preLieDifferenceStableQuotientUEA
                hopf.antipode)
              (carrier.DeltaOG a)) =
          hopf.unitLinear (carrier.epsilonOG a)) ∧
      (∀ a : preLieDifferenceStableQuotientUEA,
        hopf.mulTensor
            ((LinearMap.lTensor preLieDifferenceStableQuotientUEA
                hopf.antipode)
              (carrier.DeltaOG a)) =
          hopf.unitLinear (carrier.epsilonOG a))

/-- A full OG UEA Hopf target supplies the primitive-antipode formula data. -/
theorem og_primitive_antipode_formula_data_of_og_target
    (H : QuotientConnected.CoproductSupport.OudomGuinUEAHopfAlgebraTarget) :
    OGPrimitiveAntipodeFormulaData := by
  have hcanon := canonical_og_hopf_data_of_og_target H
  have hprim := CanonicalOudomGuinHopfData.bialgebra_treeGen_formula hcanon
  exact
    ⟨H.carrier, H.hopf, hcanon, hprim.1, hprim.2,
      H.antipode_treeGen, H.antipode_left_cancellation,
      H.antipode_right_cancellation⟩

