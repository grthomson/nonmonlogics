/--
Achieved-main-result local Hopf bridge for one addressed sequent-matching
composition step.

This is the current clean meeting point of the project:

* the algebra-side operation is an addressed graft of derivable proof trees;
* the CK side sees a nonzero admissible decomposition coefficient;
* the remainder exposes the sequent occurrence and reconstructs the composite;
* the composite proof tree lies in the direct base-indexed derivable UEA
  coalgebra sector.

Thus the theorem speaks about the intended proof-theoretic carrier, not merely
about ambient decorated trees.
-/
theorem DirectProofTheoreticHopfPrimitiveMainResult.sequent_matching_local_hopf_bridge
    {base : BaseRel}
    (h : DirectProofTheoreticHopfPrimitiveMainResult base)
    {G H : Hypersequent}
    (hstep :
      SequentMatchingProofTheoreticHypersequentCompositionStep base G H) :
    ∃ C : Hypersequent, ∃ u t v : PTree, ∃ a : Address,
      G = C + HQ.singleton u + HQ.singleton t ∧
        H = C + HQ.singleton v ∧
          DerivableTree base u ∧
            DerivableTree base t ∧
              (∃ hv : DerivableTree base v,
                letI : LieRing (DerivablePrimitiveLieCarrier base) :=
                  derivableStableQuotientLieRing base
                DirectDerivableUEACoalgebraLawsAt base
                  (derivableUEATreeGen hv)) ∧
              SequentMatchingCompositionDecomposition base u t v a ∧
              0 < graftMultiplicity u t v ∧
              0 <
                cutSplitMultiplicity v
                  (HQ.singleton u,
                    HQ.singleton (PTree.remainderGo [a] [] v)) ∧
              SplitProofTheoreticShape base
                (HQ.singleton u) (PTree.remainderGo [a] [] v) ∧
              PTree.subtreeAt (PTree.remainderGo [a] [] v) a =
                some (PTree.leaf u.conclusion) ∧
              BoundaryFill u (PTree.remainderGo [a] [] v) v := by
  rcases hstep with
    ⟨C, u, t, v, a, hG, hH, hu, ht, hg, hnode, hnotroot, hv⟩
  let hbridge :
      SequentMatchingCompositionDecomposition base u t v a :=
    sequentMatching_composition_decomposition hu ht hg hnode hnotroot
  refine
    ⟨C, u, t, v, a, hG, hH, hu, ht, ?_, hbridge,
      hbridge.composition_coefficient_nonzero,
      hbridge.decomposition_coefficient_nonzero,
      hbridge.proof_theoretic_split_shape,
      hbridge.exposed_interface,
      hbridge.reconstructs_composite⟩
  refine ⟨hv, ?_⟩
  exact h.direct_derivable_og.derivable_tree_coalgebra_laws hv

/--
Unconditional direct local Hopf bridge for addressed sequent-matching
composition.

For every material base relation, every actual proof-theoretic hypersequent
composition step generated by a matching sequent occurrence has all the data
needed by the intended Hopf reading:

* the active trees are derivable proof trees over the base;
* the composite has the direct `DerivableUEA base` primitive coalgebra laws;
* the GL/OG graft coefficient is nonzero;
* the CK split coefficient is nonzero;
* the remainder exposes the selected sequent occurrence and reconstructs the
  composite when filled by the detached proof.

This is the compact local theorem saying that the algebra-side graft and the
coalgebra-side split meet on the actual NMMS/derivable proof-tree sector.
-/
theorem directProofTheoreticHopf_sequentMatching_local_hopf_bridge
    (base : BaseRel)
    {G H : Hypersequent}
    (hstep :
      SequentMatchingProofTheoreticHypersequentCompositionStep base G H) :
    ∃ C : Hypersequent, ∃ u t v : PTree, ∃ a : Address,
      G = C + HQ.singleton u + HQ.singleton t ∧
        H = C + HQ.singleton v ∧
          DerivableTree base u ∧
            DerivableTree base t ∧
              (∃ hv : DerivableTree base v,
                letI : LieRing (DerivablePrimitiveLieCarrier base) :=
                  derivableStableQuotientLieRing base
                DirectDerivableUEACoalgebraLawsAt base
                  (derivableUEATreeGen hv)) ∧
              SequentMatchingCompositionDecomposition base u t v a ∧
              0 < graftMultiplicity u t v ∧
              0 <
                cutSplitMultiplicity v
                  (HQ.singleton u,
                    HQ.singleton (PTree.remainderGo [a] [] v)) ∧
              SplitProofTheoreticShape base
                (HQ.singleton u) (PTree.remainderGo [a] [] v) ∧
              PTree.subtreeAt (PTree.remainderGo [a] [] v) a =
                some (PTree.leaf u.conclusion) ∧
              BoundaryFill u (PTree.remainderGo [a] [] v) v :=
  (directProofTheoreticHopf_primitive_mainResult base).sequent_matching_local_hopf_bridge
    hstep

/--
NMMS-witness form of the direct local Hopf bridge.

This is the same local theorem as
`directProofTheoreticHopf_sequentMatching_local_hopf_bridge`, but it unfolds the
proof-theoretic content of the active trees: the inserted proof, the host
proof, and the composite proof are all explicitly the forgetful trees of
actual `NMMS` derivations over the same material base relation.
-/
theorem directProofTheoreticHopf_sequentMatching_local_hopf_bridge_nmms_witnesses
    (base : BaseRel)
    {G H : Hypersequent}
    (hstep :
      SequentMatchingProofTheoreticHypersequentCompositionStep base G H) :
    ∃ C : Hypersequent, ∃ u t v : PTree, ∃ a : Address,
      G = C + HQ.singleton u + HQ.singleton t ∧
        H = C + HQ.singleton v ∧
          (∃ su : MultiSequent, ∃ du : NMMS base su,
            NMMS.toTree du = u) ∧
          (∃ st : MultiSequent, ∃ dt : NMMS base st,
            NMMS.toTree dt = t) ∧
          (∃ sv : MultiSequent, ∃ dv : NMMS base sv,
            ∃ hv : DerivableTree base v,
              NMMS.toTree dv = v ∧
                letI : LieRing (DerivablePrimitiveLieCarrier base) :=
                  derivableStableQuotientLieRing base
                DirectDerivableUEACoalgebraLawsAt base
                  (derivableUEATreeGen hv)) ∧
          SequentMatchingCompositionDecomposition base u t v a ∧
          0 < graftMultiplicity u t v ∧
          0 <
            cutSplitMultiplicity v
              (HQ.singleton u,
                HQ.singleton (PTree.remainderGo [a] [] v)) ∧
          SplitProofTheoreticShape base
            (HQ.singleton u) (PTree.remainderGo [a] [] v) ∧
          PTree.subtreeAt (PTree.remainderGo [a] [] v) a =
            some (PTree.leaf u.conclusion) ∧
          BoundaryFill u (PTree.remainderGo [a] [] v) v := by
  rcases directProofTheoreticHopf_sequentMatching_local_hopf_bridge
      base hstep with
    ⟨C, u, t, v, a, hG, hH, hu, ht, hvUEA, hbridge, hgraft,
      hsplitCoeff, hsplit, hexposed, hfill⟩
  rcases hu with ⟨su, du, hdu⟩
  rcases ht with ⟨st, dt, hdt⟩
  rcases hvUEA with ⟨hv, hcoalg⟩
  rcases hv with ⟨sv, dv, hdv⟩
  refine
    ⟨C, u, t, v, a, hG, hH,
      ⟨su, du, hdu⟩,
      ⟨st, dt, hdt⟩,
      ?_,
      hbridge, hgraft, hsplitCoeff, hsplit, hexposed, hfill⟩
  exact ⟨sv, dv, ⟨sv, dv, hdv⟩, hdv, hcoalg⟩

/--
Concrete NMMS derivations generate the singleton-hypersequent composition
step whenever the inserted derivation matches a non-root leaf occurrence of the
host derivation.

This is the proof-theoretic source of the algebra-side singleton product:
`|u| + |t| --> |v|`, with all three trees coming from `NMMS`.
-/
theorem sequentMatchingProofTheoreticHypersequentCompositionStep_of_nmms_address_graft
    {base : BaseRel} {s_inner s_outer : MultiSequent}
    (d_inner : NMMS base s_inner)
    (d_outer : NMMS base s_outer)
    (a : Address)
    (hgraftable :
      PTree.IsGraftableLeafAt
        (NMMS.toTree d_inner) (NMMS.toTree d_outer) a)
    (hnode : IsNodeAddress (NMMS.toTree d_inner) ([] : Address))
    (hnotroot : a ≠ ([] : Address)) :
    ∃ d' : NMMS base s_outer,
      PTree.graftMatchingLeafAt
          (NMMS.toTree d_inner) (NMMS.toTree d_outer) a =
        some (NMMS.toTree d') ∧
      SequentMatchingProofTheoreticHypersequentCompositionStep base
        (HQ.singleton (NMMS.toTree d_inner) +
          HQ.singleton (NMMS.toTree d_outer))
        (HQ.singleton (NMMS.toTree d')) := by
  rcases
    graftMatchingLeafAt_toTree_is_toTree
      d_outer d_inner a hgraftable with
    ⟨d', hgraft⟩
  refine ⟨d', hgraft, ?_⟩
  refine
    ⟨0, NMMS.toTree d_inner, NMMS.toTree d_outer, NMMS.toTree d', a,
      ?_, ?_,
      derivableTree_of_derivation d_inner,
      derivableTree_of_derivation d_outer,
      hgraft, hnode, hnotroot,
      derivableTree_of_derivation d'⟩
  · simp
  · simp

/--
Concrete NMMS form of the local Hopf bridge.

If an actual derivation `d_inner` matches a non-root leaf occurrence in an
actual derivation `d_outer`, then the proof-tree graft is itself the tree of an
actual `NMMS` derivation `d'`.  Moreover that same local proof composition
has all of the Hopf-facing structure: direct derivable UEA primitive coalgebra
laws on the composite generator, a CK decomposition/remainder, nonzero
composition and decomposition coefficients, an exposed sequent occurrence,
and reconstruction by filling the remainder with the detached proof.
-/
theorem directProofTheoreticHopf_nmms_address_graft_local_hopf_bridge
    {base : BaseRel} {s_inner s_outer : MultiSequent}
    (d_inner : NMMS base s_inner)
    (d_outer : NMMS base s_outer)
    (a : Address)
    (hgraftable :
      PTree.IsGraftableLeafAt
        (NMMS.toTree d_inner) (NMMS.toTree d_outer) a)
    (hnode : IsNodeAddress (NMMS.toTree d_inner) ([] : Address))
    (hnotroot : a ≠ ([] : Address)) :
    ∃ d' : NMMS base s_outer,
      PTree.graftMatchingLeafAt
          (NMMS.toTree d_inner) (NMMS.toTree d_outer) a =
        some (NMMS.toTree d') ∧
      (∃ hv : DerivableTree base (NMMS.toTree d'),
        letI : LieRing (DerivablePrimitiveLieCarrier base) :=
          derivableStableQuotientLieRing base
        DirectDerivableUEACoalgebraLawsAt base
          (derivableUEATreeGen hv)) ∧
      SequentMatchingCompositionDecomposition base
        (NMMS.toTree d_inner) (NMMS.toTree d_outer) (NMMS.toTree d') a ∧
      0 <
        graftMultiplicity
          (NMMS.toTree d_inner) (NMMS.toTree d_outer) (NMMS.toTree d') ∧
      0 <
        cutSplitMultiplicity (NMMS.toTree d')
          (HQ.singleton (NMMS.toTree d_inner),
            HQ.singleton (PTree.remainderGo [a] [] (NMMS.toTree d'))) ∧
      SplitProofTheoreticShape base
        (HQ.singleton (NMMS.toTree d_inner))
        (PTree.remainderGo [a] [] (NMMS.toTree d')) ∧
      PTree.subtreeAt (PTree.remainderGo [a] [] (NMMS.toTree d')) a =
        some (PTree.leaf (NMMS.toTree d_inner).conclusion) ∧
      BoundaryFill
        (NMMS.toTree d_inner)
        (PTree.remainderGo [a] [] (NMMS.toTree d'))
        (NMMS.toTree d') := by
  rcases
    graftMatchingLeafAt_toTree_is_toTree
      d_outer d_inner a hgraftable with
    ⟨d', hgraft⟩
  let hbridge :
      SequentMatchingCompositionDecomposition base
        (NMMS.toTree d_inner) (NMMS.toTree d_outer) (NMMS.toTree d') a :=
    sequentMatching_composition_decomposition
      (derivableTree_of_derivation d_inner)
      (derivableTree_of_derivation d_outer)
      hgraft hnode hnotroot
  refine
    ⟨d', hgraft, ?_, hbridge,
      hbridge.composition_coefficient_nonzero,
      hbridge.decomposition_coefficient_nonzero,
      hbridge.proof_theoretic_split_shape,
      hbridge.exposed_interface,
      hbridge.reconstructs_composite⟩
  refine ⟨derivableTree_of_derivation d', ?_⟩
  exact
    (directProofTheoreticHopf_primitive_mainResult base).direct_derivable_og
      |>.derivable_tree_coalgebra_laws (derivableTree_of_derivation d')

/--
Singleton-hypersequent form of the concrete NMMS local Hopf bridge.

This is the most literal one-step theorem for the algebra product side.  From
two actual derivations and a matching non-root sequent occurrence, the
addressed graft produces an actual derivation `d'`; the corresponding
singleton hypersequent composition step is derivable over the same base; and
the same composite proof tree carries the direct derivable UEA primitive
coalgebra law together with the CK decomposition, nonzero product/split
coefficients, exposed occurrence, and reconstruction data.
-/
theorem directProofTheoreticHopf_nmms_address_graft_singleton_hypersequent_bridge
    {base : BaseRel} {s_inner s_outer : MultiSequent}
    (d_inner : NMMS base s_inner)
    (d_outer : NMMS base s_outer)
    (a : Address)
    (hgraftable :
      PTree.IsGraftableLeafAt
        (NMMS.toTree d_inner) (NMMS.toTree d_outer) a)
    (hnode : IsNodeAddress (NMMS.toTree d_inner) ([] : Address))
    (hnotroot : a ≠ ([] : Address)) :
    ∃ d' : NMMS base s_outer,
      PTree.graftMatchingLeafAt
          (NMMS.toTree d_inner) (NMMS.toTree d_outer) a =
        some (NMMS.toTree d') ∧
      SequentMatchingProofTheoreticHypersequentCompositionStep base
        (HQ.singleton (NMMS.toTree d_inner) +
          HQ.singleton (NMMS.toTree d_outer))
        (HQ.singleton (NMMS.toTree d')) ∧
      (∃ hv : DerivableTree base (NMMS.toTree d'),
        letI : LieRing (DerivablePrimitiveLieCarrier base) :=
          derivableStableQuotientLieRing base
        DirectDerivableUEACoalgebraLawsAt base
          (derivableUEATreeGen hv)) ∧
      SequentMatchingCompositionDecomposition base
        (NMMS.toTree d_inner) (NMMS.toTree d_outer) (NMMS.toTree d') a ∧
      0 <
        graftMultiplicity
          (NMMS.toTree d_inner) (NMMS.toTree d_outer) (NMMS.toTree d') ∧
      0 <
        cutSplitMultiplicity (NMMS.toTree d')
          (HQ.singleton (NMMS.toTree d_inner),
            HQ.singleton (PTree.remainderGo [a] [] (NMMS.toTree d'))) ∧
      SplitProofTheoreticShape base
        (HQ.singleton (NMMS.toTree d_inner))
        (PTree.remainderGo [a] [] (NMMS.toTree d')) ∧
      PTree.subtreeAt (PTree.remainderGo [a] [] (NMMS.toTree d')) a =
        some (PTree.leaf (NMMS.toTree d_inner).conclusion) ∧
      BoundaryFill
        (NMMS.toTree d_inner)
        (PTree.remainderGo [a] [] (NMMS.toTree d'))
        (NMMS.toTree d') := by
  rcases
    graftMatchingLeafAt_toTree_is_toTree
      d_outer d_inner a hgraftable with
    ⟨d', hgraft⟩
  let hstep :
      SequentMatchingProofTheoreticHypersequentCompositionStep base
        (HQ.singleton (NMMS.toTree d_inner) +
          HQ.singleton (NMMS.toTree d_outer))
        (HQ.singleton (NMMS.toTree d')) := by
    refine
      ⟨0, NMMS.toTree d_inner, NMMS.toTree d_outer, NMMS.toTree d', a,
        ?_, ?_,
        derivableTree_of_derivation d_inner,
        derivableTree_of_derivation d_outer,
        hgraft, hnode, hnotroot,
        derivableTree_of_derivation d'⟩
    · simp
    · simp
  let hbridge :
      SequentMatchingCompositionDecomposition base
        (NMMS.toTree d_inner) (NMMS.toTree d_outer) (NMMS.toTree d') a :=
    sequentMatching_composition_decomposition
      (derivableTree_of_derivation d_inner)
      (derivableTree_of_derivation d_outer)
      hgraft hnode hnotroot
  refine
    ⟨d', hgraft, hstep, ?_, hbridge,
      hbridge.composition_coefficient_nonzero,
      hbridge.decomposition_coefficient_nonzero,
      hbridge.proof_theoretic_split_shape,
      hbridge.exposed_interface,
      hbridge.reconstructs_composite⟩
  refine ⟨derivableTree_of_derivation d', ?_⟩
  exact
    (directProofTheoreticHopf_primitive_mainResult base).direct_derivable_og
      |>.derivable_tree_coalgebra_laws (derivableTree_of_derivation d')

/--
Monotone-extension form of the concrete singleton local Hopf bridge.

If two actual `NMMS base` derivations admit a matching addressed graft, then
the same singleton hypersequent product and the same CK split remain valid
after any monotone extension of the material base relation.  The composite is
still derivable over the extended base, and the direct `DerivableUEA base'`
primitive coalgebra law applies to the lifted composite generator.
-/
theorem directProofTheoreticHopf_nmms_address_graft_singleton_bridge_mono_base
    {base base' : BaseRel}
    (hbase : BaseRelExtends base base')
    {s_inner s_outer : MultiSequent}
    (d_inner : NMMS base s_inner)
    (d_outer : NMMS base s_outer)
    (a : Address)
    (hgraftable :
      PTree.IsGraftableLeafAt
        (NMMS.toTree d_inner) (NMMS.toTree d_outer) a)
    (hnode : IsNodeAddress (NMMS.toTree d_inner) ([] : Address))
    (hnotroot : a ≠ ([] : Address)) :
    ∃ d' : NMMS base s_outer,
      PTree.graftMatchingLeafAt
          (NMMS.toTree d_inner) (NMMS.toTree d_outer) a =
        some (NMMS.toTree d') ∧
      SequentMatchingProofTheoreticHypersequentCompositionStep base
        (HQ.singleton (NMMS.toTree d_inner) +
          HQ.singleton (NMMS.toTree d_outer))
        (HQ.singleton (NMMS.toTree d')) ∧
      SequentMatchingProofTheoreticHypersequentCompositionStep base'
        (HQ.singleton (NMMS.toTree d_inner) +
          HQ.singleton (NMMS.toTree d_outer))
        (HQ.singleton (NMMS.toTree d')) ∧
      DerivableHypersequent base'
        (HQ.singleton (NMMS.toTree d_inner) +
          HQ.singleton (NMMS.toTree d_outer)) ∧
      DerivableHypersequent base' (HQ.singleton (NMMS.toTree d')) ∧
      (∃ hv : DerivableTree base' (NMMS.toTree d'),
        letI : LieRing (DerivablePrimitiveLieCarrier base') :=
          derivableStableQuotientLieRing base'
        DirectDerivableUEACoalgebraLawsAt base'
          (derivableUEATreeGen hv)) ∧
      SequentMatchingCompositionDecomposition base'
        (NMMS.toTree d_inner) (NMMS.toTree d_outer) (NMMS.toTree d') a ∧
      SplitProofTheoreticShape base'
        (HQ.singleton (NMMS.toTree d_inner))
        (PTree.remainderGo [a] [] (NMMS.toTree d')) ∧
      PTree.LeafSequentsSatisfy
        (OpenTerminalSequent base'
          (SplitBoundary (HQ.singleton (NMMS.toTree d_inner))))
        (PTree.remainderGo [a] [] (NMMS.toTree d')) := by
  rcases
    directProofTheoreticHopf_nmms_address_graft_singleton_hypersequent_bridge
      d_inner d_outer a hgraftable hnode hnotroot with
    ⟨d', hgraft, hstep, _hcoal, hbridge,
      _hcompCoeff, _hsplitCoeff, _hshape, _hexposed, _hfill⟩
  let hstep' :
      SequentMatchingProofTheoreticHypersequentCompositionStep base'
        (HQ.singleton (NMMS.toTree d_inner) +
          HQ.singleton (NMMS.toTree d_outer))
        (HQ.singleton (NMMS.toTree d')) :=
    sequentMatchingProofTheoreticHypersequentCompositionStep_mono_base
      hbase hstep
  let hbridge' :
      SequentMatchingCompositionDecomposition base'
        (NMMS.toTree d_inner) (NMMS.toTree d_outer) (NMMS.toTree d') a :=
    sequentMatchingCompositionDecomposition_mono_base hbase hbridge
  refine
    ⟨d', hgraft, hstep, hstep', ?_, ?_, ?_, hbridge',
      hbridge'.proof_theoretic_split_shape, ?_⟩
  · exact
      derivableHypersequent_add
        (derivableHypersequent_singleton
          (derivableTree_mono hbase
            (derivableTree_of_derivation d_inner)))
        (derivableHypersequent_singleton
          (derivableTree_mono hbase
            (derivableTree_of_derivation d_outer)))
  · exact
      derivableHypersequent_singleton
        (derivableTree_mono hbase (derivableTree_of_derivation d'))
  · refine
      ⟨derivableTree_mono hbase (derivableTree_of_derivation d'), ?_⟩
    exact
      (directProofTheoreticHopf_primitive_mainResult base').direct_derivable_og
        |>.derivable_tree_coalgebra_laws
          (derivableTree_mono hbase (derivableTree_of_derivation d'))
  · exact
      splitProofTheoreticShape_remainder_leafSequents
        hbridge'.proof_theoretic_split_shape

/--
Base-update diagnostic for one concrete addressed NMMS graft.

The theorem packages the two update behaviours for the same composite
derivation tree.

* Along any monotone base extension, the singleton hypersequent product, the
  direct derivable UEA primitive coalgebra law, and the CK
  composition/decomposition bridge all persist.
* Along any admissible update that destroys the composite proof tree, the
  updated base admits no local bridge with that composite and no direct
  derivable UEA coalgebra law for a generator labelled by that composite.

This is the local algebraic expression of genuine nonmonotonicity: the tree
operation is fixed, but its proof-theoretic admissibility is controlled by the
current material base.
-/
theorem directProofTheoreticHopf_nmms_address_graft_base_update_diagnostic
    {base : BaseRel} {s_inner s_outer : MultiSequent}
    (d_inner : NMMS base s_inner)
    (d_outer : NMMS base s_outer)
    (a : Address)
    (hgraftable :
      PTree.IsGraftableLeafAt
        (NMMS.toTree d_inner) (NMMS.toTree d_outer) a)
    (hnode : IsNodeAddress (NMMS.toTree d_inner) ([] : Address))
    (hnotroot : a ≠ ([] : Address)) :
    ∃ d' : NMMS base s_outer,
      PTree.graftMatchingLeafAt
          (NMMS.toTree d_inner) (NMMS.toTree d_outer) a =
        some (NMMS.toTree d') ∧
      (∀ base' : BaseRel,
        BaseRelExtends base base' →
          SequentMatchingProofTheoreticHypersequentCompositionStep base'
            (HQ.singleton (NMMS.toTree d_inner) +
              HQ.singleton (NMMS.toTree d_outer))
            (HQ.singleton (NMMS.toTree d')) ∧
          DerivableHypersequent base' (HQ.singleton (NMMS.toTree d')) ∧
          (∃ hv : DerivableTree base' (NMMS.toTree d'),
            letI : LieRing (DerivablePrimitiveLieCarrier base') :=
              derivableStableQuotientLieRing base'
            DirectDerivableUEACoalgebraLawsAt base'
              (derivableUEATreeGen hv)) ∧
          SequentMatchingCompositionDecomposition base'
            (NMMS.toTree d_inner) (NMMS.toTree d_outer)
            (NMMS.toTree d') a ∧
          SplitProofTheoreticShape base'
            (HQ.singleton (NMMS.toTree d_inner))
            (PTree.remainderGo [a] [] (NMMS.toTree d'))) ∧
      (∀ {U : AdmissibleBaseUpdate},
        DerivableTreeDestroyedByUpdate U base (NMMS.toTree d') →
          ∃ base' : BaseRel,
            U base base' ∧
            ¬ DerivableTree base' (NMMS.toTree d') ∧
            (∀ u t : PTree, ∀ a : Address,
              ¬ SequentMatchingCompositionDecomposition
                  base' u t (NMMS.toTree d') a) ∧
            ¬ (∃ hv : DerivableTree base' (NMMS.toTree d'),
              letI : LieRing (DerivablePrimitiveLieCarrier base') :=
                derivableStableQuotientLieRing base'
              DirectDerivableUEACoalgebraLawsAt base'
                (derivableUEATreeGen hv))) := by
  rcases
    graftMatchingLeafAt_toTree_is_toTree
      d_outer d_inner a hgraftable with
    ⟨d', hgraft⟩
  let hbridge :
      SequentMatchingCompositionDecomposition base
        (NMMS.toTree d_inner) (NMMS.toTree d_outer) (NMMS.toTree d') a :=
    sequentMatching_composition_decomposition
      (derivableTree_of_derivation d_inner)
      (derivableTree_of_derivation d_outer)
      hgraft hnode hnotroot
  refine ⟨d', hgraft, ?_, ?_⟩
  · intro base' hbase
    let hstep' :
        SequentMatchingProofTheoreticHypersequentCompositionStep base'
          (HQ.singleton (NMMS.toTree d_inner) +
            HQ.singleton (NMMS.toTree d_outer))
          (HQ.singleton (NMMS.toTree d')) := by
      refine
        ⟨0, NMMS.toTree d_inner, NMMS.toTree d_outer,
          NMMS.toTree d', a, ?_, ?_,
          derivableTree_mono hbase (derivableTree_of_derivation d_inner),
          derivableTree_mono hbase (derivableTree_of_derivation d_outer),
          hgraft, hnode, hnotroot,
          derivableTree_mono hbase (derivableTree_of_derivation d')⟩
      · simp
      · simp
    let hbridge' :
        SequentMatchingCompositionDecomposition base'
          (NMMS.toTree d_inner) (NMMS.toTree d_outer)
          (NMMS.toTree d') a :=
      sequentMatchingCompositionDecomposition_mono_base hbase hbridge
    refine ⟨hstep', ?_, ?_, hbridge', hbridge'.proof_theoretic_split_shape⟩
    · exact
        derivableHypersequent_singleton
          (derivableTree_mono hbase (derivableTree_of_derivation d'))
    · refine
        ⟨derivableTree_mono hbase (derivableTree_of_derivation d'), ?_⟩
      exact
        (directProofTheoreticHopf_primitive_mainResult base').direct_derivable_og
          |>.derivable_tree_coalgebra_laws
            (derivableTree_mono hbase (derivableTree_of_derivation d'))
  · intro U hdestroy
    rcases
      derivableTreeDestroyedByUpdate_blocks_composite_local_bridge
        hdestroy with
      ⟨base', hU, _hv_old, hv_new, hblock, hcoal_block⟩
    exact ⟨base', hU, hv_new, hblock, hcoal_block⟩

/--
Achieved-main-result form of monotone preservation for proof-theoretic
hypersequent graft composition.

The statement is about derivations, not merely sequent shadows: the input
relation is `ProofTheoreticHypersequentGraftCompositionStep`, whose witnesses
contain singleton proof-tree grafting support over the material base.
-/
theorem DirectProofTheoreticHopfPrimitiveMainResult.hypersequent_graft_composition_after_base_extension
    {base base' : BaseRel}
    (h : DirectProofTheoreticHopfPrimitiveMainResult base)
    (hbase : BaseRelExtends base base')
    {G H : Hypersequent}
    (hstep :
      ProofTheoreticHypersequentGraftCompositionStep base G H)
    (hG : DerivableHypersequent base G) :
    DerivableHypersequent base' H := by
  let hn : NonmonotonicWeakeningGraftingMarquee base :=
    h.structural_diagnostic
  exact
    proofTheoreticHypersequentGraftCompositionStep_preserves_derivable
      (hn.proof_theoretic_graft_composition_mono_base
        hbase hstep)
      (derivableHypersequent_mono hbase hG)

/--
Achieved-main-result form of the shadow theorem for hypersequent graft
composition.  This is the point where the sequent component accounting is
visible while the actual composition remains proof-tree grafting.
-/
theorem DirectProofTheoreticHopfPrimitiveMainResult.hypersequent_graft_composition_shadow_balance
    {base : BaseRel}
    (h : DirectProofTheoreticHopfPrimitiveMainResult base)
    {G H : Hypersequent}
    (hstep :
      ProofTheoreticHypersequentGraftCompositionStep base G H) :
    ∃ U : Hypersequent,
      DerivableHypersequent base U ∧
        HQ.conclusions H + HQ.conclusions U =
          HQ.conclusions G := by
  let hn : NonmonotonicWeakeningGraftingMarquee base :=
    h.structural_diagnostic
  exact hn.proof_theoretic_graft_composition_shadow_balance hstep

/--
The achieved main result gives the intended base-managed grafting theorem:
adding a component by external weakening is allowed only when that component is
derivable over the current material base and matches a graft site of the probe
derivation.  Under exactly those hypotheses the added component both remains
inside the derivable hypersequent sector and supplies a derivable contextual
internal graft.
-/
theorem DirectProofTheoreticHopfPrimitiveMainResult.controlled_weakening_supplies_contextual_graft
    {base : BaseRel}
    (h : DirectProofTheoreticHopfPrimitiveMainResult base)
    {G : Hypersequent} {t : PTree} (u : DerivableProofTree base)
    (hG : DerivableHypersequent base G)
    (hW : (baseGraftControlledWeakeningPolicy base u).admissible t) :
    ∃ H : Hypersequent,
      DerivableHypersequent base (G + HQ.singleton t) ∧
      ContextualInternalGraft u.1 (G + HQ.singleton t) H ∧
      DerivableHypersequent base H := by
  let hn : NonmonotonicWeakeningGraftingMarquee base :=
    h.structural_diagnostic
  exact hn.base_graft_controlled_weakening_supplies_contextual_graft
    u hG hW

/--
Controlled weakening/grafting survives monotone extension of the primitive
material base relation.

This theorem is deliberately about base extension, not arbitrary update:
nonmonotonic updates may destroy old base consequences, but a genuine
`BaseRelExtends` map preserves the already licensed proof component and the
same matching graft.
-/
theorem controlled_weakening_supplies_contextual_graft_after_base_extension
    {base base' : BaseRel}
    (hbase : BaseRelExtends base base')
    {G : Hypersequent} {t : PTree} (u : DerivableProofTree base)
    (hG : DerivableHypersequent base G)
    (hW : (baseGraftControlledWeakeningPolicy base u).admissible t) :
    ∃ H : Hypersequent,
      DerivableHypersequent base' (G + HQ.singleton t) ∧
      ContextualInternalGraft u.1 (G + HQ.singleton t) H ∧
      DerivableHypersequent base' H :=
  baseGraftControlledWeakening_supplies_derivable_contextual_graft_mono_base
    hbase u hG hW

/--
Main-result form of the base-extension theorem for controlled weakening and
grafting.
-/
theorem DirectProofTheoreticHopfPrimitiveMainResult.controlled_weakening_after_base_extension
    {base base' : BaseRel}
    (_h : DirectProofTheoreticHopfPrimitiveMainResult base)
    (hbase : BaseRelExtends base base')
    {G : Hypersequent} {t : PTree} (u : DerivableProofTree base)
    (hG : DerivableHypersequent base G)
    (hW : (baseGraftControlledWeakeningPolicy base u).admissible t) :
    ∃ H : Hypersequent,
      DerivableHypersequent base' (G + HQ.singleton t) ∧
      ContextualInternalGraft u.1 (G + HQ.singleton t) H ∧
      DerivableHypersequent base' H :=
  controlled_weakening_supplies_contextual_graft_after_base_extension
    hbase u hG hW

/--
Main-result form of the genuinely nonmonotone failure case: if an admissible
base update destroys a derivable proof tree, then the destroyed tree is blocked
as a controlled external-weakening component over the updated base.

This is the negative companion to the monotone base-extension theorem above.
-/
theorem DirectProofTheoreticHopfPrimitiveMainResult.destroyed_tree_update_blocks_controlled_weakening
    {base : BaseRel}
    (_h : DirectProofTheoreticHopfPrimitiveMainResult base)
    {U : AdmissibleBaseUpdate} {t : PTree}
    (hdestroy : DerivableTreeDestroyedByUpdate U base t) :
    ∃ base' : BaseRel,
      U base base' ∧
      DerivableTree base t ∧
      ¬ DerivableTree base' t ∧
      ∀ u : DerivableProofTree base',
        ¬ (baseGraftControlledWeakeningPolicy base' u).admissible t :=
  derivableTreeDestroyedByUpdate_blocks_controlled_weakening hdestroy

/--
Achieved-main-result form of the genuinely nonmonotone failure of algebra-side
proof composition: when an admissible update destroys a derivable proof tree,
that tree cannot occur as the fixed inserted singleton of the hypersequent
graft-composition operation over the updated base.
-/
theorem DirectProofTheoreticHopfPrimitiveMainResult.destroyed_tree_update_blocks_hypersequent_composition
    {base : BaseRel}
    (h : DirectProofTheoreticHopfPrimitiveMainResult base)
    {U : AdmissibleBaseUpdate} {u : PTree}
    (hdestroy : DerivableTreeDestroyedByUpdate U base u) :
    ∃ base' : BaseRel,
      U base base' ∧
        DerivableTree base u ∧
          ¬ DerivableTree base' u ∧
            ∀ G H : Hypersequent,
              ¬ FixedInsertedProofTheoreticHypersequentGraftCompositionStep
                  base' (HQ.singleton u) G H := by
  let hn : NonmonotonicWeakeningGraftingMarquee base :=
    h.structural_diagnostic
  exact
    hn.destroyed_inserted_proof_blocks_fixed_hypersequent_composition
      hdestroy

/--
Achieved-main-result form of the destructive-update effect on the local
cut/graft bridge.

If an admissible update destroys the composite proof tree, then over the
updated base there is no sequent-matching local bridge with that composite and
no direct derivable UEA primitive coalgebra law attached to that composite
generator.
-/
theorem DirectProofTheoreticHopfPrimitiveMainResult.destroyed_composite_update_blocks_local_bridge
    {base : BaseRel}
    (_h : DirectProofTheoreticHopfPrimitiveMainResult base)
    {U : AdmissibleBaseUpdate} {v : PTree}
    (hdestroy : DerivableTreeDestroyedByUpdate U base v) :
    ∃ base' : BaseRel,
      U base base' ∧
      DerivableTree base v ∧
      ¬ DerivableTree base' v ∧
      (∀ u t : PTree, ∀ a : Address,
        ¬ SequentMatchingCompositionDecomposition base' u t v a) ∧
      ¬ (∃ hv : DerivableTree base' v,
        letI : LieRing (DerivablePrimitiveLieCarrier base') :=
          derivableStableQuotientLieRing base'
        DirectDerivableUEACoalgebraLawsAt base'
          (derivableUEATreeGen hv)) :=
  derivableTreeDestroyedByUpdate_blocks_composite_local_bridge hdestroy

/--
Proof-theoretic CK decomposition is stable under monotone base extension:
if a split term really consists of closed derivable detached subproofs and an
open derivable remainder over `base`, then the same ambient cut term has the
same proof-theoretic interpretation over any larger material base.
-/
theorem proofTheoreticSplittingSupport_after_base_extension
    {base base' : BaseRel}
    (hbase : BaseRelExtends base base')
    {t : PTree} {p : Hypersequent × PTree}
    (hp : ProofTheoreticSplittingSupport base t p) :
    ProofTheoreticSplittingSupport base' t p :=
  proofTheoreticSplittingSupport_mono_base hbase hp

/--
Main-result form of monotone preservation for proof-theoretic CK
decomposition.
-/
theorem DirectProofTheoreticHopfPrimitiveMainResult.decomposition_after_base_extension
    {base base' : BaseRel}
    (_h : DirectProofTheoreticHopfPrimitiveMainResult base)
    (hbase : BaseRelExtends base base')
    {t : PTree} {p : Hypersequent × PTree}
    (hp : ProofTheoreticSplittingSupport base t p) :
    ProofTheoreticSplittingSupport base' t p :=
  proofTheoreticSplittingSupport_after_base_extension hbase hp

/--
Main-result form of the destructive-update effect on decomposition.

If a base update destroys one proof tree that occurs in the detached forest of
an ambient CK split, then that same ambient split term is blocked as a
proof-theoretic decomposition over the updated base.
-/
theorem DirectProofTheoreticHopfPrimitiveMainResult.destroyed_tree_update_blocks_decomposition
    {base : BaseRel}
    (_h : DirectProofTheoreticHopfPrimitiveMainResult base)
    {U : AdmissibleBaseUpdate} {u : PTree}
    (hdestroy : DerivableTreeDestroyedByUpdate U base u)
    {Γ : Hypersequent} {r : PTree}
    (huΓ : u ∈ Γ) :
    ∃ base' : BaseRel,
      U base base' ∧
      DerivableTree base u ∧
      ¬ DerivableTree base' u ∧
      ¬ SplitProofTheoreticShape base' Γ r ∧
      ∀ t : PTree, ¬ ProofTheoreticSplittingSupport base' t (Γ, r) :=
  derivableTreeDestroyedByUpdate_blocks_detached_split_shape
    hdestroy huΓ

