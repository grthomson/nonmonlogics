              (A := preLieDifferenceStableQuotientUEA) a)) =
        algebraMap ℤ preLieDifferenceStableQuotientUEA
          (Coalgebra.counit (R := ℤ)
            (A := preLieDifferenceStableQuotientUEA) a) := by
  letI : MathlibOudomGuinHopfSide := W.hopf
