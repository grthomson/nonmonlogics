theorem MathlibOudomGuinHopfWitness.antipode_left_cancellation
    (W : MathlibOudomGuinHopfWitness) :
    letI : MathlibOudomGuinHopfSide := W.hopf
    letI : HopfAlgebraStruct ℤ preLieDifferenceStableQuotientUEA :=
