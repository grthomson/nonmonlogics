/--
Inserted direct grafting Lie brackets are primitive for any OG Hopf witness.
-/
theorem OudomGuinGraftingHopfWitness.primitive_stableGraftingLieBracket
    (W : OudomGuinGraftingHopfWitness)
    (x y : PTree) :
    W.target.carrier.DeltaOG
        (QuotientConnected.CoproductSupport.stableUEACanonicalIota
          (stableGraftingLieBracket
            (mkPreLieDifferenceStableQuotient (treeGen x))
            (mkPreLieDifferenceStableQuotient (treeGen y)))) =
      TensorProduct.tmul ℤ
          (QuotientConnected.CoproductSupport.stableUEACanonicalIota
            (stableGraftingLieBracket
              (mkPreLieDifferenceStableQuotient (treeGen x))
              (mkPreLieDifferenceStableQuotient (treeGen y)))) 1 +
        TensorProduct.tmul ℤ 1
          (QuotientConnected.CoproductSupport.stableUEACanonicalIota
            (stableGraftingLieBracket
              (mkPreLieDifferenceStableQuotient (treeGen x))
              (mkPreLieDifferenceStableQuotient (treeGen y)))) := by
  exact W.target.primitive_stableQuotient _

/--
Inserted OG-convention grafting Lie brackets are primitive for any OG Hopf
witness.
-/
theorem OudomGuinGraftingHopfWitness.primitive_stableOudomGuinLieBracket
    (W : OudomGuinGraftingHopfWitness)
    (x y : PTree) :
    W.target.carrier.DeltaOG
        (QuotientConnected.CoproductSupport.stableUEACanonicalIota
          (stableOudomGuinLieBracket
            (mkPreLieDifferenceStableQuotient (treeGen x))
            (mkPreLieDifferenceStableQuotient (treeGen y)))) =
      TensorProduct.tmul ℤ
          (QuotientConnected.CoproductSupport.stableUEACanonicalIota
            (stableOudomGuinLieBracket
              (mkPreLieDifferenceStableQuotient (treeGen x))
              (mkPreLieDifferenceStableQuotient (treeGen y)))) 1 +
        TensorProduct.tmul ℤ 1
          (QuotientConnected.CoproductSupport.stableUEACanonicalIota
            (stableOudomGuinLieBracket
              (mkPreLieDifferenceStableQuotient (treeGen x))
              (mkPreLieDifferenceStableQuotient (treeGen y)))) := by
  exact W.target.primitive_stableQuotient _

/--
Under an OG Hopf witness, the commutator of two inserted proof-tree
generators is primitive.
-/
theorem OudomGuinGraftingHopfWitness.primitive_treeGen_commutator
    (W : OudomGuinGraftingHopfWitness)
    (x y : PTree) :
    W.target.carrier.DeltaOG
        (stableUEA_treeGen x * stableUEA_treeGen y -
          stableUEA_treeGen y * stableUEA_treeGen x) =
      TensorProduct.tmul ℤ
          (stableUEA_treeGen x * stableUEA_treeGen y -
            stableUEA_treeGen y * stableUEA_treeGen x) 1 +
        TensorProduct.tmul ℤ 1
          (stableUEA_treeGen x * stableUEA_treeGen y -
            stableUEA_treeGen y * stableUEA_treeGen x) := by
  have hprim := W.primitive_stableOudomGuinLieBracket x y
  have hcomm :
      QuotientConnected.CoproductSupport.stableUEACanonicalIota
          (stableOudomGuinLieBracket
            (mkPreLieDifferenceStableQuotient (treeGen x))
            (mkPreLieDifferenceStableQuotient (treeGen y))) =
        stableUEA_treeGen x * stableUEA_treeGen y -
          stableUEA_treeGen y * stableUEA_treeGen x := by
    simpa [QuotientConnected.CoproductSupport.stableUEACanonicalIota] using
      stableUEA_oudomGuinLieBracket_treeGen_eq_commutator x y
  simpa [hcomm] using hprim

/--
Marquee packet for the Oudom-Guin/grafting Hopf side.

This is the proof-tree-specific Hopf algebra story separated from the CK
forest Hopf algebra:

* the primitive carrier is the stable quotient of the constrained grafting
  pre-Lie product;
* the associative Hopf carrier is the UEA of that Lie algebra;
* the coproduct is primitive on proof-tree generators and multiplicative on
  the UEA;
* the antipode negates proof-tree generators and satisfies the convolution
  cancellation laws.

The packet deliberately uses the concrete `OudomGuinGraftingHopfWitness`.
That keeps the remaining construction honest: proving the OG Hopf side means
supplying this witness.
-/
structure OudomGuinHopfAlgebraMarquee : Prop where
  preLie_input :
    OudomGuinGraftingPreLieSide
  coalgebra_side :
    OudomGuinGraftingCoalgebraSide
  hopf_side_iff_witness :
    OudomGuinGraftingHopfSide ↔
      Nonempty OudomGuinGraftingHopfWitness
  mathlib_hopf_side_from_instance :
    ∀ [HopfAlgebra ℤ preLieDifferenceStableQuotientUEA],
      MathlibOudomGuinHopfSideExists
  mathlib_witness_supplies_hopf_side :
    ∀ _W : MathlibOudomGuinHopfWitness,
      MathlibOudomGuinHopfSideExists
  witness_primitive_treeGen :
    ∀ (W : OudomGuinGraftingHopfWitness) (x : PTree),
      W.target.carrier.DeltaOG (stableUEA_treeGen x) =
        TensorProduct.tmul ℤ (stableUEA_treeGen x) 1 +
          TensorProduct.tmul ℤ 1 (stableUEA_treeGen x)
  witness_antipode_treeGen :
    ∀ (W : OudomGuinGraftingHopfWitness) (x : PTree),
      W.target.hopf.antipode (stableUEA_treeGen x) =
        -stableUEA_treeGen x
  witness_left_antipode_cancellation :
    ∀ (W : OudomGuinGraftingHopfWitness)
      (a : preLieDifferenceStableQuotientUEA),
      W.target.hopf.mulTensor
          ((LinearMap.rTensor preLieDifferenceStableQuotientUEA
              W.target.hopf.antipode)
            (W.target.carrier.DeltaOG a)) =
        W.target.hopf.unitLinear (W.target.carrier.epsilonOG a)
  witness_right_antipode_cancellation :
    ∀ (W : OudomGuinGraftingHopfWitness)
      (a : preLieDifferenceStableQuotientUEA),
      W.target.hopf.mulTensor
          ((LinearMap.lTensor preLieDifferenceStableQuotientUEA
              W.target.hopf.antipode)
            (W.target.carrier.DeltaOG a)) =
        W.target.hopf.unitLinear (W.target.carrier.epsilonOG a)
  witness_treeGen_commutator_primitive :
    ∀ (W : OudomGuinGraftingHopfWitness) (x y : PTree),
      W.target.carrier.DeltaOG
          (stableUEA_treeGen x * stableUEA_treeGen y -
            stableUEA_treeGen y * stableUEA_treeGen x) =
        TensorProduct.tmul ℤ
            (stableUEA_treeGen x * stableUEA_treeGen y -
              stableUEA_treeGen y * stableUEA_treeGen x) 1 +
          TensorProduct.tmul ℤ 1
            (stableUEA_treeGen x * stableUEA_treeGen y -
              stableUEA_treeGen y * stableUEA_treeGen x)

theorem oudomGuin_hopf_algebra_marquee :
    OudomGuinHopfAlgebraMarquee where
  preLie_input :=
    oudomGuin_grafting_preLie_side_exists
  coalgebra_side :=
    oudomGuin_grafting_coalgebra_side_exists
  hopf_side_iff_witness :=
    oudomGuin_grafting_hopf_side_iff_nonempty_witness
  mathlib_hopf_side_from_instance := by
    intro inst
    letI : HopfAlgebra ℤ preLieDifferenceStableQuotientUEA := inst
    exact mathlib_oudomGuin_hopf_side_exists_of_instance
  mathlib_witness_supplies_hopf_side := by
    intro W
    exact W.hopf_side_exists
  witness_primitive_treeGen := by
    intro W x
    exact W.primitive_treeGen x
  witness_antipode_treeGen := by
    intro W x
    exact W.antipode_treeGen x
  witness_left_antipode_cancellation := by
    intro W a
    exact W.antipode_left_cancellation a
  witness_right_antipode_cancellation := by
    intro W a
    exact W.antipode_right_cancellation a
  witness_treeGen_commutator_primitive := by
    intro W x y
    exact W.primitive_treeGen_commutator x y

/-! ### Canonical OG completion data

The two-Hopf theorem should not be completed by arbitrary Hopf data on the
stable UEA. The OG side is proof-theoretically meaningful only when its
bialgebra structure is primitive on the canonical Lie insertion `ι` of the
stable quotient. This is the algebraic place where grafting, the pre-Lie
bracket, and proof-tree generators enter the UEA Hopf algebra.
-/

/--
Canonical OG Hopf data: the UEA Hopf structure is carrier-compatible with the
OG target and its bialgebra maps satisfy the primitive formula on the canonical
Lie insertion `ι`.

This strengthens the earlier compatible-data obligation by ruling out Hopf
structures whose maps happen to have the right names but do not arise from the
grafting/pre-Lie primitive operation.
-/
def CanonicalOudomGuinHopfData
    (carrier :
      QuotientConnected.CoproductSupport.OudomGuinUEAHopfCarrierTarget)
    (hopf : QuotientConnected.StableUEAHopfData) : Prop :=
  hopf.comul = carrier.DeltaOG ∧
    hopf.counit = carrier.epsilonOG ∧
    QuotientConnected.CoproductSupport.StableUEABialgebraData.OGPrimitiveOnIota
      hopf.bialgebra

/--
Existence of canonical OG Hopf data. This is now the most precise construction
target for the grafting side of the project.
-/
def CanonicalOudomGuinHopfDataExists : Prop :=
  ∃ (carrier :
      QuotientConnected.CoproductSupport.OudomGuinUEAHopfCarrierTarget)
    (hopf : QuotientConnected.StableUEAHopfData),
    CanonicalOudomGuinHopfData carrier hopf

/--
The descended OG primitive comultiplication has the primitive tensor formula
on every stable quotient class.
-/
theorem OGPrimitiveComul_comul_eq_primitive_formula
    (q : PreLieDifferenceStableQuotient) :
    QuotientConnected.CoproductSupport.OGPrimitiveComul.comul q =
      TensorProduct.tmul ℤ (preLieDifferenceStableQuotientUEA_ι q) 1 +
        TensorProduct.tmul ℤ 1 (preLieDifferenceStableQuotientUEA_ι q) := by
  induction q using Submodule.Quotient.induction_on with
  | H a =>
      simpa [preLieDifferenceStableQuotientToUEA] using
        QuotientConnected.CoproductSupport.OGPrimitiveComul_comul_mk a

/--
The descended OG primitive counit vanishes on every stable quotient class.
-/
theorem OGPrimitiveComul_counit_eq_zero
    (q : PreLieDifferenceStableQuotient) :
    QuotientConnected.CoproductSupport.OGPrimitiveComul.counit q = 0 := by
  induction q using Submodule.Quotient.induction_on with
  | H a =>
      simpa using
        QuotientConnected.CoproductSupport.OGPrimitiveComul_counit_mk a

/-- Canonical OG data is, in particular, compatible OG Hopf data. -/
theorem compatible_og_hopf_data_of_canonical_og_hopf_data
    {carrier :
      QuotientConnected.CoproductSupport.OudomGuinUEAHopfCarrierTarget}
    {hopf : QuotientConnected.StableUEAHopfData}
    (h : CanonicalOudomGuinHopfData carrier hopf) :
    hopf.comul = carrier.DeltaOG ∧
      hopf.counit = carrier.epsilonOG := by
  exact ⟨h.1, h.2.1⟩

/--
The primitive-on-`ι` condition forces the expected OG formula on every proof
tree generator in the stable UEA.
-/
theorem CanonicalOudomGuinHopfData.bialgebra_treeGen_formula
    {carrier :
      QuotientConnected.CoproductSupport.OudomGuinUEAHopfCarrierTarget}
    {hopf : QuotientConnected.StableUEAHopfData}
    (h : CanonicalOudomGuinHopfData carrier hopf) :
    (∀ x : PTree,
      hopf.bialgebra.comul (stableUEA_treeGen x) =
        TensorProduct.tmul ℤ (stableUEA_treeGen x) 1 +
          TensorProduct.tmul ℤ 1 (stableUEA_treeGen x)) ∧
    (∀ x : PTree,
      hopf.bialgebra.counit (stableUEA_treeGen x) = 0) := by
  exact
    QuotientConnected.CoproductSupport.StableUEABialgebraData_on_treeGen_of_OGPrimitiveOnIota
        hopf.bialgebra h.2.2

/--
Canonical OG Hopf data has the primitive coproduct and zero counit on
genuinely derivable proof-tree generators inserted through the proof-theoretic
stable quotient.
-/
theorem CanonicalOudomGuinHopfData.bialgebra_derivableStableTreeGen_formula
    {carrier :
      QuotientConnected.CoproductSupport.OudomGuinUEAHopfCarrierTarget}
    {hopf : QuotientConnected.StableUEAHopfData}
    (h : CanonicalOudomGuinHopfData carrier hopf) :
    (∀ {base : BaseRel} {t : PTree} (ht : DerivableTree base t),
      hopf.bialgebra.comul
          (QuotientConnected.CoproductSupport.derivableStableUEAIota
            base
            (QuotientConnected.CoproductSupport.derivableStableTreeGen ht)) =
        TensorProduct.tmul ℤ
            (QuotientConnected.CoproductSupport.derivableStableUEAIota
              base
              (QuotientConnected.CoproductSupport.derivableStableTreeGen ht)) 1 +
          TensorProduct.tmul ℤ 1
            (QuotientConnected.CoproductSupport.derivableStableUEAIota
              base
              (QuotientConnected.CoproductSupport.derivableStableTreeGen ht))) ∧
    (∀ {base : BaseRel} {t : PTree} (ht : DerivableTree base t),
      hopf.bialgebra.counit
          (QuotientConnected.CoproductSupport.derivableStableUEAIota
            base
            (QuotientConnected.CoproductSupport.derivableStableTreeGen ht)) = 0) := by
  constructor
  · intro base t ht
    simpa using (CanonicalOudomGuinHopfData.bialgebra_treeGen_formula h).1 t
  · intro base t ht
    simpa using (CanonicalOudomGuinHopfData.bialgebra_treeGen_formula h).2 t

/--
The same canonical condition determines the UEA bialgebra maps on arbitrary
raw linear combinations of proof trees.
-/
theorem CanonicalOudomGuinHopfData.bialgebra_raw_formula
    {carrier :
      QuotientConnected.CoproductSupport.OudomGuinUEAHopfCarrierTarget}
    {hopf : QuotientConnected.StableUEAHopfData}
    (h : CanonicalOudomGuinHopfData carrier hopf)
    (a : linearProofTreeCarrier) :
    hopf.bialgebra.comul (preLieDifferenceStableQuotientToUEA a) =
        QuotientConnected.CoproductSupport.OGPrimitiveComul.comul
          (mkPreLieDifferenceStableQuotient a) ∧
      hopf.bialgebra.counit (preLieDifferenceStableQuotientToUEA a) =
        QuotientConnected.CoproductSupport.OGPrimitiveComul.counit
          (mkPreLieDifferenceStableQuotient a) := by
  exact
    QuotientConnected.CoproductSupport.StableUEABialgebraData_on_mk_eq_OGPrimitive_of_OGPrimitiveOnIota
        hopf.bialgebra h.2.2 a

/--
Canonical OG Hopf data supplies the OG side needed for the two-Hopf theorem.
-/
theorem compatible_og_hopf_data_exists_of_canonical_og_hopf_data_exists
    (h : CanonicalOudomGuinHopfDataExists) :
    ∃ (carrier :
        QuotientConnected.CoproductSupport.OudomGuinUEAHopfCarrierTarget)
      (hopf : QuotientConnected.StableUEAHopfData),
      hopf.comul = carrier.DeltaOG ∧
        hopf.counit = carrier.epsilonOG := by
  rcases h with ⟨carrier, hopf, hcanon⟩
  exact
    ⟨carrier, hopf,
      compatible_og_hopf_data_of_canonical_og_hopf_data hcanon⟩

/--
Every full OG UEA Hopf target is canonical: its bialgebra maps satisfy the
primitive formula on the canonical Lie insertion `ι`.
-/
theorem canonical_og_hopf_data_of_og_target
    (H : QuotientConnected.CoproductSupport.OudomGuinUEAHopfAlgebraTarget) :
    CanonicalOudomGuinHopfData H.carrier H.hopf := by
  refine ⟨H.comul_eq, H.counit_eq, ?_⟩
  constructor
  · intro q
    calc
      H.hopf.bialgebra.comulAlgHom
          (preLieDifferenceStableQuotientUEA_ι q) =
        H.hopf.bialgebra.comul
          (preLieDifferenceStableQuotientUEA_ι q) := by
          exact
            StableUEABialgebraData.comulAlgHom_apply_simp
              H.hopf.bialgebra (preLieDifferenceStableQuotientUEA_ι q)
      _ = H.carrier.DeltaOG
          (preLieDifferenceStableQuotientUEA_ι q) := by
          have h :=
            congrArg
              (fun f => f (preLieDifferenceStableQuotientUEA_ι q))
              H.comul_eq
          simpa [StableUEAHopfData.comul, StableUEABialgebraData.comul] using h
      _ = TensorProduct.tmul ℤ (preLieDifferenceStableQuotientUEA_ι q) 1 +
          TensorProduct.tmul ℤ 1 (preLieDifferenceStableQuotientUEA_ι q) := by
          simpa [QuotientConnected.CoproductSupport.stableUEACanonicalIota]
            using H.primitive_stableQuotient q
      _ = QuotientConnected.CoproductSupport.OGPrimitiveComul.comul q := by
          exact (OGPrimitiveComul_comul_eq_primitive_formula q).symm
  · intro q
    calc
      H.hopf.bialgebra.counitAlgHom
          (preLieDifferenceStableQuotientUEA_ι q) =
        H.hopf.bialgebra.counit
          (preLieDifferenceStableQuotientUEA_ι q) := by
          exact
            StableUEABialgebraData.counitAlgHom_apply_simp
              H.hopf.bialgebra (preLieDifferenceStableQuotientUEA_ι q)
      _ = H.carrier.epsilonOG
          (preLieDifferenceStableQuotientUEA_ι q) := by
          have h :=
            congrArg
              (fun f => f (preLieDifferenceStableQuotientUEA_ι q))
              H.counit_eq
          simpa [StableUEAHopfData.counit, StableUEABialgebraData.counit] using h
      _ = 0 := by
          simpa [QuotientConnected.CoproductSupport.stableUEACanonicalIota]
            using H.counit_stableQuotient q
      _ = QuotientConnected.CoproductSupport.OGPrimitiveComul.counit q := by
          exact (OGPrimitiveComul_counit_eq_zero q).symm

/-- Existence of a full OG UEA Hopf target supplies canonical OG Hopf data. -/
theorem canonical_og_hopf_data_exists_of_og_target
    (h :
      ∃ _H : QuotientConnected.CoproductSupport.OudomGuinUEAHopfAlgebraTarget,
        True) :
    CanonicalOudomGuinHopfDataExists := by
  rcases h with ⟨H, -⟩
  exact ⟨H.carrier, H.hopf, canonical_og_hopf_data_of_og_target H⟩

/--
Canonical OG Hopf data is equivalent to the full OG UEA Hopf target.

This shows that the primitive-on-`ι` refinement is not an extra artificial
layer: the carrier-correct target already contains enough proof-tree primitive
information to force canonicity.
-/
theorem canonical_og_hopf_data_exists_iff_og_target :
    CanonicalOudomGuinHopfDataExists ↔
      ∃ _H : QuotientConnected.CoproductSupport.OudomGuinUEAHopfAlgebraTarget,
        True := by
  constructor
  · intro h
    exact
      (QuotientConnected.CoproductSupport.oudomGuinUEAHopfAlgebraTarget_exists_iff_compatible_hopf_data).2
        (compatible_og_hopf_data_exists_of_canonical_og_hopf_data_exists h)
  · intro h
    exact canonical_og_hopf_data_exists_of_og_target h

/-! ## External product and internal grafting -/

/-- Hypersequent multiplication is external juxtaposition of components. -/
abbrev ExternalProduct : Hypersequent -> Hypersequent -> Hypersequent :=
  ExternalJuxtaposition

/-- Internal proof composition is the existing matching-leaf grafting support. -/
abbrev InternalGraftSupport (u t : PTree) : List PTree :=
  treeGraftSupport u t

/--
The product in the Hopf algebra is the external hypersequent product, not the
internal proof-composition/grafting product.
-/
theorem external_product_on_tree_generators
    (R : Type) [Semiring R] (u t : PTree) :
    (treeMonomial R u : HypersequentAlgebra R) * treeMonomial R t =
      hseqMonomial R
        (ExternalProduct (HQ.treeSingleton u) (HQ.treeSingleton t)) := by
  exact hypersequentAlgebra_mul_is_external_product R u t

/--
The image of raw proof-tree grafting in the hypersequent algebra is exactly the
singleton-hypersequent internal grafting element.
-/
theorem raw_grafting_maps_to_internal_hypersequent_grafting
    (u t : PTree) :
    primitiveToHypersequentAlgebra
        (Syntax.graftPreLie
          (Syntax.treeGen u)
          (Syntax.treeGen t)) =
      treeGraftCompositionElement Int u t := by
  exact primitiveToHypersequentAlgebra_graftPreLie_on_generators u t

/--
Tree-level proof-theoretic grafting is also a singleton-hypersequent
operation.

This is the common-carrier reading: the algebra side may work inside the same
hypersequent/forest universe as the coalgebra side, with proof composition
appearing on one-component hypersequents and external context supplied by
ordinary hypersequent juxtaposition.
-/
theorem proof_theoretic_grafting_lives_on_singleton_hypersequents
    {base : BaseRel} {u t v : PTree}
    (h : ProofTheoreticGraftingSupport base u t v) :
    ProofTheoreticSingletonHypersequentGraftingSupport base
      (HQ.singleton u) (HQ.singleton t) (HQ.singleton v) :=
  proofTheoreticSingletonHypersequentGraftingSupport_of_tree_support h

/--
The singleton-hypersequent reading still remembers the actual internal graft:
the host singleton is transformed into the output singleton by
`ContextualInternalGraft`.
-/
theorem singleton_hypersequent_grafting_has_contextual_graft
    {base : BaseRel} {U T V : Hypersequent}
    (h : ProofTheoreticSingletonHypersequentGraftingSupport base U T V) :
    ∃ u t v : PTree,
      U = HQ.singleton u ∧
        T = HQ.singleton t ∧
          V = HQ.singleton v ∧
            ContextualInternalGraft u T V :=
  proofTheoreticSingletonHypersequentGraftingSupport_contextual h

theorem singleton_hypersequent_grafting_extends_across_external_context
    {base : BaseRel} {U T V C : Hypersequent}
    (h : ProofTheoreticSingletonHypersequentGraftingSupport base U T V)
    (hC : DerivableHypersequent base C) :
    ∃ u : PTree,
      DerivableHypersequent base U ∧
        DerivableHypersequent base (ExternalProduct C T) ∧
          ContextualInternalGraft u
            (ExternalProduct C T) (ExternalProduct C V) ∧
            DerivableHypersequent base (ExternalProduct C V) ∧
              HQ.conclusions (ExternalProduct C V) =
                HQ.conclusions (ExternalProduct C T) := by
  rcases
    proofTheoreticSingletonHypersequentGraftingSupport_add_context
      h hC with
  ⟨u, hU, hCT, hctx, hCV, hshadow⟩
  refine ⟨u, hU, ?_, ?_, ?_, ?_⟩
  · simpa [ExternalProduct, ExternalJuxtaposition, add_comm] using hCT
  · simpa [ExternalProduct, ExternalJuxtaposition, add_comm] using hctx
  · simpa [ExternalProduct, ExternalJuxtaposition, add_comm] using hCV
  · simpa [ExternalProduct, ExternalJuxtaposition, add_comm] using hshadow

/--
The contextual singleton graft is one of the admissible derivable internal
grafting steps.

This strengthens the common-carrier theorem above: it does not merely exhibit
a contextual graft inside the surrounding hypersequent, but identifies it as
the closed-sector structural/proof-composition rule whose inserted proof tree
is derivable over the same material base.
-/
theorem singleton_hypersequent_grafting_realizes_derivable_internal_step
    {base : BaseRel} {U T V C : Hypersequent}
    (h : ProofTheoreticSingletonHypersequentGraftingSupport base U T V)
    (hC : DerivableHypersequent base C) :
    ∃ u : PTree,
      DerivableHypersequent base U ∧
        DerivableHypersequent base (ExternalProduct C T) ∧
          FixedDerivableContextualInternalGraftStep base u
            (ExternalProduct C T) (ExternalProduct C V) ∧
            DerivableHypersequent base (ExternalProduct C V) ∧
              HQ.conclusions (ExternalProduct C V) =
                HQ.conclusions (ExternalProduct C T) := by
  rcases
    proofTheoreticSingletonHypersequentGraftingSupport_add_context_step
      h hC with
  ⟨u, hU, hCT, hstep, hCV, hshadow⟩
  refine ⟨u, hU, ?_, ?_, ?_, ?_⟩
  · simpa [ExternalProduct, ExternalJuxtaposition, add_comm] using hCT
  · simpa [ExternalProduct, ExternalJuxtaposition, add_comm] using hstep
  · simpa [ExternalProduct, ExternalJuxtaposition, add_comm] using hCV
  · simpa [ExternalProduct, ExternalJuxtaposition, add_comm] using hshadow

theorem singleton_hypersequent_grafting_realizes_general_internal_step
    {base : BaseRel} {U T V C : Hypersequent}
    (h : ProofTheoreticSingletonHypersequentGraftingSupport base U T V)
    (hC : DerivableHypersequent base C) :
    DerivableContextualInternalGraftStep base
      (ExternalProduct C T) (ExternalProduct C V) := by
  rcases
    singleton_hypersequent_grafting_realizes_derivable_internal_step
      h hC with
  ⟨u, _hU, _hCT, hstep, _hCV, _hshadow⟩
  exact ⟨u, hstep⟩

theorem singleton_grafting_components_are_base_derivable_external_weakening
    {base : BaseRel} {U T V C : Hypersequent}
    (h : ProofTheoreticSingletonHypersequentGraftingSupport base U T V) :
    ExternalWeakeningMove (baseDerivableWeakeningPolicy base)
        C (ExternalProduct C U) ∧
      ExternalWeakeningMove (baseDerivableWeakeningPolicy base)
        C (ExternalProduct C T) ∧
        ExternalWeakeningMove (baseDerivableWeakeningPolicy base)
          C (ExternalProduct C V) := by
  rcases
    proofTheoreticSingletonHypersequentGraftingSupport_externalWeakening_components
      (C := C) h with
  ⟨hU, hT, hV⟩
  exact
    ⟨by simpa [ExternalProduct, ExternalJuxtaposition] using hU,
      by simpa [ExternalProduct, ExternalJuxtaposition] using hT,
      by simpa [ExternalProduct, ExternalJuxtaposition] using hV⟩

/--
The singleton proof-theoretic graft is also a hypersequent composition step:
inside an external context, the inserted proof component and host proof
component are replaced by the grafted proof component.
-/
theorem singleton_grafting_realizes_hypersequent_composition_step
    {base : BaseRel} {U T V C : Hypersequent}
    (h : ProofTheoreticSingletonHypersequentGraftingSupport base U T V) :
    ProofTheoreticHypersequentGraftCompositionStep base
      (ExternalProduct (ExternalProduct C U) T)
      (ExternalProduct C V) := by
  simpa [ExternalProduct, ExternalJuxtaposition] using
    (proofTheoreticHypersequentGraftCompositionStep_of_singleton_support
      (C := C) h)

theorem singleton_hypersequent_grafting_extends_across_external_context_mono_base
    {base base' : BaseRel}
    (hbase : BaseRelExtends base base')
    {U T V C : Hypersequent}
    (h : ProofTheoreticSingletonHypersequentGraftingSupport base U T V)
    (hC : DerivableHypersequent base C) :
    ∃ u : PTree,
      DerivableHypersequent base' U ∧
        DerivableHypersequent base' (ExternalProduct C T) ∧
          ContextualInternalGraft u
            (ExternalProduct C T) (ExternalProduct C V) ∧
            DerivableHypersequent base' (ExternalProduct C V) ∧
              HQ.conclusions (ExternalProduct C V) =
                HQ.conclusions (ExternalProduct C T) := by
  rcases
    proofTheoreticSingletonHypersequentGraftingSupport_add_context_mono_base
      hbase h hC with
  ⟨u, hU, hCT, hctx, hCV, hshadow⟩
  refine ⟨u, hU, ?_, ?_, ?_, ?_⟩
  · simpa [ExternalProduct, ExternalJuxtaposition, add_comm] using hCT
  · simpa [ExternalProduct, ExternalJuxtaposition, add_comm] using hctx
  · simpa [ExternalProduct, ExternalJuxtaposition, add_comm] using hCV
  · simpa [ExternalProduct, ExternalJuxtaposition, add_comm] using hshadow

/--
Grafting changes the proof label but preserves the ordinary sequent shadow of
the active component.
-/
theorem internal_grafting_preserves_hypersequent_shadow
    {u : PTree} {G H : Hypersequent}
    (h : ContextualInternalGraft u G H) :
    HQ.conclusions H = HQ.conclusions G := by
  exact contextualInternalGraft_preserves_conclusions h

/--
External juxtaposition adds ordinary sequent shadows componentwise.  This is
the hypersequent/forest interpretation of the tensor-product basis appearing
in the coproduct.
-/
theorem external_product_adds_shadows (G H : Hypersequent) :
    HQ.conclusions (ExternalProduct G H) =
      HQ.conclusions G + HQ.conclusions H := by
  exact externalJuxtaposition_conclusions G H

/-! ## The pre-Lie theorem is still part of the proof-tree story -/

/--
On the stable proof-tree quotient, matching-leaf grafting satisfies the pre-Lie
identity.  This is the Oudom-Guin/pre-Lie theorem already proved in the
development, re-exported here next to the Hopf interface.
-/
theorem stable_quotient_grafting_preLie_identity
    (a b c : QuotientConnected.PreLieDifferenceStableQuotient) :
    QuotientConnected.preLieDifferenceStableQuotientAssociator a b c =
      QuotientConnected.preLieDifferenceStableQuotientAssociator b a c := by
  exact QuotientConnected.proofTreeSpine_stable_quotient_preLie_identity a b c

/--
For tree generators, the raw pre-Lie coefficient is the number of matching-leaf
graftings producing the output tree.
-/
theorem raw_grafting_coefficient_eq_matching_leaf_count
    (u t v : PTree) :
    Syntax.graftPreLie
        (Syntax.treeGen u)
        (Syntax.treeGen t) v =
      ((InternalGraftSupport u t).count v : Int) := by
  simpa [InternalGraftSupport, treeGraftSupport]
    using QuotientConnected.graftPreLie_generators_apply_eq_count u t v

/-! ## Nonmonotonic rigidity: weakening must respect exact matching -/

/--
The graft-controlled weakening policy is exactly the existence of a matching
internal graft target.
-/
theorem graft_controlled_weakening_iff_exact_matching
    (u t : PTree) :
    (graftControlledWeakeningPolicy u).admissible t <->
      Exists (InternalGraft u t) := by
  exact graftControlledWeakeningPolicy_admissible_iff u t

/--
If a proposed added component has no exact matching leaf for the probe `u`,
then it is not admissible for graft-controlled external weakening.
-/
theorem no_exact_matching_no_graft_controlled_weakening
    {u t : PTree}
    (h : forall v : PTree, Not (InternalGraft u t v)) :
    Not ((graftControlledWeakeningPolicy u).admissible t) := by
  intro hadm
  rcases (graft_controlled_weakening_iff_exact_matching u t).mp hadm with
    ⟨v, hv⟩
  exact h v hv

theorem destroyed_update_blocks_proof_theoretic_grafting_as_host
    {U : AdmissibleBaseUpdate} {base : BaseRel} {t : PTree}
    (h : DerivableTreeDestroyedByUpdate U base t) :
    ∃ base' : BaseRel,
      U base base' ∧
        DerivableTree base t ∧
          ¬ DerivableTree base' t ∧
            ∀ u v : PTree,
              ¬ ProofTheoreticGraftingSupport base' u t v :=
  derivableTreeDestroyedByUpdate_blocks_grafting_support_as_host h

theorem destroyed_update_blocks_singleton_hypersequent_grafting_as_host
    {U : AdmissibleBaseUpdate} {base : BaseRel} {t : PTree}
    (h : DerivableTreeDestroyedByUpdate U base t) :
    ∃ base' : BaseRel,
      U base base' ∧
        DerivableTree base t ∧
          ¬ DerivableTree base' t ∧
            ∀ U V : Hypersequent,
              ¬ ProofTheoreticSingletonHypersequentGraftingSupport
                base' U (HQ.singleton t) V :=
  derivableTreeDestroyedByUpdate_blocks_singleton_grafting_support_as_host h

/--
Conversely, an exact matching graft witness makes an externally added
component proof-theoretically active in any surrounding hypersequent context.
-/
theorem exact_matching_adds_contextual_graft
    {u t v : PTree} (G : Hypersequent)
    (h : InternalGraft u t v) :
    ContextualGraftable u (ExternalProduct G (HQ.treeSingleton t)) := by
  simpa [ExternalProduct] using
    contextualGraftable_of_added_component G h

/-! ## Cut side: admissible-cut tensor coefficients -/

/-- The finite admissible-cut support of the coproduct of one proof tree. -/
abbrev CutSplitSupport (t : PTree) : List HypersequentTensorBasis :=
  coalgebraTreeSplittingTensorSupport t

/-- Multiplicity of a tensor-basis split in the cut coproduct support. -/
def cutSplitMultiplicity (t : PTree) (p : HypersequentTensorBasis) : Nat := by
  classical
  exact ((CutSplitSupport t).filter (fun q => q = p)).length

theorem cutSplitMultiplicity_pos_of_mem
    {t : PTree} {p : HypersequentTensorBasis}
    (hp : p ∈ CutSplitSupport t) :
    0 < cutSplitMultiplicity t p := by
  classical
  unfold cutSplitMultiplicity
  have hfilter : p ∈ (CutSplitSupport t).filter (fun q => q = p) := by
    simpa using hp
  exact List.length_pos_of_ne_nil (by
    intro hnil
    rw [hnil] at hfilter
    cases hfilter)

/--
Positive cut coefficient is equivalent to support membership.

This is the first coefficient/support bridge on the CK side: the coproduct
coefficient is nonzero exactly when an admissible cut realizes the tensor
split.
-/
theorem cutSplitMultiplicity_pos_iff_mem
    {t : PTree} {p : HypersequentTensorBasis} :
    0 < cutSplitMultiplicity t p ↔ p ∈ CutSplitSupport t := by
  constructor
  · intro hpos
    by_contra hp
    have hnone :
        ∀ q ∈ CutSplitSupport t, ¬ q = p := by
      intro q hq hqp
      exact hp (hqp ▸ hq)
    have hfilter :
        (CutSplitSupport t).filter (fun q => q = p) = [] := by
      apply List.eq_nil_iff_forall_not_mem.2
      intro q hq
      simp only [List.mem_filter] at hq
      exact hnone q hq.1 (of_decide_eq_true hq.2)
    unfold cutSplitMultiplicity at hpos
    rw [hfilter] at hpos
    simp at hpos
  · exact cutSplitMultiplicity_pos_of_mem

/--
Every tensor basis element in the CK coproduct support is realized by an
admissible cut.
-/
theorem exists_coalgebra_cut_of_mem_cutSplitSupport
    {t : PTree} {p : HypersequentTensorBasis}
    (hp : p ∈ CutSplitSupport t) :
    ∃ cut : List Address,
      cut ∈ coalgebraAdmissibleCuts t ∧
        coalgebraTensorTermOfCutList t cut = p := by
  rcases (mem_coalgebraTreeSplittingTensorSupport_iff).1 hp with
    ⟨cut, hcut, hpterm⟩
  exact ⟨cut, hcut, hpterm.symm⟩

/-- Multiplicity of an output tree in the internal grafting support. -/
def graftMultiplicity (u t v : PTree) : Nat :=
  (InternalGraftSupport u t).count v

@[simp]
theorem graftMultiplicity_eq_count (u t v : PTree) :
    graftMultiplicity u t v = (PTree.matchingLeafGraftings u t).count v := by
  rfl

/--
Positive graft coefficient is equivalent to internal grafting support
membership.

This is the graft-side analogue of `cutSplitMultiplicity_pos_iff_mem`.
-/
theorem graftMultiplicity_pos_iff_mem
    {u t v : PTree} :
    0 < graftMultiplicity u t v ↔ v ∈ InternalGraftSupport u t := by
  unfold graftMultiplicity
  constructor
  · intro hpos
    by_contra hv
    have hcount : (InternalGraftSupport u t).count v = 0 :=
      List.count_eq_zero.mpr hv
    rw [hcount] at hpos
    exact Nat.lt_irrefl 0 hpos
  · intro hv
    have hne : (InternalGraftSupport u t).count v ≠ 0 := by
      intro hzero
      exact (List.count_eq_zero.mp hzero) hv
    exact Nat.pos_of_ne_zero hne

/-! ## First cut/graft bridge: exact composition gives a coproduct cut -/

theorem singleton_node_cut_mem_coalgebraAdmissibleCuts
    {t : PTree} {a : Address}
    (hnode : IsNodeAddress t a) :
    [a] ∈ coalgebraAdmissibleCuts t := by
  have hvalid : PTree.ValidAddress t a :=
    validAddress_of_isNodeAddress hnode
  have hmem : a ∈ PTree.allAddresses t :=
    mem_allAddresses_of_validAddress hvalid
  have hraw : [a] ∈ PTree.allAdmissibleCuts t := by
    apply PTree.mem_allAdmissibleCuts_of_sublist_valid_antichain
    · exact singleton_sublist_of_mem hmem
    · simp
    · intro b hb
      simp at hb
      simpa [hb] using hvalid
    · intro b hb c hc hbc
      simp at hb hc
      subst b
      subst c
      exact False.elim (hbc rfl)
  exact (mem_coalgebraAdmissibleCuts_iff).2
    ⟨hraw, Or.inr (Or.inr (fun b hb => by
      simp at hb
      simpa [hb] using hnode))⟩

theorem graft_address_is_nodeAddress_of_inserted_root_node
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (hnode : IsNodeAddress u ([] : Address)) :
    IsNodeAddress v a := by
  rcases hnode with ⟨r, s, cs, hsub⟩
  have hu : u = PTree.node r s cs := by
    simpa [PTree.subtreeAt] using hsub
  exact ⟨r, s, cs, by
    simpa [hu] using
      subtreeAt_graftMatchingLeafAt_self u t a v hg⟩

theorem graft_address_cut_mem_coalgebraAdmissibleCuts
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (hnode : IsNodeAddress u ([] : Address)) :
    [a] ∈ coalgebraAdmissibleCuts v := by
  exact singleton_node_cut_mem_coalgebraAdmissibleCuts
    (graft_address_is_nodeAddress_of_inserted_root_node hg hnode)

theorem graft_address_cut_mem_cut_split_support
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (hnode : IsNodeAddress u ([] : Address)) :
    coalgebraTensorTermOfCutList v [a] ∈ CutSplitSupport v := by
  exact (mem_coalgebraTreeSplittingTensorSupport_iff).2
    ⟨[a], graft_address_cut_mem_coalgebraAdmissibleCuts hg hnode, rfl⟩

theorem graft_address_cut_tensor_term_eq_insert_remainder
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (hnotroot : a ≠ ([] : Address)) :
    coalgebraTensorTermOfCutList v [a] =
      (HQ.singleton u, HQ.singleton (PTree.remainderGo [a] [] v)) := by
  have hnil : ([a] : List Address) ≠ [] := by simp
  have hroot : ([] : Address) ∉ ([a] : List Address) := by
    simpa using hnotroot
  rw [coalgebraTensorTermOfCutList_of_ne_nil_of_root_not_mem hnil hroot]
  simp [HQ.singleton, HQ.ofForest,
    subtreeAt_graftMatchingLeafAt_self u t a v hg]

theorem graft_address_cut_insert_remainder_mem_cut_split_support
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (hnode : IsNodeAddress u ([] : Address))
    (hnotroot : a ≠ ([] : Address)) :
    (HQ.singleton u, HQ.singleton (PTree.remainderGo [a] [] v)) ∈
      CutSplitSupport v := by
  rw [← graft_address_cut_tensor_term_eq_insert_remainder hg hnotroot]
  exact graft_address_cut_mem_cut_split_support hg hnode

theorem singleton_leaf_nonroot_not_mem_coalgebraAdmissibleCuts
    {t : PTree} {a : Address} {seq : MultiSequent}
    (hleaf : PTree.subtreeAt t a = some (PTree.leaf seq))
    (hnotroot : a ≠ ([] : Address)) :
    [a] ∉ coalgebraAdmissibleCuts t := by
  intro hcut
  rcases (mem_coalgebraAdmissibleCuts_iff).1 hcut with ⟨_hraw, hcoal⟩
  rcases hcoal with hnil | hroot | hnodes
  · simp at hnil
  · simp at hroot
    exact hnotroot hroot
  · rcases hnodes a (by simp) with ⟨r, s, cs, hnode⟩
    rw [hleaf] at hnode
    cases hnode

theorem exact_leaf_graft_has_no_internal_graft_address_cut
    {u t v : PTree} {a : Address} {seq : MultiSequent}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (hu : u = PTree.leaf seq)
    (hnotroot : a ≠ ([] : Address)) :
    [a] ∉ coalgebraAdmissibleCuts v := by
  apply singleton_leaf_nonroot_not_mem_coalgebraAdmissibleCuts
  · simpa [hu] using subtreeAt_graftMatchingLeafAt_self u t a v hg
  · exact hnotroot

theorem graft_address_cut_mem_iff_inserted_root_node
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (hnotroot : a ≠ ([] : Address)) :
    [a] ∈ coalgebraAdmissibleCuts v ↔ IsNodeAddress u ([] : Address) := by
  constructor
  · intro hcut
    cases u with
    | leaf seq =>
        exact False.elim
          (exact_leaf_graft_has_no_internal_graft_address_cut
            hg rfl hnotroot hcut)
    | node r s cs =>
        exact ⟨r, s, cs, by simp [PTree.subtreeAt]⟩
  · intro hnode
    exact graft_address_cut_mem_coalgebraAdmissibleCuts hg hnode

theorem exact_node_graft_cut_split_coefficient_positive
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (hnode : IsNodeAddress u ([] : Address))
    (hnotroot : a ≠ ([] : Address)) :
    0 <
      cutSplitMultiplicity v
        (HQ.singleton u, HQ.singleton (PTree.remainderGo [a] [] v)) := by
  exact cutSplitMultiplicity_pos_of_mem
    (graft_address_cut_insert_remainder_mem_cut_split_support
      hg hnode hnotroot)

/--
Local coefficient bridge for one exact node graft.

If grafting `u` into `t` at a non-root address produces `v`, and the inserted
proof has a node root, then:

* the grafting product has positive coefficient at `v`; and
* the CK cut coproduct of `v` has positive coefficient at the tensor split
  consisting of the inserted proof and the corresponding remainder/context.
-/
theorem exact_node_graft_has_positive_graft_and_cut_coefficients
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (hnode : IsNodeAddress u ([] : Address))
    (hnotroot : a ≠ ([] : Address)) :
    0 < graftMultiplicity u t v ∧
      0 <
        cutSplitMultiplicity v
          (HQ.singleton u, HQ.singleton (PTree.remainderGo [a] [] v)) := by
  constructor
  · exact graftMultiplicity_pos_iff_mem.2
      (mem_treeGraftSupport_of_graftMatchingLeafAt_eq_some hg)
  · exact exact_node_graft_cut_split_coefficient_positive
      hg hnode hnotroot

/--
Cutting a tree at an address where the subtree is `u` turns that address into
the interface leaf labelled by `u.conclusion`.
-/
theorem subtreeAt_singleton_remainder_is_interface
    {t u : PTree} {a : Address}
    (hsub : PTree.subtreeAt t a = some u) :
    PTree.subtreeAt (PTree.remainderGo [a] [] t) a =
      some (PTree.leaf u.conclusion) := by
  induction a generalizing t with
  | nil =>
      simp [PTree.subtreeAt] at hsub
      cases hsub
      cases u <;> simp [PTree.remainderGo, PTree.subtreeAt, PTree.conclusion]
  | cons i rest ih =>
      cases t with
      | leaf s =>
          simp [PTree.subtreeAt] at hsub
      | node r s cs =>
          by_cases hi : i < cs.length
          · have hchild : PTree.subtreeAt cs[i] rest = some u := by
              simpa [PTree.subtreeAt, hi] using hsub
            have hroot : ([] : Address) ∉ ([i :: rest] : List Address) := by
              simp
            rw [PTree.remainderGo_node_root_not_mem
              (r := r) (s := s) (cs := cs)
              (cut := [i :: rest]) hroot]
            simpa [PTree.subtreeAt, hi, PTree.restrictCut] using
              ih (t := cs[i]) hchild
          · simp [PTree.subtreeAt, hi] at hsub

/--
For a singleton cut below child `i`, the remainder of a rule node is obtained
by replacing exactly that child by the child-remainder.  All other premises are
unchanged.
-/
theorem singleton_remainder_children_eq_replaceNth
    (cs : List PTree) (i : Nat) (rest : Address) (hi : i < cs.length) :
    cs.attach.mapIdx (fun j child =>
        PTree.remainderGo (PTree.restrictCut [i :: rest] j) [] child.1) =
      PTree.replaceNth cs i (PTree.remainderGo [rest] [] cs[i]) := by
  apply List.ext_getElem
  · simp [List.length_mapIdx, replaceNth_length]
  · intro j hleft hright
    have hj : j < cs.length := by
      simpa [List.length_mapIdx] using hright
    by_cases hji : j = i
    · subst j
      simp [List.getElem_mapIdx, PTree.restrictCut]
    · have hleft' : j < (PTree.replaceNth cs i
          (PTree.remainderGo [rest] [] cs[i])).length := by
        simpa [replaceNth_length] using hj
      have hij : ¬ i = j := by
        intro h
        exact hji h.symm
      calc
        (cs.attach.mapIdx (fun j child =>
            PTree.remainderGo (PTree.restrictCut [i :: rest] j) [] child.1))[j] =
            PTree.remainderGo [] [] cs[j] := by
              simp [List.getElem_mapIdx, PTree.restrictCut, hij]
        _ = cs[j] := by
              simp [PTree.remainderGo_nil]
        _ = (PTree.replaceNth cs i
              (PTree.remainderGo [rest] [] cs[i]))[j]'hleft' := by
              simpa using
                (getElem_replaceNth_of_ne cs i j
                  (PTree.remainderGo [rest] [] cs[i]) hj hji).symm

/-- Replacing a list entry by the entry already there does not change the list. -/
theorem replaceNth_self_getElem
    (cs : List PTree) (i : Nat) (hi : i < cs.length) :
    PTree.replaceNth cs i cs[i] = cs := by
  apply List.ext_getElem
  · simp [replaceNth_length]
  · intro j hleft hright
    by_cases hji : j = i
    · subst j
      simp
    · have hj : j < cs.length := by
        simpa [replaceNth_length] using hleft
      simpa using (getElem_replaceNth_of_ne cs i j cs[i] hj hji)

/--
Cutting below the root preserves the outer conclusion sequent and root rule
label of the surrounding proof tree.

Proof-theoretically: a non-root decomposition exposes an internal
subderivation as an interface, but it does not change the rule application at
the top of the surrounding derivation.
-/
theorem singleton_remainder_nonroot_preserves_root_labels
    (t : PTree) {a : Address}
    (hnotroot : a ≠ ([] : Address)) :
    (PTree.remainderGo [a] [] t).conclusion = t.conclusion ∧
      (PTree.remainderGo [a] [] t).rootRule? = t.rootRule? := by
  cases t with
  | leaf s =>
      simp [PTree.remainderGo, PTree.conclusion, PTree.rootRule?]
  | node r s cs =>
      have hroot : ([] : Address) ∉ ([a] : List Address) := by
        simpa using hnotroot
      rw [PTree.remainderGo_node_root_not_mem
        (r := r) (s := s) (cs := cs) (cut := [a]) hroot]
      simp [PTree.conclusion, PTree.rootRule?]

/--
Cutting below the root preserves the number of immediate premises of the
surrounding proof-tree node.

This is the multi-premise rule constraint in a small algebraic form: a
singleton decomposition may alter one premise occurrence, but it does not
erase or duplicate the siblings consumed by the same rule application.
-/
theorem singleton_remainder_nonroot_preserves_root_premise_count
    (t : PTree) {a : Address}
    (hnotroot : a ≠ ([] : Address)) :
    (PTree.remainderGo [a] [] t).rootChildren.length =
      t.rootChildren.length := by
  cases t with
  | leaf s =>
      simp [PTree.remainderGo, PTree.rootChildren]
  | node r s cs =>
      have hroot : ([] : Address) ∉ ([a] : List Address) := by
        simpa using hnotroot
      rw [PTree.remainderGo_node_root_not_mem
        (r := r) (s := s) (cs := cs) (cut := [a]) hroot]
      simp [PTree.rootChildren, List.length_mapIdx]

/--
Filling the interface leaf created by a singleton decomposition reconstructs
the original tree.
-/
theorem modifyAt_singleton_remainder_reconstructs
    {t u : PTree} {a : Address}
    (hsub : PTree.subtreeAt t a = some u) :
    PTree.modifyAt (PTree.remainderGo [a] [] t) a (fun _ => u) =
      some t := by
  induction a generalizing t with
  | nil =>
      simp [PTree.subtreeAt] at hsub
      cases hsub
      cases u <;> simp [PTree.modifyAt]
  | cons i rest ih =>
      cases t with
      | leaf s =>
          simp [PTree.subtreeAt] at hsub
      | node r s cs =>
          by_cases hi : i < cs.length
          · have hchild : PTree.subtreeAt cs[i] rest = some u := by
              simpa [PTree.subtreeAt, hi] using hsub
            have hroot : ([] : Address) ∉ ([i :: rest] : List Address) := by
              simp
            rw [PTree.remainderGo_node_root_not_mem
              (r := r) (s := s) (cs := cs)
              (cut := [i :: rest]) hroot]
            rw [singleton_remainder_children_eq_replaceNth cs i rest hi]
            have hih := ih (t := cs[i]) hchild
            simp [PTree.modifyAt, hi, hih, replaceNth_replaceNth_same,
              replaceNth_self_getElem cs i hi]
          · simp [PTree.subtreeAt, hi] at hsub

/--
The singleton remainder can be reconstructed by the proof-theoretic matching
graft, not merely by raw tree replacement.
-/
theorem singleton_remainder_graftMatchingLeafAt_reconstructs
    {t u : PTree} {a : Address}
    (hsub : PTree.subtreeAt t a = some u) :
    PTree.graftMatchingLeafAt u (PTree.remainderGo [a] [] t) a = some t := by
  have hleaf :
      PTree.subtreeAt (PTree.remainderGo [a] [] t) a =
        some (PTree.leaf u.conclusion) :=
    subtreeAt_singleton_remainder_is_interface hsub
  rw [PTree.graftMatchingLeafAt_eq_some_of_match
    (u := u) (t := PTree.remainderGo [a] [] t)
    (a := a) (s := u.conclusion) hleaf rfl]
  exact modifyAt_singleton_remainder_reconstructs hsub

/--
Local proof-theoretic shape of a singleton occurrence decomposition.

This is not a claim that every CK decomposition is logically admissible.  It
says that when a selected occurrence really is a subtree of `t`, decomposing at
that occurrence produces an interface leaf, preserves the surrounding root
labels when the occurrence is non-root, and can be reconstructed by filling the
interface with the selected subderivation.
-/
structure SingletonOccurrenceDecomposition
    (t u : PTree) (a : Address) : Prop where
  selected_occurrence : PTree.subtreeAt t a = some u
  nonroot_occurrence : a ≠ ([] : Address)
  exposed_interface :
    PTree.subtreeAt (PTree.remainderGo [a] [] t) a =
      some (PTree.leaf u.conclusion)
  preserves_outer_conclusion :
    (PTree.remainderGo [a] [] t).conclusion = t.conclusion
  preserves_outer_rule :
    (PTree.remainderGo [a] [] t).rootRule? = t.rootRule?
  preserves_outer_premise_count :
    (PTree.remainderGo [a] [] t).rootChildren.length =
      t.rootChildren.length
  reconstructs_original :
    PTree.modifyAt (PTree.remainderGo [a] [] t) a (fun _ => u) =
      some t

/--
Every non-root selected subtree gives a well-behaved singleton occurrence
decomposition.
-/
theorem singleton_occurrence_decomposition_of_subtreeAt
    {t u : PTree} {a : Address}
    (hsub : PTree.subtreeAt t a = some u)
    (hnotroot : a ≠ ([] : Address)) :
    SingletonOccurrenceDecomposition t u a := by
  have hlabels := singleton_remainder_nonroot_preserves_root_labels t hnotroot
  exact
    { selected_occurrence := hsub
      nonroot_occurrence := hnotroot
      exposed_interface := subtreeAt_singleton_remainder_is_interface hsub
      preserves_outer_conclusion := hlabels.1
      preserves_outer_rule := hlabels.2
      preserves_outer_premise_count :=
        singleton_remainder_nonroot_preserves_root_premise_count t hnotroot
      reconstructs_original := modifyAt_singleton_remainder_reconstructs hsub }

/--
The admissible decomposition produced at the sequent-matching composition site
exposes an interface leaf labelled by the inserted proof's conclusion.
-/
theorem sequentMatching_decomposition_exposes_interface
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v) :
    PTree.subtreeAt (PTree.remainderGo [a] [] v) a =
      some (PTree.leaf u.conclusion) := by
  have hsub : PTree.subtreeAt v a = some u :=
    subtreeAt_graftMatchingLeafAt_self u t a v hg
  exact subtreeAt_singleton_remainder_is_interface hsub

/--
The remainder/context exposed by decomposing at the sequent-matching
composition site is filled by the inserted proof to reconstruct the composite
proof tree.
-/
theorem sequentMatching_remainder_reconstructs_composite
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v) :
    PTree.graftMatchingLeafAt u (PTree.remainderGo [a] [] v) a = some v := by
  have hsub : PTree.subtreeAt v a = some u :=
    subtreeAt_graftMatchingLeafAt_self u t a v hg
  have hleaf :
      PTree.subtreeAt (PTree.remainderGo [a] [] v) a =
        some (PTree.leaf u.conclusion) :=
    subtreeAt_singleton_remainder_is_interface hsub
  rw [PTree.graftMatchingLeafAt_eq_some_of_match
    (u := u) (t := PTree.remainderGo [a] [] v)
    (a := a) (s := u.conclusion) hleaf rfl]
  exact modifyAt_singleton_remainder_reconstructs hsub

/--
Proof-theoretic form of local reconstruction: after decomposition, the
inserted proof fills the exposed remainder/context and recovers the composite.
-/
theorem sequentMatching_boundaryFill_reconstructs_composite
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v) :
    BoundaryFill u (PTree.remainderGo [a] [] v) v := by
  unfold BoundaryFill InternalGraft
  exact ⟨a, sequentMatching_remainder_reconstructs_composite hg⟩

/--
Sequentially fill a list of marked sequent occurrences by matching grafts.

For an admissible antichain the intended theorem is that this order does not
matter, but the operation is deliberately list-based so that it can serve as
the coefficient-counting witness before quotienting to hypersequents.
-/
def fillOccurrenceList : PTree -> List (Address × PTree) -> Option PTree
| context, [] => some context
| context, (a, u) :: rest =>
    match PTree.graftMatchingLeafAt u context a with
    | some context' => fillOccurrenceList context' rest
    | none => none

/-- The subtrees selected by a list of cut addresses. -/
def extractedSubtreesAt (t : PTree) (cut : List Address) : Forest :=
  cut.filterMap (PTree.subtreeAt t)

/--
The proof-theoretic reconstruction predicate for a cut forest.

It says that the extracted proof trees, paired with their original addresses,
can be grafted into the remainder/context to recover the original tree.
-/
def CutForestReconstructs
    (cut : List Address) (forest : Forest) (context out : PTree) : Prop :=
  fillOccurrenceList context (cut.zip forest) = some out

/--
The canonical reconstruction statement attached to a raw cut list.

For a genuine CK admissible cut this is the proof-theoretic content we want
behind the coalgebra term: detached subproofs plus the remainder reconstruct
the original proof tree.
-/
def CutForestReconstructionTarget
    (t : PTree) (cut : List Address) : Prop :=
  CutForestReconstructs cut (extractedSubtreesAt t cut)
    (PTree.remainderGo cut [] t) t

@[simp] theorem fillOccurrenceList_nil (context : PTree) :
    fillOccurrenceList context [] = some context := by
  rfl

theorem fillOccurrenceList_singleton
    {context u out : PTree} {a : Address}
    (h : PTree.graftMatchingLeafAt u context a = some out) :
    fillOccurrenceList context [(a, u)] = some out := by
  simp [fillOccurrenceList, h]

/--
The singleton case of forest reconstruction.

This is the base case of the desired antichain theorem: cutting out one
subproof and then grafting it back at the same sequent occurrence recovers the
original proof tree.
-/
theorem singleton_cutForestReconstructionTarget_of_subtreeAt
    {t u : PTree} {a : Address}
    (hsub : PTree.subtreeAt t a = some u) :
    CutForestReconstructionTarget t [a] := by
  unfold CutForestReconstructionTarget CutForestReconstructs
    extractedSubtreesAt
  simp [hsub, fillOccurrenceList,
    singleton_remainder_graftMatchingLeafAt_reconstructs hsub]

/-- The empty cut reconstructs trivially: no subproof is detached. -/
theorem empty_cutForestReconstructionTarget
    (t : PTree) :
    CutForestReconstructionTarget t [] := by
  unfold CutForestReconstructionTarget CutForestReconstructs
    extractedSubtreesAt
  simp [PTree.remainderGo_nil]

/--
The root cut reconstructs by extracting the whole proof and grafting it into
the root interface leaf.
-/
theorem root_cutForestReconstructionTarget
    (t : PTree) :
    CutForestReconstructionTarget t [[]] := by
  have hsub : PTree.subtreeAt t ([] : Address) = some t := by
    cases t <;> simp [PTree.subtreeAt]
  exact singleton_cutForestReconstructionTarget_of_subtreeAt
    (t := t) (u := t) (a := ([] : Address)) hsub

/--
Every singleton CK-admissible cut reconstructs by grafting the detached proof
back into the exposed sequent occurrence.
-/
theorem singleton_coalgebra_cutForestReconstructionTarget
    {t : PTree} {a : Address}
    (hcut : [a] ∈ coalgebraAdmissibleCuts t) :
    CutForestReconstructionTarget t [a] := by
  rcases subtreeAt_some_of_mem_coalgebraAdmissibleCuts
      (t := t) (cut := [a]) (a := a) hcut (by simp) with
    ⟨u, hsub⟩
  exact singleton_cutForestReconstructionTarget_of_subtreeAt hsub

/-- Moving the head of a cut list to the end is a permutation. -/
theorem perm_append_singleton_cons (a : Address) (rest : List Address) :
    List.Perm (rest ++ [a]) (a :: rest) := by
  induction rest with
  | nil =>
      simp
  | cons b rest ih =>
      exact (List.Perm.cons b ih).trans (List.Perm.swap a b rest)

/--
If every address in `rest` is incomparable with `a`, then no part of `rest`
lies below the prefix `a`.
-/
theorem restrictCutAt_eq_nil_of_forall_incomparable
    {a : Address} {rest : List Address}
    (hinc : ∀ b : Address, b ∈ rest → ¬ PTree.comparable a b) :
    PTree.restrictCutAt rest a = [] := by
  apply List.eq_nil_iff_forall_not_mem.2
  intro c hc
  have hc' : a ++ c ∈ rest :=
    (PTree.mem_restrictCutAt_iff
      (cut := rest) (pfx := a) (addr := c)).1 hc
  exact hinc (a ++ c) hc' (Or.inl ⟨c, rfl⟩)

/--
If `a` is incomparable with every address in `rest`, the subtree at `a`
survives pruning by `rest` unchanged.
-/
theorem subtreeAt_remainderGo_of_forall_incomparable
    {t u : PTree} {a : Address} {rest : List Address}
    (hsub : PTree.subtreeAt t a = some u)
    (hinc : ∀ b : Address, b ∈ rest → ¬ PTree.comparable a b) :
    PTree.subtreeAt (PTree.remainderGo rest [] t) a = some u := by
  have hdesc :
      PTree.subtreeAt (PTree.remainderGo rest [] t) a =
        some (PTree.remainderGo (PTree.restrictCutAt rest a) [] u) :=
    PTree.subtreeAt_remainderGo_of_forall_not_ancestor
      (cut := rest) (a := a) (t := t) (u := u) hsub
      (by
        intro b hb hanc
        exact hinc b hb (Or.inr hanc))
  have hrestrict : PTree.restrictCutAt rest a = [] :=
    restrictCutAt_eq_nil_of_forall_incomparable hinc
  simpa [hrestrict, PTree.remainderGo_nil] using hdesc

/--
Head-step reconstruction for an antichain cut.

If `a` is the head selected occurrence and every remaining selected occurrence
is independent from it, grafting the detached head subproof into the full
remainder recovers the tail remainder.
-/
theorem head_graft_reconstructs_tail_remainder_of_forall_incomparable
    {t u : PTree} {a : Address} {rest : List Address}
    (hsub : PTree.subtreeAt t a = some u)
    (hinc : ∀ b : Address, b ∈ rest → ¬ PTree.comparable a b) :
    PTree.graftMatchingLeafAt u
        (PTree.remainderGo (a :: rest) [] t) a =
      some (PTree.remainderGo rest [] t) := by
  have hsubAfterRest :
      PTree.subtreeAt (PTree.remainderGo rest [] t) a = some u :=
    subtreeAt_remainderGo_of_forall_incomparable hsub hinc
  have hfill0 :
      PTree.graftMatchingLeafAt u
          (PTree.remainderGo [a] [] (PTree.remainderGo rest [] t)) a =
        some (PTree.remainderGo rest [] t) :=
    singleton_remainder_graftMatchingLeafAt_reconstructs hsubAfterRest
  have hstage :
      PTree.remainderGo [a] [] (PTree.remainderGo rest [] t) =
        PTree.remainderGo (rest ++ [a]) [] t := by
    exact PTree.remainderGo_remainderGo_eq rest [a] [] t
  have hpermEq :
      PTree.remainderGo (rest ++ [a]) [] t =
        PTree.remainderGo (a :: rest) [] t := by
    exact PTree.remainderGo_eq_of_perm
      (perm_append_singleton_cons a rest) [] t
  have hfill1 :
      PTree.graftMatchingLeafAt u
          (PTree.remainderGo (rest ++ [a]) [] t) a =
        some (PTree.remainderGo rest [] t) := by
    simpa [hstage] using hfill0
  rw [hpermEq] at hfill1
  exact hfill1

/--
Abstract antichain reconstruction theorem.

Any finite list of valid, pairwise incomparable selected proof occurrences
reconstructs by grafting the extracted subproofs back into the remainder, in
the order of the list.
-/
theorem antichain_cutForestReconstructionTarget_of_valid_antichain
    {t : PTree} {cut : List Address}
    (hvalid : ∀ a : Address, a ∈ cut → ∃ u, PTree.subtreeAt t a = some u)
    (hnodup : cut.Nodup)
    (hanti :
      ∀ a : Address, a ∈ cut →
        ∀ b : Address, b ∈ cut →
          a ≠ b → ¬ PTree.comparable a b) :
    CutForestReconstructionTarget t cut := by
  induction cut with
  | nil =>
      exact empty_cutForestReconstructionTarget t
  | cons a rest ih =>
      rcases hvalid a (by simp) with ⟨u, hsub⟩
      have hnotin : a ∉ rest := by
        have hnodup' : a ∉ rest ∧ rest.Nodup := by
          simpa using hnodup
        exact hnodup'.1
      have hvalidRest :
          ∀ b : Address, b ∈ rest → ∃ v, PTree.subtreeAt t b = some v := by
        intro b hb
        exact hvalid b (by simp [hb])
      have hnodupRest : rest.Nodup := by
        have hnodup' : a ∉ rest ∧ rest.Nodup := by
          simpa using hnodup
        exact hnodup'.2
      have hantiRest :
          ∀ b : Address, b ∈ rest →
            ∀ c : Address, c ∈ rest →
              b ≠ c → ¬ PTree.comparable b c := by
        intro b hb c hc hbc
        exact hanti b (by simp [hb]) c (by simp [hc]) hbc
      have hincHead :
          ∀ b : Address, b ∈ rest → ¬ PTree.comparable a b := by
        intro b hb
        exact hanti a (by simp) b (by simp [hb])
          (by
            intro hab
            subst b
            exact hnotin hb)
      have hfill :
          PTree.graftMatchingLeafAt u
              (PTree.remainderGo (a :: rest) [] t) a =
            some (PTree.remainderGo rest [] t) :=
        head_graft_reconstructs_tail_remainder_of_forall_incomparable
          hsub hincHead
      have ihRest :
          CutForestReconstructionTarget t rest :=
        ih hvalidRest hnodupRest hantiRest
      unfold CutForestReconstructionTarget CutForestReconstructs
        extractedSubtreesAt at ihRest ⊢
      simpa [hsub, fillOccurrenceList, hfill] using ihRest

/--
Every CK-admissible cut reconstructs by grafting.

This is the general cut/graft reconstruction theorem: the CK antichain
condition is exactly what lets the detached forest be grafted back into the
remainder, occurrence by occurrence, to recover the original proof tree.
-/
theorem coalgebra_cutForestReconstructionTarget
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts t) :
    CutForestReconstructionTarget t cut := by
  exact antichain_cutForestReconstructionTarget_of_valid_antichain
    (t := t) (cut := cut)
    (fun a ha => subtreeAt_some_of_mem_coalgebraAdmissibleCuts hcut ha)
    (nodup_of_mem_coalgebraAdmissibleCuts hcut)
    (antichain_of_mem_coalgebraAdmissibleCuts hcut)

/--
If a selected address is incomparable with a singleton cut, its subtree survives
unchanged in the singleton remainder.
-/
theorem subtreeAt_singleton_remainder_of_incomparable
    {t u : PTree} {a b : Address}
    (hsub : PTree.subtreeAt t a = some u)
    (hinc : ¬ PTree.comparable a b) :
    PTree.subtreeAt (PTree.remainderGo [b] [] t) a = some u := by
  have hdesc :
      PTree.subtreeAt (PTree.remainderGo [b] [] t) a =
        some (PTree.remainderGo (PTree.restrictCutAt [b] a) [] u) :=
    PTree.subtreeAt_remainderGo_of_forall_not_ancestor
      (cut := [b]) (a := a) (t := t) (u := u) hsub
      (by
        intro c hc hanc
        simp at hc
        subst c
        exact hinc (Or.inr hanc))
  have hrestrict : PTree.restrictCutAt [b] a = [] := by
    apply List.eq_nil_iff_forall_not_mem.2
    intro c hc
    have hc' : a ++ c ∈ ([b] : List Address) :=
      (PTree.mem_restrictCutAt_iff
        (cut := [b]) (pfx := a) (addr := c)).1 hc
    simp at hc'
    subst b
    exact hinc (Or.inl ⟨c, rfl⟩)
  simpa [hrestrict, PTree.remainderGo_nil] using hdesc

/--
The two-site antichain reconstruction theorem.

If `a` and `b` are incomparable selected sequent occurrences, then the two
detached subproofs can be grafted back into the two-leaf remainder to recover
the original proof tree.
-/
theorem two_incomparable_cutForestReconstructs_of_subtreeAt
    {t u w : PTree} {a b : Address}
    (hsubA : PTree.subtreeAt t a = some u)
    (hsubB : PTree.subtreeAt t b = some w)
    (hinc : ¬ PTree.comparable a b) :
    CutForestReconstructs [a, b] [u, w]
      (PTree.remainderGo [a, b] [] t) t := by
  have hsubA_after_b :
      PTree.subtreeAt (PTree.remainderGo [b] [] t) a = some u :=
    subtreeAt_singleton_remainder_of_incomparable hsubA hinc
  have hfillA0 :
      PTree.graftMatchingLeafAt u
          (PTree.remainderGo [a] [] (PTree.remainderGo [b] [] t)) a =
        some (PTree.remainderGo [b] [] t) :=
    singleton_remainder_graftMatchingLeafAt_reconstructs hsubA_after_b
  have hstage :
      PTree.remainderGo [a] [] (PTree.remainderGo [b] [] t) =
        PTree.remainderGo ([b] ++ [a]) [] t := by
    exact PTree.remainderGo_remainderGo_eq [b] [a] [] t
  have hperm : List.Perm (([b] ++ [a]) : List Address) [a, b] := by
    simpa using (List.Perm.swap a b [])
  have hpermEq :
      PTree.remainderGo ([b] ++ [a]) [] t =
        PTree.remainderGo [a, b] [] t := by
    exact PTree.remainderGo_eq_of_perm hperm [] t
  have hfillA1 :
      PTree.graftMatchingLeafAt u
          (PTree.remainderGo ([b] ++ [a]) [] t) a =
        some (PTree.remainderGo [b] [] t) := by
    simpa [hstage] using hfillA0
  have hfillA :
      PTree.graftMatchingLeafAt u
          (PTree.remainderGo [a, b] [] t) a =
        some (PTree.remainderGo [b] [] t) := by
    rw [hpermEq] at hfillA1
    exact hfillA1
  have hfillB :
      PTree.graftMatchingLeafAt w (PTree.remainderGo [b] [] t) b =
        some t :=
    singleton_remainder_graftMatchingLeafAt_reconstructs hsubB
  simp [CutForestReconstructs, fillOccurrenceList, hfillA, hfillB]

/--
The canonical two-site antichain reconstruction target.

This is the first nontrivial forest case: the detached forest has two
independent proof trees and the remainder has two matching sequent interfaces.
-/
theorem two_incomparable_cutForestReconstructionTarget_of_subtreeAt
    {t u w : PTree} {a b : Address}
    (hsubA : PTree.subtreeAt t a = some u)
    (hsubB : PTree.subtreeAt t b = some w)
    (hinc : ¬ PTree.comparable a b) :
    CutForestReconstructionTarget t [a, b] := by
  unfold CutForestReconstructionTarget extractedSubtreesAt
  simp [hsubA, hsubB,
    two_incomparable_cutForestReconstructs_of_subtreeAt
      hsubA hsubB hinc]

/--
Every two-address CK-admissible cut has the canonical two-site
reconstruction property.

This is the same theorem as the previous one, but with the incomparability and
subtree hypotheses extracted from the coalgebra admissibility judgment itself.
-/
theorem two_site_coalgebra_cutForestReconstructionTarget
    {t : PTree} {a b : Address}
    (hcut : [a, b] ∈ coalgebraAdmissibleCuts t) :
    CutForestReconstructionTarget t [a, b] := by
  rcases subtreeAt_some_of_mem_coalgebraAdmissibleCuts
      (t := t) (cut := [a, b]) (a := a) hcut (by simp) with
    ⟨u, hsubA⟩
  rcases subtreeAt_some_of_mem_coalgebraAdmissibleCuts
      (t := t) (cut := [a, b]) (a := b) hcut (by simp) with
    ⟨w, hsubB⟩
  have hnodup : ([a, b] : List Address).Nodup :=
    nodup_of_mem_coalgebraAdmissibleCuts hcut
  have hne : a ≠ b := by
    simpa using hnodup
  have hinc : ¬ PTree.comparable a b :=
    antichain_of_mem_coalgebraAdmissibleCuts hcut
      a (by simp) b (by simp) hne
  exact two_incomparable_cutForestReconstructionTarget_of_subtreeAt
    hsubA hsubB hinc

/-- A two-address CK cut cannot be a root-boundary cut. -/
theorem root_not_mem_two_site_coalgebra_cut
    {t : PTree} {a b : Address}
    (hcut : [a, b] ∈ coalgebraAdmissibleCuts t) :
    ([] : Address) ∉ ([a, b] : List Address) := by
  intro hroot
  have heq :
      ([a, b] : List Address) = [([] : Address)] :=
    eq_singleton_root_of_mem_coalgebraAdmissibleCuts_of_root_mem hcut hroot
  have hlen := congrArg List.length heq
  simp at hlen

/-- A two-address CK cut is an internal cut. -/
theorem internalCut_of_two_site_coalgebra_cut
    {t : PTree} {a b : Address}
    (hcut : [a, b] ∈ coalgebraAdmissibleCuts t) :
    InternalCut ([a, b] : List Address) := by
  exact ⟨by simp, root_not_mem_two_site_coalgebra_cut hcut⟩

/-- The first address of a two-address CK cut is a genuine rule-node address. -/
theorem left_nodeAddress_of_two_site_coalgebra_cut
    {t : PTree} {a b : Address}
    (hcut : [a, b] ∈ coalgebraAdmissibleCuts t) :
    IsNodeAddress t a := by
  exact node_addresses_of_mem_coalgebraAdmissibleCuts_of_internal
    hcut (internalCut_of_two_site_coalgebra_cut hcut) a (by simp)

/-- The second address of a two-address CK cut is a genuine rule-node address. -/
theorem right_nodeAddress_of_two_site_coalgebra_cut
    {t : PTree} {a b : Address}
    (hcut : [a, b] ∈ coalgebraAdmissibleCuts t) :
    IsNodeAddress t b := by
  exact node_addresses_of_mem_coalgebraAdmissibleCuts_of_internal
    hcut (internalCut_of_two_site_coalgebra_cut hcut) b (by simp)

/--
The tensor term of a two-site CK cut is the detached two-proof forest paired
with the remainder/context.
-/
theorem two_site_coalgebraTensorTerm_eq_of_subtreeAt
    {t u w : PTree} {a b : Address}
    (hcut : [a, b] ∈ coalgebraAdmissibleCuts t)
    (hsubA : PTree.subtreeAt t a = some u)
    (hsubB : PTree.subtreeAt t b = some w) :
    coalgebraTensorTermOfCutList t [a, b] =
      (HQ.ofForest [u, w], HQ.singleton (PTree.remainderGo [a, b] [] t)) := by
  have hnil : ([a, b] : List Address) ≠ [] := by
    simp
  have hroot : ([] : Address) ∉ ([a, b] : List Address) :=
    root_not_mem_two_site_coalgebra_cut hcut
  rw [coalgebraTensorTermOfCutList_of_ne_nil_of_root_not_mem hnil hroot]
  simp [hsubA, hsubB, HQ.ofForest]

/--
Existential form of the two-site tensor theorem, using only CK admissibility.
-/
theorem two_site_coalgebraTensorTerm_exposes_detached_forest
    {t : PTree} {a b : Address}
    (hcut : [a, b] ∈ coalgebraAdmissibleCuts t) :
    ∃ u w : PTree,
      PTree.subtreeAt t a = some u ∧
      PTree.subtreeAt t b = some w ∧
      coalgebraTensorTermOfCutList t [a, b] =
        (HQ.ofForest [u, w],
          HQ.singleton (PTree.remainderGo [a, b] [] t)) := by
  rcases subtreeAt_some_of_mem_coalgebraAdmissibleCuts
      (t := t) (cut := [a, b]) (a := a) hcut (by simp) with
    ⟨u, hsubA⟩
  rcases subtreeAt_some_of_mem_coalgebraAdmissibleCuts
      (t := t) (cut := [a, b]) (a := b) hcut (by simp) with
    ⟨w, hsubB⟩
  exact ⟨u, w, hsubA, hsubB,
    two_site_coalgebraTensorTerm_eq_of_subtreeAt hcut hsubA hsubB⟩

/--
All CK-admissible cuts of cardinality at most two reconstruct by grafting.

This is the current finite frontier of the general antichain reconstruction
theorem: no cut, one selected proof occurrence, and two independent selected
proof occurrences are all controlled.
-/
theorem low_cardinality_coalgebra_cutForestReconstructionTarget
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts t)
    (hlen : cut.length ≤ 2) :
    CutForestReconstructionTarget t cut := by
  cases cut with
  | nil =>
      exact empty_cutForestReconstructionTarget t
  | cons a rest =>
      cases rest with
      | nil =>
          exact singleton_coalgebra_cutForestReconstructionTarget
            (t := t) (a := a) (by simpa using hcut)
      | cons b rest' =>
          cases rest' with
          | nil =>
              exact two_site_coalgebra_cutForestReconstructionTarget
                (t := t) (a := a) (b := b) (by simpa using hcut)
          | cons c rest'' =>
              simp at hlen
              omega

/--
The singleton decomposition at a non-root sequent-matching composition site has
the expected occurrence-decomposition shape.
-/
theorem sequentMatching_singleton_occurrence_decomposition
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (hnotroot : a ≠ ([] : Address)) :
    SingletonOccurrenceDecomposition v u a := by
  exact singleton_occurrence_decomposition_of_subtreeAt
    (subtreeAt_graftMatchingLeafAt_self u t a v hg) hnotroot

/--
Local composition/decomposition bridge for one sequent-matching proof
composition.

The hypothesis that the inserted proof has a rule node at its root excludes
the degenerate case where the coproduct is trying to cut out a mere interface
leaf.  In proof-theoretic terms: we are composing by an actual non-atomic
subderivation.

This package says that one sequent-matching composition simultaneously gives:

* a closed derivation of the composed proof tree;
* an admissible proof composition judgment;
* a nonzero algebra coefficient for the composition product;
* an admissible CK decomposition of the composed proof into the inserted
  subderivation and its remainder/context;
* a nonzero coalgebra coefficient for that decomposition.
-/
structure SequentMatchingCompositionDecomposition
    (base : BaseRel) (u t v : PTree) (a : Address) : Prop where
  closed_composite : DerivableTree base v
  admissible_composition : ProofTheoreticGraftingSupport base u t v
  composition_coefficient_nonzero : 0 < graftMultiplicity u t v
  admissible_decomposition :
    (HQ.singleton u, HQ.singleton (PTree.remainderGo [a] [] v)) ∈
      CutSplitSupport v
  proof_theoretic_split_shape :
    SplitProofTheoreticShape base
      (HQ.singleton u) (PTree.remainderGo [a] [] v)
  exposed_interface :
    PTree.subtreeAt (PTree.remainderGo [a] [] v) a =
      some (PTree.leaf u.conclusion)
  reconstructs_composite :
    BoundaryFill u (PTree.remainderGo [a] [] v) v
  decomposition_coefficient_nonzero :
    0 <
      cutSplitMultiplicity v
        (HQ.singleton u, HQ.singleton (PTree.remainderGo [a] [] v))

/--
One sequent-matching composition by a non-atomic proof gives the local
composition/decomposition bridge.

This is the theorem we should use as the local building block for the eventual
global reconstruction multiplicity theorem.
-/
theorem sequentMatching_composition_decomposition
    {base : BaseRel} {u t v : PTree} {a : Address}
    (hu : DerivableTree base u)
    (ht : DerivableTree base t)
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (hnode : IsNodeAddress u ([] : Address))
    (hnotroot : a ≠ ([] : Address)) :
    SequentMatchingCompositionDecomposition base u t v a := by
  have hproof : ProofTheoreticGraftingSupport base u t v := by
    apply proofTheoreticGraftingSupport_of_derivable_mem hu ht
    simpa [AmbientGraftingSupport, treeGraftSupport] using
      mem_treeGraftSupport_of_graftMatchingLeafAt_eq_some hg
  have hcoeffs :=
    exact_node_graft_has_positive_graft_and_cut_coefficients
      hg hnode hnotroot
  exact
    { closed_composite :=
        derivable_of_proofTheoreticGraftingSupport hproof
      admissible_composition := hproof
      composition_coefficient_nonzero := hcoeffs.1
      admissible_decomposition :=
        graft_address_cut_insert_remainder_mem_cut_split_support
          hg hnode hnotroot
      proof_theoretic_split_shape :=
        QuotientConnected.HypersequentRoute.singleton_occurrence_splitProofTheoreticShape
          (derivable_of_proofTheoreticGraftingSupport hproof)
          (subtreeAt_graftMatchingLeafAt_self u t a v hg)
      exposed_interface :=
        sequentMatching_decomposition_exposes_interface hg
      reconstructs_composite :=
        sequentMatching_boundaryFill_reconstructs_composite hg
      decomposition_coefficient_nonzero := hcoeffs.2 }

/--
Monotone base extension preserves the local sequent-matching
composition/decomposition bridge.

The algebraic and coalgebraic coefficients are purely tree-theoretic, so they
are unchanged.  What changes with the material base is the proof-theoretic
sector: closed derivability of the composite and validity of the open
remainder are transported along `BaseRelExtends`.
-/
theorem sequentMatchingCompositionDecomposition_mono_base
    {base base' : BaseRel}
    (hbase : BaseRelExtends base base')
    {u t v : PTree} {a : Address}
    (h : SequentMatchingCompositionDecomposition base u t v a) :
    SequentMatchingCompositionDecomposition base' u t v a :=
  { closed_composite :=
      derivableTree_mono hbase h.closed_composite
    admissible_composition :=
      proofTheoreticGraftingSupport_mono_base hbase h.admissible_composition
    composition_coefficient_nonzero :=
      h.composition_coefficient_nonzero
    admissible_decomposition :=
      h.admissible_decomposition
    proof_theoretic_split_shape :=
      splitProofTheoreticShape_mono_base hbase h.proof_theoretic_split_shape
    exposed_interface :=
      h.exposed_interface
    reconstructs_composite :=
      h.reconstructs_composite
    decomposition_coefficient_nonzero :=
      h.decomposition_coefficient_nonzero }

/--
If the composite proof tree is not derivable over a base, then no local
sequent-matching composition/decomposition bridge can have that composite over
that base.

This is the closed-proof side of the obstruction: a CK split may still exist
as an ambient tree cut, but it is not a proof-theoretic local Hopf bridge
unless the composite is a closed NMMS proof tree over the current material
base.
-/
theorem sequentMatchingCompositionDecomposition_not_of_composite_nonderivable
    {base : BaseRel} {u t v : PTree} {a : Address}
    (hv : ¬ DerivableTree base v) :
    ¬ SequentMatchingCompositionDecomposition base u t v a := by
  intro h
  exact hv h.closed_composite

/--
Destructive base updates block the local bridge at the composite.

If an admissible update destroys a proof tree `v`, then over the updated base
there is no sequent-matching local cut/graft bridge whose composite is `v`.
Moreover the direct derivable UEA primitive coalgebra statement cannot even be
formed for a generator attached to `v`, because such a generator requires a
proof that `v` is derivable over the updated base.
-/
theorem derivableTreeDestroyedByUpdate_blocks_composite_local_bridge
    {U : AdmissibleBaseUpdate} {base : BaseRel} {v : PTree}
    (h : DerivableTreeDestroyedByUpdate U base v) :
    ∃ base' : BaseRel,
      U base base' ∧
      DerivableTree base v ∧
      ¬ DerivableTree base' v ∧
      (∀ u t : PTree, ∀ a : Address,
        ¬ SequentMatchingCompositionDecomposition base' u t v a) ∧
      ¬ (∃ hv : DerivableTree base' v,
        letI : LieRing (DerivablePrimitiveLieCarrier base') :=
          derivableStableQuotientLieRing base'
        DirectDerivableUEACoalgebraLawsAt base'
          (derivableUEATreeGen hv)) := by
  rcases h with ⟨base', hU, hv_old, hv_new⟩
  refine ⟨base', hU, hv_old, hv_new, ?_, ?_⟩
  · intro u t a
    exact
      sequentMatchingCompositionDecomposition_not_of_composite_nonderivable
        hv_new
  · rintro ⟨hv, _hcoal⟩
    exact hv_new hv

/--
The composite proof in a sequent-matching cut/graft bridge is closed: all of
its terminal sequents are material axioms of the underlying base relation.
-/
theorem sequentMatching_composite_terminalSequents_material
    {base : BaseRel} {u t v : PTree} {a : Address}
    (h : SequentMatchingCompositionDecomposition base u t v a) :
    PTree.LeafSequentsSatisfy
      (MaterialTerminalSequent base) v :=
  derivableTree_leafSequents_material h.closed_composite

/--
The remainder in a sequent-matching cut/graft bridge is an open proof context:
every terminal sequent is either a material/base axiom or one of the exposed
hypotheses coming from the detached proof.

This is the proof-theoretic frontier condition for the CK side of the bridge.
It is what prevents the coalgebraic remainder from being read as arbitrary
tree syntax.
-/
theorem sequentMatching_remainder_terminalSequents_axioms_or_hypotheses
    {base : BaseRel} {u t v : PTree} {a : Address}
    (h : SequentMatchingCompositionDecomposition base u t v a) :
    PTree.LeafSequentsSatisfy
      (OpenTerminalSequent base (SplitBoundary (HQ.singleton u)))
      (PTree.remainderGo [a] [] v) :=
  splitProofTheoreticShape_remainder_leafSequents h.proof_theoretic_split_shape

theorem exact_node_graft_has_internal_and_cut_support
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (hnode : IsNodeAddress u ([] : Address)) :
    v ∈ InternalGraftSupport u t ∧
      coalgebraTensorTermOfCutList v [a] ∈ CutSplitSupport v := by
  exact ⟨mem_treeGraftSupport_of_graftMatchingLeafAt_eq_some hg,
    graft_address_cut_mem_cut_split_support hg hnode⟩

/--
An exact graft between closed proof trees is not merely an ambient tree
operation: it lands in the proof-theoretic grafting support.

This is the local proof-theoretic strengthening of the graft side of the
cut/graft bridge.
-/
theorem exact_graft_proofTheoreticGraftingSupport
    {base : BaseRel} {u t v : PTree} {a : Address}
    (hu : DerivableTree base u)
    (ht : DerivableTree base t)
    (hg : PTree.graftMatchingLeafAt u t a = some v) :
    ProofTheoreticGraftingSupport base u t v := by
  apply proofTheoreticGraftingSupport_of_derivable_mem hu ht
  simpa [AmbientGraftingSupport, treeGraftSupport] using
    mem_treeGraftSupport_of_graftMatchingLeafAt_eq_some hg

/--
Proof-theoretic cut/graft bridge for a single exact node graft.

The graft output has internal graft support, the corresponding singleton cut
appears in the coproduct support, and the graft output is a genuine closed
derivation over the same material base.
-/
theorem exact_node_derivable_graft_has_internal_cut_and_proof_support
    {base : BaseRel} {u t v : PTree} {a : Address}
    (hu : DerivableTree base u)
    (ht : DerivableTree base t)
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (hnode : IsNodeAddress u ([] : Address)) :
    ProofTheoreticGraftingSupport base u t v ∧
      v ∈ InternalGraftSupport u t ∧
        coalgebraTensorTermOfCutList v [a] ∈ CutSplitSupport v := by
  exact ⟨exact_graft_proofTheoreticGraftingSupport hu ht hg,
    exact_node_graft_has_internal_and_cut_support hg hnode⟩

/--
The root cut is the basic proof-theoretic cut/graft round trip.

This is the closed/open substitution reading of the coproduct: detach the
whole proof, leave its conclusion as a boundary leaf, then realize that
boundary by the detached proof.
-/
theorem root_cut_graft_roundTrip
    {base : BaseRel} {t : PTree}
    (ht : DerivableTree base t) :
    ProofTheoreticCutGraftRoundTrip base t
      (HQ.singleton t, PTree.leaf t.conclusion) :=
  root_proofTheoreticCutGraftRoundTrip ht

/-! ## Occurrence-marked cut/graft interface -/

/--
A base-sound interface policy turns an allowed fill by a genuine proof tree
into derivability of the marked interface sequent.

This is the quantified proof-theoretic hook we need for controlled weakening:
the policy may be exact matching, a base/material entailment policy, or a
structural-rule policy, but it must prove this soundness property to remain
inside the genuine proof sector.
-/
theorem baseSound_policy_fill_derives_interface
    {base : BaseRel} {P : ProofContextTree.InterfacePolicy base}
    (hP : P.BaseSound)
    {u : PTree} {source : MultiSequent}
    (hu : DerivableTree base u)
    (hfill : P.mayFill source u.conclusion) :
    DerivableSequent base source := by
  apply hP hfill
  rcases hu with ⟨s, d, rfl⟩
  rw [toTree_conclusion d]
  exact ⟨d⟩

/--
For every interface policy, marking the whole proof tree and filling it back
with the same tree reconstructs the original proof-context tree.

This is the occurrence-sensitive version of the root cut/graft round trip.  It
is deliberately stated for all policies because reflexive same-sequent filling
is the neutral case shared by exact, material, and structural policies.
-/
theorem policy_root_mark_fill_roundTrip
    {base : BaseRel} (P : ProofContextTree.InterfacePolicy base)
    (t : PTree) :
    ∃ ctx filled : ProofContextTree,
      ProofContextTree.markAt ([] : Address) t [] = some ctx ∧
        ProofContextTree.fillAtWith P t ctx [] = some filled ∧
          filled = ProofContextTree.ofPTree t := by
  exact ProofContextTree.root_mark_fillWith_reconstructs P t

/--
The root marked occurrence always has policy-mediated fill support.

This packages the existential form that can later be linearized into a
grafting product support relation.
-/
theorem policy_root_fill_support
    {base : BaseRel} (P : ProofContextTree.InterfacePolicy base)
    (t : PTree) :
    ∃ ctx : ProofContextTree,
      ProofContextTree.markAt ([] : Address) t [] = some ctx ∧
        ProofContextTree.PolicyFillSupport P t ctx
          (ProofContextTree.ofPTree t) := by
  exact ProofContextTree.exists_policyFillSupport_for_marked_root P t

/--
The original GL/pre-Lie one-step graft support embeds into the exact-policy
graft support.

This keeps the route honest: policy-mediated structural composition extends
the old exact matching-leaf product rather than replacing it with unrelated
syntax.
-/
theorem exact_internal_graft_has_policy_support
    {base : BaseRel} {u t v : PTree}
    (hg : InternalGraft u t v) :
    PolicyInternalGraft
      (ProofContextTree.exactInterfacePolicy base) u t v :=
  exactPolicyInternalGraft_of_InternalGraft hg

/--
On tree generators, the exact-policy product is the original GL/pre-Lie
matching-leaf grafting product.

This is the algebra-side normalization theorem for the policy framework:
structural policies may vary the product, but exact matching recovers the
already-proved pre-Lie route.
-/
theorem exact_policy_product_on_generators_is_graftPreLie
    {base : BaseRel} (u t : PTree) :
    policyGraftPreLie
        (ProofContextTree.exactInterfacePolicy base)
        (treeGen u) (treeGen t) =
      graftPreLie (treeGen u) (treeGen t) := by
  exact exactPolicyGraftPreLie_on_generators u t

/--
For any structural/interface policy, nonzero coefficient in the policy product
is exactly existence of a policy-mediated graft witness.

This is the coefficient-level proof-theoretic reading of the algebra side.
-/
theorem policy_product_coefficient_detects_grafting
    {base : BaseRel} (P : ProofContextTree.InterfacePolicy base)
    (u t v : PTree) :
    policyGraftPreLieTree P u t v ≠ 0 ↔
      PolicyInternalGraft P u t v := by
  exact policyGraftPreLieTree_coeff_ne_zero_iff P u t v

/--
Support-level form of the same fact: the algebraic support of the policy
product is exactly the policy-mediated proof-composition relation.
-/
theorem policy_product_support_detects_grafting
    {base : BaseRel} (P : ProofContextTree.InterfacePolicy base)
    (u t v : PTree) :
    v ∈ (policyGraftPreLieTree P u t).support ↔
      PolicyInternalGraft P u t v :=
  mem_support_policyGraftPreLieTree_iff P u t v

/--
For exact matching, product support is ordinary exact internal grafting.
-/
theorem exact_policy_product_support_detects_internal_grafting
    {base : BaseRel} (u t v : PTree) :
    v ∈
        (policyGraftPreLieTree
          (ProofContextTree.exactInterfacePolicy base) u t).support ↔
      InternalGraft u t v :=
  mem_support_exactPolicyGraftPreLieTree_iff_internalGraft u t v

/--
Extending structural/interface rules preserves all nonzero coefficients of the
policy-sensitive graft product.
-/
theorem policy_extension_preserves_product_coefficients
    {base : BaseRel}
    {P Q : ProofContextTree.InterfacePolicy base}
    (hPQ : P.Extends Q)
    {u t v : PTree}
    (hcoeff : policyGraftPreLieTree Q u t v ≠ 0) :
    policyGraftPreLieTree P u t v ≠ 0 := by
  exact policyGraftPreLieTree_coeff_ne_zero_mono hPQ hcoeff

/--
Extending structural/interface rules can only enlarge one-step composition
support.

This is the support-level form of Dosen's point that changing structural
assumptions changes the deductive behavior of the same formal punctuation.
-/
theorem policy_extension_preserves_product_support
    {base : BaseRel}
    {P Q : ProofContextTree.InterfacePolicy base}
    (hPQ : P.Extends Q)
    {u t v : PTree}
    (hv : v ∈ (policyGraftPreLieTree Q u t).support) :
    v ∈ (policyGraftPreLieTree P u t).support := by
  exact (policy_product_support_detects_grafting P u t v).2
    (policyInternalGraft_mono hPQ
      ((policy_product_support_detects_grafting Q u t v).1 hv))

/--
Set-theoretic version: the outputs allowed by the weaker policy are included
among the outputs allowed by the stronger policy.
-/
theorem policy_extension_productSupport_subset
    {base : BaseRel}
    {P Q : ProofContextTree.InterfacePolicy base}
    (hPQ : P.Extends Q)
    (u t : PTree) :
    PolicyGraftProductSupport Q u t ⊆
      PolicyGraftProductSupport P u t := by
  intro v hv
  exact policyInternalGraft_mono hPQ hv

/--
If the weaker structural/interface policy already has a bad coefficient, then
any stronger policy has the same bad coefficient.

So extending structural rules cannot repair an existing algebraic escape from
the genuine proof sector; it can only preserve or add possible escapes.
-/
theorem policy_extension_preserves_coefficient_escape
    {base : BaseRel}
    {P Q : ProofContextTree.InterfacePolicy base}
    (hPQ : P.Extends Q)
    (hesc : Q.CoefficientEscapesDerivable) :
    P.CoefficientEscapesDerivable := by
  rcases hesc with ⟨u, t, v, hu, ht, hcoeff, hv⟩
  exact ⟨u, t, v, hu, ht,
    policy_extension_preserves_product_coefficients hPQ hcoeff, hv⟩

/--
If the stronger policy extends exact sequent matching, then the original
Grossman-Larsson/pre-Lie grafting support is a sub-support of the
policy-sensitive grafting support.
-/
theorem exact_grafting_support_subset_of_extends_exact
    {base : BaseRel}
    {P : ProofContextTree.InterfacePolicy base}
    (hP : P.Extends (ProofContextTree.exactInterfacePolicy base))
    {u t v : PTree}
    (hv : v ∈ InternalGraftSupport u t) :
    v ∈ (policyGraftPreLieTree P u t).support := by
  have hg : InternalGraft u t v :=
    internalGraft_of_mem_matchingLeafGraftings
      (by simpa [InternalGraftSupport, treeGraftSupport] using hv)
  exact (policy_product_support_detects_grafting P u t v).2
    (policyInternalGraft_mono hP
      (exact_internal_graft_has_policy_support (base := base) hg))

/--
Every policy-mediated graft has a labelled occurrence witness: address,
source sequent, policy permission, and tree modification.
-/
theorem policy_graft_has_labelled_occurrence
    {base : BaseRel} {P : ProofContextTree.InterfacePolicy base}
    {u t v : PTree}
    (hg : PolicyInternalGraft P u t v) :
    Nonempty (PolicyGraftOccurrence P u t v) :=
  policyInternalGraft_has_labelled_occurrence hg

/--
The inserted proof tree remains visible, with all of its internal labels, below
the graft address.
-/
theorem policy_graft_preserves_inserted_subtree_labels
    {base : BaseRel} {P : ProofContextTree.InterfacePolicy base}
    {u t v : PTree} {a c : Address}
    (hg : policyGraftMatchingLeafAt P u t a = some v) :
    PTree.subtreeAt v (a ++ c) = PTree.subtreeAt u c :=
  policyGraftMatchingLeafAt_subtreeAt_append hg

/--
If a policy graft occurs below the root, then the outer root sequent label and
root rule label are preserved.
-/
theorem policy_nonroot_graft_preserves_outer_root_labels
    {base : BaseRel} {P : ProofContextTree.InterfacePolicy base}
    {u t v : PTree} {a : Address}
    (hane : a ≠ [])
    (hg : policyGraftMatchingLeafAt P u t a = some v) :
    v.conclusion = t.conclusion ∧
      v.rootRule? = t.rootRule? :=
  policyGraftMatchingLeafAt_nonroot_preserves_root_labels hane hg

/--
Exact matching is proof-theoretically admissible as a structural/interface
policy: it preserves the genuine derivable proof-tree sector.
-/
theorem exact_policy_preserves_derivable_grafting
    (base : BaseRel) :
    (ProofContextTree.exactInterfacePolicy base).PreservesDerivableGrafting :=
  exactInterfacePolicy_preservesDerivableGrafting base

/--
Support-level admissibility is equivalent to derivability preservation for
policy-mediated grafting.
-/
theorem policy_support_preserves_derivable_iff_preserves_grafting
    {base : BaseRel} {P : ProofContextTree.InterfacePolicy base} :
    P.SupportPreservesDerivable ↔ P.PreservesDerivableGrafting :=
  supportPreservesDerivable_iff_preservesDerivableGrafting

/--
Any structural/interface policy that preserves derivable grafting has a
generator-level product landing in the derivable proof-tree submodule.
-/
theorem policy_product_preserves_derivable_sector_of_preserves
    {base : BaseRel} {P : ProofContextTree.InterfacePolicy base}
    (hP : P.PreservesDerivableGrafting)
    {u t : PTree}
    (hu : DerivableTree base u)
    (ht : DerivableTree base t) :
    policyGraftPreLieTree P u t ∈ derivableTreeSubmodule base :=
  policyGraftPreLieTree_mem_derivableTreeSubmodule_of_preserves hP hu ht

/--
Carrier-level version: an admissible structural/interface policy gives a
bilinear product on the whole linear span of genuine proof trees, not merely on
individual proof-tree generators.
-/
theorem policy_product_restricts_to_derivable_carrier
    {base : BaseRel} {P : ProofContextTree.InterfacePolicy base}
    (hP : P.PreservesDerivableGrafting)
    {x y : PreLieCarrier}
    (hx : x ∈ derivableTreeSubmodule base)
    (hy : y ∈ derivableTreeSubmodule base) :
    policyGraftPreLie P x y ∈ derivableTreeSubmodule base :=
  policyGraftPreLie_mem_derivableTreeSubmodule_of_preserves hP hx hy

/--
On closed proof-tree generators, the restricted policy product is exactly the
policy-sensitive grafting sum.
-/
theorem policy_derivable_product_on_generators
    {base : BaseRel} {P : ProofContextTree.InterfacePolicy base}
    (hP : P.PreservesDerivableGrafting)
    (u t : DerivableProofTree base) :
    (policyDerivableGraftPreLie P hP
        (derivableTreeGen u) (derivableTreeGen t) : PreLieCarrier) =
      policyGraftPreLieTree P u.1 t.1 :=
  policyDerivableGraftPreLie_treeGen hP u t

/--
The exact interface policy recovers the original Grossman-Larsson grafting
product on the whole ambient linear carrier.
-/
theorem exact_policy_product_is_original_grafting
    {base : BaseRel} :
    policyGraftPreLie
        (ProofContextTree.exactInterfacePolicy base) =
      graftPreLie :=
  exactPolicyGraftPreLie_eq_graftPreLie

/--
On the derivable proof-tree carrier, exact policy grafting is the old restricted
derivable grafting product.
-/
theorem exact_policy_derivable_product_is_derivable_grafting
    {base : BaseRel}
    (x y : DerivablePreLieCarrier base) :
    policyDerivableGraftPreLie
        (ProofContextTree.exactInterfacePolicy base)
        (exactInterfacePolicy_preservesDerivableGrafting base) x y =
      derivableGraftPreLie base x y :=
  exactPolicyDerivableGraftPreLie_eq_derivableGraftPreLie x y

/--
Exact policy also recovers the old restricted derivable grafting associator.
-/
theorem exact_policy_derivable_associator_is_derivable_associator
    {base : BaseRel}
    (x y z : DerivablePreLieCarrier base) :
    policyDerivableGraftAssociator
        (ProofContextTree.exactInterfacePolicy base)
        (exactInterfacePolicy_preservesDerivableGrafting base) x y z =
      derivableGraftAssociator base x y z :=
  exactPolicyDerivableGraftAssociator_eq_derivableGraftAssociator x y z

/--
Consequently, exact-policy grafting has the policy-sensitive right pre-Lie law
whenever the original derivable grafting product has the usual right pre-Lie
law.
-/
theorem exact_policy_derivable_right_preLieLaw_of_derivable
    {base : BaseRel}
    (h : DerivableRightPreLieLaw base) :
    PolicyDerivableRightPreLieLaw
      (ProofContextTree.exactInterfacePolicy base)
      (exactInterfacePolicy_preservesDerivableGrafting base) :=
  exactPolicyDerivableRightPreLieLaw_of_derivable h

/--
Proof-theoretic and algebraic escape agree: a policy leaves the genuine proof
sector by grafting iff its policy product has a nonzero coefficient at a
non-derivable output from derivable inputs.
-/
theorem policy_escape_iff_coefficient_escape
    {base : BaseRel} {P : ProofContextTree.InterfacePolicy base} :
    P.EscapesDerivableGrafting ↔
      P.CoefficientEscapesDerivable :=
  coefficientEscapesDerivable_iff_escapesDerivableGrafting.symm

/--
Equivalently, a structural/interface policy preserves proof-theoretic
admissibility exactly when the policy product has no bad coefficient.
-/
theorem policy_preserves_derivable_iff_no_bad_product_coefficient
    {base : BaseRel} {P : ProofContextTree.InterfacePolicy base} :
    P.PreservesDerivableGrafting ↔
      ¬ P.CoefficientEscapesDerivable :=
  preservesDerivableGrafting_iff_no_coefficient_escape

/--
Exact matching has no bad product coefficient.  This records that the original
matching-leaf GL product is proof-theoretically admissible on genuine
derivations.
-/
theorem exact_policy_product_has_no_bad_coefficient
    (base : BaseRel) :
    ¬ (ProofContextTree.exactInterfacePolicy base).CoefficientEscapesDerivable :=
  exactInterfacePolicy_no_coefficient_escape base

/--
Hypersequent-level structural rules have the same diagnostic shape as
policy-grafting: preserving the closed sector is equivalent to having no
closed-sector escape.
-/
theorem external_structural_rule_preserves_iff_no_escape
    {base : BaseRel} {R : Hypersequent → Hypersequent → Prop} :
    PreservesClosedSector base R ↔ ¬ EscapesClosedSector base R :=
  preservesClosedSector_iff_not_escapes

/--
Internal grafting by a derivable inserted proof is a closed-sector-preserving
hypersequent transformation.

This is the hypersequent-carrier version of the proof-theoretic grafting
claim: grafting is admissible as a structural/proof-composition step only when
the inserted tree is itself a closed derivation over the current base.
-/
theorem derivable_internal_grafting_preserves_closed_sector
    (base : BaseRel) :
    PreservesClosedSector base
      (DerivableContextualInternalGraftStep base) :=
  derivableContextualInternalGraftStep_preservesClosedSector base

theorem derivable_internal_grafting_has_no_escape
    (base : BaseRel) :
    ¬ EscapesClosedSector base
      (DerivableContextualInternalGraftStep base) :=
  derivableContextualInternalGraftStep_no_escape base

theorem derivable_internal_grafting_step_mono_base
    {base base' : BaseRel}
    (hbase : BaseRelExtends base base')
    {G H : Hypersequent}
    (hstep : DerivableContextualInternalGraftStep base G H) :
    DerivableContextualInternalGraftStep base' G H :=
  derivableContextualInternalGraftStep_mono_base hbase hstep

/--
The two-component proof-theoretic graft-composition step is preserved by
genuine extension of the material base relation.

This keeps the theorem at the derivation level: the preserved object is not
just a sequent equation, but the existence of derivable singleton proof
components and a matching proof-tree graft between them.
-/
theorem proof_theoretic_hypersequent_graft_composition_step_mono_base
    {base base' : BaseRel}
    (hbase : BaseRelExtends base base')
    {G H : Hypersequent}
    (hstep :
      ProofTheoreticHypersequentGraftCompositionStep base G H) :
    ProofTheoreticHypersequentGraftCompositionStep base' G H :=
  proofTheoreticHypersequentGraftCompositionStep_mono_base
    hbase hstep

/--
Bridge theorem exposing the proof-tree witnesses inside a hypersequent
graft-composition step.

The active part of the hypersequent operation is not determined by the
sequent shadow alone: it consists of derivable inserted, host, and output
proof trees together with matching-leaf grafting support.
-/
theorem proof_theoretic_hypersequent_graft_composition_tree_witnesses
    {base : BaseRel} {G H : Hypersequent}
    (hstep :
      ProofTheoreticHypersequentGraftCompositionStep base G H) :
    ∃ C : Hypersequent, ∃ u t v : PTree,
      G = C + HQ.singleton u + HQ.singleton t ∧
        H = C + HQ.singleton v ∧
          DerivableTree base u ∧
            DerivableTree base t ∧
              AmbientGraftingSupport u t v ∧
                DerivableTree base v :=
  proofTheoreticHypersequentGraftCompositionStep_tree_witnesses
    hstep

/--
The address-level sequent-matching case of proof-theoretic hypersequent
composition.

This is the local situation where the algebra-side grafting operation and the
CK decomposition side meet cleanly: a derivable inserted node proof `u` is
grafted into a non-root matching leaf occurrence `a` of a derivable host proof
`t`, producing a derivable composite proof `v`.  The surrounding hypersequent
context `C` is external bookkeeping; the active operation is the addressed
proof-tree graft.
-/
def SequentMatchingProofTheoreticHypersequentCompositionStep
    (base : BaseRel) (G H : Hypersequent) : Prop :=
  ∃ C : Hypersequent, ∃ u t v : PTree, ∃ a : Address,
    G = C + HQ.singleton u + HQ.singleton t ∧
      H = C + HQ.singleton v ∧
        DerivableTree base u ∧
          DerivableTree base t ∧
            PTree.graftMatchingLeafAt u t a = some v ∧
              IsNodeAddress u ([] : Address) ∧
                a ≠ ([] : Address) ∧
                  DerivableTree base v

/--
The address-level sequent-matching composition step is a genuine
proof-theoretic hypersequent graft-composition step.
-/
theorem sequentMatchingProofTheoreticHypersequentCompositionStep_to_graft_composition
    {base : BaseRel} {G H : Hypersequent}
    (hstep :
      SequentMatchingProofTheoreticHypersequentCompositionStep base G H) :
    ProofTheoreticHypersequentGraftCompositionStep base G H := by
  rcases hstep with
    ⟨C, u, t, v, a, rfl, rfl, hu, ht, hg, _hnode, _hnotroot, hv⟩
  have hpt : ProofTheoreticGraftingSupport base u t v := by
    exact
      ⟨hu, ht,
        by
          simpa [AmbientGraftingSupport, treeGraftSupport] using
            mem_treeGraftSupport_of_graftMatchingLeafAt_eq_some hg,
        hv⟩
  exact
    proofTheoreticHypersequentGraftCompositionStep_of_singleton_support
      (C := C)
      (proofTheoreticSingletonHypersequentGraftingSupport_of_tree_support
        hpt)

/--
An address-level sequent-matching hypersequent composition step yields the
local CK/composition bridge for its active proof trees.

This is the precise local cut/graft theorem: the same addressed graft that
produces the composite proof also gives a CK decomposition of that composite
into the inserted subproof and its remainder/context, with positive
composition and decomposition coefficients.
-/
theorem sequentMatchingProofTheoreticHypersequentCompositionStep_local_bridge
    {base : BaseRel} {G H : Hypersequent}
    (hstep :
      SequentMatchingProofTheoreticHypersequentCompositionStep base G H) :
    ∃ C : Hypersequent, ∃ u t v : PTree, ∃ a : Address,
      G = C + HQ.singleton u + HQ.singleton t ∧
        H = C + HQ.singleton v ∧
          SequentMatchingCompositionDecomposition base u t v a := by
  rcases hstep with
    ⟨C, u, t, v, a, hG, hH, hu, ht, hg, hnode, hnotroot, _hv⟩
  exact
    ⟨C, u, t, v, a, hG, hH,
      sequentMatching_composition_decomposition
        hu ht hg hnode hnotroot⟩

/--
Exact characterization of the address-level product by the local CK bridge.

This is the local algebra/coalgebra equivalence in its cleanest form.  A
sequent-matching hypersequent composition step is exactly the data of:

* the two hypersequent equations `G = C + {u} + {t}` and `H = C + {v}`;
* one addressed matching graft `u` into `t` at a non-root occurrence `a`;
* the local proof-theoretic CK bridge for the resulting composite `v`.

The reverse direction is important: once the local bridge and exact addressed
graft are known, no further proof-theoretic data is needed to recover the
hypersequent product step.
-/
theorem sequentMatchingProofTheoreticHypersequentCompositionStep_iff_exact_local_bridge
    {base : BaseRel} {G H : Hypersequent} :
    SequentMatchingProofTheoreticHypersequentCompositionStep base G H ↔
      ∃ C : Hypersequent, ∃ u t v : PTree, ∃ a : Address,
        G = C + HQ.singleton u + HQ.singleton t ∧
          H = C + HQ.singleton v ∧
            PTree.graftMatchingLeafAt u t a = some v ∧
              IsNodeAddress u ([] : Address) ∧
                a ≠ ([] : Address) ∧
                  SequentMatchingCompositionDecomposition
                    base u t v a := by
  constructor
  · intro hstep
    rcases hstep with
      ⟨C, u, t, v, a, hG, hH, hu, ht, hg, hnode, hnotroot, _hv⟩
    exact
      ⟨C, u, t, v, a, hG, hH, hg, hnode, hnotroot,
        sequentMatching_composition_decomposition
          hu ht hg hnode hnotroot⟩
  · rintro
      ⟨C, u, t, v, a, hG, hH, hg, hnode, hnotroot, hbridge⟩
    exact
      ⟨C, u, t, v, a, hG, hH,
        hbridge.admissible_composition.1,
        hbridge.admissible_composition.2.1,
        hg, hnode, hnotroot,
        hbridge.closed_composite⟩

/--
Coefficient-level form of the address-level hypersequent composition bridge.

The algebra-side grafting coefficient for the active proof-tree composition is
nonzero, and the CK coproduct coefficient of the resulting composite at the
corresponding detached-proof/remainder tensor is nonzero.
-/
theorem sequentMatchingProofTheoreticHypersequentCompositionStep_coefficients
    {base : BaseRel} {G H : Hypersequent}
    (hstep :
      SequentMatchingProofTheoreticHypersequentCompositionStep base G H) :
    ∃ C : Hypersequent, ∃ u t v : PTree, ∃ a : Address,
      G = C + HQ.singleton u + HQ.singleton t ∧
        H = C + HQ.singleton v ∧
          0 < graftMultiplicity u t v ∧
            0 <
              cutSplitMultiplicity v
                (HQ.singleton u,
                  HQ.singleton (PTree.remainderGo [a] [] v)) := by
  rcases
    sequentMatchingProofTheoreticHypersequentCompositionStep_local_bridge
      hstep with
    ⟨C, u, t, v, a, hG, hH, hbridge⟩
  exact
    ⟨C, u, t, v, a, hG, hH,
      hbridge.composition_coefficient_nonzero,
      hbridge.decomposition_coefficient_nonzero⟩

/--
Proof-theoretic CK form of the address-level hypersequent composition bridge.

The same local composition step produces a proof-theoretic split shape, exposes
the interface occurrence in the remainder, and reconstructs the composite by
filling that occurrence with the detached proof.
-/
theorem sequentMatchingProofTheoreticHypersequentCompositionStep_ck_reconstruction
    {base : BaseRel} {G H : Hypersequent}
    (hstep :
      SequentMatchingProofTheoreticHypersequentCompositionStep base G H) :
    ∃ C : Hypersequent, ∃ u t v : PTree, ∃ a : Address,
      G = C + HQ.singleton u + HQ.singleton t ∧
        H = C + HQ.singleton v ∧
          SplitProofTheoreticShape base
            (HQ.singleton u) (PTree.remainderGo [a] [] v) ∧
            PTree.subtreeAt (PTree.remainderGo [a] [] v) a =
              some (PTree.leaf u.conclusion) ∧
              BoundaryFill u (PTree.remainderGo [a] [] v) v := by
  rcases
    sequentMatchingProofTheoreticHypersequentCompositionStep_local_bridge
      hstep with
    ⟨C, u, t, v, a, hG, hH, hbridge⟩
  exact
    ⟨C, u, t, v, a, hG, hH,
      hbridge.proof_theoretic_split_shape,
      hbridge.exposed_interface,
      hbridge.reconstructs_composite⟩

/--
Address-level sequent-matching hypersequent composition preserves the closed
derivable sector.

The context closedness comes from the input hypersequent, while the active
output proof is already part of the addressed derivation witness.
-/
theorem sequentMatchingProofTheoreticHypersequentCompositionStep_preserves_derivable
    {base : BaseRel} {G H : Hypersequent}
    (hstep :
      SequentMatchingProofTheoreticHypersequentCompositionStep base G H)
    (hG : DerivableHypersequent base G) :
    DerivableHypersequent base H := by
  exact
    proofTheoreticHypersequentGraftCompositionStep_preserves_derivable
      (sequentMatchingProofTheoreticHypersequentCompositionStep_to_graft_composition
        hstep)
      hG

/--
Address-level sequent-matching hypersequent composition is stable under
genuine extension of the material base relation.
-/
theorem sequentMatchingProofTheoreticHypersequentCompositionStep_mono_base
    {base base' : BaseRel}
    (hbase : BaseRelExtends base base')
    {G H : Hypersequent}
    (hstep :
      SequentMatchingProofTheoreticHypersequentCompositionStep base G H) :
    SequentMatchingProofTheoreticHypersequentCompositionStep base' G H := by
  rcases hstep with
    ⟨C, u, t, v, a, hG, hH, hu, ht, hg, hnode, hnotroot, hv⟩
  exact
    ⟨C, u, t, v, a, hG, hH,
      derivableTree_mono hbase hu,
      derivableTree_mono hbase ht,
      hg, hnode, hnotroot,
      derivableTree_mono hbase hv⟩

/--
The two-component proof-theoretic graft-composition step preserves the closed
hypersequent sector.

This is the derivation-level version of the algebra-side composition claim:
two singleton proof components can be composed only when the singleton graft
support supplies genuine derivational provenance over the current base.
-/
theorem proof_theoretic_hypersequent_graft_composition_preserves_closed_sector
    (base : BaseRel) :
    PreservesClosedSector base
      (ProofTheoreticHypersequentGraftCompositionStep base) := by
  intro G H hstep hG
  exact
    proofTheoreticHypersequentGraftCompositionStep_preserves_derivable
      hstep hG

theorem proof_theoretic_hypersequent_graft_composition_has_no_escape
    (base : BaseRel) :
    ¬ EscapesClosedSector base
      (ProofTheoreticHypersequentGraftCompositionStep base) :=
  preservesClosedSector_iff_not_escapes.1
    (proof_theoretic_hypersequent_graft_composition_preserves_closed_sector
      base)

theorem proof_theoretic_hypersequent_graft_composition_shadow_balance
    {base : BaseRel} {G H : Hypersequent}
    (hstep :
      ProofTheoreticHypersequentGraftCompositionStep base G H) :
    ∃ U : Hypersequent,
      DerivableHypersequent base U ∧
        HQ.conclusions H + HQ.conclusions U =
          HQ.conclusions G :=
  proofTheoreticHypersequentGraftCompositionStep_shadow_balance hstep

/--
Monotone base extension preserves the actual derivation-level hypersequent
composition and its closedness.

This is the algebra-side companion to the nonmonotonic obstruction theorem:
if the material base is only extended, a previously licensed graft-composition
step remains licensed, and a closed derivable input still has a closed
derivable output over the larger base.
-/
theorem proof_theoretic_hypersequent_graft_composition_preserves_closed_sector_after_base_extension
    {base base' : BaseRel}
    (hbase : BaseRelExtends base base')
    {G H : Hypersequent}
    (hstep :
      ProofTheoreticHypersequentGraftCompositionStep base G H)
    (hG : DerivableHypersequent base G) :
    DerivableHypersequent base' H := by
  exact
    proofTheoreticHypersequentGraftCompositionStep_preserves_derivable
      (proofTheoreticHypersequentGraftCompositionStep_mono_base
        hbase hstep)
      (derivableHypersequent_mono hbase hG)

theorem fixed_derivable_internal_grafting_preserves_closed_sector
    (base : BaseRel) (u : PTree) :
    PreservesClosedSector base
      (FixedDerivableContextualInternalGraftStep base u) :=
  fixedDerivableContextualInternalGraftStep_preservesClosedSector base u

theorem fixed_derivable_internal_grafting_has_no_escape
    (base : BaseRel) (u : PTree) :
    ¬ EscapesClosedSector base
      (FixedDerivableContextualInternalGraftStep base u) :=
  fixedDerivableContextualInternalGraftStep_no_escape base u

theorem destroyed_update_blocks_fixed_derivable_internal_grafting
    {U : AdmissibleBaseUpdate} {base : BaseRel} {u : PTree}
    (h : DerivableTreeDestroyedByUpdate U base u) :
    ∃ base' : BaseRel,
      U base base' ∧
        DerivableTree base u ∧
          ¬ DerivableTree base' u ∧
            ∀ G H : Hypersequent,
              ¬ FixedDerivableContextualInternalGraftStep base' u G H :=
  derivableTreeDestroyedByUpdate_blocks_fixed_internal_grafting_step h

/--
If a nonmonotonic update destroys an inserted proof tree, then the full
two-component hypersequent composition step using that inserted singleton is
blocked over the updated base.

This is the same obstruction as fixed internal grafting, but stated at the
common hypersequent carrier where algebra-side composition consumes
`C + HQ.singleton u + T` and produces `C + V`.
-/
theorem destroyed_update_blocks_fixed_inserted_hypersequent_graft_composition
    {U : AdmissibleBaseUpdate} {base : BaseRel} {u : PTree}
    (h : DerivableTreeDestroyedByUpdate U base u) :
    ∃ base' : BaseRel,
      U base base' ∧
        DerivableTree base u ∧
          ¬ DerivableTree base' u ∧
            ∀ G H : Hypersequent,
              ¬ FixedInsertedProofTheoreticHypersequentGraftCompositionStep
                  base' (HQ.singleton u) G H :=
  derivableTreeDestroyedByUpdate_blocks_fixed_inserted_hypersequent_graft_composition
    h

/--
Base-managed external weakening cannot escape the closed derivable sector.
-/
theorem base_derivable_external_weakening_has_no_escape
    (base : BaseRel) :
    ¬ EscapesClosedSector base
      (ExternalWeakeningMove (baseDerivableWeakeningPolicy base)) :=
  baseDerivableExternalWeakening_no_escape base

/--
Labelled base-managed external weakening cannot escape the closed derivable
sector either.  This is the same admissibility fact with the structural-rule
label retained.
-/
theorem labelled_base_derivable_external_weakening_has_no_escape
    (base : BaseRel) :
    ¬ EscapesClosedSector base
      (LabelledExternalStep
        (baseDerivableWeakeningPolicy base)
        StructuralRuleTag.externalWeakening) :=
  labelledBaseDerivableExternalWeakening_no_escape base

/--
Free external weakening escapes exactly when the ambient tree syntax contains
some non-derivable tree over the current base.
-/
theorem free_external_weakening_escape_iff_exists_nonderivable_tree
    {base : BaseRel} :
    EscapesClosedSector base
      (ExternalWeakeningMove freeExternalWeakeningPolicy) ↔
      ∃ t : PTree, ¬ DerivableTree base t :=
  freeExternalWeakening_escapesClosedSector_iff_exists_nonderivable_tree

/-! ## Marquee theorem packets -/

/--
Marquee theorem packet 1: a structural/interface policy is algebraically
admissible exactly when its grafting product has no bad coefficient.

This is meant to be one of the headline proof-theoretic diagnostics:
structural rules become policies, and the algebra detects whether they escape
the genuine derivable proof-tree sector.
-/
structure StructuralPolicyDiagnosticMarquee
    (base : BaseRel) (P : ProofContextTree.InterfacePolicy base) : Prop where
  support_admissibility :
    P.SupportPreservesDerivable ↔ P.PreservesDerivableGrafting
  escape_coefficient :
    P.EscapesDerivableGrafting ↔ P.CoefficientEscapesDerivable
  admissible_iff_no_bad_coefficient :
    P.PreservesDerivableGrafting ↔ ¬ P.CoefficientEscapesDerivable
  product_restricts :
    P.PreservesDerivableGrafting →
      ∀ {x y : PreLieCarrier},
        x ∈ derivableTreeSubmodule base →
        y ∈ derivableTreeSubmodule base →
        policyGraftPreLie P x y ∈ derivableTreeSubmodule base

theorem structural_policy_diagnostic_marquee
    {base : BaseRel} (P : ProofContextTree.InterfacePolicy base) :
    StructuralPolicyDiagnosticMarquee base P where
  support_admissibility :=
    policy_support_preserves_derivable_iff_preserves_grafting
  escape_coefficient :=
    policy_escape_iff_coefficient_escape
  admissible_iff_no_bad_coefficient :=
    policy_preserves_derivable_iff_no_bad_product_coefficient
  product_restricts := by
    intro hP x y hx hy
    exact policy_product_restricts_to_derivable_carrier hP hx hy

/--
Marquee theorem packet 1b: schematic material/interface structure.

This is the general-case version of controlled weakening.  We do not choose a
specific material consequence relation; instead, any base-indexed schema that
proves its own soundness yields structurally labelled proof traces that remain
conservative over ordinary NMMS derivability, while its extracted interface
policy inherits the algebraic support/coefficient diagnostics.
-/
structure MaterialInterfaceSchemaMarquee
    (base : BaseRel)
    (S : ProofContextTree.MaterialInterfaceSchema base) : Prop where
  extracted_policy_base_sound :
    S.toPolicy.BaseSound
  schematic_traces_conservative :
    forall {s : MultiSequent},
      SchematicProof base S s ->
        DerivableSequent base s
  interface_fill_has_structural_label :
    forall {source target : MultiSequent}
      (hfill : S.mayFill source target)
      (d : SchematicProof base S target),
        exists child : ProofTraceTree,
          SchematicProof.toTraceTree
              (SchematicProof.interfaceFillStep hfill d) =
            ProofTraceTree.node
              (ProofStepLabel.structural StructuralRuleTag.interfaceFill)
              source
              [child]
  extracted_policy_diagnostic :
    StructuralPolicyDiagnosticMarquee base S.toPolicy

theorem material_interface_schema_marquee
    {base : BaseRel}
    (S : ProofContextTree.MaterialInterfaceSchema base) :
    MaterialInterfaceSchemaMarquee base S where
  extracted_policy_base_sound :=
    S.toPolicy_baseSound
  schematic_traces_conservative := by
    intro s d
    exact SchematicProof.derivableSequent d
  interface_fill_has_structural_label := by
    intro source target hfill d
    exact ⟨SchematicProof.toTraceTree d, rfl⟩
  extracted_policy_diagnostic :=
    structural_policy_diagnostic_marquee S.toPolicy

/--
Marquee theorem packet 2: exact sequent matching is the conservative
proof-theoretic GL/pre-Lie product.

It has no bad coefficient, it agrees with the original Grossman-Larsson
grafting product on the ambient carrier, it agrees with the restricted
derivable product on the proof-theoretic carrier, and it inherits the old
derivable right pre-Lie law.
-/
structure ExactGraftingMarquee (base : BaseRel) : Prop where
  no_bad_coefficient :
    ¬ (ProofContextTree.exactInterfacePolicy base).CoefficientEscapesDerivable
  ambient_product_is_original :
    policyGraftPreLie
        (ProofContextTree.exactInterfacePolicy base) =
      graftPreLie
  derivable_product_is_original :
    ∀ x y : DerivablePreLieCarrier base,
      policyDerivableGraftPreLie
          (ProofContextTree.exactInterfacePolicy base)
          (exactInterfacePolicy_preservesDerivableGrafting base) x y =
        derivableGraftPreLie base x y
  preLie_law_from_derivable :
    DerivableRightPreLieLaw base →
      PolicyDerivableRightPreLieLaw
        (ProofContextTree.exactInterfacePolicy base)
        (exactInterfacePolicy_preservesDerivableGrafting base)

theorem exact_grafting_marquee (base : BaseRel) :
    ExactGraftingMarquee base where
  no_bad_coefficient :=
    exact_policy_product_has_no_bad_coefficient base
  ambient_product_is_original :=
    exact_policy_product_is_original_grafting
  derivable_product_is_original :=
    exact_policy_derivable_product_is_derivable_grafting
  preLie_law_from_derivable :=
    exact_policy_derivable_right_preLieLaw_of_derivable

/--
Marquee theorem packet 3: nonmonotonicity appears as constrained weakening and
constrained grafting.

The point is not that external weakening is unavailable as syntax.  The point
is that an external weakening move is proof-theoretically admissible only when
the added component is licensed by the current material base, or by a specified
grafting/interface policy.  Free weakening is kept as the monotone comparison
case, and it escapes precisely when the ambient tree syntax contains a tree
that is not derivable over the current base.
-/
structure NonmonotonicWeakeningGraftingMarquee
    (base : BaseRel) : Prop where
  minimal_nmms_has_no_external_weakening :
    ∀ G H : Hypersequent,
      ¬ ExternalWeakeningMove nmmsWeakeningPolicy G H
  base_derivable_external_weakening_no_escape :
    ¬ EscapesClosedSector base
      (ExternalWeakeningMove (baseDerivableWeakeningPolicy base))
  labelled_base_derivable_external_weakening_no_escape :
    ¬ EscapesClosedSector base
      (LabelledExternalStep
        (baseDerivableWeakeningPolicy base)
        StructuralRuleTag.externalWeakening)
  derivable_internal_grafting_no_escape :
    ¬ EscapesClosedSector base
      (DerivableContextualInternalGraftStep base)
  proof_theoretic_graft_composition_no_escape :
    ¬ EscapesClosedSector base
      (ProofTheoreticHypersequentGraftCompositionStep base)
  proof_theoretic_graft_composition_mono_base :
    ∀ {base' : BaseRel} {G H : Hypersequent},
      BaseRelExtends base base' →
        ProofTheoreticHypersequentGraftCompositionStep base G H →
          ProofTheoreticHypersequentGraftCompositionStep base' G H
  proof_theoretic_graft_composition_tree_witnesses :
    ∀ {G H : Hypersequent},
      ProofTheoreticHypersequentGraftCompositionStep base G H →
        ∃ C : Hypersequent, ∃ u t v : PTree,
          G = C + HQ.singleton u + HQ.singleton t ∧
            H = C + HQ.singleton v ∧
              DerivableTree base u ∧
                DerivableTree base t ∧
                  AmbientGraftingSupport u t v ∧
                    DerivableTree base v
  proof_theoretic_graft_composition_shadow_balance :
    ∀ {G H : Hypersequent},
      ProofTheoreticHypersequentGraftCompositionStep base G H →
        ∃ U : Hypersequent,
          DerivableHypersequent base U ∧
            HQ.conclusions H + HQ.conclusions U =
              HQ.conclusions G
  free_external_weakening_escapes_iff_nonderivable_tree :
    EscapesClosedSector base
      (ExternalWeakeningMove freeExternalWeakeningPolicy) ↔
        ∃ t : PTree, ¬ DerivableTree base t
  exact_internal_weakening_is_exact_grafting :
    ∀ u t a,
      WeakeningMediatedGraftableAt exactInternalWeakeningPolicy u t a ↔
        PTree.IsGraftableLeafAt u t a
  free_internal_weakening_allows_every_leaf :
    ∀ {u t a},
      LeafAt t a →
        WeakeningMediatedGraftableAt freeInternalWeakeningPolicy u t a
  base_graft_controlled_weakening_supplies_contextual_graft :
    ∀ {G : Hypersequent} {t : PTree} (u : DerivableProofTree base),
      DerivableHypersequent base G →
        (baseGraftControlledWeakeningPolicy base u).admissible t →
          ∃ H : Hypersequent,
            DerivableHypersequent base (G + HQ.singleton t) ∧
            ContextualInternalGraft u.1 (G + HQ.singleton t) H ∧
            DerivableHypersequent base H
  schematic_material_interface_diagnostic :
    ∀ S : ProofContextTree.MaterialInterfaceSchema base,
      MaterialInterfaceSchemaMarquee base S
  schematic_proof_nonempty_mono_base :
    ∀ {base' : BaseRel}
      {S : ProofContextTree.MaterialInterfaceSchema base}
      {S' : ProofContextTree.MaterialInterfaceSchema base'}
      {s : MultiSequent},
        BaseRelExtends base base' →
          S'.Extends S →
            Nonempty (SchematicProof base S s) →
              Nonempty (SchematicProof base' S' s)
  schematic_proof_trace_mono_base :
    ∀ {base' : BaseRel}
      {S : ProofContextTree.MaterialInterfaceSchema base}
      {S' : ProofContextTree.MaterialInterfaceSchema base'}
      {s : MultiSequent}
      (hbase : BaseRelExtends base base')
      (hS : S'.Extends S)
      (d : SchematicProof base S s),
        SchematicProof.toTraceTree
            (SchematicProof.mapBase hbase hS d) =
          SchematicProof.toTraceTree d
  destroyed_entailment_blocks_schematic_proofs :
    ∀ {U : AdmissibleBaseUpdate} {Gamma Theta : Multiset MyProp},
      LogicalEntailmentDestroyedByUpdate U base Gamma Theta →
        ∃ base' : BaseRel,
          U base base' ∧
            LogicalEntails base Gamma Theta ∧
              ∀ S' : ProofContextTree.MaterialInterfaceSchema base',
                SchematicProof base' S' (Gamma ∣∼ Theta) → False
  destroyed_inserted_proof_blocks_fixed_internal_grafting :
    ∀ {U : AdmissibleBaseUpdate} {u : PTree},
      DerivableTreeDestroyedByUpdate U base u →
        ∃ base' : BaseRel,
          U base base' ∧
            DerivableTree base u ∧
              ¬ DerivableTree base' u ∧
                ∀ G H : Hypersequent,
                  ¬ FixedDerivableContextualInternalGraftStep base' u G H
  destroyed_inserted_proof_blocks_fixed_hypersequent_composition :
    ∀ {U : AdmissibleBaseUpdate} {u : PTree},
      DerivableTreeDestroyedByUpdate U base u →
        ∃ base' : BaseRel,
          U base base' ∧
            DerivableTree base u ∧
              ¬ DerivableTree base' u ∧
                ∀ G H : Hypersequent,
                  ¬ FixedInsertedProofTheoreticHypersequentGraftCompositionStep
                      base' (HQ.singleton u) G H
  exact_grafting_product_has_no_bad_coefficient :
    ¬ (ProofContextTree.exactInterfacePolicy base).CoefficientEscapesDerivable
  exact_grafting_product_is_original :
    policyGraftPreLie
        (ProofContextTree.exactInterfacePolicy base) =
      graftPreLie

theorem nonmonotonic_weakening_grafting_marquee
    (base : BaseRel) :
    NonmonotonicWeakeningGraftingMarquee base where
  minimal_nmms_has_no_external_weakening :=
    no_nmmsExternalWeakeningMove
  base_derivable_external_weakening_no_escape :=
    base_derivable_external_weakening_has_no_escape base
  labelled_base_derivable_external_weakening_no_escape :=
    labelled_base_derivable_external_weakening_has_no_escape base
  derivable_internal_grafting_no_escape :=
    derivable_internal_grafting_has_no_escape base
  proof_theoretic_graft_composition_no_escape :=
    proof_theoretic_hypersequent_graft_composition_has_no_escape base
  proof_theoretic_graft_composition_mono_base := by
    intro base' G H hbase hstep
    exact
      proof_theoretic_hypersequent_graft_composition_step_mono_base
        hbase hstep
  proof_theoretic_graft_composition_tree_witnesses := by
    intro G H hstep
    exact
      proof_theoretic_hypersequent_graft_composition_tree_witnesses
        hstep
  proof_theoretic_graft_composition_shadow_balance := by
    intro G H hstep
    exact
      proof_theoretic_hypersequent_graft_composition_shadow_balance
        hstep
  free_external_weakening_escapes_iff_nonderivable_tree :=
    free_external_weakening_escape_iff_exists_nonderivable_tree
  exact_internal_weakening_is_exact_grafting :=
    weakeningMediatedGraftableAt_exact_iff
  free_internal_weakening_allows_every_leaf := by
    intro u t a hleaf
    exact weakeningMediatedGraftableAt_free_of_leaf hleaf
  base_graft_controlled_weakening_supplies_contextual_graft := by
    intro G t u hG hW
    exact baseGraftControlledWeakening_supplies_derivable_contextual_graft
      u hG hW
  schematic_material_interface_diagnostic := by
    intro S
    exact material_interface_schema_marquee S
  schematic_proof_nonempty_mono_base := by
    intro base' S S' s hbase hS hd
    rcases hd with ⟨d⟩
    exact ⟨SchematicProof.mapBase hbase hS d⟩
  schematic_proof_trace_mono_base := by
    intro base' S S' s hbase hS d
    exact SchematicProof.toTraceTree_mapBase hbase hS d
  destroyed_entailment_blocks_schematic_proofs := by
    intro U Gamma Theta hdestroy
    exact
      SchematicProof.destroyed_logical_entailment_blocks_schematic_proofs
        hdestroy
  destroyed_inserted_proof_blocks_fixed_internal_grafting := by
    intro U u hdestroy
    exact destroyed_update_blocks_fixed_derivable_internal_grafting hdestroy
  destroyed_inserted_proof_blocks_fixed_hypersequent_composition := by
    intro U u hdestroy
    exact
      destroyed_update_blocks_fixed_inserted_hypersequent_graft_composition
        hdestroy
  exact_grafting_product_has_no_bad_coefficient :=
    exact_policy_product_has_no_bad_coefficient base
  exact_grafting_product_is_original :=
    exact_policy_product_is_original_grafting

/--
At the support level, changing structural/interface policy changes the
algebraic reconstruction side, not the already-defined CK cut support.

The theorem is deliberately tautological: it records the design boundary.  To
make the coalgebra itself policy-sensitive, we would need to change
`coalgebraAdmissibleCuts`, not merely the graft/fill policy.
-/
theorem cut_support_independent_of_interface_policy
    {base : BaseRel}
    (_P _Q : ProofContextTree.InterfacePolicy base)
    (t : PTree) :
    CutSplitSupport t = CutSplitSupport t := by
  rfl

/--
Diagnostic for changing structural assumptions while keeping the same
underlying proof-tree punctuation.

If `P` extends `Q`, then every one-step composition allowed by `Q` is still
allowed by `P`, every nonzero product coefficient for `Q` remains nonzero for
`P`, and every bad coefficient of `Q` is inherited by `P`.  The present CK
decomposition support is unchanged because it has not yet been parameterized
by interface policy.
-/
structure StructuralAssumptionChangeDiagnostic
    {base : BaseRel}
    (P Q : ProofContextTree.InterfacePolicy base) : Prop where
  composition_support_inclusion :
    ∀ u t v : PTree,
      v ∈ (policyGraftPreLieTree Q u t).support →
        v ∈ (policyGraftPreLieTree P u t).support
  composition_coefficient_inclusion :
    ∀ u t v : PTree,
      policyGraftPreLieTree Q u t v ≠ 0 →
        policyGraftPreLieTree P u t v ≠ 0
  coefficient_escape_inclusion :
    Q.CoefficientEscapesDerivable →
      P.CoefficientEscapesDerivable
  decomposition_support_unchanged :
    ∀ t : PTree, CutSplitSupport t = CutSplitSupport t

theorem structural_assumption_change_diagnostic_of_extension
    {base : BaseRel}
    {P Q : ProofContextTree.InterfacePolicy base}
    (hPQ : P.Extends Q) :
    StructuralAssumptionChangeDiagnostic P Q where
  composition_support_inclusion := by
    intro u t v hv
    exact policy_extension_preserves_product_support hPQ hv
  composition_coefficient_inclusion := by
    intro u t v hcoeff
    exact policy_extension_preserves_product_coefficients hPQ hcoeff
  coefficient_escape_inclusion := by
    intro hesc
    exact policy_extension_preserves_coefficient_escape hPQ hesc
  decomposition_support_unchanged := by
    intro t
    rfl

/--
The Hopf coproduct of a one-tree basis vector is the tensor-linearization of
the admissible-cut split support.
-/
theorem coproduct_on_tree_is_cut_split_tensor_sum
    (K : Type) [CommRing K]
    [LeftDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    [RightDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    (t : PTree) :
    proofTreeHopfComul K (treeMonomial K t) =
      hypersequentTensorAlgToTensorProductLinearMap K
        (coalgebraTreeSplittingTensorElement K t) := by
  exact proofTreeHopf_comul_tree K t

/-! ## Local duality targets -/

/--
The local singleton cut/graft coefficient comparison, stated with the
remainder/context as the second input.

This is intentionally a `Prop`, not a claimed theorem.  In full generality,
one cannot compare grafting into the original host with cutting into the
right-hand tensor factor of the coproduct: the coproduct returns the
remainder/context, not the pre-composition host.  The local comparison must
therefore count graftings of `u` into that exposed context.
-/
def SingletonCutGraftCoefficientTarget
    (u context out : PTree) : Prop :=
  graftMultiplicity u context out =
    cutSplitMultiplicity out (HQ.singleton u, HQ.singleton context)

/--
The local reconstruction theorem supplies evidence for the singleton
coefficient target whenever the context is the actual remainder exposed by a
known sequent-matching composition.

This is deliberately one-directional: arbitrary CK decompositions are not
claimed to arise from logical/proof-theoretic composition without further
admissibility hypotheses.
-/
theorem sequentMatching_remainder_satisfies_singleton_target_evidence
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v) :
    v ∈ InternalGraftSupport u (PTree.remainderGo [a] [] v) := by
  exact mem_treeGraftSupport_of_graftMatchingLeafAt_eq_some
    (sequentMatching_remainder_reconstructs_composite hg)

/--
Occurrence-indexed reconstruction multiplicity.

This is the local, proof-theoretically sharp reconstruction count: it remembers
the marked sequent occurrence/address at which the detached proof is inserted.
For a successful fill at that exact occurrence the multiplicity is `1`, and
otherwise it is `0`.
-/
def OccurrenceReconstructMultiplicity
    (u context out : PTree) (a : Address) : Nat :=
  if PTree.graftMatchingLeafAt u context a = some out then 1 else 0

/--
The occurrence fibre of a one-step reconstruction.

This is the algebra-side analogue of an addressed cut fibre: it is the list of
sequent occurrences in the context at which the proof `u` can be inserted to
reconstruct exactly `out`.
-/
noncomputable def ReconstructionOccurrenceFibre
    (u context out : PTree) : List Address := by
  classical
  exact (PTree.allAddresses context).filter
    (fun a => PTree.graftMatchingLeafAt u context a = some out)

/-- The one-step grafting coefficient, read as an occurrence-fibre cardinality. -/
noncomputable def ReconstructionOccurrenceMultiplicity
    (u context out : PTree) : Nat :=
  (ReconstructionOccurrenceFibre u context out).length

theorem mem_reconstructionOccurrenceFibre_iff
    {u context out : PTree} {a : Address} :
    a ∈ ReconstructionOccurrenceFibre u context out ↔
      a ∈ PTree.allAddresses context ∧
        PTree.graftMatchingLeafAt u context a = some out := by
  classical
  unfold ReconstructionOccurrenceFibre
  simp

/--
A successful matching graft takes place at an actual address of the context.
-/
theorem mem_allAddresses_of_graftMatchingLeafAt_eq_some
    {u context out : PTree} {a : Address}
    (h : PTree.graftMatchingLeafAt u context a = some out) :
    a ∈ PTree.allAddresses context := by
  have hgraftable :
      PTree.IsGraftableLeafAt u context a :=
    PTree.isGraftableLeafAt_of_graftMatchingLeafAt_eq_some
      u context a out h
  have hsub :
      PTree.subtreeAt context a = some (PTree.leaf u.conclusion) :=
    (PTree.IsGraftableLeafAt_iff u context a).1 hgraftable
  exact
    PTree.subtreeAt_some_implies_mem_allAddresses
      context (PTree.leaf u.conclusion) a hsub

/--
Every successful one-step matching graft determines a reconstruction
occurrence.
-/
theorem reconstructionOccurrenceFibre_mem_of_graftMatchingLeafAt_eq_some
    {u context out : PTree} {a : Address}
    (h : PTree.graftMatchingLeafAt u context a = some out) :
    a ∈ ReconstructionOccurrenceFibre u context out := by
  rw [mem_reconstructionOccurrenceFibre_iff]
  exact ⟨mem_allAddresses_of_graftMatchingLeafAt_eq_some h, h⟩

/--
Counting the outputs of a `filterMap` is the same as counting the inputs whose
image is the requested output.  This is the small combinatorial lemma behind
the grafting coefficient theorem below.
-/
theorem count_filterMap_eq_length_filter_some
    {alpha beta : Type} [DecidableEq beta]
    (f : alpha -> Option beta) (xs : List alpha) (b : beta) :
    ((xs.filterMap f).count b) =
      (xs.filter (fun x => f x = some b)).length := by
  induction xs with
  | nil =>
      simp
  | cons x xs ih =>
      cases h : f x with
      | none =>
          simp [h, ih]
      | some y =>
          by_cases hy : y = b
          · subst y
            simp [h, ih]
          · have hs : Not (some y = some b) := by
              intro heq
              cases heq
              exact hy rfl
            simp [h, hy, hs, ih]

/--
The grafting/pre-Lie coefficient is exactly the cardinality of the
reconstruction occurrence fibre.

Thus coefficients of the algebra product count matching sequent occurrences,
not merely unlabelled output trees.
-/
theorem graftMultiplicity_eq_reconstructionOccurrenceMultiplicity
    (u context out : PTree) :
    graftMultiplicity u context out =
      ReconstructionOccurrenceMultiplicity u context out := by
  classical
  unfold graftMultiplicity InternalGraftSupport treeGraftSupport
    ReconstructionOccurrenceMultiplicity ReconstructionOccurrenceFibre
  exact count_filterMap_eq_length_filter_some
    (PTree.graftMatchingLeafAt u context) (PTree.allAddresses context) out

/--
The reconstruction occurrence fibre is nonempty exactly when there is a
matching sequent occurrence that reconstructs the requested output.
-/
theorem reconstructionOccurrenceMultiplicity_pos_iff_exists_occurrence
    (u context out : PTree) :
    0 < ReconstructionOccurrenceMultiplicity u context out ↔
      ∃ a : Address,
        a ∈ PTree.allAddresses context ∧
          PTree.graftMatchingLeafAt u context a = some out := by
  unfold ReconstructionOccurrenceMultiplicity
  rw [List.length_pos_iff_exists_mem]
  constructor
  · intro h
    rcases h with ⟨a, ha⟩
    exact ⟨a, (mem_reconstructionOccurrenceFibre_iff).1 ha⟩
  · intro h
    rcases h with ⟨a, ha⟩
    exact ⟨a, (mem_reconstructionOccurrenceFibre_iff).2 ha⟩

/--
Nonzero one-step grafting coefficient, in reconstruction-occurrence form.

This is the algebra-side support theorem parallel to
`cutSplitMultiplicity_pos_iff_exists_addressed_cut`.
-/
theorem graftMultiplicity_pos_iff_exists_reconstruction_occurrence
    (u context out : PTree) :
    0 < graftMultiplicity u context out ↔
      ∃ a : Address,
        a ∈ PTree.allAddresses context ∧
          PTree.graftMatchingLeafAt u context a = some out := by
  rw [graftMultiplicity_eq_reconstructionOccurrenceMultiplicity]
  exact reconstructionOccurrenceMultiplicity_pos_iff_exists_occurrence
    u context out

/--
After decomposing a sequent-matching composition, the original address is a
reconstruction occurrence of the exposed context.
-/
theorem sequentMatching_address_mem_reconstructionOccurrenceFibre
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v) :
    a ∈ ReconstructionOccurrenceFibre
      u (PTree.remainderGo [a] [] v) v :=
  reconstructionOccurrenceFibre_mem_of_graftMatchingLeafAt_eq_some
    (sequentMatching_remainder_reconstructs_composite hg)

/--
Consequently the algebra-side reconstruction coefficient is positive for the
context obtained by the corresponding singleton decomposition.
-/
theorem sequentMatching_reconstructionOccurrenceMultiplicity_pos
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v) :
    0 <
      ReconstructionOccurrenceMultiplicity
        u (PTree.remainderGo [a] [] v) v := by
  unfold ReconstructionOccurrenceMultiplicity
  exact List.length_pos_of_mem
    (sequentMatching_address_mem_reconstructionOccurrenceFibre hg)

/--
The same statement read as a nonzero one-step grafting coefficient.
-/
theorem sequentMatching_remainder_graftMultiplicity_pos
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v) :
    0 < graftMultiplicity u (PTree.remainderGo [a] [] v) v := by
  rw [graftMultiplicity_eq_reconstructionOccurrenceMultiplicity]
  exact sequentMatching_reconstructionOccurrenceMultiplicity_pos hg

/--
Addressed singleton-cut multiplicity.

This is the coalgebra-side local count before quotienting away occurrence
information into the ambient hypersequent tensor basis.  It records whether
the particular singleton cut `[a]` is admissible and has the requested tensor
term.
-/
def SingletonAddressCutMultiplicity
    (t : PTree) (a : Address) (p : HypersequentTensorBasis) : Nat := by
  classical
  exact
    if [a] ∈ coalgebraAdmissibleCuts t ∧
        coalgebraTensorTermOfCutList t [a] = p then 1 else 0

/--
The addressed-cut fibre over a tensor basis element.

This is the global CK coefficient before forgetting how it was obtained: it is
the list of admissible cuts whose normalized tensor term is exactly `p`.
-/
noncomputable def AddressedCutFibre
    (t : PTree) (p : HypersequentTensorBasis) : List (List Address) := by
  classical
  exact (coalgebraAdmissibleCuts t).filter
    (fun cut => coalgebraTensorTermOfCutList t cut = p)

/-- The CK coefficient, read as the cardinality of an addressed-cut fibre. -/
noncomputable def AddressedCutMultiplicity
    (t : PTree) (p : HypersequentTensorBasis) : Nat :=
  (AddressedCutFibre t p).length

theorem mem_addressedCutFibre_iff
    {t : PTree} {p : HypersequentTensorBasis} {cut : List Address} :
    cut ∈ AddressedCutFibre t p ↔
      cut ∈ coalgebraAdmissibleCuts t ∧
        coalgebraTensorTermOfCutList t cut = p := by
  classical
  unfold AddressedCutFibre
  simp

/--
The singleton-address part of an addressed-cut fibre.

This is the subfibre relevant to one-step grafting: a singleton cut exposes
one subderivation occurrence.  Multi-cut fibres are the genuinely forest-level
part of the coproduct.
-/
noncomputable def SingletonAddressCutFibre
    (t : PTree) (p : HypersequentTensorBasis) : List Address :=
  (AddressedCutFibre t p).filterMap
    (fun cut =>
      match cut with
      | [a] => some a
      | _ => none)

noncomputable def SingletonAddressCutFibreMultiplicity
    (t : PTree) (p : HypersequentTensorBasis) : Nat :=
  (SingletonAddressCutFibre t p).length

theorem length_filter_map_eq_filter_preimage
    {α β : Type} [DecidableEq β]
    (f : α → β) (xs : List α) (b : β) :
    ((xs.map f).filter (fun y => y = b)).length =
      (xs.filter (fun x => f x = b)).length := by
  induction xs with
  | nil =>
      simp
  | cons x xs ih =>
      by_cases h : f x = b
      · rw [List.map_cons]
        rw [List.filter_cons_of_pos
          (p := fun y => decide (y = b)) (a := f x)
          (by simp [h])]
        rw [List.filter_cons_of_pos
          (p := fun x => decide (f x = b)) (a := x)
          (by simp [h])]
        simp [ih]
      · have hdec : ¬ decide (f x = b) = true := by
          simpa [decide_eq_true_eq] using h
        rw [List.map_cons]
        rw [List.filter_cons_of_neg
          (p := fun y => decide (y = b)) (a := f x) hdec]
        rw [List.filter_cons_of_neg
          (p := fun x => decide (f x = b)) (a := x) hdec]
        exact ih

/--
The normalized CK coefficient is exactly the cardinality of the addressed-cut
fibre.

This is the first globalization step: coefficients of the tensor coproduct are
not mysterious algebraic scalars; they count admissible decomposition
occurrences whose normalized tensor term has collapsed to the same basis
element.
-/
theorem cutSplitMultiplicity_eq_addressedCutMultiplicity
    (t : PTree) (p : HypersequentTensorBasis) :
    cutSplitMultiplicity t p = AddressedCutMultiplicity t p := by
  classical
  unfold cutSplitMultiplicity AddressedCutMultiplicity AddressedCutFibre
    CutSplitSupport coalgebraTreeSplittingTensorSupport
  exact length_filter_map_eq_filter_preimage
    (coalgebraTensorTermOfCutList t) (coalgebraAdmissibleCuts t) p

/--
The addressed-cut fibre is nonempty exactly when some admissible cut produces
the tensor basis element.
-/
theorem addressedCutMultiplicity_pos_iff_exists_cut
    (t : PTree) (p : HypersequentTensorBasis) :
    0 < AddressedCutMultiplicity t p ↔
      ∃ cut : List Address,
        cut ∈ coalgebraAdmissibleCuts t ∧
          coalgebraTensorTermOfCutList t cut = p := by
  unfold AddressedCutMultiplicity
  rw [List.length_pos_iff_exists_mem]
  constructor
  · intro h
    rcases h with ⟨cut, hcut⟩
    exact ⟨cut, (mem_addressedCutFibre_iff).1 hcut⟩
  · intro h
    rcases h with ⟨cut, hcut⟩
    exact ⟨cut, (mem_addressedCutFibre_iff).2 hcut⟩

/--
Nonzero CK tensor coefficient, in proof-decomposition form.

This is the support theorem with addresses exposed: a tensor basis element has
positive coefficient in the normalized CK coproduct exactly when there exists
an admissible cut whose normalized tensor term is that basis element.
-/
theorem cutSplitMultiplicity_pos_iff_exists_addressed_cut
    (t : PTree) (p : HypersequentTensorBasis) :
    0 < cutSplitMultiplicity t p ↔
      ∃ cut : List Address,
        cut ∈ coalgebraAdmissibleCuts t ∧
          coalgebraTensorTermOfCutList t cut = p := by
  rw [cutSplitMultiplicity_eq_addressedCutMultiplicity]
  exact addressedCutMultiplicity_pos_iff_exists_cut t p

/--
The explicit detached-forest tensor term of a two-site CK cut lies in the
addressed cut fibre.
-/
theorem two_site_addressedCutFibre_mem_of_subtreeAt
    {t u w : PTree} {a b : Address}
    (hcut : [a, b] ∈ coalgebraAdmissibleCuts t)
    (hsubA : PTree.subtreeAt t a = some u)
    (hsubB : PTree.subtreeAt t b = some w) :
    [a, b] ∈
      AddressedCutFibre t
        (HQ.ofForest [u, w],
          HQ.singleton (PTree.remainderGo [a, b] [] t)) := by
  rw [mem_addressedCutFibre_iff]
  exact ⟨hcut,
    two_site_coalgebraTensorTerm_eq_of_subtreeAt hcut hsubA hsubB⟩

/--
The explicit detached-forest tensor basis element has positive CK coproduct
coefficient.
-/
theorem two_site_cutSplitMultiplicity_pos_of_subtreeAt
    {t u w : PTree} {a b : Address}
    (hcut : [a, b] ∈ coalgebraAdmissibleCuts t)
    (hsubA : PTree.subtreeAt t a = some u)
    (hsubB : PTree.subtreeAt t b = some w) :
    0 <
      cutSplitMultiplicity t
        (HQ.ofForest [u, w],
          HQ.singleton (PTree.remainderGo [a, b] [] t)) := by
  exact
    (cutSplitMultiplicity_pos_iff_exists_addressed_cut
      t (HQ.ofForest [u, w],
        HQ.singleton (PTree.remainderGo [a, b] [] t))).2
      ⟨[a, b], hcut,
        two_site_coalgebraTensorTerm_eq_of_subtreeAt hcut hsubA hsubB⟩

/--
General CK cut/graft bridge.

An admissible CK cut is simultaneously:

* a coproduct decomposition;
* a graft-reconstructible proof decomposition;
* an addressed cut-fibre element;
* a nonzero coefficient of the CK coproduct at its tensor term.
-/
structure CKCutGraftBridge
    (t : PTree) (cut : List Address) : Prop where
  admissible_ck_cut :
    cut ∈ coalgebraAdmissibleCuts t
  reconstruction :
    CutForestReconstructionTarget t cut
  addressed_cut_fibre_member :
    cut ∈ AddressedCutFibre t (coalgebraTensorTermOfCutList t cut)
  ck_coefficient_nonzero :
    0 < cutSplitMultiplicity t (coalgebraTensorTermOfCutList t cut)

/-- Every CK-admissible cut gives the general cut/graft bridge. -/
theorem ck_cut_graft_bridge_of_mem_coalgebraAdmissibleCuts
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts t) :
    CKCutGraftBridge t cut where
  admissible_ck_cut := hcut
  reconstruction :=
    coalgebra_cutForestReconstructionTarget hcut
  addressed_cut_fibre_member := by
    rw [mem_addressedCutFibre_iff]
    exact ⟨hcut, rfl⟩
  ck_coefficient_nonzero := by
    exact
      (cutSplitMultiplicity_pos_iff_exists_addressed_cut
        t (coalgebraTensorTermOfCutList t cut)).2
        ⟨cut, hcut, rfl⟩

/--
Support-level cut/graft bridge.

Every tensor term in the CK coproduct support is generated by a
graft-reconstructible admissible cut.
-/
theorem cutSplitSupport_terms_have_graft_reconstruction
    {t : PTree} {p : HypersequentTensorBasis}
    (hp : p ∈ CutSplitSupport t) :
    ∃ cut : List Address,
      CKCutGraftBridge t cut ∧
        coalgebraTensorTermOfCutList t cut = p := by
  rcases exists_coalgebra_cut_of_mem_cutSplitSupport hp with
    ⟨cut, hcut, hpterm⟩
  exact ⟨cut, ck_cut_graft_bridge_of_mem_coalgebraAdmissibleCuts hcut, hpterm⟩

/--
Coefficient-level CK cut/graft bridge.

A tensor coefficient in the CK coproduct is nonzero exactly when it is
realized by an admissible cut with a canonical graft reconstruction.
-/
theorem cutSplitMultiplicity_pos_iff_exists_ck_cut_graft_bridge
    (t : PTree) (p : HypersequentTensorBasis) :
    0 < cutSplitMultiplicity t p ↔
      ∃ cut : List Address,
        CKCutGraftBridge t cut ∧
          coalgebraTensorTermOfCutList t cut = p := by
  constructor
  · intro hpos
    rcases (cutSplitMultiplicity_pos_iff_exists_addressed_cut t p).1 hpos with
      ⟨cut, hcut, hpterm⟩
    exact ⟨cut, ck_cut_graft_bridge_of_mem_coalgebraAdmissibleCuts hcut, hpterm⟩
  · rintro ⟨cut, hbridge, hpterm⟩
    simpa [hpterm] using hbridge.ck_coefficient_nonzero

/--
Support-level iff for the CK cut/graft bridge.

A tensor basis element is present in the CK coproduct support exactly when it
is produced by a graft-reconstructible admissible cut.
-/
theorem mem_cutSplitSupport_iff_exists_ck_cut_graft_bridge
    {t : PTree} {p : HypersequentTensorBasis} :
    p ∈ CutSplitSupport t ↔
      ∃ cut : List Address,
        CKCutGraftBridge t cut ∧
          coalgebraTensorTermOfCutList t cut = p := by
  constructor
  · exact cutSplitSupport_terms_have_graft_reconstruction
  · intro hbridge
    exact
      (cutSplitMultiplicity_pos_iff_mem).1
        ((cutSplitMultiplicity_pos_iff_exists_ck_cut_graft_bridge t p).2
          hbridge)

/--
The CK cut fibre refined by graft reconstruction.

This is the same addressed fibre, but filtered through the proof-theoretic
condition that the detached forest and remainder reconstruct by grafting.
-/
noncomputable def GraftReconstructibleCutFibre
    (t : PTree) (p : HypersequentTensorBasis) : List (List Address) := by
  classical
  exact (AddressedCutFibre t p).filter
    (fun cut => CutForestReconstructionTarget t cut)

/-- The coefficient count of graft-reconstructible CK decompositions. -/
noncomputable def GraftReconstructibleCutMultiplicity
    (t : PTree) (p : HypersequentTensorBasis) : Nat :=
  (GraftReconstructibleCutFibre t p).length

theorem mem_graftReconstructibleCutFibre_iff
    {t : PTree} {p : HypersequentTensorBasis} {cut : List Address} :
    cut ∈ GraftReconstructibleCutFibre t p ↔
      cut ∈ coalgebraAdmissibleCuts t ∧
        coalgebraTensorTermOfCutList t cut = p ∧
          CutForestReconstructionTarget t cut := by
  classical
  unfold GraftReconstructibleCutFibre
  rw [List.mem_filter]
  constructor
  · intro h
    rcases (mem_addressedCutFibre_iff).1 h.1 with ⟨hcut, hpterm⟩
    exact ⟨hcut, hpterm, of_decide_eq_true h.2⟩
  · rintro ⟨hcut, hpterm, hreconstruct⟩
    exact
      ⟨(mem_addressedCutFibre_iff).2 ⟨hcut, hpterm⟩,
        by simpa [decide_eq_true_eq] using hreconstruct⟩

/--
Every addressed CK cut is graft-reconstructible, so the refined fibre is the
ordinary addressed fibre.
-/
theorem graftReconstructibleCutFibre_eq_addressedCutFibre
    (t : PTree) (p : HypersequentTensorBasis) :
    GraftReconstructibleCutFibre t p = AddressedCutFibre t p := by
  classical
  unfold GraftReconstructibleCutFibre
  exact List.filter_eq_self.2 (by
    intro cut hcut
    simpa [decide_eq_true_eq] using
      coalgebra_cutForestReconstructionTarget
        ((mem_addressedCutFibre_iff).1 hcut).1)

/--
The CK coproduct coefficient is the number of graft-reconstructible admissible
proof decompositions producing the tensor term.
-/
theorem cutSplitMultiplicity_eq_graftReconstructibleCutMultiplicity
    (t : PTree) (p : HypersequentTensorBasis) :
    cutSplitMultiplicity t p =
      GraftReconstructibleCutMultiplicity t p := by
  rw [cutSplitMultiplicity_eq_addressedCutMultiplicity]
  unfold AddressedCutMultiplicity GraftReconstructibleCutMultiplicity
  rw [graftReconstructibleCutFibre_eq_addressedCutFibre]

/--
Two-site CK cut/graft bridge.

A two-address CK cut is not only a coalgebra decomposition: it also has a
canonical graft reconstruction, and it contributes a nonzero coefficient to
the addressed coproduct fibre determined by its tensor term.
-/
structure TwoSiteCKCutGraftBridge
    (t : PTree) (a b : Address) : Prop where
  admissible_ck_cut :
    [a, b] ∈ coalgebraAdmissibleCuts t
  left_rule_occurrence :
    IsNodeAddress t a
  right_rule_occurrence :
    IsNodeAddress t b
  reconstruction :
    CutForestReconstructionTarget t [a, b]
  tensor_term_exposes_detached_forest :
    ∃ u w : PTree,
      PTree.subtreeAt t a = some u ∧
      PTree.subtreeAt t b = some w ∧
      coalgebraTensorTermOfCutList t [a, b] =
        (HQ.ofForest [u, w],
          HQ.singleton (PTree.remainderGo [a, b] [] t))
  detached_forest_coefficient_nonzero :
    ∃ u w : PTree,
      PTree.subtreeAt t a = some u ∧
      PTree.subtreeAt t b = some w ∧
      0 <
        cutSplitMultiplicity t
          (HQ.ofForest [u, w],
            HQ.singleton (PTree.remainderGo [a, b] [] t))
  addressed_cut_fibre_member :
    [a, b] ∈
      AddressedCutFibre t (coalgebraTensorTermOfCutList t [a, b])
  ck_coefficient_nonzero :
    0 <
      cutSplitMultiplicity t
        (coalgebraTensorTermOfCutList t [a, b])

/--
Every two-address CK-admissible cut gives the two-site cut/graft bridge.
-/
theorem two_site_ck_cut_graft_bridge_of_mem_coalgebraAdmissibleCuts
    {t : PTree} {a b : Address}
    (hcut : [a, b] ∈ coalgebraAdmissibleCuts t) :
    TwoSiteCKCutGraftBridge t a b where
  admissible_ck_cut := hcut
  left_rule_occurrence :=
    left_nodeAddress_of_two_site_coalgebra_cut hcut
  right_rule_occurrence :=
    right_nodeAddress_of_two_site_coalgebra_cut hcut
  reconstruction :=
    two_site_coalgebra_cutForestReconstructionTarget hcut
  tensor_term_exposes_detached_forest :=
    two_site_coalgebraTensorTerm_exposes_detached_forest hcut
  detached_forest_coefficient_nonzero := by
    rcases two_site_coalgebraTensorTerm_exposes_detached_forest hcut with
      ⟨u, w, hsubA, hsubB, _hterm⟩
    exact ⟨u, w, hsubA, hsubB,
      two_site_cutSplitMultiplicity_pos_of_subtreeAt hcut hsubA hsubB⟩
  addressed_cut_fibre_member := by
    rw [mem_addressedCutFibre_iff]
    exact ⟨hcut, rfl⟩
  ck_coefficient_nonzero := by
    exact
      (cutSplitMultiplicity_pos_iff_exists_addressed_cut
        t (coalgebraTensorTermOfCutList t [a, b])).2
        ⟨[a, b], hcut, rfl⟩

/--
An exact sequent-matching node graft contributes its singleton cut to the
global addressed-cut fibre of the composite proof.
-/
theorem sequentMatching_singleton_cut_mem_addressedCutFibre
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (hnode : IsNodeAddress u ([] : Address))
    (hnotroot : a ≠ ([] : Address)) :
    [a] ∈ AddressedCutFibre v
      (HQ.singleton u, HQ.singleton (PTree.remainderGo [a] [] v)) := by
  rw [mem_addressedCutFibre_iff]
  exact ⟨
    graft_address_cut_mem_coalgebraAdmissibleCuts hg hnode,
    graft_address_cut_tensor_term_eq_insert_remainder hg hnotroot⟩

/--
The same contribution, read in the singleton-address subfibre.
-/
theorem sequentMatching_address_mem_singletonAddressCutFibre
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (hnode : IsNodeAddress u ([] : Address))
    (hnotroot : a ≠ ([] : Address)) :
    a ∈ SingletonAddressCutFibre v
      (HQ.singleton u, HQ.singleton (PTree.remainderGo [a] [] v)) := by
  unfold SingletonAddressCutFibre
  exact List.mem_filterMap.2
    ⟨[a],
      sequentMatching_singleton_cut_mem_addressedCutFibre
        hg hnode hnotroot,
      by simp⟩

/--
Consequently, the singleton-address part of the global CK fibre has positive
cardinality whenever it comes from an exact sequent-matching node graft.
-/
theorem sequentMatching_singletonAddressCutFibreMultiplicity_pos
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (hnode : IsNodeAddress u ([] : Address))
    (hnotroot : a ≠ ([] : Address)) :
    0 <
      SingletonAddressCutFibreMultiplicity v
        (HQ.singleton u, HQ.singleton (PTree.remainderGo [a] [] v)) := by
  unfold SingletonAddressCutFibreMultiplicity
  exact List.length_pos_of_mem
    (sequentMatching_address_mem_singletonAddressCutFibre
      hg hnode hnotroot)

/--
An exact sequent-matching node graft gives a positive global addressed-cut
coefficient for the corresponding tensor term.
-/
theorem sequentMatching_addressedCutMultiplicity_pos
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (hnode : IsNodeAddress u ([] : Address))
    (hnotroot : a ≠ ([] : Address)) :
    0 <
      AddressedCutMultiplicity v
        (HQ.singleton u, HQ.singleton (PTree.remainderGo [a] [] v)) := by
  exact (addressedCutMultiplicity_pos_iff_exists_cut
    v (HQ.singleton u, HQ.singleton (PTree.remainderGo [a] [] v))).2
      ⟨[a],
        graft_address_cut_mem_coalgebraAdmissibleCuts hg hnode,
        graft_address_cut_tensor_term_eq_insert_remainder hg hnotroot⟩

/--
After decomposing a sequent-matching composition, filling the exposed
occurrence at the same address has occurrence multiplicity `1`.
-/
theorem sequentMatching_occurrence_reconstructMultiplicity_eq_one
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v) :
    OccurrenceReconstructMultiplicity
      u (PTree.remainderGo [a] [] v) v a = 1 := by
  simp [OccurrenceReconstructMultiplicity,
    sequentMatching_remainder_reconstructs_composite hg]

/--
The addressed singleton cut corresponding to a non-root node graft has local
coalgebra multiplicity `1`.
-/
theorem sequentMatching_singletonAddressCutMultiplicity_eq_one
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (hnode : IsNodeAddress u ([] : Address))
    (hnotroot : a ≠ ([] : Address)) :
    SingletonAddressCutMultiplicity v a
      (HQ.singleton u, HQ.singleton (PTree.remainderGo [a] [] v)) = 1 := by
  have hcut : [a] ∈ coalgebraAdmissibleCuts v :=
    graft_address_cut_mem_coalgebraAdmissibleCuts hg hnode
  have hterm :
      coalgebraTensorTermOfCutList v [a] =
        (HQ.singleton u, HQ.singleton (PTree.remainderGo [a] [] v)) :=
    graft_address_cut_tensor_term_eq_insert_remainder hg hnotroot
  simp [SingletonAddressCutMultiplicity, hcut, hterm]

/--
Local occurrence-level cut/graft duality.

For one exact sequent-matching node graft, the marked grafting occurrence and
the corresponding addressed singleton cut have the same coefficient: both are
`1`.  This is the atom that should feed the global coefficient theorem before
occurrence data is collapsed to hypersequent tensor coefficients.
-/
theorem sequentMatching_occurrence_cut_graft_duality
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (hnode : IsNodeAddress u ([] : Address))
    (hnotroot : a ≠ ([] : Address)) :
    OccurrenceReconstructMultiplicity
        u (PTree.remainderGo [a] [] v) v a =
      SingletonAddressCutMultiplicity v a
        (HQ.singleton u, HQ.singleton (PTree.remainderGo [a] [] v)) := by
  rw [sequentMatching_occurrence_reconstructMultiplicity_eq_one hg,
    sequentMatching_singletonAddressCutMultiplicity_eq_one hg hnode hnotroot]

/--
The reconstruction multiplicity induces a basis-level pairing between a
coproduct tensor term `(detached forest, remainder)` and an output proof tree.

This is the concrete coefficient-level dualization we can state before
building a completed graded dual Hopf algebra: the coproduct coefficient is
tested against the reconstruction coefficient.
-/
def ReconstructionCoefficientPairing
    (reconstructMultiplicity :
      Hypersequent -> Hypersequent -> PTree -> Nat) :
    HypersequentTensorBasis -> PTree -> Nat
| (F, R), t => reconstructMultiplicity F R t

/--
The global coefficient target for a proposed reconstruction multiplicity.

Given a function that counts reconstructions of a tensor split `(F, R)` back to
a proof tree `t`, this says that admissible cuts and reconstructions are
coefficient-dual.
-/
def CutGraftCoefficientDuality
    (reconstructMultiplicity :
      Hypersequent -> Hypersequent -> PTree -> Nat) : Prop :=
  forall (t : PTree) (F R : Hypersequent),
    cutSplitMultiplicity t (F, R) = reconstructMultiplicity F R t

/--
Canonical CK reconstruction multiplicity.

It counts admissible CK decompositions of `t` with detached forest `F` and
remainder `R`, after refining the cut fibre by graft reconstruction.
-/
noncomputable def CKGraftReconstructionMultiplicity
    (F R : Hypersequent) (t : PTree) : Nat :=
  GraftReconstructibleCutMultiplicity t (F, R)

/--
The canonical CK reconstruction multiplicity is coefficient-dual to the CK
coproduct by construction plus the general graft-reconstruction theorem.
-/
theorem ckGraftReconstructionMultiplicity_coefficient_duality :
    CutGraftCoefficientDuality CKGraftReconstructionMultiplicity := by
  intro t F R
  exact cutSplitMultiplicity_eq_graftReconstructibleCutMultiplicity t (F, R)

/--
Pairing form of coefficient duality.

This is the basis-level duality statement: pairing a tensor term with a tree
by counting reconstructions gives exactly the coefficient of that tensor term
in the CK coproduct of the tree.
-/
theorem cutGraftCoefficientDuality_iff_pairing
    (reconstructMultiplicity :
      Hypersequent -> Hypersequent -> PTree -> Nat) :
    CutGraftCoefficientDuality reconstructMultiplicity ↔
      ∀ (p : HypersequentTensorBasis) (t : PTree),
        ReconstructionCoefficientPairing reconstructMultiplicity p t =
          cutSplitMultiplicity t p := by
  constructor
  · intro h p t
    rcases p with ⟨F, R⟩
    exact (h t F R).symm
  · intro h t F R
    exact (h (F, R) t).symm

/--
If reconstruction multiplicity is coefficient-dual to CK splitting, then a
nonzero reconstruction pairing detects exactly a graft-reconstructible
admissible CK decomposition.
-/
theorem reconstructionCoefficientPairing_pos_iff_exists_ck_cut_graft_bridge
    {reconstructMultiplicity :
      Hypersequent -> Hypersequent -> PTree -> Nat}
    (hcoeff : CutGraftCoefficientDuality reconstructMultiplicity)
    (p : HypersequentTensorBasis) (t : PTree) :
    0 < ReconstructionCoefficientPairing reconstructMultiplicity p t ↔
      ∃ cut : List Address,
        CKCutGraftBridge t cut ∧
          coalgebraTensorTermOfCutList t cut = p := by
  have hpair :
      ReconstructionCoefficientPairing reconstructMultiplicity p t =
        cutSplitMultiplicity t p :=
    (cutGraftCoefficientDuality_iff_pairing reconstructMultiplicity).1
      hcoeff p t
  rw [hpair]
  exact cutSplitMultiplicity_pos_iff_exists_ck_cut_graft_bridge t p

/--
Pairing the canonical CK reconstruction multiplicity with a tree recovers the
CK coproduct coefficient.
-/
theorem ckGraftReconstructionCoefficientPairing_eq_cutSplitMultiplicity
    (p : HypersequentTensorBasis) (t : PTree) :
    ReconstructionCoefficientPairing CKGraftReconstructionMultiplicity p t =
      cutSplitMultiplicity t p := by
  exact
    (cutGraftCoefficientDuality_iff_pairing
      CKGraftReconstructionMultiplicity).1
      ckGraftReconstructionMultiplicity_coefficient_duality p t

/--
Marquee theorem target 3: the global cut/graft duality package.

The first two fields are already proved infrastructure: the carriers are
connected by the primitive-to-forest map, and root splitting has a genuine
proof-theoretic round trip.  The final field is the hard remaining theorem:
coefficient-level equality between admissible CK cuts and compatible grafting
reconstructions.
-/
structure CutGraftDualityMarqueeTarget
    (base : BaseRel)
    (reconstructMultiplicity :
      Hypersequent -> Hypersequent -> PTree -> Nat) : Prop where
  carrier_bridge : CarrierBridgeTarget
  root_roundTrip :
    ∀ {t : PTree},
      DerivableTree base t →
        ProofTheoreticCutGraftRoundTrip base t
          (HQ.singleton t, PTree.leaf t.conclusion)
  coefficient_duality : CutGraftCoefficientDuality reconstructMultiplicity
  reconstruction_pairing_detects_ck_graft_decompositions :
    ∀ (p : HypersequentTensorBasis) (t : PTree),
      0 < ReconstructionCoefficientPairing reconstructMultiplicity p t ↔
        ∃ cut : List Address,
          CKCutGraftBridge t cut ∧
            coalgebraTensorTermOfCutList t cut = p

/--
The global cut/graft marquee theorem is now reduced to the coefficient-duality
problem.  This keeps the open goal honest: carrier comparison and the basic
proof-theoretic round trip are no longer vague desiderata; the missing piece is
the reconstruction multiplicity theorem.
-/
theorem cut_graft_duality_marquee_of_coefficient_duality
    {base : BaseRel}
    {reconstructMultiplicity :
      Hypersequent -> Hypersequent -> PTree -> Nat}
    (hcoeff : CutGraftCoefficientDuality reconstructMultiplicity) :
    CutGraftDualityMarqueeTarget base reconstructMultiplicity where
  carrier_bridge :=
    primitiveToHypersequentAlgebra_is_carrier_bridge
  root_roundTrip := by
    intro t ht
    exact root_cut_graft_roundTrip ht
  coefficient_duality := hcoeff
  reconstruction_pairing_detects_ck_graft_decompositions := by
    exact
      reconstructionCoefficientPairing_pos_iff_exists_ck_cut_graft_bridge
        hcoeff

/--
The CK/reconstruction side already has a complete cut/graft duality package
for the canonical reconstruction multiplicity.

This is not yet the full two-Hopf theorem: it does not construct the
Oudom-Guin grafting Hopf algebra.  It does show that the CK coproduct is
exactly dual to counting graft-reconstructible admissible proof
decompositions.
-/
theorem ck_cut_graft_duality_marquee
    (base : BaseRel) :
    CutGraftDualityMarqueeTarget
      base CKGraftReconstructionMultiplicity := by
  exact
    cut_graft_duality_marquee_of_coefficient_duality
      ckGraftReconstructionMultiplicity_coefficient_duality

/-! ## Axioms, base consequences, and CK antipode cancellation -/

/--
A proof tree whose conclusion has the usual sequent-calculus identity/initial
shape `A, Γ ⊢ A, Θ`.

This is deliberately phrased at the conclusion level.  The current NMMS system
does not assume a global identity axiom constructor; when such a schema is
admissible, it produces derivations whose forgotten trees have
identity-shaped conclusions.
-/
def IdentityConclusionTree (t : PTree) : Prop :=
  IdentityAxiomSequent t.conclusion

/--
A one-node proof tree obtained directly from the material/base consequence
relation by `baseAx`.

These are the genuinely non-logical proof-tree leaves: they are not produced
by logical connective rules, but by the primitive material turnstile
`⊢₀`.
-/
def MaterialBaseAxiomTree (base : BaseRel) (t : PTree) : Prop :=
  ∃ Γ Θ, base Γ Θ ∧ t = PTree.leaf (Γ ∣∼ Θ)

/-- A material/base consequence gives a derivable proof-tree leaf by `baseAx`. -/
theorem materialBaseAxiomTree_derivable
    {base : BaseRel} {t : PTree}
    (ht : MaterialBaseAxiomTree base t) :
    DerivableTree base t := by
  rcases ht with ⟨Γ, Θ, hbase, rfl⟩
  exact derivableTree_of_derivation (NMMS.baseAx hbase)

/-- Direct constructor form of `materialBaseAxiomTree_derivable`. -/
theorem baseAx_derivable_tree
    {base : BaseRel} {Γ Θ : Multiset MyProp}
    (hbase : MaterialEntails base Γ Θ) :
    DerivableTree base (PTree.leaf (Γ ∣∼ Θ)) := by
  exact materialBaseAxiomTree_derivable
    ⟨Γ, Θ, hbase, rfl⟩

/--
If the unrestricted logical identity schema is admissible, it supplies
derivable proof trees with identity-shaped conclusions.

This is the proof-theoretic axiom idea in tree form: identity is a property of
proof-tree conclusions, not automatically the Hopf unit.
-/
theorem logicalIdentityAxiom_has_derivable_identity_tree
    {base : BaseRel}
    (hId : LogicalIdentityAxiomAdmissible base)
    (A : MyProp.{0}) (Γ Θ : Multiset MyProp.{0}) :
    ∃ t : PTree,
      DerivableTree base t ∧ IdentityConclusionTree t := by
  rcases hId A Γ Θ with ⟨d⟩
  refine ⟨NMMS.toTree d, derivableTree_of_derivation d, ?_⟩
  exact ⟨A, Γ, Θ, toTree_conclusion d⟩

section AxiomAntipodeDiagnostic

variable (K : Type) [CommRing K]
variable
  [LeftDistribClass
    (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
variable
  [RightDistribClass
    (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]

/--
Every single proof-tree generator, including an identity axiom tree or a
material `baseAx` leaf, lies in the augmentation ideal of the CK forest Hopf
algebra.
-/
theorem ck_counit_kills_single_tree
    (t : PTree) :
    proofTreeHopfCounit K (treeMonomial K t) = 0 := by
  exact proofTreeHopf_counit_tree K t

/--
Over a nontrivial coefficient ring, no single proof-tree generator is the CK
Hopf unit.  The unit is the empty hypersequent/empty forest.
-/
theorem ck_single_tree_ne_hopf_unit
    [Nontrivial K] (t : PTree) :
    treeMonomial K t ≠ (1 : ProofTreeHopfCarrier K) := by
  intro h
  have hzero :
      proofTreeHopfCounit K (treeMonomial K t) = 0 :=
    ck_counit_kills_single_tree K t
  rw [h] at hzero
  rw [proofTreeHopf_counit_one K] at hzero
  exact one_ne_zero hzero

/--
Left antipode convolution kills every single proof-tree generator because the
Hopf antipode law is `m (S ⊗ id) Δ = η ε`, and `ε` vanishes on nonempty
proof-tree forests.
-/
theorem ck_left_antipode_cancellation_kills_single_tree
    (t : PTree) :
    (LinearMap.mul' K (ProofTreeHopfCarrier K) ∘ₗ
        LinearMap.lTensor (ProofTreeHopfCarrier K)
          (proofTreeHopfAntipode K) ∘ₗ
          proofTreeHopfComul K) (treeMonomial K t) = 0 := by
  exact proofTreeHopf_left_antipode_cancellation_tree_eq_zero K t

/--
Right antipode convolution also kills every single proof-tree generator.
-/
theorem ck_right_antipode_cancellation_kills_single_tree
    (t : PTree) :
    (LinearMap.mul' K (ProofTreeHopfCarrier K) ∘ₗ
        LinearMap.rTensor (ProofTreeHopfCarrier K)
          (proofTreeHopfAntipode K) ∘ₗ
          proofTreeHopfComul K) (treeMonomial K t) = 0 := by
  exact proofTreeHopf_right_antipode_cancellation_tree_eq_zero K t

/--
Compact diagnostic packet for the current CK forest Hopf algebra.

The theorem is intentionally about a single tree generator.  A logical
identity axiom tree or a material `baseAx` leaf can instantiate it, but neither
is thereby identified with the Hopf unit.
-/
structure CKAxiomAntipodeDiagnostic (t : PTree) : Prop where
  counit_zero :
    proofTreeHopfCounit K (treeMonomial K t) = 0
  not_hopf_unit :
    treeMonomial K t ≠ (1 : ProofTreeHopfCarrier K)
  left_antipode_cancellation_zero :
    (LinearMap.mul' K (ProofTreeHopfCarrier K) ∘ₗ
        LinearMap.lTensor (ProofTreeHopfCarrier K)
          (proofTreeHopfAntipode K) ∘ₗ
          proofTreeHopfComul K) (treeMonomial K t) = 0
  right_antipode_cancellation_zero :
    (LinearMap.mul' K (ProofTreeHopfCarrier K) ∘ₗ
        LinearMap.rTensor (ProofTreeHopfCarrier K)
          (proofTreeHopfAntipode K) ∘ₗ
          proofTreeHopfComul K) (treeMonomial K t) = 0

/-- The CK axiom/antipode diagnostic applies to every proof-tree generator. -/
theorem ck_axiom_antipode_diagnostic
    [Nontrivial K] (t : PTree) :
    CKAxiomAntipodeDiagnostic K t where
  counit_zero :=
    ck_counit_kills_single_tree K t
  not_hopf_unit :=
    ck_single_tree_ne_hopf_unit K t
  left_antipode_cancellation_zero :=
    ck_left_antipode_cancellation_kills_single_tree K t
  right_antipode_cancellation_zero :=
    ck_right_antipode_cancellation_kills_single_tree K t

/--
Material `baseAx` leaves instantiate the CK diagnostic: primitive non-logical
consequences are proof content, not the empty forest/unit.
-/
theorem materialBaseAxiomTree_ck_axiom_antipode_diagnostic
    [Nontrivial K]
    {base : BaseRel} {t : PTree}
    (_ht : MaterialBaseAxiomTree base t) :
    CKAxiomAntipodeDiagnostic K t :=
  ck_axiom_antipode_diagnostic K t

/--
Identity-conclusion proof trees instantiate the same CK diagnostic.  Thus the
current CK antipode cancellation should not be read as reducing an axiom
sequent to a categorical identity; it reduces a nonempty generator through the
augmentation.
-/
theorem identityConclusionTree_ck_axiom_antipode_diagnostic
    [Nontrivial K]
    {t : PTree}
    (_ht : IdentityConclusionTree t) :
    CKAxiomAntipodeDiagnostic K t :=
  ck_axiom_antipode_diagnostic K t

end AxiomAntipodeDiagnostic

/-! ## Actual derivations and the OG primitive coproduct -/

/--
Canonical OG comultiplication on the stable UEA has the primitive formula on
the generator associated to a genuinely derivable proof tree.

This is the proof-theoretic version of the canonical UEA result: the input is
not merely an ambient decorated tree, but a member of the stable quotient
generated from `DerivableTree base`.
-/
theorem canonicalOGPrimitiveComul_derivableStableTreeGen
    {base : BaseRel} {t : PTree}
    (ht : DerivableTree base t) :
    QuotientConnected.CoproductSupport.stableUEA_OGPrimitiveCanonicalComulAlgHom
        (QuotientConnected.CoproductSupport.derivableStableUEAIota
          base
          (QuotientConnected.CoproductSupport.derivableStableTreeGen ht)) =
      TensorProduct.tmul Int
          (QuotientConnected.CoproductSupport.derivableStableUEAIota
            base
            (QuotientConnected.CoproductSupport.derivableStableTreeGen ht)) 1 +
        TensorProduct.tmul Int 1
          (QuotientConnected.CoproductSupport.derivableStableUEAIota
            base
            (QuotientConnected.CoproductSupport.derivableStableTreeGen ht)) := by
  simpa using
    QuotientConnected.CoproductSupport.stableUEA_OGPrimitiveCanonicalComulAlgHom_treeGen_formula
      t

/--
Canonical OG comultiplication, stated directly for the tree obtained from an
actual `NMMS` derivation.

This is the main safeguard against drifting into a Hopf algebra of arbitrary
decorated trees: the generator here is explicitly `NMMS.toTree d`.
-/
theorem canonicalOGPrimitiveComul_of_NMMS_derivation
    {base : BaseRel} {s : MultiSequent}
    (d : NMMS.{0} base s) :
    QuotientConnected.CoproductSupport.stableUEA_OGPrimitiveCanonicalComulAlgHom
        (stableUEA_treeGen (NMMS.toTree d)) =
      TensorProduct.tmul Int
          (stableUEA_treeGen (NMMS.toTree d)) 1 +
        TensorProduct.tmul Int 1 (stableUEA_treeGen (NMMS.toTree d)) := by
  exact
    QuotientConnected.CoproductSupport.stableUEA_OGPrimitiveCanonicalComulAlgHom_treeGen_formula
      (NMMS.toTree d)

/--
The same statement, but through the proof-theoretic stable carrier generated
by the derivability witness of an actual derivation.
-/
theorem canonicalOGPrimitiveComul_derivableStableTreeGen_of_NMMS_derivation
    {base : BaseRel} {s : MultiSequent}
    (d : NMMS.{0} base s) :
    QuotientConnected.CoproductSupport.stableUEA_OGPrimitiveCanonicalComulAlgHom
        (QuotientConnected.CoproductSupport.derivableStableUEAIota
          base
          (QuotientConnected.CoproductSupport.derivableStableTreeGen
            (derivableTree_of_derivation d))) =
      TensorProduct.tmul Int
          (QuotientConnected.CoproductSupport.derivableStableUEAIota
            base
            (QuotientConnected.CoproductSupport.derivableStableTreeGen
              (derivableTree_of_derivation d))) 1 +
        TensorProduct.tmul Int 1
          (QuotientConnected.CoproductSupport.derivableStableUEAIota
            base
            (QuotientConnected.CoproductSupport.derivableStableTreeGen
              (derivableTree_of_derivation d))) := by
  exact canonicalOGPrimitiveComul_derivableStableTreeGen
    (derivableTree_of_derivation d)

/--
Primitive material consequences supplied by the base relation also instantiate
the canonical OG primitive formula.

Thus `baseAx` leaves are not treated as anonymous tree syntax: they are the
non-logical atoms of the proof-theoretic carrier.
-/
theorem canonicalOGPrimitiveComul_material_baseAx_leaf
    {base : BaseRel} {Gamma Theta : Multiset MyProp}
    (hbase : MaterialEntails base Gamma Theta) :
    QuotientConnected.CoproductSupport.stableUEA_OGPrimitiveCanonicalComulAlgHom
        (stableUEA_treeGen (PTree.leaf (MultiSequent.mk Gamma Theta))) =
      TensorProduct.tmul Int
          (stableUEA_treeGen (PTree.leaf (MultiSequent.mk Gamma Theta))) 1 +
        TensorProduct.tmul Int 1
          (stableUEA_treeGen (PTree.leaf (MultiSequent.mk Gamma Theta))) := by
  simpa using
    canonicalOGPrimitiveComul_of_NMMS_derivation
      (NMMS.baseAx hbase)

/--
Material `baseAx` leaves also satisfy the primitive formula as elements of the
derivable stable quotient over the chosen base relation.
-/
theorem canonicalOGPrimitiveComul_derivable_material_baseAx
    {base : BaseRel} {Gamma Theta : Multiset MyProp}
    (hbase : MaterialEntails base Gamma Theta) :
    QuotientConnected.CoproductSupport.stableUEA_OGPrimitiveCanonicalComulAlgHom
        (QuotientConnected.CoproductSupport.derivableStableUEAIota
          base
          (QuotientConnected.CoproductSupport.derivableStableTreeGen
            (baseAx_derivable_tree hbase))) =
      TensorProduct.tmul Int
          (QuotientConnected.CoproductSupport.derivableStableUEAIota
            base
            (QuotientConnected.CoproductSupport.derivableStableTreeGen
              (baseAx_derivable_tree hbase))) 1 +
        TensorProduct.tmul Int 1
          (QuotientConnected.CoproductSupport.derivableStableUEAIota
            base
            (QuotientConnected.CoproductSupport.derivableStableTreeGen
              (baseAx_derivable_tree hbase))) := by
  exact canonicalOGPrimitiveComul_derivableStableTreeGen
    (baseAx_derivable_tree hbase)

/--
Specification for the first proof-theoretic OG algebra-side coproduct theorem.

The algebra map is required to be the Oudom-Guin primitive coproduct on the
stable Lie insertion `ι`, and we record the two proof-theoretic consequences
that matter here: actual `NMMS` derivations and material `baseAx` leaves have
the expected primitive tensor formula.
-/
def CanonicalOGDerivableCoproductSpec
    (base : BaseRel)
    (Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor) : Prop :=
  (∀ q : PreLieDifferenceStableQuotient,
      Phi (preLieDifferenceStableQuotientUEA_ι q) =
        QuotientConnected.CoproductSupport.OGPrimitiveComul.comul q) ∧
    (∀ {t : PTree} (ht : DerivableTree base t),
      Phi
          (QuotientConnected.CoproductSupport.derivableStableUEAIota
            base
            (QuotientConnected.CoproductSupport.derivableStableTreeGen ht)) =
        TensorProduct.tmul ℤ
            (QuotientConnected.CoproductSupport.derivableStableUEAIota
              base
              (QuotientConnected.CoproductSupport.derivableStableTreeGen ht)) 1 +
          TensorProduct.tmul ℤ 1
            (QuotientConnected.CoproductSupport.derivableStableUEAIota
              base
              (QuotientConnected.CoproductSupport.derivableStableTreeGen ht))) ∧
    (∀ {s : MultiSequent} (d : NMMS.{0} base s),
      Phi (stableUEA_treeGen (NMMS.toTree d)) =
        TensorProduct.tmul ℤ (stableUEA_treeGen (NMMS.toTree d)) 1 +
          TensorProduct.tmul ℤ 1 (stableUEA_treeGen (NMMS.toTree d))) ∧
    (∀ {Gamma Theta : Multiset MyProp}
        (hbase : MaterialEntails base Gamma Theta),
      Phi
          (QuotientConnected.CoproductSupport.derivableStableUEAIota
            base
            (QuotientConnected.CoproductSupport.derivableStableTreeGen
              (baseAx_derivable_tree hbase))) =
        TensorProduct.tmul ℤ
            (QuotientConnected.CoproductSupport.derivableStableUEAIota
              base
              (QuotientConnected.CoproductSupport.derivableStableTreeGen
                (baseAx_derivable_tree hbase))) 1 +
          TensorProduct.tmul ℤ 1
            (QuotientConnected.CoproductSupport.derivableStableUEAIota
              base
              (QuotientConnected.CoproductSupport.derivableStableTreeGen
                (baseAx_derivable_tree hbase))))

/--
First big algebra-side theorem.

For every material base relation, there is a unique UEA algebra map realizing
the Oudom-Guin primitive coproduct, and this unique map has the expected
primitive formula on actual NMMS derivations and primitive material
consequences.

This is not merely a Hopf algebra of decorated rooted trees: the theorem names
the derivable sector and the material `baseAx` rule in its statement.
-/
theorem canonicalOGDerivableCoproduct_existsUnique
    (base : BaseRel) :
    ∃! Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor,
      CanonicalOGDerivableCoproductSpec base Phi := by
  refine
    ⟨QuotientConnected.CoproductSupport.stableUEA_OGPrimitiveCanonicalComulAlgHom,
      ?_, ?_⟩
  · refine ⟨?_, ?_, ?_, ?_⟩
    · exact
        QuotientConnected.CoproductSupport.stableUEA_OGPrimitiveCanonicalComulAlgHom_ι_formula
    · intro t ht
      exact canonicalOGPrimitiveComul_derivableStableTreeGen ht
    · intro s d
      exact canonicalOGPrimitiveComul_of_NMMS_derivation d
    · intro Gamma Theta hbase
      exact canonicalOGPrimitiveComul_derivable_material_baseAx hbase
  · intro Phi hPhi
    exact
      QuotientConnected.CoproductSupport.stableUEA_OGPrimitiveCanonicalComulAlgHom_unique
        Phi hPhi.1

/-! ### API for the proof-theoretic OG coproduct theorem -/

/--
The canonical algebra map supplied by the Oudom-Guin primitive coproduct.

It is independent of a chosen material base relation, but the theorems below
explain how it acts on the derivable sector over each base.
-/
abbrev canonicalOGDerivableCoproduct :
    preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor :=
  QuotientConnected.CoproductSupport.stableUEA_OGPrimitiveCanonicalComulAlgHom

/-- Formula predicate for a single proof-tree generator. -/
def CanonicalOGCoproductOnTree
    (Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor)
    (t : PTree) : Prop :=
  Phi (stableUEA_treeGen t) =
    TensorProduct.tmul ℤ (stableUEA_treeGen t) 1 +
      TensorProduct.tmul ℤ 1 (stableUEA_treeGen t)

/-- Formula predicate for every tree in a forest. -/
def CanonicalOGCoproductOnForest
    (Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor)
    (f : Forest) : Prop :=
  ∀ t : PTree, t ∈ f → CanonicalOGCoproductOnTree Phi t

/-- Formula predicate for every proof-tree component of a hypersequent. -/
def CanonicalOGCoproductOnHypersequent
    (Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor)
    (G : Hypersequent) : Prop :=
  ∀ t : PTree, t ∈ G → CanonicalOGCoproductOnTree Phi t

/-- The canonical map satisfies the derivable coproduct specification. -/
theorem canonicalOGDerivableCoproduct_spec
    (base : BaseRel) :
    CanonicalOGDerivableCoproductSpec
      base canonicalOGDerivableCoproduct := by
  refine ⟨?_, ?_, ?_, ?_⟩
  · exact
      QuotientConnected.CoproductSupport.stableUEA_OGPrimitiveCanonicalComulAlgHom_ι_formula
  · intro t ht
    exact canonicalOGPrimitiveComul_derivableStableTreeGen ht
  · intro s d
    exact canonicalOGPrimitiveComul_of_NMMS_derivation d
  · intro Gamma Theta hbase
    exact canonicalOGPrimitiveComul_derivable_material_baseAx hbase

/-- The canonical map exists as a derivable OG coproduct. -/
theorem canonicalOGDerivableCoproduct_exists
    (base : BaseRel) :
    ∃ Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor,
      CanonicalOGDerivableCoproductSpec base Phi := by
  exact ⟨canonicalOGDerivableCoproduct,
    canonicalOGDerivableCoproduct_spec base⟩

/--
Uniqueness in a direct form: any algebra map satisfying the derivable
specification is the canonical OG derivable coproduct.
-/
theorem canonicalOGDerivableCoproduct_eq_of_spec
    {base : BaseRel}
    {Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor}
    (hPhi : CanonicalOGDerivableCoproductSpec base Phi) :
    Phi = canonicalOGDerivableCoproduct := by
  exact
    QuotientConnected.CoproductSupport.stableUEA_OGPrimitiveCanonicalComulAlgHom_unique
      Phi hPhi.1

/--
Agreement with the OG primitive coproduct on the Lie insertion `ι` already
determines the whole derivable coproduct.
-/
theorem canonicalOGDerivableCoproduct_eq_of_iota_formula
    (Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor)
    (hPhi :
      ∀ q : PreLieDifferenceStableQuotient,
        Phi (preLieDifferenceStableQuotientUEA_ι q) =
          QuotientConnected.CoproductSupport.OGPrimitiveComul.comul q) :
    Phi = canonicalOGDerivableCoproduct := by
  exact
    QuotientConnected.CoproductSupport.stableUEA_OGPrimitiveCanonicalComulAlgHom_unique
      Phi hPhi

/--
The derivable-sector specification is equivalent to the generator-level
Oudom-Guin primitive formula on `ι`.
-/
theorem canonicalOGDerivableCoproductSpec_iff_iota_formula
    (base : BaseRel)
    (Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor) :
    CanonicalOGDerivableCoproductSpec base Phi ↔
      ∀ q : PreLieDifferenceStableQuotient,
        Phi (preLieDifferenceStableQuotientUEA_ι q) =
          QuotientConnected.CoproductSupport.OGPrimitiveComul.comul q := by
  constructor
  · intro hPhi
    exact hPhi.1
  · intro hPhi
    have hEq :
        Phi = canonicalOGDerivableCoproduct :=
      canonicalOGDerivableCoproduct_eq_of_iota_formula Phi hPhi
    rw [hEq]
    exact canonicalOGDerivableCoproduct_spec base

/-! ### NMMS derivation targets -/

/--
The proof-theoretic part of the OG coproduct specification.

This deliberately talks only about actual derivations of the nonmonotonic
material calculus.  The target generator is not an arbitrary decorated tree:
it is `stableUEA_treeGen (NMMS.toTree d)` for some genuine derivation `d`.
-/
def NMMSTargetCoproductSpec
    (base : BaseRel)
    (Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor) :
    Prop :=
  ∀ {s : MultiSequent} (d : NMMS.{0} base s),
    Phi (stableUEA_treeGen (NMMS.toTree d)) =
      TensorProduct.tmul ℤ (stableUEA_treeGen (NMMS.toTree d)) 1 +
        TensorProduct.tmul ℤ 1 (stableUEA_treeGen (NMMS.toTree d))

/-- The derivable OG coproduct specification restricts to actual NMMS targets. -/
theorem CanonicalOGDerivableCoproductSpec.to_nmmsTargetCoproductSpec
    {base : BaseRel}
    {Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor}
    (hPhi : CanonicalOGDerivableCoproductSpec base Phi) :
    NMMSTargetCoproductSpec base Phi := by
  intro s d
  exact hPhi.2.2.1 d

/-- The canonical OG derivable coproduct satisfies the NMMS-target formula. -/
theorem canonicalOGDerivableCoproduct_nmmsTargetCoproductSpec
    (base : BaseRel) :
    NMMSTargetCoproductSpec base canonicalOGDerivableCoproduct :=
  (canonicalOGDerivableCoproduct_spec base).to_nmmsTargetCoproductSpec

/--
Pointwise uniqueness on actual derivation targets.

An NMMS-target specification alone does not determine the whole UEA algebra
map; it determines the part of the map visible on genuine derivations.  This
is the proof-theoretic uniqueness statement we can honestly use without
silently assuming every ambient tree is derivable.
-/
theorem NMMSTargetCoproductSpec.eq_canonical_on_derivation
    {base : BaseRel}
    {Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor}
    (hPhi : NMMSTargetCoproductSpec base Phi)
    {s : MultiSequent}
    (d : NMMS.{0} base s) :
    Phi (stableUEA_treeGen (NMMS.toTree d)) =
      canonicalOGDerivableCoproduct
        (stableUEA_treeGen (NMMS.toTree d)) := by
  calc
    Phi (stableUEA_treeGen (NMMS.toTree d))
        = TensorProduct.tmul ℤ (stableUEA_treeGen (NMMS.toTree d)) 1 +
            TensorProduct.tmul ℤ 1 (stableUEA_treeGen (NMMS.toTree d)) := hPhi d
    _ = canonicalOGDerivableCoproduct
          (stableUEA_treeGen (NMMS.toTree d)) := by
          exact (canonicalOGPrimitiveComul_of_NMMS_derivation d).symm

/--
Two algebra maps satisfying the NMMS-target specification agree on every
actual derivation generator.
-/
theorem NMMSTargetCoproductSpec.eq_on_derivation
    {base : BaseRel}
    {Phi Psi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor}
    (hPhi : NMMSTargetCoproductSpec base Phi)
    (hPsi : NMMSTargetCoproductSpec base Psi)
    {s : MultiSequent}
    (d : NMMS.{0} base s) :
    Phi (stableUEA_treeGen (NMMS.toTree d)) =
      Psi (stableUEA_treeGen (NMMS.toTree d)) := by
  calc
    Phi (stableUEA_treeGen (NMMS.toTree d))
        = canonicalOGDerivableCoproduct
            (stableUEA_treeGen (NMMS.toTree d)) :=
          hPhi.eq_canonical_on_derivation d
    _ = Psi (stableUEA_treeGen (NMMS.toTree d)) := by
          exact (hPsi.eq_canonical_on_derivation d).symm

/--
Material `baseAx` specialization of the NMMS-target formula.

The nonlogical material consequence relation is therefore not merely present
in the background: every primitive material inference supplied by `base`
appears as one of the actual derivation generators controlled by the OG
coproduct formula.
-/
theorem NMMSTargetCoproductSpec.on_material_baseAx_leaf
    {base : BaseRel}
    {Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor}
    (hPhi : NMMSTargetCoproductSpec base Phi)
    {Γ Θ : Multiset MyProp}
    (hbase : MaterialEntails base Γ Θ) :
    Phi (stableUEA_treeGen (PTree.leaf (MultiSequent.mk Γ Θ))) =
      TensorProduct.tmul ℤ
          (stableUEA_treeGen (PTree.leaf (MultiSequent.mk Γ Θ))) 1 +
        TensorProduct.tmul ℤ 1
          (stableUEA_treeGen (PTree.leaf (MultiSequent.mk Γ Θ))) := by
  simpa [NMMS.toTree] using hPhi (NMMS.baseAx hbase)

/--
First NMMS-target main theorem.

For each material base relation there is a canonical OG algebra map satisfying
the primitive tensor formula on all genuine `NMMS` derivations, and it is
unique on those actual derivation generators.
-/
theorem nmmsTargetCoproduct_existsUniqueOnDerivations
    (base : BaseRel) :
    ∃ Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor,
      NMMSTargetCoproductSpec base Phi ∧
        ∀ Psi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor,
          NMMSTargetCoproductSpec base Psi →
            ∀ {s : MultiSequent} (d : NMMS.{0} base s),
              Psi (stableUEA_treeGen (NMMS.toTree d)) =
                Phi (stableUEA_treeGen (NMMS.toTree d)) := by
  refine
    ⟨canonicalOGDerivableCoproduct,
      canonicalOGDerivableCoproduct_nmmsTargetCoproductSpec base, ?_⟩
  intro Psi hPsi s d
  exact hPsi.eq_canonical_on_derivation d

/--
Any full OG Hopf target satisfies the NMMS-target coproduct specification.
-/
theorem OudomGuinUEAHopfAlgebraTarget.nmmsTargetCoproductSpec
    (H : QuotientConnected.CoproductSupport.OudomGuinUEAHopfAlgebraTarget)
    (base : BaseRel) :
    NMMSTargetCoproductSpec base H.DeltaOGAlgHom := by
  intro s d
  calc
    H.DeltaOGAlgHom (stableUEA_treeGen (NMMS.toTree d))
        = H.carrier.DeltaOG (stableUEA_treeGen (NMMS.toTree d)) := by
          simp
    _ = TensorProduct.tmul ℤ (stableUEA_treeGen (NMMS.toTree d)) 1 +
          TensorProduct.tmul ℤ 1 (stableUEA_treeGen (NMMS.toTree d)) := by
          exact
            QuotientConnected.CoproductSupport.OudomGuinUEAHopfAlgebraTarget.primitive_treeGen
              H (NMMS.toTree d)

/--
Any full Oudom-Guin Hopf target has the canonical OG primitive coproduct.

This is the algebra-side rigidity theorem we need for the proof-theoretic
story: once the coproduct is an algebra map and is primitive on the inserted
stable proof-tree quotient, there is no second OG coproduct hiding in the
background.  The target's coproduct is the canonical map used by the
derivable-sector theorems below.
-/
theorem OudomGuinUEAHopfAlgebraTarget.DeltaOGAlgHom_eq_canonicalOGDerivableCoproduct
    (H : QuotientConnected.CoproductSupport.OudomGuinUEAHopfAlgebraTarget) :
    H.DeltaOGAlgHom = canonicalOGDerivableCoproduct := by
  apply canonicalOGDerivableCoproduct_eq_of_iota_formula
  intro q
  calc
    H.DeltaOGAlgHom (preLieDifferenceStableQuotientUEA_ι q)
        = H.carrier.DeltaOG (preLieDifferenceStableQuotientUEA_ι q) := by
          simp
    _ = TensorProduct.tmul ℤ (preLieDifferenceStableQuotientUEA_ι q) 1 +
          TensorProduct.tmul ℤ 1 (preLieDifferenceStableQuotientUEA_ι q) := by
          simpa [QuotientConnected.CoproductSupport.stableUEACanonicalIota] using
            H.primitive_stableQuotient q
    _ = QuotientConnected.CoproductSupport.OGPrimitiveComul.comul q := by
          exact (OGPrimitiveComul_comul_eq_primitive_formula q).symm

/--
Linear-map form of the same rigidity theorem.

This is often the more useful form when comparing with the CK coproduct,
because the CK side is usually expressed as a linear map into a tensor
carrier rather than as an algebra homomorphism.
-/
theorem OudomGuinUEAHopfAlgebraTarget.DeltaOG_eq_canonicalOGDerivableCoproduct
    (H : QuotientConnected.CoproductSupport.OudomGuinUEAHopfAlgebraTarget) :
    H.carrier.DeltaOG = canonicalOGDerivableCoproduct.toLinearMap := by
  have hAlg :=
    OudomGuinUEAHopfAlgebraTarget.DeltaOGAlgHom_eq_canonicalOGDerivableCoproduct
      H
  ext a
  have hApply := congrArg
    (fun F : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor => F a)
    hAlg
  simpa using hApply

/--
Witness form of OG coproduct rigidity.

The concrete grafting Hopf witness introduced earlier therefore cannot
choose a different coproduct from the canonical primitive OG coproduct.
-/
theorem OudomGuinGraftingHopfWitness.DeltaOGAlgHom_eq_canonicalOGDerivableCoproduct
    (W : OudomGuinGraftingHopfWitness) :
    W.target.DeltaOGAlgHom = canonicalOGDerivableCoproduct :=
  OudomGuinUEAHopfAlgebraTarget.DeltaOGAlgHom_eq_canonicalOGDerivableCoproduct
    W.target

/--
Witness form at the underlying linear-map level.
-/
theorem OudomGuinGraftingHopfWitness.DeltaOG_eq_canonicalOGDerivableCoproduct
    (W : OudomGuinGraftingHopfWitness) :
    W.target.carrier.DeltaOG =
      canonicalOGDerivableCoproduct.toLinearMap :=
  OudomGuinUEAHopfAlgebraTarget.DeltaOG_eq_canonicalOGDerivableCoproduct
    W.target

/--
Actual-derivation form of OG coproduct rigidity.

For every derivation in the nonmonotonic material calculus, the full OG Hopf
target and the canonical derivable coproduct agree on the UEA generator of
the proof tree extracted by `NMMS.toTree`.
-/
theorem OudomGuinUEAHopfAlgebraTarget.DeltaOG_eq_canonical_on_NMMS_derivation
    (H : QuotientConnected.CoproductSupport.OudomGuinUEAHopfAlgebraTarget)
    {base : BaseRel} {s : MultiSequent}
    (d : NMMS.{0} base s) :
    H.carrier.DeltaOG (stableUEA_treeGen (NMMS.toTree d)) =
      canonicalOGDerivableCoproduct
        (stableUEA_treeGen (NMMS.toTree d)) := by
  have hLin :=
    OudomGuinUEAHopfAlgebraTarget.DeltaOG_eq_canonicalOGDerivableCoproduct
      H
  have hApply := congrArg
    (fun F : preLieDifferenceStableQuotientUEA →ₗ[ℤ] stableUEATensor =>
      F (stableUEA_treeGen (NMMS.toTree d)))
    hLin
  simpa using hApply

/--
Material-base-axiom form of OG coproduct rigidity.

This is the point where the primitive material consequence relation enters
the OG algebra side: a nonlogical `baseAx` proof leaf is still governed by
the same canonical primitive coproduct once it is a genuine NMMS derivation.
-/
theorem OudomGuinUEAHopfAlgebraTarget.DeltaOG_eq_canonical_on_material_baseAx
    (H : QuotientConnected.CoproductSupport.OudomGuinUEAHopfAlgebraTarget)
    {base : BaseRel} {Γ Θ : Multiset MyProp}
    (hbase : MaterialEntails base Γ Θ) :
    H.carrier.DeltaOG
        (stableUEA_treeGen (NMMS.toTree (NMMS.baseAx hbase))) =
      canonicalOGDerivableCoproduct
        (stableUEA_treeGen (NMMS.toTree (NMMS.baseAx hbase))) := by
  exact
    OudomGuinUEAHopfAlgebraTarget.DeltaOG_eq_canonical_on_NMMS_derivation
      H (NMMS.baseAx hbase)

/--
Concrete witness form on actual derivations.
-/
theorem OudomGuinGraftingHopfWitness.DeltaOG_eq_canonical_on_NMMS_derivation
    (W : OudomGuinGraftingHopfWitness)
    {base : BaseRel} {s : MultiSequent}
    (d : NMMS.{0} base s) :
    W.target.carrier.DeltaOG (stableUEA_treeGen (NMMS.toTree d)) =
      canonicalOGDerivableCoproduct
        (stableUEA_treeGen (NMMS.toTree d)) :=
  OudomGuinUEAHopfAlgebraTarget.DeltaOG_eq_canonical_on_NMMS_derivation
    W.target d

/-- Projection: the specification gives the formula on the Lie insertion. -/
theorem CanonicalOGDerivableCoproductSpec.on_iota
    {base : BaseRel}
    {Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor}
    (hPhi : CanonicalOGDerivableCoproductSpec base Phi)
    (q : PreLieDifferenceStableQuotient) :
    Phi (preLieDifferenceStableQuotientUEA_ι q) =
      QuotientConnected.CoproductSupport.OGPrimitiveComul.comul q :=
  hPhi.1 q

/-- Projection: the specification gives the formula on derivable generators. -/
theorem CanonicalOGDerivableCoproductSpec.on_derivableStableTreeGen
    {base : BaseRel}
    {Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor}
    (hPhi : CanonicalOGDerivableCoproductSpec base Phi)
    {t : PTree}
    (ht : DerivableTree base t) :
    Phi
        (QuotientConnected.CoproductSupport.derivableStableUEAIota
          base
          (QuotientConnected.CoproductSupport.derivableStableTreeGen ht)) =
      TensorProduct.tmul ℤ
          (QuotientConnected.CoproductSupport.derivableStableUEAIota
            base
            (QuotientConnected.CoproductSupport.derivableStableTreeGen ht)) 1 +
        TensorProduct.tmul ℤ 1
          (QuotientConnected.CoproductSupport.derivableStableUEAIota
            base
            (QuotientConnected.CoproductSupport.derivableStableTreeGen ht)) :=
  hPhi.2.1 ht

/--
Projection: a derivable proof tree, viewed as an ordinary UEA tree generator,
has the primitive tensor formula.
-/
theorem CanonicalOGDerivableCoproductSpec.on_tree_of_derivable
    {base : BaseRel}
    {Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor}
    (hPhi : CanonicalOGDerivableCoproductSpec base Phi)
    {t : PTree}
    (ht : DerivableTree base t) :
    CanonicalOGCoproductOnTree Phi t := by
  simpa [CanonicalOGCoproductOnTree] using
    hPhi.on_derivableStableTreeGen ht

/-- Projection: actual NMMS derivations satisfy the primitive tensor formula. -/
theorem CanonicalOGDerivableCoproductSpec.on_NMMS_derivation
    {base : BaseRel}
    {Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor}
    (hPhi : CanonicalOGDerivableCoproductSpec base Phi)
    {s : MultiSequent}
    (d : NMMS.{0} base s) :
    CanonicalOGCoproductOnTree Phi (NMMS.toTree d) := by
  simpa [CanonicalOGCoproductOnTree] using hPhi.2.2.1 d

/--
Projection: primitive material consequences supplied by `baseAx` satisfy the
ordinary tree-generator formula.
-/
theorem CanonicalOGDerivableCoproductSpec.on_material_baseAx_tree
    {base : BaseRel}
    {Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor}
    (hPhi : CanonicalOGDerivableCoproductSpec base Phi)
    {Gamma Theta : Multiset MyProp}
    (hbase : MaterialEntails base Gamma Theta) :
    CanonicalOGCoproductOnTree Phi
      (PTree.leaf (MultiSequent.mk Gamma Theta)) := by
  simpa [CanonicalOGCoproductOnTree] using
    hPhi.2.2.1 (NMMS.baseAx hbase)

/--
Projection: primitive material consequences supplied by `baseAx` satisfy the
formula inside the proof-theoretic stable quotient.
-/
theorem CanonicalOGDerivableCoproductSpec.on_derivable_material_baseAx
    {base : BaseRel}
    {Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor}
    (hPhi : CanonicalOGDerivableCoproductSpec base Phi)
    {Gamma Theta : Multiset MyProp}
    (hbase : MaterialEntails base Gamma Theta) :
    Phi
        (QuotientConnected.CoproductSupport.derivableStableUEAIota
          base
          (QuotientConnected.CoproductSupport.derivableStableTreeGen
            (baseAx_derivable_tree hbase))) =
      TensorProduct.tmul ℤ
          (QuotientConnected.CoproductSupport.derivableStableUEAIota
            base
            (QuotientConnected.CoproductSupport.derivableStableTreeGen
              (baseAx_derivable_tree hbase))) 1 +
        TensorProduct.tmul ℤ 1
          (QuotientConnected.CoproductSupport.derivableStableUEAIota
            base
            (QuotientConnected.CoproductSupport.derivableStableTreeGen
              (baseAx_derivable_tree hbase))) :=
  hPhi.2.2.2 hbase

/-- Empty forests vacuously satisfy the componentwise primitive formula. -/
theorem CanonicalOGCoproductOnForest.nil
    (Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor) :
    CanonicalOGCoproductOnForest Phi [] := by
  intro t ht
  simp at ht

/-- Cons closure for the forest-level primitive formula. -/
theorem CanonicalOGCoproductOnForest.cons
    {Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor}
    {t : PTree} {f : Forest}
    (ht : CanonicalOGCoproductOnTree Phi t)
    (hf : CanonicalOGCoproductOnForest Phi f) :
    CanonicalOGCoproductOnForest Phi (t :: f) := by
  intro u hu
  simp at hu
  rcases hu with rfl | hu
  · exact ht
  · exact hf u hu

/-- Append closure for the forest-level primitive formula. -/
theorem CanonicalOGCoproductOnForest.append
    {Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor}
    {f g : Forest}
    (hf : CanonicalOGCoproductOnForest Phi f)
    (hg : CanonicalOGCoproductOnForest Phi g) :
    CanonicalOGCoproductOnForest Phi (f ++ g) := by
  intro t ht
  rw [List.mem_append] at ht
  rcases ht with ht | ht
  · exact hf t ht
  · exact hg t ht

/-- A derivable forest lies in the componentwise canonical OG coproduct sector. -/
theorem CanonicalOGDerivableCoproductSpec.on_derivableForest
    {base : BaseRel}
    {Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor}
    (hPhi : CanonicalOGDerivableCoproductSpec base Phi)
    {f : Forest}
    (hf : DerivableForest base f) :
    CanonicalOGCoproductOnForest Phi f := by
  intro t ht
  exact hPhi.on_tree_of_derivable (hf t ht)

/-- Empty hypersequents vacuously satisfy the componentwise primitive formula. -/
theorem CanonicalOGCoproductOnHypersequent.zero
    (Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor) :
    CanonicalOGCoproductOnHypersequent Phi (0 : Hypersequent) := by
  intro t ht
  simp at ht

/-- Singleton hypersequent characterization. -/
theorem CanonicalOGCoproductOnHypersequent.singleton_iff
    {Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor}
    {t : PTree} :
    CanonicalOGCoproductOnHypersequent Phi (HQ.singleton t) ↔
      CanonicalOGCoproductOnTree Phi t := by
  constructor
  · intro h
    exact h t (by simp [HQ.singleton])
  · intro ht u hu
    simp [HQ.singleton] at hu
    subst u
    exact ht

/-- Singleton introduction for the hypersequent primitive formula. -/
theorem CanonicalOGCoproductOnHypersequent.singleton
    {Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor}
    {t : PTree}
    (ht : CanonicalOGCoproductOnTree Phi t) :
    CanonicalOGCoproductOnHypersequent Phi (HQ.singleton t) :=
  (CanonicalOGCoproductOnHypersequent.singleton_iff).2 ht

/-- External hypersequent sum preserves the componentwise primitive formula. -/
theorem CanonicalOGCoproductOnHypersequent.add
    {Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor}
    {G H : Hypersequent}
    (hG : CanonicalOGCoproductOnHypersequent Phi G)
    (hH : CanonicalOGCoproductOnHypersequent Phi H) :
    CanonicalOGCoproductOnHypersequent Phi (G + H) := by
  intro t ht
  rw [Multiset.mem_add] at ht
  rcases ht with ht | ht
  · exact hG t ht
  · exact hH t ht

/-- Left projection from an external hypersequent sum. -/
theorem CanonicalOGCoproductOnHypersequent.left_of_add
    {Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor}
    {G H : Hypersequent}
    (hGH : CanonicalOGCoproductOnHypersequent Phi (G + H)) :
    CanonicalOGCoproductOnHypersequent Phi G := by
  intro t ht
  exact hGH t (by
    rw [Multiset.mem_add]
    exact Or.inl ht)

/-- Right projection from an external hypersequent sum. -/
theorem CanonicalOGCoproductOnHypersequent.right_of_add
    {Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor}
    {G H : Hypersequent}
    (hGH : CanonicalOGCoproductOnHypersequent Phi (G + H)) :
    CanonicalOGCoproductOnHypersequent Phi H := by
  intro t ht
  exact hGH t (by
    rw [Multiset.mem_add]
    exact Or.inr ht)

/-- Forest-to-hypersequent transfer for the componentwise primitive formula. -/
theorem CanonicalOGCoproductOnHypersequent.ofForest
    {Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor}
    {f : Forest}
    (hf : CanonicalOGCoproductOnForest Phi f) :
    CanonicalOGCoproductOnHypersequent Phi (HQ.ofForest f) := by
  intro t ht
  simp [HQ.ofForest] at ht
  exact hf t ht

/--
A derivable hypersequent lies in the componentwise canonical OG coproduct
sector.
-/
theorem CanonicalOGDerivableCoproductSpec.on_derivableHypersequent
    {base : BaseRel}
    {Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor}
    (hPhi : CanonicalOGDerivableCoproductSpec base Phi)
    {G : Hypersequent}
    (hG : DerivableHypersequent base G) :
    CanonicalOGCoproductOnHypersequent Phi G := by
  intro t ht
  exact hPhi.on_tree_of_derivable (hG t ht)

/--
A derivable proof hypersequent lies in the componentwise canonical OG coproduct
sector.
-/
theorem CanonicalOGDerivableCoproductSpec.on_derivableProofHypersequent
    {base : BaseRel}
    {Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor}
    (hPhi : CanonicalOGDerivableCoproductSpec base Phi)
    (G : DerivableProofHypersequent base) :
    CanonicalOGCoproductOnHypersequent Phi G.1 :=
  hPhi.on_derivableHypersequent G.2

/--
Base-extension version: if a tree is derivable over `base`, then after a
material base extension it is still in the derivable stable quotient and the
canonical OG coproduct has the same primitive formula there.
-/
theorem canonicalOGDerivableCoproduct_baseExtension_derivableStableTreeGen
    {base base' : BaseRel}
    (hbase : BaseRelExtends base base')
    {t : PTree}
    (ht : DerivableTree base t) :
    canonicalOGDerivableCoproduct
        (QuotientConnected.CoproductSupport.derivableStableUEAIota
          base'
          (QuotientConnected.CoproductSupport.derivableStableTreeGen
            (derivableTree_mono hbase ht))) =
      TensorProduct.tmul ℤ
          (QuotientConnected.CoproductSupport.derivableStableUEAIota
            base'
            (QuotientConnected.CoproductSupport.derivableStableTreeGen
              (derivableTree_mono hbase ht))) 1 +
        TensorProduct.tmul ℤ 1
          (QuotientConnected.CoproductSupport.derivableStableUEAIota
            base'
            (QuotientConnected.CoproductSupport.derivableStableTreeGen
              (derivableTree_mono hbase ht))) := by
  exact canonicalOGPrimitiveComul_derivableStableTreeGen
    (derivableTree_mono hbase ht)

/--
Any map satisfying the specification over the extended base has the same
base-extension derivable-stable formula.
-/
theorem CanonicalOGDerivableCoproductSpec.on_baseExtension_derivableStableTreeGen
    {base base' : BaseRel}
    {Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor}
    (hPhi : CanonicalOGDerivableCoproductSpec base' Phi)
    (hbase : BaseRelExtends base base')
    {t : PTree}
    (ht : DerivableTree base t) :
    Phi
        (QuotientConnected.CoproductSupport.derivableStableUEAIota
          base'
          (QuotientConnected.CoproductSupport.derivableStableTreeGen
            (derivableTree_mono hbase ht))) =
      TensorProduct.tmul ℤ
          (QuotientConnected.CoproductSupport.derivableStableUEAIota
            base'
            (QuotientConnected.CoproductSupport.derivableStableTreeGen
              (derivableTree_mono hbase ht))) 1 +
        TensorProduct.tmul ℤ 1
          (QuotientConnected.CoproductSupport.derivableStableUEAIota
            base'
            (QuotientConnected.CoproductSupport.derivableStableTreeGen
              (derivableTree_mono hbase ht))) := by
  exact hPhi.on_derivableStableTreeGen (derivableTree_mono hbase ht)

/--
Canonical componentwise formula for derivable forests.
-/
theorem canonicalOGDerivableCoproduct_on_derivableForest
    {base : BaseRel} {f : Forest}
    (hf : DerivableForest base f) :
    CanonicalOGCoproductOnForest canonicalOGDerivableCoproduct f :=
  (canonicalOGDerivableCoproduct_spec base).on_derivableForest hf

/--
Canonical componentwise formula for derivable hypersequents.
-/
theorem canonicalOGDerivableCoproduct_on_derivableHypersequent
    {base : BaseRel} {G : Hypersequent}
    (hG : DerivableHypersequent base G) :
    CanonicalOGCoproductOnHypersequent canonicalOGDerivableCoproduct G :=
  (canonicalOGDerivableCoproduct_spec base).on_derivableHypersequent hG

/--
Canonical componentwise formula for derivable proof hypersequents.
-/
theorem canonicalOGDerivableCoproduct_on_derivableProofHypersequent
    {base : BaseRel}
    (G : DerivableProofHypersequent base) :
    CanonicalOGCoproductOnHypersequent canonicalOGDerivableCoproduct G.1 :=
  (canonicalOGDerivableCoproduct_spec base).on_derivableProofHypersequent G

/--
Canonical formula for actual derivations, stated through the componentwise
tree predicate.
-/
theorem canonicalOGDerivableCoproduct_on_NMMS_derivation
    {base : BaseRel} {s : MultiSequent}
    (d : NMMS.{0} base s) :
    CanonicalOGCoproductOnTree
      canonicalOGDerivableCoproduct (NMMS.toTree d) :=
  (canonicalOGDerivableCoproduct_spec base).on_NMMS_derivation d

/--
Canonical formula for material `baseAx` leaves, stated through the
componentwise tree predicate.
-/
theorem canonicalOGDerivableCoproduct_on_material_baseAx_tree
    {base : BaseRel} {Gamma Theta : Multiset MyProp}
    (hbase : MaterialEntails base Gamma Theta) :
    CanonicalOGCoproductOnTree canonicalOGDerivableCoproduct
      (PTree.leaf (MultiSequent.mk Gamma Theta)) :=
  (canonicalOGDerivableCoproduct_spec base).on_material_baseAx_tree hbase

/--
Marquee statement for the derivable OG algebra-side coproduct.

This is the cleaned-up theorem packet extracted from the first big result:
there is a distinguished algebra map, it is unique, it is determined by the
OG primitive formula on `ι`, and it acts correctly on derivable trees,
derivable forests, derivable hypersequents, actual NMMS derivations, material
base axioms, and base extensions.
-/
structure CanonicalOGDerivableCoproductMarquee
    (base : BaseRel) : Type where
  coproduct :
    preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor
  coproduct_eq_canonical :
    coproduct = canonicalOGDerivableCoproduct
  specification :
    CanonicalOGDerivableCoproductSpec base coproduct
  exists_unique :
    ∃! Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor,
      CanonicalOGDerivableCoproductSpec base Phi
  unique :
    ∀ Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor,
      CanonicalOGDerivableCoproductSpec base Phi →
        Phi = coproduct
  determined_by_iota :
    ∀ Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor,
      (∀ q : PreLieDifferenceStableQuotient,
        Phi (preLieDifferenceStableQuotientUEA_ι q) =
          QuotientConnected.CoproductSupport.OGPrimitiveComul.comul q) →
        Phi = coproduct
  spec_iff_iota :
    ∀ Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor,
      CanonicalOGDerivableCoproductSpec base Phi ↔
        ∀ q : PreLieDifferenceStableQuotient,
          Phi (preLieDifferenceStableQuotientUEA_ι q) =
            QuotientConnected.CoproductSupport.OGPrimitiveComul.comul q
  derivable_tree_formula :
    ∀ {t : PTree},
      DerivableTree base t →
        CanonicalOGCoproductOnTree coproduct t
  derivable_stable_tree_formula :
    ∀ {t : PTree} (ht : DerivableTree base t),
      coproduct
          (QuotientConnected.CoproductSupport.derivableStableUEAIota
            base
            (QuotientConnected.CoproductSupport.derivableStableTreeGen ht)) =
        TensorProduct.tmul ℤ
            (QuotientConnected.CoproductSupport.derivableStableUEAIota
              base
              (QuotientConnected.CoproductSupport.derivableStableTreeGen ht)) 1 +
          TensorProduct.tmul ℤ 1
            (QuotientConnected.CoproductSupport.derivableStableUEAIota
              base
              (QuotientConnected.CoproductSupport.derivableStableTreeGen ht))
  actual_derivation_formula :
    ∀ {s : MultiSequent} (d : NMMS.{0} base s),
      CanonicalOGCoproductOnTree coproduct (NMMS.toTree d)
  material_baseAx_tree_formula :
    ∀ {Gamma Theta : Multiset MyProp},
      MaterialEntails base Gamma Theta →
        CanonicalOGCoproductOnTree coproduct
          (PTree.leaf (MultiSequent.mk Gamma Theta))
  material_baseAx_stable_formula :
    ∀ {Gamma Theta : Multiset MyProp}
      (hbase : MaterialEntails base Gamma Theta),
      coproduct
          (QuotientConnected.CoproductSupport.derivableStableUEAIota
            base
            (QuotientConnected.CoproductSupport.derivableStableTreeGen
              (baseAx_derivable_tree hbase))) =
        TensorProduct.tmul ℤ
            (QuotientConnected.CoproductSupport.derivableStableUEAIota
              base
              (QuotientConnected.CoproductSupport.derivableStableTreeGen
                (baseAx_derivable_tree hbase))) 1 +
          TensorProduct.tmul ℤ 1
            (QuotientConnected.CoproductSupport.derivableStableUEAIota
              base
              (QuotientConnected.CoproductSupport.derivableStableTreeGen
                (baseAx_derivable_tree hbase)))
  derivable_forest_formula :
    ∀ {f : Forest},
      DerivableForest base f →
        CanonicalOGCoproductOnForest coproduct f
  derivable_hypersequent_formula :
    ∀ {G : Hypersequent},
      DerivableHypersequent base G →
        CanonicalOGCoproductOnHypersequent coproduct G
  derivable_proof_hypersequent_formula :
    ∀ G : DerivableProofHypersequent base,
      CanonicalOGCoproductOnHypersequent coproduct G.1
  base_extension_stable_formula :
    ∀ {base' : BaseRel}
      (hbase : BaseRelExtends base base')
      {t : PTree}
      (ht : DerivableTree base t),
      coproduct
          (QuotientConnected.CoproductSupport.derivableStableUEAIota
            base'
            (QuotientConnected.CoproductSupport.derivableStableTreeGen
              (derivableTree_mono hbase ht))) =
        TensorProduct.tmul ℤ
            (QuotientConnected.CoproductSupport.derivableStableUEAIota
              base'
              (QuotientConnected.CoproductSupport.derivableStableTreeGen
                (derivableTree_mono hbase ht))) 1 +
          TensorProduct.tmul ℤ 1
            (QuotientConnected.CoproductSupport.derivableStableUEAIota
              base'
              (QuotientConnected.CoproductSupport.derivableStableTreeGen
                (derivableTree_mono hbase ht)))

/--
The derivable OG algebra-side coproduct marquee theorem.
-/
noncomputable def canonicalOGDerivableCoproduct_marquee
    (base : BaseRel) :
    CanonicalOGDerivableCoproductMarquee base where
  coproduct :=
    canonicalOGDerivableCoproduct
  coproduct_eq_canonical :=
    rfl
  specification :=
    canonicalOGDerivableCoproduct_spec base
  exists_unique :=
    canonicalOGDerivableCoproduct_existsUnique base
  unique := by
    intro Phi hPhi
    exact canonicalOGDerivableCoproduct_eq_of_spec hPhi
  determined_by_iota := by
    intro Phi hPhi
    exact canonicalOGDerivableCoproduct_eq_of_iota_formula Phi hPhi
  spec_iff_iota := by
    intro Phi
    exact canonicalOGDerivableCoproductSpec_iff_iota_formula base Phi
  derivable_tree_formula := by
    intro t ht
    exact (canonicalOGDerivableCoproduct_spec base).on_tree_of_derivable ht
  derivable_stable_tree_formula := by
    intro t ht
    exact
      (canonicalOGDerivableCoproduct_spec base).on_derivableStableTreeGen ht
  actual_derivation_formula := by
    intro s d
    exact (canonicalOGDerivableCoproduct_spec base).on_NMMS_derivation d
  material_baseAx_tree_formula := by
    intro Gamma Theta hbase
    exact
      (canonicalOGDerivableCoproduct_spec base).on_material_baseAx_tree hbase
  material_baseAx_stable_formula := by
    intro Gamma Theta hbase
    exact
      (canonicalOGDerivableCoproduct_spec base).on_derivable_material_baseAx
        hbase
  derivable_forest_formula := by
    intro f hf
    exact
      (canonicalOGDerivableCoproduct_spec base).on_derivableForest hf
  derivable_hypersequent_formula := by
    intro G hG
    exact
      (canonicalOGDerivableCoproduct_spec base).on_derivableHypersequent hG
  derivable_proof_hypersequent_formula := by
    intro G
    exact
      (canonicalOGDerivableCoproduct_spec base).on_derivableProofHypersequent G
  base_extension_stable_formula := by
    intro base' hbase t ht
    exact
      canonicalOGDerivableCoproduct_baseExtension_derivableStableTreeGen
        hbase ht

/--
Projection of the marquee theorem to actual derivations.
-/
theorem CanonicalOGDerivableCoproductMarquee.actual_derivation
    {base : BaseRel}
    (H : CanonicalOGDerivableCoproductMarquee base)
    {s : MultiSequent}
    (d : NMMS.{0} base s) :
    CanonicalOGCoproductOnTree H.coproduct (NMMS.toTree d) :=
  H.actual_derivation_formula d

/--
Projection of the marquee theorem to derivable hypersequents.
-/
theorem CanonicalOGDerivableCoproductMarquee.derivable_hypersequent
    {base : BaseRel}
    (H : CanonicalOGDerivableCoproductMarquee base)
    {G : Hypersequent}
    (hG : DerivableHypersequent base G) :
    CanonicalOGCoproductOnHypersequent H.coproduct G :=
  H.derivable_hypersequent_formula hG

/--
Projection of the marquee theorem to material `baseAx` leaves.
-/
theorem CanonicalOGDerivableCoproductMarquee.material_baseAx
    {base : BaseRel}
    (H : CanonicalOGDerivableCoproductMarquee base)
    {Gamma Theta : Multiset MyProp}
    (hbase : MaterialEntails base Gamma Theta) :
    CanonicalOGCoproductOnTree H.coproduct
      (PTree.leaf (MultiSequent.mk Gamma Theta)) :=
  H.material_baseAx_tree_formula hbase

/-! ## Two-Hopf-side duality target -/

/--
The real two-Hopf-side marquee theorem.

This says exactly what remains to be achieved:

* the CK forest side is a completed Hopf algebra;
* the grafting/pre-Lie side has been completed to the OG UEA Hopf target;
* tree generators are connected to both carriers;
* external weakening and grafting remain constrained by the material base;
* local proof-theoretic cut/graft reconstruction holds;
* coefficient duality holds between CK cuts and grafting reconstructions.

The last field is the basis-level dualization.  A later finite graded dual
could repackage it as an honest Hopf pairing, but this is the mathematical
content we can target now.
-/
structure TwoHopfCutGraftDualityMarquee
    (base : BaseRel)
    (reconstructMultiplicity :
      Hypersequent -> Hypersequent -> PTree -> Nat) : Prop where
  ck_forest_hopf :
    Nonempty (CompletedForestHopfSide ℤ)
  og_grafting_hopf :
    OudomGuinGraftingHopfSide
  og_hopf_algebra_marquee :
    OudomGuinHopfAlgebraMarquee
  raw_to_forest_generator_bridge :
    CarrierBridgeTarget
  stable_to_og_generator_bridge :
    ∀ t : PTree,
      QuotientConnected.CoproductSupport.stableUEACanonicalIota
          (mkPreLieDifferenceStableQuotient (treeGen t)) =
        stableUEA_treeGen t
  nonmonotonic_weakening_and_grafting :
    NonmonotonicWeakeningGraftingMarquee base
  ck_coefficients_are_addressed_cut_fibres :
    ∀ (t : PTree) (p : HypersequentTensorBasis),
      cutSplitMultiplicity t p = AddressedCutMultiplicity t p
  ck_nonzero_coefficients_are_decompositions :
    ∀ (t : PTree) (p : HypersequentTensorBasis),
      0 < cutSplitMultiplicity t p ↔
        ∃ cut : List Address,
          cut ∈ coalgebraAdmissibleCuts t ∧
            coalgebraTensorTermOfCutList t cut = p
  ck_nonzero_coefficients_are_graft_reconstructible_decompositions :
    ∀ (t : PTree) (p : HypersequentTensorBasis),
      0 < cutSplitMultiplicity t p ↔
        ∃ cut : List Address,
          CKCutGraftBridge t cut ∧
            coalgebraTensorTermOfCutList t cut = p
  graft_coefficients_are_reconstruction_occurrences :
    ∀ (u context out : PTree),
      graftMultiplicity u context out =
        ReconstructionOccurrenceMultiplicity u context out
  graft_nonzero_coefficients_are_reconstructions :
    ∀ (u context out : PTree),
      0 < graftMultiplicity u context out ↔
        ∃ a : Address,
          a ∈ PTree.allAddresses context ∧
            PTree.graftMatchingLeafAt u context a = some out
  local_proof_theoretic_cut_graft :
    ∀ {u t v : PTree} {a : Address},
      DerivableTree base u →
      DerivableTree base t →
      PTree.graftMatchingLeafAt u t a = some v →
      IsNodeAddress u ([] : Address) →
      a ≠ ([] : Address) →
        SequentMatchingCompositionDecomposition base u t v a
  local_occurrence_coefficient_duality :
    ∀ {u t v : PTree} {a : Address},
      PTree.graftMatchingLeafAt u t a = some v →
      IsNodeAddress u ([] : Address) →
      a ≠ ([] : Address) →
        OccurrenceReconstructMultiplicity
            u (PTree.remainderGo [a] [] v) v a =
          SingletonAddressCutMultiplicity v a
            (HQ.singleton u, HQ.singleton (PTree.remainderGo [a] [] v))
  two_site_antichain_reconstruction :
    ∀ {t u w : PTree} {a b : Address},
      PTree.subtreeAt t a = some u →
      PTree.subtreeAt t b = some w →
      ¬ PTree.comparable a b →
        CutForestReconstructionTarget t [a, b]
  two_site_ck_cut_reconstruction :
    ∀ {t : PTree} {a b : Address},
      [a, b] ∈ coalgebraAdmissibleCuts t →
        CutForestReconstructionTarget t [a, b]
  two_site_ck_cut_graft_bridge :
    ∀ {t : PTree} {a b : Address},
      [a, b] ∈ coalgebraAdmissibleCuts t →
        TwoSiteCKCutGraftBridge t a b
  low_cardinality_ck_cut_reconstruction :
    ∀ {t : PTree} {cut : List Address},
      cut ∈ coalgebraAdmissibleCuts t →
      cut.length ≤ 2 →
        CutForestReconstructionTarget t cut
  ck_cut_reconstruction :
    ∀ {t : PTree} {cut : List Address},
      cut ∈ coalgebraAdmissibleCuts t →
        CutForestReconstructionTarget t cut
  ck_cut_graft_bridge :
    ∀ {t : PTree} {cut : List Address},
      cut ∈ coalgebraAdmissibleCuts t →
        CKCutGraftBridge t cut
  coefficient_pairing_dualizes_coproduct :
    ∀ (p : HypersequentTensorBasis) (t : PTree),
      ReconstructionCoefficientPairing reconstructMultiplicity p t =
        cutSplitMultiplicity t p
  coefficient_pairing_detects_ck_graft_decompositions :
    ∀ (p : HypersequentTensorBasis) (t : PTree),
      0 < ReconstructionCoefficientPairing reconstructMultiplicity p t ↔
        ∃ cut : List Address,
          CKCutGraftBridge t cut ∧
            coalgebraTensorTermOfCutList t cut = p

/--
The two-Hopf-side marquee theorem is reduced to the two genuinely missing
ingredients: an OG/grafting Hopf witness and the reconstruction coefficient
duality theorem.
-/
theorem two_hopf_cut_graft_duality_marquee_of_og_hopf_and_coefficients
    {base : BaseRel}
    {reconstructMultiplicity :
      Hypersequent -> Hypersequent -> PTree -> Nat}
    [LeftDistribClass
      (TensorProduct ℤ (HypersequentAlgebra ℤ) (HypersequentAlgebra ℤ))]
    [RightDistribClass
      (TensorProduct ℤ (HypersequentAlgebra ℤ) (HypersequentAlgebra ℤ))]
    (hog : OudomGuinGraftingHopfSide)
    (hcoeff : CutGraftCoefficientDuality reconstructMultiplicity) :
    TwoHopfCutGraftDualityMarquee base reconstructMultiplicity where
  ck_forest_hopf :=
    completed_forest_hopf_side_exists ℤ
  og_grafting_hopf :=
    hog
  og_hopf_algebra_marquee :=
    oudomGuin_hopf_algebra_marquee
  raw_to_forest_generator_bridge :=
    primitiveToHypersequentAlgebra_is_carrier_bridge
  stable_to_og_generator_bridge :=
    og_uea_tree_generator_bridge
  nonmonotonic_weakening_and_grafting :=
    nonmonotonic_weakening_grafting_marquee base
  ck_coefficients_are_addressed_cut_fibres :=
    cutSplitMultiplicity_eq_addressedCutMultiplicity
  ck_nonzero_coefficients_are_decompositions :=
    cutSplitMultiplicity_pos_iff_exists_addressed_cut
  ck_nonzero_coefficients_are_graft_reconstructible_decompositions :=
    cutSplitMultiplicity_pos_iff_exists_ck_cut_graft_bridge
  graft_coefficients_are_reconstruction_occurrences :=
    graftMultiplicity_eq_reconstructionOccurrenceMultiplicity
  graft_nonzero_coefficients_are_reconstructions :=
    graftMultiplicity_pos_iff_exists_reconstruction_occurrence
  local_proof_theoretic_cut_graft := by
    intro u t v a hu ht hg hnode hnotroot
    exact sequentMatching_composition_decomposition hu ht hg hnode hnotroot
  local_occurrence_coefficient_duality := by
    intro u t v a hg hnode hnotroot
    exact sequentMatching_occurrence_cut_graft_duality hg hnode hnotroot
  two_site_antichain_reconstruction := by
    intro t u w a b hsubA hsubB hinc
    exact two_incomparable_cutForestReconstructionTarget_of_subtreeAt
      hsubA hsubB hinc
  two_site_ck_cut_reconstruction := by
    intro t a b hcut
    exact two_site_coalgebra_cutForestReconstructionTarget hcut
  two_site_ck_cut_graft_bridge := by
    intro t a b hcut
    exact two_site_ck_cut_graft_bridge_of_mem_coalgebraAdmissibleCuts hcut
  low_cardinality_ck_cut_reconstruction := by
    intro t cut hcut hlen
    exact low_cardinality_coalgebra_cutForestReconstructionTarget hcut hlen
  ck_cut_reconstruction := by
    intro t cut hcut
    exact coalgebra_cutForestReconstructionTarget hcut
  ck_cut_graft_bridge := by
    intro t cut hcut
    exact ck_cut_graft_bridge_of_mem_coalgebraAdmissibleCuts hcut
  coefficient_pairing_dualizes_coproduct := by
    exact
      (cutGraftCoefficientDuality_iff_pairing
        reconstructMultiplicity).1 hcoeff
  coefficient_pairing_detects_ck_graft_decompositions := by
    exact
      reconstructionCoefficientPairing_pos_iff_exists_ck_cut_graft_bridge
        hcoeff

/--
With the canonical CK reconstruction multiplicity, the two-Hopf-side marquee
is reduced to the OG/grafting Hopf witness alone.
-/
theorem two_hopf_cut_graft_duality_marquee_of_og_hopf
    {base : BaseRel}
    [LeftDistribClass
      (TensorProduct ℤ (HypersequentAlgebra ℤ) (HypersequentAlgebra ℤ))]
    [RightDistribClass
      (TensorProduct ℤ (HypersequentAlgebra ℤ) (HypersequentAlgebra ℤ))]
    (hog : OudomGuinGraftingHopfSide) :
    TwoHopfCutGraftDualityMarquee
      base CKGraftReconstructionMultiplicity := by
  exact
    two_hopf_cut_graft_duality_marquee_of_og_hopf_and_coefficients
      (base := base)
      (reconstructMultiplicity := CKGraftReconstructionMultiplicity)
      hog
      ckGraftReconstructionMultiplicity_coefficient_duality

/--
For the canonical CK reconstruction multiplicity, the full two-Hopf marquee is
equivalent to supplying the OG/grafting Hopf side.

All CK-side coefficient and reconstruction content is now internal to this
file; the remaining mathematical construction is precisely the
Oudom-Guin-side Hopf witness.
-/
theorem two_hopf_cut_graft_duality_marquee_iff_og_hopf
    {base : BaseRel}
    [LeftDistribClass
      (TensorProduct ℤ (HypersequentAlgebra ℤ) (HypersequentAlgebra ℤ))]
    [RightDistribClass
      (TensorProduct ℤ (HypersequentAlgebra ℤ) (HypersequentAlgebra ℤ))] :
    TwoHopfCutGraftDualityMarquee
        base CKGraftReconstructionMultiplicity ↔
      OudomGuinGraftingHopfSide := by
  constructor
  · intro h
    exact h.og_grafting_hopf
  · intro hog
    exact two_hopf_cut_graft_duality_marquee_of_og_hopf
      (base := base) hog

/--
Concrete witness form of the final two-Hopf theorem.

With the canonical CK reconstruction multiplicity, proving the two-Hopf
cut/graft theorem is equivalent to supplying a concrete OG Hopf witness:
primitive coproduct on grafting generators, multiplicative extension to the
UEA, and antipode cancellation.
-/
theorem two_hopf_cut_graft_duality_marquee_iff_og_witness
    {base : BaseRel}
    [LeftDistribClass
      (TensorProduct ℤ (HypersequentAlgebra ℤ) (HypersequentAlgebra ℤ))]
    [RightDistribClass
      (TensorProduct ℤ (HypersequentAlgebra ℤ) (HypersequentAlgebra ℤ))] :
    TwoHopfCutGraftDualityMarquee
        base CKGraftReconstructionMultiplicity ↔
      Nonempty OudomGuinGraftingHopfWitness := by
  exact
    (two_hopf_cut_graft_duality_marquee_iff_og_hopf
      (base := base)).trans
      oudomGuin_grafting_hopf_side_iff_nonempty_witness

/--
Carrier-correct target form of the final two-Hopf theorem.

This is the sharpest statement of the remaining obligation: with the canonical
CK reconstruction multiplicity, the final CK/OG cut-graft theorem is
equivalent to existence of a carrier-correct UEA Hopf target.
-/
theorem two_hopf_cut_graft_duality_marquee_iff_og_target
    {base : BaseRel}
    [LeftDistribClass
      (TensorProduct ℤ (HypersequentAlgebra ℤ) (HypersequentAlgebra ℤ))]
    [RightDistribClass
      (TensorProduct ℤ (HypersequentAlgebra ℤ) (HypersequentAlgebra ℤ))] :
    TwoHopfCutGraftDualityMarquee
        base CKGraftReconstructionMultiplicity ↔
      ∃ _H : QuotientConnected.CoproductSupport.OudomGuinUEAHopfAlgebraTarget,
        True := by
  exact
    (two_hopf_cut_graft_duality_marquee_iff_og_witness
      (base := base)).trans
      oudomGuin_grafting_hopf_witness_iff_og_target

/--
Compatible-Hopf-data form of the final two-Hopf theorem.

This is the same reduction with the OG target unpacked: the remaining
algebraic obligation is a carrier-correct proof-tree coalgebra together with
UEA Hopf data whose coproduct and counit are those carrier maps.
-/
theorem two_hopf_cut_graft_duality_marquee_iff_compatible_og_hopf_data
    {base : BaseRel}
    [LeftDistribClass
      (TensorProduct ℤ (HypersequentAlgebra ℤ) (HypersequentAlgebra ℤ))]
    [RightDistribClass
      (TensorProduct ℤ (HypersequentAlgebra ℤ) (HypersequentAlgebra ℤ))] :
    TwoHopfCutGraftDualityMarquee
        base CKGraftReconstructionMultiplicity ↔
      ∃ (carrier :
          QuotientConnected.CoproductSupport.OudomGuinUEAHopfCarrierTarget)
        (hopf :
          QuotientConnected.StableUEAHopfData),
        hopf.comul = carrier.DeltaOG ∧
          hopf.counit = carrier.epsilonOG := by
  exact
    (two_hopf_cut_graft_duality_marquee_iff_og_target
      (base := base)).trans
      QuotientConnected.CoproductSupport.oudomGuinUEAHopfAlgebraTarget_exists_iff_compatible_hopf_data

/--
Extract the compatible OG Hopf data from the final two-Hopf theorem.

This is the algebraic content forced by the theorem: a proof-tree carrier
coalgebra together with matching Hopf data on the UEA.
-/
theorem compatible_og_hopf_data_of_two_hopf_cut_graft_duality_marquee
    {base : BaseRel}
    [LeftDistribClass
      (TensorProduct ℤ (HypersequentAlgebra ℤ) (HypersequentAlgebra ℤ))]
    [RightDistribClass
      (TensorProduct ℤ (HypersequentAlgebra ℤ) (HypersequentAlgebra ℤ))]
    (h :
      TwoHopfCutGraftDualityMarquee
        base CKGraftReconstructionMultiplicity) :
      ∃ (carrier :
          QuotientConnected.CoproductSupport.OudomGuinUEAHopfCarrierTarget)
        (hopf :
          QuotientConnected.StableUEAHopfData),
        hopf.comul = carrier.DeltaOG ∧
          hopf.counit = carrier.epsilonOG :=
  (two_hopf_cut_graft_duality_marquee_iff_compatible_og_hopf_data
    (base := base)).mp h

/--
Construct the final two-Hopf theorem from compatible OG Hopf data.

This is the direct use form of the current main reduction.
-/
theorem two_hopf_cut_graft_duality_marquee_of_compatible_og_hopf_data
    {base : BaseRel}
    [LeftDistribClass
      (TensorProduct ℤ (HypersequentAlgebra ℤ) (HypersequentAlgebra ℤ))]
    [RightDistribClass
      (TensorProduct ℤ (HypersequentAlgebra ℤ) (HypersequentAlgebra ℤ))]
    (carrier :
      QuotientConnected.CoproductSupport.OudomGuinUEAHopfCarrierTarget)
    (hopf : QuotientConnected.StableUEAHopfData)
    (hcomul : hopf.comul = carrier.DeltaOG)
    (hcounit : hopf.counit = carrier.epsilonOG) :
    TwoHopfCutGraftDualityMarquee
      base CKGraftReconstructionMultiplicity :=
  (two_hopf_cut_graft_duality_marquee_iff_compatible_og_hopf_data
    (base := base)).mpr
    ⟨carrier, hopf, hcomul, hcounit⟩

/-- A concrete OG Hopf witness completes the final two-Hopf theorem. -/
theorem two_hopf_cut_graft_duality_marquee_of_og_witness
    {base : BaseRel}
    [LeftDistribClass
      (TensorProduct ℤ (HypersequentAlgebra ℤ) (HypersequentAlgebra ℤ))]
    [RightDistribClass
      (TensorProduct ℤ (HypersequentAlgebra ℤ) (HypersequentAlgebra ℤ))]
    (W : OudomGuinGraftingHopfWitness) :
    TwoHopfCutGraftDualityMarquee
      base CKGraftReconstructionMultiplicity := by
  exact
    (two_hopf_cut_graft_duality_marquee_iff_og_witness
      (base := base)).2 ⟨W⟩

/--
An explicit carrier-correct OG Hopf target completes the final two-Hopf
cut/graft theorem directly.

This is the clean construction path: prove the UEA Hopf target, turn it into
the concrete OG witness, and the CK/OG cut-graft theorem follows.
-/
theorem two_hopf_cut_graft_duality_marquee_of_og_target
    {base : BaseRel}
    [LeftDistribClass
      (TensorProduct ℤ (HypersequentAlgebra ℤ) (HypersequentAlgebra ℤ))]
    [RightDistribClass
