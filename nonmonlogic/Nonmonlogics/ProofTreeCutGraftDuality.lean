/--
The main result yields an OG target whose Hopf operations have the expected
primitive behavior on genuinely derivable proof-tree generators.
-/
theorem ProofTheoreticHopfMainResult.exists_og_target_derivable_treeGen_formulas
    {base : BaseRel}
    [LeftDistribClass
      (TensorProduct ℤ (HypersequentAlgebra ℤ) (HypersequentAlgebra ℤ))]
    [RightDistribClass
      (TensorProduct ℤ (HypersequentAlgebra ℤ) (HypersequentAlgebra ℤ))]
    (h : ProofTheoreticHopfMainResult base) :
    ∃ H : QuotientConnected.CoproductSupport.OudomGuinUEAHopfAlgebraTarget,
      (∀ {t : PTree} (ht : DerivableTree base t),
        H.carrier.DeltaOG
            (QuotientConnected.CoproductSupport.derivableStableUEAIota
              base (QuotientConnected.CoproductSupport.derivableStableTreeGen ht)) =
          TensorProduct.tmul ℤ
              (QuotientConnected.CoproductSupport.derivableStableUEAIota
                base (QuotientConnected.CoproductSupport.derivableStableTreeGen ht)) 1 +
            TensorProduct.tmul ℤ 1
              (QuotientConnected.CoproductSupport.derivableStableUEAIota
                base (QuotientConnected.CoproductSupport.derivableStableTreeGen ht))) ∧
      (∀ {t : PTree} (ht : DerivableTree base t),
        H.carrier.epsilonOG
            (QuotientConnected.CoproductSupport.derivableStableUEAIota
              base (QuotientConnected.CoproductSupport.derivableStableTreeGen ht)) = 0) ∧
      (∀ {t : PTree} (ht : DerivableTree base t),
        H.hopf.antipode
            (QuotientConnected.CoproductSupport.derivableStableUEAIota
              base (QuotientConnected.CoproductSupport.derivableStableTreeGen ht)) =
          -QuotientConnected.CoproductSupport.derivableStableUEAIota
            base (QuotientConnected.CoproductSupport.derivableStableTreeGen ht)) ∧
      (∀ {t : PTree} (ht : DerivableTree base t),
        H.hopf.mulTensor
            ((LinearMap.rTensor preLieDifferenceStableQuotientUEA
                H.hopf.antipode)
              (H.carrier.DeltaOG
                (QuotientConnected.CoproductSupport.derivableStableUEAIota
                  base (QuotientConnected.CoproductSupport.derivableStableTreeGen ht)))) =
          H.hopf.unitLinear 0) ∧
      (∀ {t : PTree} (ht : DerivableTree base t),
        H.hopf.mulTensor
            ((LinearMap.lTensor preLieDifferenceStableQuotientUEA
                H.hopf.antipode)
              (H.carrier.DeltaOG
                (QuotientConnected.CoproductSupport.derivableStableUEAIota
                  base (QuotientConnected.CoproductSupport.derivableStableTreeGen ht)))) =
          H.hopf.unitLinear 0) := by
  have htarget :
      ∃ _H : QuotientConnected.CoproductSupport.OudomGuinUEAHopfAlgebraTarget,
        True :=
    (proofTheoreticHopf_mainResult_iff_og_target base).1 h
  rcases htarget with ⟨H, -⟩
  refine ⟨H, ?_, ?_, ?_, ?_, ?_⟩
  · intro t ht
    exact H.carrier.primitive_derivableStableTreeGen ht
  · intro t ht
    exact H.carrier.counit_derivableStableTreeGen ht
  · intro t ht
    exact H.antipode_derivableStableTreeGen ht
  · intro t ht
    exact H.antipode_left_cancels_derivableStableTreeGen ht
  · intro t ht
    exact H.antipode_right_cancels_derivableStableTreeGen ht

/--
Main-result form of OG coproduct rigidity.

The full proof-theoretic Hopf package does not merely produce some OG Hopf
target.  It produces an OG target whose coproduct is forced to be the
canonical derivable coproduct, and this equality is visible on the UEA
generators associated with actual `NMMS` derivations over the base relation.
-/
theorem ProofTheoreticHopfMainResult.exists_og_target_with_canonical_coproduct
    {base : BaseRel}
    [LeftDistribClass
      (TensorProduct ℤ (HypersequentAlgebra ℤ) (HypersequentAlgebra ℤ))]
    [RightDistribClass
      (TensorProduct ℤ (HypersequentAlgebra ℤ) (HypersequentAlgebra ℤ))]
    (h : ProofTheoreticHopfMainResult base) :
    ∃ H : QuotientConnected.CoproductSupport.OudomGuinUEAHopfAlgebraTarget,
      H.DeltaOGAlgHom = canonicalOGDerivableCoproduct ∧
      H.carrier.DeltaOG = canonicalOGDerivableCoproduct.toLinearMap ∧
      (∀ {s : MultiSequent} (d : NMMS.{0} base s),
        H.carrier.DeltaOG (stableUEA_treeGen (NMMS.toTree d)) =
          canonicalOGDerivableCoproduct
            (stableUEA_treeGen (NMMS.toTree d))) := by
  have htarget :
      ∃ _H : QuotientConnected.CoproductSupport.OudomGuinUEAHopfAlgebraTarget,
        True :=
    (proofTheoreticHopf_mainResult_iff_og_target base).1 h
  rcases htarget with ⟨H, -⟩
  refine ⟨H, ?_, ?_, ?_⟩
  · exact
      OudomGuinUEAHopfAlgebraTarget.DeltaOGAlgHom_eq_canonicalOGDerivableCoproduct
        H
  · exact
      OudomGuinUEAHopfAlgebraTarget.DeltaOG_eq_canonicalOGDerivableCoproduct
        H
  · intro s d
    exact
      OudomGuinUEAHopfAlgebraTarget.DeltaOG_eq_canonical_on_NMMS_derivation
        H d

/--
Main-result form of the first NMMS-target theorem.

If the proof-theoretic Hopf package holds for a base relation, then it
supplies an OG Hopf target whose coproduct satisfies the primitive formula on
every actual `NMMS` derivation, and every other algebra map satisfying that
same NMMS-target formula agrees with it on those derivation generators.
-/
theorem ProofTheoreticHopfMainResult.exists_og_target_unique_on_NMMS_derivations
    {base : BaseRel}
    [LeftDistribClass
      (TensorProduct ℤ (HypersequentAlgebra ℤ) (HypersequentAlgebra ℤ))]
    [RightDistribClass
      (TensorProduct ℤ (HypersequentAlgebra ℤ) (HypersequentAlgebra ℤ))]
    (h : ProofTheoreticHopfMainResult base) :
    ∃ H : QuotientConnected.CoproductSupport.OudomGuinUEAHopfAlgebraTarget,
      NMMSTargetCoproductSpec base H.DeltaOGAlgHom ∧
        ∀ Phi : preLieDifferenceStableQuotientUEA →ₐ[ℤ] stableUEATensor,
          NMMSTargetCoproductSpec base Phi →
            ∀ {s : MultiSequent} (d : NMMS.{0} base s),
              Phi (stableUEA_treeGen (NMMS.toTree d)) =
                H.DeltaOGAlgHom (stableUEA_treeGen (NMMS.toTree d)) := by
  have htarget :
      ∃ _H : QuotientConnected.CoproductSupport.OudomGuinUEAHopfAlgebraTarget,
        True :=
    (proofTheoreticHopf_mainResult_iff_og_target base).1 h
  rcases htarget with ⟨H, -⟩
  refine
    ⟨H,
      OudomGuinUEAHopfAlgebraTarget.nmmsTargetCoproductSpec H base,
      ?_⟩
  intro Phi hPhi s d
  exact
    NMMSTargetCoproductSpec.eq_on_derivation hPhi
      (OudomGuinUEAHopfAlgebraTarget.nmmsTargetCoproductSpec H base) d

