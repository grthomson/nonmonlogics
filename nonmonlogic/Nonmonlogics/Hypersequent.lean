theorem nodeRightStage_remainderGo_eq_of_append_stage_root
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (happendStage :
      PTree.remainderGo (cut₁ ++ cut₂) [] (PTree.node r s cs) =
        PTree.remainderGo (nodeAmbientCutOfRightWitness cut₁ cut₂) []
          (PTree.node r s cs)) :
    PTree.remainderGo cut₂ []
      (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁)) =
      PTree.remainderGo (nodeAmbientCutOfRightWitness cut₁ cut₂) []
        (PTree.node r s cs) := by
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₁ with
    ⟨_hcoal₁, hint₁⟩
  have hfirst :
      PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁) =
        PTree.remainderGo cut₁ [] (PTree.node r s cs) := by
    simpa [nodeRootFreeCutRemainderChildren] using
      (PTree.remainderGo_node_root_not_mem
        (r := r) (s := s) (cs := cs)
        (cut := cut₁) hint₁.2).symm
  calc
    PTree.remainderGo cut₂ []
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))
        =
      PTree.remainderGo cut₂ []
        (PTree.remainderGo cut₁ [] (PTree.node r s cs)) := by
        rw [hfirst]
    _ = PTree.remainderGo (cut₁ ++ cut₂) [] (PTree.node r s cs) := by
        simpa using
          PTree.remainderGo_remainderGo_eq
            cut₁ cut₂ [] (PTree.node r s cs)
    _ = PTree.remainderGo (nodeAmbientCutOfRightWitness cut₁ cut₂) []
        (PTree.node r s cs) := happendStage

