    Coalgebra R (HypersequentAlgebra R) :=
  hypersequentNormalizedCoalgebra_of_completionData (R := R) C.data

theorem coassoc
    (C : HypersequentNormalizedCoalgebraCompletion R) :
    HypersequentNormalizedCoalgebraCoassoc R :=
  (C.axioms).coassoc

theorem rightCounit
    (C : HypersequentNormalizedCoalgebraCompletion R) :
    HypersequentNormalizedCoalgebraRightCounit R :=
  (C.axioms).rightCounit

theorem leftCounit
    (C : HypersequentNormalizedCoalgebraCompletion R) :
    HypersequentNormalizedCoalgebraLeftCounit R :=
  (C.axioms).leftCounit

end HypersequentNormalizedCoalgebraCompletion

/-- Data completing the normalized bialgebra. -/
structure HypersequentNormalizedBialgebraCompletionData : Prop where
  coalgebraData : HypersequentNormalizedCoalgebraCompletionData R
  comul_mul : HypersequentNormalizedComulMul R

/--
Decomposition-based bialgebra completion.  Since `hypersequentNormalizedComulMul`
is already proved (under the tensor-product distributivity instances), the
only non-algebraic input here is the staged monomial extension bridge.
-/
structure HypersequentNormalizedBialgebraDecompositionData : Prop where
