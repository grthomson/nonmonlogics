/--
The detached hypersequent of a root-free node cut is invariant under
permuting the cut addresses.  This lets the coassociativity argument use the
CK/GL antichain itself rather than the incidental list order chosen by
`sublists`.
-/
theorem nodeRootFreeCutDetachedHypersequent_eq_of_perm_internal
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (hcut₂ : cut₂ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (hperm : cut₁.Perm cut₂) :
    HQ.ofForest (nodeRootFreeCutDetachedForest cs cut₁) =
      HQ.ofForest (nodeRootFreeCutDetachedForest cs cut₂) := by
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₁ with
    ⟨hcoal₁, hint₁⟩
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₂ with
    ⟨hcoal₂, hint₂⟩
  calc
    HQ.ofForest (nodeRootFreeCutDetachedForest cs cut₁)
        =
      HQ.ofForest
        (cut₁.filterMap (PTree.subtreeAt (PTree.node r s cs))) := by
        exact (nodeRootFreeCut_filterMap_hypersequent_eq
          (r := r) (s := s) (cs := cs)
          (cut := cut₁) hcoal₁ hint₁.2).symm
    _ =
      HQ.ofForest
        (cut₂.filterMap (PTree.subtreeAt (PTree.node r s cs))) := by
        exact HQ.ofForest_eq_of_perm
          (hperm.filterMap (PTree.subtreeAt (PTree.node r s cs)))
    _ =
      HQ.ofForest (nodeRootFreeCutDetachedForest cs cut₂) := by
        exact nodeRootFreeCut_filterMap_hypersequent_eq
          (r := r) (s := s) (cs := cs)
          (cut := cut₂) hcoal₂ hint₂.2

/--
The root-free remainder node is invariant under permuting the first-stage
antichain.  This is the descent-side version of saying that admissible cuts
are simultaneous antichains, not ordered operations.
-/
theorem nodeRootFreeCutRemainderNode_eq_of_perm_internal
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (hcut₂ : cut₂ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (hperm : cut₁.Perm cut₂) :
    PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁) =
      PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₂) := by
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₁ with
    ⟨_hcoal₁, hint₁⟩
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₂ with
    ⟨_hcoal₂, hint₂⟩
  have hrem₁ :
      PTree.remainderGo cut₁ [] (PTree.node r s cs) =
        PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁) := by
    simpa [nodeRootFreeCutRemainderChildren] using
      PTree.remainderGo_node_root_not_mem
        (r := r) (s := s) (cs := cs) (cut := cut₁) hint₁.2
  have hrem₂ :
      PTree.remainderGo cut₂ [] (PTree.node r s cs) =
        PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₂) := by
    simpa [nodeRootFreeCutRemainderChildren] using
      PTree.remainderGo_node_root_not_mem
        (r := r) (s := s) (cs := cs) (cut := cut₂) hint₂.2
  calc
    PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁)
        = PTree.remainderGo cut₁ [] (PTree.node r s cs) := hrem₁.symm
    _ = PTree.remainderGo cut₂ [] (PTree.node r s cs) :=
        PTree.remainderGo_eq_of_perm hperm [] (PTree.node r s cs)
    _ = PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₂) := hrem₂

theorem nodeRootFreeCutDetachedHypersequent_eq_fullyCanonicalLeftProfileWitness
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {w : List Address × List (List Address)}
    (hw : w ∈ nodeLeftInternalInternalNormalProfileWitnesses r s cs) :
    HQ.ofForest (nodeRootFreeCutDetachedForest cs w.1) =
      HQ.ofForest
        (nodeRootFreeCutDetachedForest cs
          (nodeCanonicalAmbientCutOfRightWitness r s cs
            (nodeLeftProfileWitnessCanonicalFirstCut r s cs w)
            (nodeLeftProfileWitnessCanonicalSecondCut r s cs w))) := by
  rcases (mem_nodeLeftInternalInternalNormalProfileWitnesses_iff
      (r := r) (s := s) (cs := cs) (w := w)).1 hw with
    ⟨ambient, hambient, profile, _hprofile, rfl⟩
  have hfirst :=
    nodeLeftProfileWitnessCanonicalFirstCut_mem_internalCoalgebraAdmissibleCuts
      (r := r) (s := s) (cs := cs) (w := (ambient, profile)) hw
  have hsecond :=
    nodeLeftProfileWitnessCanonicalSecondCut_mem_internalCoalgebraAdmissibleCuts
      (r := r) (s := s) (cs := cs) (w := (ambient, profile)) hw
  have hcanon :
      nodeCanonicalAmbientCutOfRightWitness r s cs
          (nodeLeftProfileWitnessCanonicalFirstCut r s cs (ambient, profile))
          (nodeLeftProfileWitnessCanonicalSecondCut r s cs (ambient, profile)) ∈
        internalCoalgebraAdmissibleCuts (PTree.node r s cs) :=
    nodeCanonicalAmbientCut_mem_internalCoalgebraAdmissibleCuts
      (r := r) (s := s) (cs := cs)
      (cut₁ := nodeLeftProfileWitnessCanonicalFirstCut r s cs (ambient, profile))
      (cut₂ := nodeLeftProfileWitnessCanonicalSecondCut r s cs (ambient, profile))
      hfirst hsecond
  exact
    nodeRootFreeCutDetachedHypersequent_eq_of_perm_internal
      (r := r) (s := s) (cs := cs)
      (cut₁ := ambient)
      (cut₂ :=
        nodeCanonicalAmbientCutOfRightWitness r s cs
          (nodeLeftProfileWitnessCanonicalFirstCut r s cs (ambient, profile))
          (nodeLeftProfileWitnessCanonicalSecondCut r s cs (ambient, profile)))
      hambient hcanon
      (nodeCanonicalAmbientCut_fullyCanonicalLeftProfileWitness_perm_ambient
        (r := r) (s := s) (cs := cs)
        (w := (ambient, profile)) hw).symm

theorem nodeRootFreeCutRemainderNode_eq_fullyCanonicalLeftProfileWitness
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {w : List Address × List (List Address)}
    (hw : w ∈ nodeLeftInternalInternalNormalProfileWitnesses r s cs) :
    PTree.node r s (nodeRootFreeCutRemainderChildren cs w.1) =
