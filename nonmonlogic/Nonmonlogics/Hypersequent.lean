      have hacRaw :
          a ++ c ∈ nodeLeftProfileWitnessFirstCut cs (ambient, profile) := by
        exact (PTree.mem_canonicalCut_iff.1 (by simpa [first] using hacFirst)).2
      rcases (mem_nodeLeftProfileWitnessFirstCut_iff_exists_zip
          (cs := cs) (w := (ambient, profile)) (x := a ++ c)).1 hacRaw with
        ⟨b, cutB, d, hzipB, hd, happend⟩
      have hbAddrs : b ∈ addrs := by
        simpa [addrs] using
          List.left_mem_of_mem_zip
            (xs := nodeRootFreeCutPrefixedRestrictions cs ambient)
            (ys := profile) (a := b) (b := cutB) hzipB
      have hbAmbient : b ∈ ambient := (hpref.mem_iff).2 hbAddrs
      by_cases hba : b = a
      · subst b
        have hcutEq : cutB = cut :=
          List.right_eq_of_mem_zip_same_left_of_nodup
            (xs := addrs) (ys := profile) (a := a)
            (b₁ := cutB) (b₂ := cut) hnodupAddrs
            (by simpa [addrs] using hzipB)
            (by simpa [addrs] using hzip)
        subst cutB
        have hdc : d = c := by
          exact (List.append_right_injective a (by simpa using happend)).symm
        simpa [hdc] using hd
      · have hcomp : PTree.comparable b a := by
          exact forestProfile_comparable_of_common_descendant
            (a := b) (b := a) (c := a ++ c)
            ⟨d, happend⟩ ⟨c, rfl⟩
        exact False.elim
          (antichain_of_mem_coalgebraAdmissibleCuts hambientCoal
            b hbAmbient a haAmbient hba hcomp)
    · intro hc
      have hacRaw :
          a ++ c ∈ nodeLeftProfileWitnessFirstCut cs (ambient, profile) :=
        mem_nodeLeftProfileWitnessFirstCut_of_mem_zip
          (cs := cs) (w := (ambient, profile))
          (a := a) (cut := cut) (c := c) hzip hc
      have hacAll : a ++ c ∈ PTree.allAddresses t := by
        rcases subtreeAt_some_of_mem_coalgebraAdmissibleCuts hcut hc with
          ⟨v, hv⟩
        have hsubAppend : PTree.subtreeAt t (a ++ c) = some v := by
          rw [PTree.subtreeAt_append_of_subtreeAt hsub]
          exact hv
        exact PTree.subtreeAt_some_implies_mem_allAddresses
          (t := t) (u := v) (a := a ++ c) hsubAppend
      have hacFirst : a ++ c ∈ first := by
        exact PTree.mem_canonicalCut_iff.2
          ⟨by simpa [t] using hacAll, by simpa [first] using hacRaw⟩
      exact (PTree.mem_restrictCutAt_iff
        (cut := first) (pfx := a) (addr := c)).2 hacFirst
  have hperm :
      (PTree.restrictCutAt first a).Perm cut :=
    (List.perm_ext_iff_of_nodup
      (nodup_of_mem_allAdmissibleCuts hrestrictRaw)
      (nodup_of_mem_coalgebraAdmissibleCuts hcut)).2 hmem
  exact
    List.eq_of_perm_of_sublist_of_sublist_nodup
      hperm hrestrictSub hcutSub (PTree.allAddresses_nodup u)

theorem nodeRightWitnessAmbientProfile_eq_leftProfileWitnessProfile
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {w : List Address × List (List Address)}
    (hw : w ∈ nodeLeftInternalInternalNormalProfileWitnesses r s cs) :
    nodeRightWitnessAmbientProfile r s cs
        (nodeLeftProfileWitnessCanonicalFirstCut r s cs w)
        (nodeLeftProfileWitnessCanonicalSecondCut r s cs w) = w.2 := by
  classical
  rcases (mem_nodeLeftInternalInternalNormalProfileWitnesses_iff
      (r := r) (s := s) (cs := cs) (w := w)).1 hw with
    ⟨ambient, hambient, profile, hprofile, rfl⟩
  let addrs := nodeRootFreeCutPrefixedRestrictions cs ambient
  let first := nodeLeftProfileWitnessCanonicalFirstCut r s cs (ambient, profile)
  let second := nodeLeftProfileWitnessCanonicalSecondCut r s cs (ambient, profile)
  have hcanonAmbient :
      nodeCanonicalAmbientCutOfRightWitness r s cs first second = ambient := by
    simpa [first, second] using
      nodeCanonicalAmbientCut_fullyCanonicalLeftProfileWitness_eq_ambient
        (r := r) (s := s) (cs := cs) (w := (ambient, profile)) hw
  have hlen : profile.length = addrs.length := by
    exact (nodeLeftProfileWitness_prefixed_length_eq_profile
      (r := r) (s := s) (cs := cs)
      (cut := ambient) (profile := profile) hambient hprofile).symm
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hambient with
    ⟨hambientCoal, hambientInternal⟩
  have hpref : List.Perm ambient addrs := by
    simpa [addrs] using
      nodeRootFreeCut_perm_prefixedRestrictions
        (r := r) (s := s) (cs := cs)
        (cut := ambient) hambientCoal hambientInternal.2
  have hnodupAddrs : addrs.Nodup := by
    exact (hpref.nodup_iff).1
      (nodup_of_mem_internalCoalgebraAdmissibleCuts hambient)
  have hprofileEq :
      profile =
        addrs.map (fun a =>
          if a ∈ second then
            PTree.restrictCutAt first a
          else
            [([] : Address)]) := by
    apply List.eq_map_of_forall_mem_zip_eq hlen
    intro a cut hzip
    by_cases hroot : cut = [([] : Address)]
    · have hnotSecond : a ∉ second := by
        intro haSecond
        have haRaw : a ∈ nodeLeftProfileWitnessSecondCut cs (ambient, profile) :=
          (PTree.mem_canonicalCut_iff.1 (by simpa [second] using haSecond)).2
        rcases (mem_nodeLeftProfileWitnessSecondCut_iff_exists_zip_nonroot
            (cs := cs) (w := (ambient, profile)) (a := a)).1 haRaw with
          ⟨cut', hzip', hnonroot'⟩
        have hcutEq : cut' = cut :=
          List.right_eq_of_mem_zip_same_left_of_nodup
            (xs := addrs) (ys := profile) (a := a)
            (b₁ := cut') (b₂ := cut) hnodupAddrs
            (by simpa [addrs] using hzip')
            (by simpa [addrs] using hzip)
        exact hnonroot' (hcutEq.trans hroot)
      simp [hroot, hnotSecond]
    · have haRaw : a ∈ nodeLeftProfileWitnessSecondCut cs (ambient, profile) :=
        mem_nodeLeftProfileWitnessSecondCut_of_mem_zip_nonroot
          (cs := cs) (w := (ambient, profile))
          (a := a) (cut := cut)
          (by simpa [addrs] using hzip) hroot
      have haSecond : a ∈ second := by
        have haAll :
            a ∈ PTree.allAddresses
              (PTree.node r s
                (nodeRootFreeCutRemainderChildren cs first)) :=
          mem_allAddresses_of_validAddress
            (validAddress_of_isNodeAddress
              (by
                simpa [first] using
                  isNodeAddress_canonicalFirst_remainder_of_mem_nodeLeftProfileWitnessSecondCut
                    (r := r) (s := s) (cs := cs)
                    (w := (ambient, profile)) hw haRaw))
        exact PTree.mem_canonicalCut_iff.2
          ⟨by simpa [first] using haAll, by simpa [second] using haRaw⟩
      have hrestrict :
          PTree.restrictCutAt first a = cut := by
        simpa [first] using
          restrictCutAt_canonicalFirst_eq_profileCut_of_mem_zip_nonroot
            (r := r) (s := s) (cs := cs)
            (w := (ambient, profile)) hw
            (by simpa [addrs] using hzip) hroot
      simp [haSecond, hrestrict]
  simpa [nodeRightWitnessAmbientProfile, addrs, first, second,
    hcanonAmbient] using hprofileEq.symm

