  apply nodeRightNormalSupport_subset_left_of_canonical_forest_support
      (r := r) (s := s) (cs := cs)
  · intro cut₁ cut₂ hcut₁ hcut₂
    exact nodeCanonicalAmbientForestSupport_of_outside_inside_perms
      (r := r) (s := s) (cs := cs)
      (cut₁ := cut₁) (cut₂ := cut₂)
      hcut₁ hcut₂
      (hambient cut₁ cut₂ hcut₁ hcut₂)
      (hfirst cut₁ cut₂ hcut₁ hcut₂)
  · exact hp

