      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁)))
    (hsub :
      List.Sublist (nodeAmbientCutOfRightWitness cut₁ cut₂)
        (PTree.allAddresses (PTree.node r s cs)))
    (hnodup : (cut₁ ++ cut₂).Nodup)
    (hcross :
      ∀ a, a ∈ cut₁ →
        ∀ b, b ∈ cut₂ →
          a ≠ b → ¬ PTree.comparable a b) :
    nodeAmbientCutOfRightWitness cut₁ cut₂ ∈
      internalCoalgebraAdmissibleCuts (PTree.node r s cs) := by
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₁ with
    ⟨hcoal₁, _hint₁⟩
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₂ with
    ⟨hcoal₂, _hint₂⟩
  apply nodeAmbientCut_mem_internalCoalgebraAdmissibleCuts_of_sublist_append_nodup_antichain
      (r := r) (s := s) (cs := cs)
      (cut₁ := cut₁) (cut₂ := cut₂)
      hcut₁ hcut₂ hsub hnodup
  exact append_antichain_of_parts
    (antichain_of_mem_coalgebraAdmissibleCuts hcoal₁)
    (antichain_of_mem_coalgebraAdmissibleCuts hcoal₂)
    hcross

/--
The split of the ambient detached forest suggested by a right witness.

The first component is the forest detached by the first cut; the second
component is the forest detached by the second cut inside the first remainder.
-/
noncomputable def nodeAmbientSplitOfRightWitness
    (r : RuleTag) (s : MultiSequent) (cs : List PTree)
    (cut₁ cut₂ : List Address) : HypersequentTensorBasis :=
  let rem := PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁)
  let p := coalgebraTensorTermOfCutList rem cut₂
  (HQ.ofForest (nodeRootFreeCutDetachedForest cs cut₁), p.1)

theorem nodeRightNormalWitnessTriple_eq_ambient_split
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address}
    (hrem :
      (coalgebraTensorTermOfCutList
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))
        cut₂).2 =
        HQ.singleton
          (PTree.node r s
            (nodeRootFreeCutRemainderChildren cs
              (nodeAmbientCutOfRightWitness cut₁ cut₂)))) :
    (let q :=
      coalgebraTensorTermOfCutList
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))
        cut₂
    (HQ.ofForest (nodeRootFreeCutDetachedForest cs cut₁), q.1, q.2)) =
      ((nodeAmbientSplitOfRightWitness r s cs cut₁ cut₂).1,
        (nodeAmbientSplitOfRightWitness r s cs cut₁ cut₂).2,
        HQ.singleton
          (PTree.node r s
            (nodeRootFreeCutRemainderChildren cs
              (nodeAmbientCutOfRightWitness cut₁ cut₂)))) := by
  simp [nodeAmbientSplitOfRightWitness, nodeAmbientCutOfRightWitness, hrem]

/--
If the ambient cut is an internal coalgebra cut, the right-witness split is a
proper split of its detached forest, and the staged remainder agrees with the
ambient remainder, then the right witness contributes an atom on the left
node-normal support.
-/
theorem nodeRightWitness_mem_leftNormalSupport_of_ambient
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address}
    (hambient :
      nodeAmbientCutOfRightWitness cut₁ cut₂ ∈
        internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (hsplit :
      nodeAmbientSplitOfRightWitness r s cs cut₁ cut₂ ∈
        coalgebraForestProperSplittingTensorSupport
          (nodeRootFreeCutDetachedForest cs
            (nodeAmbientCutOfRightWitness cut₁ cut₂)))
    (hrem :
      (coalgebraTensorTermOfCutList
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))
        cut₂).2 =
        HQ.singleton
          (PTree.node r s
            (nodeRootFreeCutRemainderChildren cs
              (nodeAmbientCutOfRightWitness cut₁ cut₂)))) :
    (let q :=
      coalgebraTensorTermOfCutList
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))
        cut₂
    (HQ.ofForest (nodeRootFreeCutDetachedForest cs cut₁), q.1, q.2))
      ∈ nodeLeftInternalInternalNormalSupport r s cs := by
  rw [nodeRightNormalWitnessTriple_eq_ambient_split
    (r := r) (s := s) (cs := cs)
    (cut₁ := cut₁) (cut₂ := cut₂) hrem]
  exact (mem_nodeLeftInternalInternalNormalSupport_iff
    (r := r) (s := s) (cs := cs)).2
    ⟨nodeAmbientCutOfRightWitness cut₁ cut₂, hambient,
      nodeAmbientSplitOfRightWitness r s cs cut₁ cut₂, hsplit, rfl⟩

