    (hnd :
      ∀ cut₁ cut₂ : List Address,
        cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs) →
        cut₂ ∈ internalCoalgebraAdmissibleCuts
          (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁)) →
        ∀ a : Address, a ∈ cut₁ →
          ∀ b : Address, b ∈ cut₂ → ¬ PTree.isAncestorOf b a)
    {p : HypersequentTripleBasis}
    (hp : p ∈ nodeRightInternalInternalNormalSupport r s cs) :
    p ∈ nodeLeftInternalInternalNormalSupport r s cs := by
  apply nodeRightNormalSupport_subset_left_of_canonical_forest_remainder
      (r := r) (s := s) (cs := cs)
      (hforest := hforest)
  · intro cut₁ cut₂ hcut₁ hcut₂
    exact nodeRightStage_remainderGo_eq_of_no_second_dominates_first
      (r := r) (s := s) (cs := cs)
      (cut₁ := cut₁) (cut₂ := cut₂)
      hcut₁ (hnd cut₁ cut₂ hcut₁ hcut₂)
  · exact hp

theorem removed_left_address_dominated_by_right
    {cut₁ cut₂ : List Address} {a : Address}
    (ha₁ : a ∈ cut₁)
    (hastage : a ∉ stageAmbientCut cut₁ cut₂) :
    ∃ b : Address, b ∈ cut₂ ∧ PTree.isAncestorOf b a := by
  classical
  by_contra hnone
  have hnd : ∀ b : Address, b ∈ cut₂ → ¬ PTree.isAncestorOf b a := by
    intro b hb hba
    exact hnone ⟨b, hb, hba⟩
  exact hastage
    (mem_stageAmbientCut_left_of_not_dominated
      (cut₁ := cut₁) (cut₂ := cut₂) ha₁ hnd)

theorem mem_append_iff_stage_or_removed_left
    {cut₁ cut₂ : List Address} {a : Address} :
    a ∈ cut₁ ++ cut₂ ↔
      Or (a ∈ stageAmbientCut cut₁ cut₂)
        (And (a ∈ cut₁)
          (Exists fun b : Address =>
            And (b ∈ cut₂) (PTree.isAncestorOf b a))) := by
  constructor
  · intro ha
    rcases List.mem_append.1 ha with ha₁ | ha₂
    · by_cases hastage : a ∈ stageAmbientCut cut₁ cut₂
      · exact Or.inl hastage
      · exact Or.inr
          ⟨ha₁,
            removed_left_address_dominated_by_right
              (cut₁ := cut₁) (cut₂ := cut₂) ha₁ hastage⟩
    · exact Or.inl
        (mem_stageAmbientCut_right (cut₁ := cut₁) (cut₂ := cut₂) ha₂)
  · intro ha
    rcases ha with hastage | hremoved
    · exact mem_append_of_mem_stageAmbientCut
        (cut₁ := cut₁) (cut₂ := cut₂) hastage
    · exact List.mem_append.2 (Or.inl hremoved.1)

/--
Cut addresses become leaves in the corresponding remainder.

This is the local no-recutting fact needed for the staged extension
bijection: an internal coalgebra cut of a remainder cannot choose an address
that was already cut at the previous stage, because that address has been
collapsed to a primitive/interface leaf.
-/
theorem exists_leaf_subtreeAt_remainderGo_of_mem_isAdmissibleCut
    {t : PTree} {cut : List Address} {a : Address}
    (C : PTree.IsAdmissibleCut t)
    (ha : a ∈ C.nodes) :
    ∃ s : MultiSequent,
      PTree.subtreeAt (PTree.remainderGo C.nodes [] t) a =
        some (PTree.leaf s) := by
  induction a generalizing t cut with
  | nil =>
      cases t with
      | leaf s =>
          exact ⟨s, by simp [PTree.remainderGo, PTree.subtreeAt]⟩
      | node r s cs =>
          have hroot : ([] : Address) ∈ C.nodes := ha
          exact ⟨s, by simp [PTree.remainderGo, PTree.subtreeAt, hroot]⟩
  | cons i rest ih =>
      cases t with
      | leaf s =>
          have hvalid := C.valid (i :: rest) ha
          simp [PTree.ValidAddress, PTree.validAddress, PTree.subtreeAt] at hvalid
      | node r s cs =>
          have hroot : ([] : Address) ∉ C.nodes := by
            intro hnil
            exact C.antichain ([] : Address) hnil (i :: rest) ha
              (by simp)
              (Or.inl (PTree.root_isAncestorOf (i :: rest)))
          have hvalid := C.valid (i :: rest) ha
          have hi : i < cs.length := by
            by_contra hi
            simp [PTree.ValidAddress, PTree.validAddress,
              PTree.subtreeAt, hi] at hvalid
          have hrest : rest ∈ PTree.restrictCut C.nodes i := by
            exact (PTree.mem_restrictCut_iff
              (cut := C.nodes) (i := i) (addr := rest)).2 ha
          let Cchild : PTree.IsAdmissibleCut cs[i] :=
            PTree.isAdmissibleCut_restrictCut C i hi
          rcases ih
              (t := cs[i])
              (cut := PTree.restrictCut C.nodes i)
              Cchild
              (by
                change rest ∈ PTree.restrictCut C.nodes i
                exact hrest) with
            ⟨leafSeq, hleaf⟩
          refine ⟨leafSeq, ?_⟩
          have hrem :
              PTree.remainderGo C.nodes [] (PTree.node r s cs) =
                PTree.node r s
                  (cs.attach.mapIdx (fun j child =>
                    PTree.remainderGo (PTree.restrictCut C.nodes j) []
                      child.1)) := by
            exact PTree.remainderGo_node_root_not_mem
              (r := r) (s := s) (cs := cs) (cut := C.nodes) hroot
          rw [hrem]
          simpa [PTree.subtreeAt, hi, Cchild] using hleaf

theorem not_mem_internal_cut_of_remainder_at_previous_cut
    {t : PTree} {cut₁ cut₂ : List Address} {a : Address}
    (hcut₁ : cut₁ ∈ coalgebraAdmissibleCuts t)
    (ha₁ : a ∈ cut₁)
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.remainderGo cut₁ [] t)) :
    a ∉ cut₂ := by
  intro ha₂
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₂ with
    ⟨hcoal₂, hinternal₂⟩
  rcases exists_leaf_subtreeAt_remainderGo_of_mem_isAdmissibleCut
      (t := t) (cut := cut₁) (a := a)
      (PTree.isAdmissibleCut_of_mem_allAdmissibleCuts
        ((mem_coalgebraAdmissibleCuts_iff).1 hcut₁).1)
      (by simpa using ha₁) with
    ⟨leafSeq, hleaf⟩
  have hleaf' :
      PTree.subtreeAt (PTree.remainderGo cut₁ [] t) a =
        some (PTree.leaf leafSeq) := by
    simpa using hleaf
  have hnode :=
    node_addresses_of_mem_coalgebraAdmissibleCuts_of_internal
      hcoal₂ hinternal₂ a ha₂
  rcases hnode with ⟨r, s, cs, hsub⟩
  rw [hleaf'] at hsub
  cases hsub

theorem disjoint_previous_cut_second_internal_cut
    {t : PTree} {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ coalgebraAdmissibleCuts t)
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.remainderGo cut₁ [] t)) :
    ∀ a : Address, a ∈ cut₁ → a ∉ cut₂ := by
  intro a ha₁
  exact not_mem_internal_cut_of_remainder_at_previous_cut
    (t := t) (cut₁ := cut₁) (cut₂ := cut₂) hcut₁ ha₁ hcut₂

theorem not_isNodeAddress_below_leaf
    {t : PTree} {a b : Address} {s : MultiSequent}
    (hleaf : PTree.subtreeAt t a = some (PTree.leaf s))
    (hab : PTree.isAncestorOf a b)
    (hne : b ≠ a) :
    ¬ IsNodeAddress t b := by
  intro hnode
  rcases hab with ⟨c, hbEq⟩
  cases c with
  | nil =>
      simp at hbEq
      exact hne hbEq
  | cons i rest =>
      rcases hnode with ⟨r, s', cs, hsub⟩
      have hnone :
          PTree.subtreeAt t (a ++ (i :: rest)) = none :=
        subtreeAt_eq_leaf_append_none
          t a (i :: rest) s hleaf (by simp)
      rw [hbEq] at hsub
      rw [hnone] at hsub
      cases hsub

theorem not_previous_cut_ancestor_of_second_internal_cut
    {t : PTree} {cut₁ cut₂ : List Address} {a b : Address}
    (hcut₁ : cut₁ ∈ coalgebraAdmissibleCuts t)
    (ha₁ : a ∈ cut₁)
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.remainderGo cut₁ [] t))
    (hb₂ : b ∈ cut₂) :
    ¬ PTree.isAncestorOf a b := by
  intro hab
  have hneq : b ≠ a := by
    intro hba
    subst b
    exact disjoint_previous_cut_second_internal_cut
      (t := t) (cut₁ := cut₁) (cut₂ := cut₂)
      hcut₁ hcut₂ a ha₁ hb₂
  rcases exists_leaf_subtreeAt_remainderGo_of_mem_isAdmissibleCut
      (t := t) (cut := cut₁) (a := a)
      (PTree.isAdmissibleCut_of_mem_allAdmissibleCuts
        ((mem_coalgebraAdmissibleCuts_iff).1 hcut₁).1)
      ha₁ with
    ⟨leafSeq, hleaf⟩
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₂ with
    ⟨hcoal₂, hint₂⟩
  have hnode₂ : IsNodeAddress (PTree.remainderGo cut₁ [] t) b :=
    node_addresses_of_mem_coalgebraAdmissibleCuts_of_internal
      hcoal₂ hint₂ b hb₂
  exact not_isNodeAddress_below_leaf
    (t := PTree.remainderGo cut₁ [] t)
    (a := a) (b := b) hleaf hab hneq hnode₂

/--
Concrete descent form for a second-stage internal cut address.

A second-stage internal cut address in the first remainder is never below a
first-stage cut leaf.  Therefore the subtree at that address in the first
remainder is the original subtree pruned by the first cut restricted under
that address.
-/
theorem subtreeAt_first_remainder_second_internal_cut_eq_restricted
    {t : PTree} {cut₁ cut₂ : List Address} {b : Address} {u : PTree}
    (hcut₁ : cut₁ ∈ coalgebraAdmissibleCuts t)
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.remainderGo cut₁ [] t))
    (hb₂ : b ∈ cut₂)
    (hsub : PTree.subtreeAt t b = some u) :
    PTree.subtreeAt (PTree.remainderGo cut₁ [] t) b =
      some (PTree.remainderGo (PTree.restrictCutAt cut₁ b) [] u) := by
  apply PTree.subtreeAt_remainderGo_of_forall_not_ancestor
      (cut := cut₁) (a := b) (t := t) (u := u) hsub
  intro a ha₁
  exact not_previous_cut_ancestor_of_second_internal_cut
    (t := t) (cut₁ := cut₁) (cut₂ := cut₂)
    (a := a) (b := b) hcut₁ ha₁ hcut₂ hb₂

/--
The forest of second-stage detached components, expressed back in the original
tree by restricting the first-stage cut below each second-stage address.
-/
noncomputable def secondStageRestrictedRemainderForest
    (t : PTree) (cut₁ cut₂ : List Address) : Forest :=
  cut₂.filterMap (fun b =>
    match PTree.subtreeAt t b with
    | some u => some (PTree.remainderGo (PTree.restrictCutAt cut₁ b) [] u)
    | none => none)

/-- Original subtrees addressed by the second-stage cut. -/
noncomputable def secondStageOriginalSubtreeForest
    (t : PTree) (cut₂ : List Address) : Forest :=
  cut₂.filterMap (PTree.subtreeAt t)

/-- First-stage detached components lying inside second-stage subtrees. -/
noncomputable def firstStageInsideSecondForest
    (t : PTree) (cut₁ cut₂ : List Address) : Forest :=
  cut₂.flatMap (fun b =>
    match PTree.subtreeAt t b with
    | some u => (PTree.restrictCutAt cut₁ b).filterMap (PTree.subtreeAt u)
    | none => [])

/-- Address-level version of `firstStageInsideSecondForest`. -/
noncomputable def firstStageInsideSecondAddresses
    (cut₁ cut₂ : List Address) : List Address :=
  cut₂.flatMap (fun b =>
    (PTree.restrictCutAt cut₁ b).map (fun c => b ++ c))

/-- First-stage detached components not swallowed by a later second-stage cut. -/
noncomputable def firstStageOutsideSecondForest
    (t : PTree) (cut₁ cut₂ : List Address) : Forest := by
  classical
  exact cut₁.filterMap (fun a =>
    if ∀ b : Address, b ∈ cut₂ → ¬ PTree.isAncestorOf b a then
      PTree.subtreeAt t a
    else
      none)

/-- First-stage detached components lying under some second-stage address. -/
noncomputable def firstStageDominatedBySecondForest
    (t : PTree) (cut₁ cut₂ : List Address) : Forest := by
  classical
  exact cut₁.filterMap (fun a =>
    if ∃ b : Address, b ∈ cut₂ ∧ PTree.isAncestorOf b a then
      PTree.subtreeAt t a
    else
      none)

/-- Address-level version of `firstStageDominatedBySecondForest`. -/
noncomputable def firstStageDominatedBySecondAddresses
    (cut₁ cut₂ : List Address) : List Address := by
  classical
  exact cut₁.filter (fun a =>
    decide (∃ b : Address, b ∈ cut₂ ∧ PTree.isAncestorOf b a))

/-- First-stage cut addresses which survive a later second-stage cut. -/
noncomputable def firstStageSurvivingAddresses
    (cut₁ cut₂ : List Address) : List Address := by
  classical
  exact cut₁.filter (fun a =>
    decide (∀ b : Address, b ∈ cut₂ → ¬ PTree.isAncestorOf b a))

theorem stageAmbientCut_flatMap_rightProfileAt_eq_outside_append_inside_of_disjoint
    {cut₁ cut₂ : List Address}
    (hdisjoint : ∀ a ∈ cut₁, a ∉ cut₂) :
    (stageAmbientCut cut₁ cut₂).flatMap (fun a =>
        if a ∈ cut₂ then
          (PTree.restrictCutAt cut₁ a).map (fun c => a ++ c)
        else
          [a]) =
      firstStageSurvivingAddresses cut₁ cut₂ ++
        firstStageInsideSecondAddresses cut₁ cut₂ := by
  classical
  unfold stageAmbientCut firstStageSurvivingAddresses firstStageInsideSecondAddresses
  rw [List.flatMap_append]
  congr 1
  · apply List.flatMap_eq_self_of_forall_singleton
    intro a ha
    have ha₁ : a ∈ cut₁ := (List.mem_filter.1 ha).1
    have hnot : a ∉ cut₂ := hdisjoint a ha₁
    simp [hnot]
  · apply List.flatMap_congr
    intro a ha
    simp [ha]

noncomputable def firstStageOutsideSecondProfilePairs
    (t : PTree) (cut₁ cut₂ : List Address) :
    List (PTree × List Address) := by
  classical
  exact cut₁.filterMap (fun a =>
    if ∀ b : Address, b ∈ cut₂ → ¬ PTree.isAncestorOf b a then
      match PTree.subtreeAt t a with
      | some u => some (u, [([] : Address)])
      | none => none
    else
      none)

noncomputable def secondStageRestrictedProfilePairs
    (t : PTree) (cut₁ cut₂ : List Address) :
    List (PTree × List Address) :=
  cut₂.filterMap (fun b =>
    match PTree.subtreeAt t b with
    | some u => some (u, PTree.restrictCutAt cut₁ b)
    | none => none)

noncomputable def stagedRightWitnessProfilePairs
    (t : PTree) (cut₁ cut₂ : List Address) :
    List (PTree × List Address) :=
  firstStageOutsideSecondProfilePairs t cut₁ cut₂ ++
    secondStageRestrictedProfilePairs t cut₁ cut₂

theorem filter_filterMap_eq_filterMap_if_core
    {α β : Type _} (xs : List α) (p : α → Prop) [DecidablePred p]
    (f : α → Option β) :
    (xs.filter (fun x => decide (p x))).filterMap f =
      xs.filterMap (fun x => if p x then f x else none) := by
  induction xs with
  | nil =>
      simp
  | cons x xs ih =>
      by_cases hx : p x
      · cases hfx : f x <;> simp [List.filter, hx, ih, hfx]
      · simp [List.filter, hx, ih]

theorem coalgebraForestTensorTermOfPairs_firstStageOutsideSecond
    (t : PTree) (cut₁ cut₂ : List Address) :
    coalgebraForestTensorTermOfPairs
        (firstStageOutsideSecondProfilePairs t cut₁ cut₂) =
      (HQ.ofForest (firstStageOutsideSecondForest t cut₁ cut₂), 0) := by
  classical
  induction cut₁ with
  | nil =>
      simp [firstStageOutsideSecondProfilePairs,
        firstStageOutsideSecondForest, HypersequentTensorBasis.one]
  | cons a rest ih =>
      have htail :
          coalgebraForestTensorTermOfPairs
              (List.filterMap
                (fun a =>
                  if ∀ b : Address, b ∈ cut₂ → ¬ PTree.isAncestorOf b a then
                    match PTree.subtreeAt t a with
                    | some u => some (u, [([] : Address)])
                    | none => none
                  else none)
                rest) =
            (HQ.ofForest
              (List.filterMap
                (fun a =>
                  if ∀ b : Address, b ∈ cut₂ → ¬ PTree.isAncestorOf b a then
                    PTree.subtreeAt t a
                  else none)
                rest), 0) := by
        simpa [firstStageOutsideSecondProfilePairs,
          firstStageOutsideSecondForest] using ih
      by_cases hsurvive :
          ∀ b : Address, b ∈ cut₂ → ¬ PTree.isAncestorOf b a
      · cases hsub : PTree.subtreeAt t a with
        | none =>
            simpa [firstStageOutsideSecondProfilePairs,
              firstStageOutsideSecondForest, hsurvive, hsub] using htail
        | some u =>
            have htail_fst :
                (coalgebraForestTensorTermOfPairs
                    (List.filterMap
                      (fun a =>
                        if ∀ b : Address, b ∈ cut₂ →
                            ¬ PTree.isAncestorOf b a then
                          match PTree.subtreeAt t a with
                          | some u => some (u, [([] : Address)])
                          | none => none
                        else none)
                      rest)).1 =
                  HQ.ofForest
                    (List.filterMap
                      (fun a =>
                        if ∀ b : Address, b ∈ cut₂ →
                            ¬ PTree.isAncestorOf b a then
                          PTree.subtreeAt t a
                        else none)
                      rest) :=
              congrArg Prod.fst htail
            have htail_snd :
                (coalgebraForestTensorTermOfPairs
                    (List.filterMap
                      (fun a =>
                        if ∀ b : Address, b ∈ cut₂ →
                            ¬ PTree.isAncestorOf b a then
                          match PTree.subtreeAt t a with
                          | some u => some (u, [([] : Address)])
                          | none => none
                        else none)
                      rest)).2 = 0 :=
              congrArg Prod.snd htail
            let tailPairs : List (PTree × List Address) :=
              List.filterMap
                (fun a =>
                  if ∀ b : Address, b ∈ cut₂ →
                      ¬ PTree.isAncestorOf b a then
                    match PTree.subtreeAt t a with
                    | some u => some (u, [([] : Address)])
                    | none => none
                  else none)
                rest
            let tailForest : Forest :=
              List.filterMap
                (fun a =>
                  if ∀ b : Address, b ∈ cut₂ →
                      ¬ PTree.isAncestorOf b a then
                    PTree.subtreeAt t a
                  else none)
                rest
            have htail' :
                coalgebraForestTensorTermOfPairs tailPairs =
                  (HQ.ofForest tailForest, 0) := by
              simpa [tailPairs, tailForest] using htail
            have hcalc :
                coalgebraForestTensorTermOfPairs
                    ((u, [([] : Address)]) :: tailPairs) =
                  (HQ.ofForest (u :: tailForest), 0) := by
              calc
                coalgebraForestTensorTermOfPairs
                    ((u, [([] : Address)]) :: tailPairs)
                    =
                    HypersequentTensorBasis.mul
                      (coalgebraTensorTermOfCutList u [([] : Address)])
                      (coalgebraForestTensorTermOfPairs tailPairs) := rfl
                _ =
                    HypersequentTensorBasis.mul
                      (HQ.singleton u, 0)
                      (HQ.ofForest tailForest, 0) := by
                      rw [coalgebraTensorTermOfCutList_root, htail']
                _ = (HQ.ofForest (u :: tailForest), 0) := by
                      simp [HypersequentTensorBasis.mul, HQ.ofForest_cons]
            have hpairs :
                firstStageOutsideSecondProfilePairs t (a :: rest) cut₂ =
                  (u, [([] : Address)]) :: tailPairs := by
              simp only [firstStageOutsideSecondProfilePairs,
                List.filterMap_cons, if_pos hsurvive, hsub, tailPairs]
            have hforest :
                firstStageOutsideSecondForest t (a :: rest) cut₂ =
                  u :: tailForest := by
              simp only [firstStageOutsideSecondForest,
                List.filterMap_cons, if_pos hsurvive, hsub, tailForest]
            rw [hpairs, hforest]
            exact hcalc
      · simpa [firstStageOutsideSecondProfilePairs,
          firstStageOutsideSecondForest, hsurvive] using htail

theorem stageAmbientCut_profilePairs_eq_stagedRightWitnessProfilePairs
    {t : PTree} {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts t)
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.remainderGo cut₁ [] t)) :
    (stageAmbientCut cut₁ cut₂).filterMap (fun a =>
        match PTree.subtreeAt t a with
        | some u =>
            some
              (u,
                if a ∈ cut₂ then
                  PTree.restrictCutAt cut₁ a
                else
                  [([] : Address)])
        | none => none) =
      stagedRightWitnessProfilePairs t cut₁ cut₂ := by
  classical
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₁ with
    ⟨hcoal₁, _hint₁⟩
  unfold stageAmbientCut stagedRightWitnessProfilePairs
    firstStageOutsideSecondProfilePairs secondStageRestrictedProfilePairs
  rw [List.filterMap_append]
  congr 1
  · rw [filter_filterMap_eq_filterMap_if_core
      cut₁
      (fun a => ∀ b : Address, b ∈ cut₂ → ¬ PTree.isAncestorOf b a)
      (fun a =>
        match PTree.subtreeAt t a with
        | some u =>
            some
              (u,
                if a ∈ cut₂ then
                  PTree.restrictCutAt cut₁ a
                else
                  [([] : Address)])
        | none => none)]
    apply List.filterMap_congr
    intro a ha
    by_cases hsurvive :
        ∀ b : Address, b ∈ cut₂ → ¬ PTree.isAncestorOf b a
    · have hnot₂ : a ∉ cut₂ := by
        intro ha₂
        exact disjoint_previous_cut_second_internal_cut
          (t := t) (cut₁ := cut₁) (cut₂ := cut₂)
          hcoal₁ hcut₂ a ha ha₂
      cases hsub : PTree.subtreeAt t a <;>
        simp [hsurvive, hnot₂, hsub]
    · simp [hsurvive]
  · apply List.filterMap_congr
    intro b hb
    cases hsub : PTree.subtreeAt t b <;> simp [hb, hsub]

theorem not_forall_not_isAncestorOf_iff_exists
    (cut₂ : List Address) (a : Address) :
    (¬ ∀ b : Address, b ∈ cut₂ → ¬ PTree.isAncestorOf b a) ↔
      ∃ b : Address, b ∈ cut₂ ∧ PTree.isAncestorOf b a := by
  constructor
  · intro h
    by_contra hnone
    exact h (by
      intro b hb hba
      exact hnone ⟨b, hb, hba⟩)
  · rintro ⟨b, hb, hba⟩ hforall
    exact hforall b hb hba

theorem firstStageForest_perm_outside_append_dominated
    (t : PTree) (cut₁ cut₂ : List Address) :
    List.Perm
      (cut₁.filterMap (PTree.subtreeAt t))
      (firstStageOutsideSecondForest t cut₁ cut₂ ++
        firstStageDominatedBySecondForest t cut₁ cut₂) := by
  classical
  let P : Address → Prop :=
    fun a => ∀ b : Address, b ∈ cut₂ → ¬ PTree.isAncestorOf b a
  have haddr :=
    List.perm_filter_append_filter_not cut₁
      (fun a => decide (P a))
  have hpart :
      List.Perm
        (cut₁.filterMap (PTree.subtreeAt t))
        ((cut₁.filter (fun a => decide (P a))).filterMap
            (PTree.subtreeAt t) ++
          (cut₁.filter (fun a => ! decide (P a))).filterMap
            (PTree.subtreeAt t)) := by
    simpa [P, List.filterMap_append] using
      haddr.filterMap (PTree.subtreeAt t)
  have houtside :
      (cut₁.filter (fun a => decide (P a))).filterMap
          (PTree.subtreeAt t) =
        firstStageOutsideSecondForest t cut₁ cut₂ := by
    simpa [P, firstStageOutsideSecondForest] using
      (filter_filterMap_eq_filterMap_if_core cut₁ P (PTree.subtreeAt t))
  have hdominated :
      (cut₁.filter (fun a => ! decide (P a))).filterMap
          (PTree.subtreeAt t) =
        firstStageDominatedBySecondForest t cut₁ cut₂ := by
    have hfilter :
        (cut₁.filter (fun a => ! decide (P a))).filterMap
            (PTree.subtreeAt t) =
          (cut₁.filter (fun a => decide (¬ P a))).filterMap
            (PTree.subtreeAt t) := by
      congr 1
      apply List.filter_congr
      intro a _ha
      by_cases ha : P a <;> simp [ha]
    have hnot :
        (cut₁.filter (fun a => decide (¬ P a))).filterMap
            (PTree.subtreeAt t) =
          cut₁.filterMap
            (fun a => if ¬ P a then PTree.subtreeAt t a else none) :=
      filter_filterMap_eq_filterMap_if_core cut₁ (fun a => ¬ P a)
        (PTree.subtreeAt t)
    exact hfilter.trans (by
      simpa [P, firstStageDominatedBySecondForest,
        not_forall_not_isAncestorOf_iff_exists] using hnot)
  simpa [firstStageOutsideSecondForest,
    firstStageDominatedBySecondForest, houtside, hdominated]
    using hpart

theorem filter_filterMap_eq_filterMap_if
    {α β : Type _} (xs : List α) (p : α → Prop) [DecidablePred p]
    (f : α → Option β) :
    (xs.filter (fun x => decide (p x))).filterMap f =
      xs.filterMap (fun x => if p x then f x else none) := by
  induction xs with
  | nil =>
      simp
  | cons x xs ih =>
      by_cases hx : p x
      · cases hfx : f x <;> simp [List.filter, hx, ih, hfx]
      · simp [List.filter, hx, ih]

theorem firstStageDominatedBySecondForest_eq_filterMap_addresses
    (t : PTree) (cut₁ cut₂ : List Address) :
    firstStageDominatedBySecondForest t cut₁ cut₂ =
      (firstStageDominatedBySecondAddresses cut₁ cut₂).filterMap
        (PTree.subtreeAt t) := by
  classical
  unfold firstStageDominatedBySecondForest
    firstStageDominatedBySecondAddresses
  rw [filter_filterMap_eq_filterMap_if]

/-- Subtree lookup commutes with appending an address below a known subtree. -/
theorem PTree.subtreeAt_append_of_subtreeAt
    {t u : PTree} {a b : Address}
    (hsub : PTree.subtreeAt t a = some u) :
    PTree.subtreeAt t (a ++ b) = PTree.subtreeAt u b := by
  induction a generalizing t u with
  | nil =>
      simp [PTree.subtreeAt] at hsub
      subst u
      simp
  | cons i rest ih =>
      cases t with
      | leaf s =>
          simp [PTree.subtreeAt] at hsub
      | node r s cs =>
          by_cases hi : i < cs.length
          · simp [PTree.subtreeAt, hi] at hsub
            simpa [List.cons_append, PTree.subtreeAt, hi] using
              ih (t := cs[i]) (u := u) hsub
          · simp [PTree.subtreeAt, hi] at hsub

theorem firstStageInsideSecondForest_eq_filterMap_addresses
    {t : PTree} {cut₁ cut₂ : List Address}
    (hvalid₂ : ∀ b : Address, b ∈ cut₂ → ∃ u, PTree.subtreeAt t b = some u) :
    firstStageInsideSecondForest t cut₁ cut₂ =
      (firstStageInsideSecondAddresses cut₁ cut₂).filterMap
        (PTree.subtreeAt t) := by
  induction cut₂ with
  | nil =>
      simp [firstStageInsideSecondForest, firstStageInsideSecondAddresses]
  | cons b rest ih =>
      rcases hvalid₂ b (by simp) with ⟨u, hsub⟩
      have htail :
          firstStageInsideSecondForest t cut₁ rest =
            (firstStageInsideSecondAddresses cut₁ rest).filterMap
              (PTree.subtreeAt t) := by
        apply ih
        intro c hc
        exact hvalid₂ c (by simp [hc])
      have hhead :
          (PTree.restrictCutAt cut₁ b).filterMap (PTree.subtreeAt u) =
            ((PTree.restrictCutAt cut₁ b).map (fun c => b ++ c)).filterMap
              (PTree.subtreeAt t) := by
        rw [List.filterMap_map]
        apply List.filterMap_congr
        intro c _hc
        exact (PTree.subtreeAt_append_of_subtreeAt
          (t := t) (u := u) (a := b) (b := c) hsub).symm
      simpa [firstStageInsideSecondForest, firstStageInsideSecondAddresses,
        hsub, hhead, List.filterMap_append] using htail

theorem mem_firstStageInsideSecondAddresses_iff
    {cut₁ cut₂ : List Address} {a : Address} :
    a ∈ firstStageInsideSecondAddresses cut₁ cut₂ ↔
      ∃ b : Address, b ∈ cut₂ ∧
        ∃ c : Address, c ∈ PTree.restrictCutAt cut₁ b ∧ a = b ++ c := by
  unfold firstStageInsideSecondAddresses
  constructor
  · intro ha
    rcases List.mem_flatMap.1 ha with ⟨b, hb, haMap⟩
    rcases List.mem_map.1 haMap with ⟨c, hc, hEq⟩
    exact ⟨b, hb, c, hc, hEq.symm⟩
  · rintro ⟨b, hb, c, hc, rfl⟩
    exact List.mem_flatMap.2
      ⟨b, hb, List.mem_map.2 ⟨c, hc, rfl⟩⟩

theorem mem_firstStageDominatedBySecondAddresses_iff
    {cut₁ cut₂ : List Address} {a : Address} :
    a ∈ firstStageDominatedBySecondAddresses cut₁ cut₂ ↔
      a ∈ cut₁ ∧ ∃ b : Address, b ∈ cut₂ ∧ PTree.isAncestorOf b a := by
  classical
  unfold firstStageDominatedBySecondAddresses
  simp

theorem mem_firstStageInsideSecondAddresses_iff_dominated
    {cut₁ cut₂ : List Address} {a : Address} :
    a ∈ firstStageInsideSecondAddresses cut₁ cut₂ ↔
      a ∈ cut₁ ∧ ∃ b : Address, b ∈ cut₂ ∧ PTree.isAncestorOf b a := by
  constructor
  · intro ha
    rcases (mem_firstStageInsideSecondAddresses_iff
      (cut₁ := cut₁) (cut₂ := cut₂) (a := a)).1 ha with
      ⟨b, hb, c, hc, rfl⟩
    have hcut₁ : b ++ c ∈ cut₁ := by
      simpa using
        (PTree.mem_restrictCutAt_iff
          (cut := cut₁) (pfx := b) (addr := c)).1 hc
    exact ⟨hcut₁, b, hb, ⟨c, rfl⟩⟩
  · rintro ⟨ha₁, b, hb₂, c, hEq⟩
    exact (mem_firstStageInsideSecondAddresses_iff
      (cut₁ := cut₁) (cut₂ := cut₂) (a := a)).2
      ⟨b, hb₂, c,
        (PTree.mem_restrictCutAt_iff
          (cut := cut₁) (pfx := b) (addr := c)).2 (by
            simpa [hEq] using ha₁),
        hEq⟩

theorem comparable_of_common_descendant
    {a b c : Address}
    (ha : PTree.isAncestorOf a c)
    (hb : PTree.isAncestorOf b c) :
    PTree.comparable a b := by
  rcases ha with ⟨ca, hca⟩
  rcases hb with ⟨cb, hcb⟩
  by_cases hlen : a.length ≤ b.length
  · have hp : a <+: b ++ cb := by
      refine ⟨ca, ?_⟩
      exact hca.symm.trans hcb
    have hpab : a <+: b :=
      (List.isPrefix_append_of_length
        (l₁ := a) (l₂ := b) (l₃ := cb) hlen).1 hp
    rcases hpab with ⟨d, hd⟩
    exact Or.inl ⟨d, hd.symm⟩
  · have hlen' : b.length ≤ a.length := Nat.le_of_not_ge hlen
    have hp : b <+: a ++ ca := by
      refine ⟨cb, ?_⟩
      exact hcb.symm.trans hca
    have hpba : b <+: a :=
      (List.isPrefix_append_of_length
        (l₁ := b) (l₂ := a) (l₃ := ca) hlen').1 hp
    rcases hpba with ⟨d, hd⟩
    exact Or.inr ⟨d, hd.symm⟩

theorem comparable_prefixes_of_comparable_appends
    {a b c d : Address}
    (hcomp : PTree.comparable (a ++ c) (b ++ d)) :
    PTree.comparable a b := by
  rcases hcomp with hleft | hright
  · have ha : PTree.isAncestorOf a (b ++ d) := by
      rcases hleft with ⟨e, he⟩
      exact ⟨c ++ e, by
        rw [he, List.append_assoc]⟩
    have hb : PTree.isAncestorOf b (b ++ d) := ⟨d, rfl⟩
    exact comparable_of_common_descendant ha hb
  · have ha : PTree.isAncestorOf a (a ++ c) := ⟨c, rfl⟩
    have hb : PTree.isAncestorOf b (a ++ c) := by
      rcases hright with ⟨e, he⟩
      exact ⟨d ++ e, by
        rw [he, List.append_assoc]⟩
    exact comparable_of_common_descendant ha hb

theorem comparable_suffixes_of_comparable_same_prefix
    {p a b : Address}
    (hcomp : PTree.comparable (p ++ a) (p ++ b)) :
    PTree.comparable a b := by
  rcases hcomp with hleft | hright
  · rcases hleft with ⟨c, hc⟩
    exact Or.inl ⟨c, by
      exact (List.append_right_injective p)
        (by simpa [List.append_assoc] using hc)⟩
  · rcases hright with ⟨c, hc⟩
    exact Or.inr ⟨c, by
      exact (List.append_right_injective p)
        (by simpa [List.append_assoc] using hc)⟩

theorem restrictCutAt_nodup_of_nodup
    {cut : List Address} {pfx : Address}
    (hnodup : cut.Nodup) :
    (PTree.restrictCutAt cut pfx).Nodup := by
  induction pfx generalizing cut with
  | nil =>
      simpa [PTree.restrictCutAt] using hnodup
  | cons i rest ih =>
      simpa [PTree.restrictCutAt] using
        ih (cut := PTree.restrictCut cut i)
          (PTree.restrictCut_nodup_of_nodup hnodup)

theorem prefix_restrictCutAt_nodup_of_nodup
    {cut : List Address} {pfx : Address}
    (hnodup : cut.Nodup) :
    ((PTree.restrictCutAt cut pfx).map (fun c => pfx ++ c)).Nodup := by
  exact (restrictCutAt_nodup_of_nodup
    (cut := cut) (pfx := pfx) hnodup).map
      (List.append_right_injective pfx)

theorem firstStageInsideSecondAddresses_nodup
    {cut₁ cut₂ : List Address}
    (hnodup₁ : cut₁.Nodup)
    (hnodup₂ : cut₂.Nodup)
    (hanti₂ :
      ∀ b₁, b₁ ∈ cut₂ →
        ∀ b₂, b₂ ∈ cut₂ →
          b₁ ≠ b₂ → ¬ PTree.comparable b₁ b₂) :
    (firstStageInsideSecondAddresses cut₁ cut₂).Nodup := by
  unfold firstStageInsideSecondAddresses
  rw [List.nodup_flatMap]
  constructor
  · intro b _hb
    exact prefix_restrictCutAt_nodup_of_nodup
      (cut := cut₁) (pfx := b) hnodup₁
  · exact hnodup₂.pairwise_of_forall_ne (by
      intro b₁ hb₁ b₂ hb₂ hne x hx₁ hx₂
      rcases List.mem_map.1 hx₁ with ⟨c₁, _hc₁, hx₁Eq⟩
      rcases List.mem_map.1 hx₂ with ⟨c₂, _hc₂, hx₂Eq⟩
      have hanc₁ : PTree.isAncestorOf b₁ x := ⟨c₁, hx₁Eq.symm⟩
      have hanc₂ : PTree.isAncestorOf b₂ x := ⟨c₂, hx₂Eq.symm⟩
      exact hanti₂ b₁ hb₁ b₂ hb₂ hne
        (comparable_of_common_descendant hanc₁ hanc₂))

theorem firstStageDominatedBySecondAddresses_perm_inside
    {cut₁ cut₂ : List Address}
    (hnodup₁ : cut₁.Nodup)
    (hnodup₂ : cut₂.Nodup)
    (hanti₂ :
      ∀ b₁, b₁ ∈ cut₂ →
        ∀ b₂, b₂ ∈ cut₂ →
          b₁ ≠ b₂ → ¬ PTree.comparable b₁ b₂) :
    List.Perm
      (firstStageDominatedBySecondAddresses cut₁ cut₂)
      (firstStageInsideSecondAddresses cut₁ cut₂) := by
  classical
  have hdomNodup :
      (firstStageDominatedBySecondAddresses cut₁ cut₂).Nodup := by
    unfold firstStageDominatedBySecondAddresses
    exact list_filter_nodup
      (fun a => decide
        (∃ b : Address, b ∈ cut₂ ∧ PTree.isAncestorOf b a))
      hnodup₁
  have hinsNodup :
      (firstStageInsideSecondAddresses cut₁ cut₂).Nodup :=
    firstStageInsideSecondAddresses_nodup
      (cut₁ := cut₁) (cut₂ := cut₂)
      hnodup₁ hnodup₂ hanti₂
  have hsubDomInside :
      List.Subperm
        (firstStageDominatedBySecondAddresses cut₁ cut₂)
        (firstStageInsideSecondAddresses cut₁ cut₂) :=
    hdomNodup.subperm (by
      intro a ha
      exact (mem_firstStageInsideSecondAddresses_iff_dominated
        (cut₁ := cut₁) (cut₂ := cut₂) (a := a)).2
        ((mem_firstStageDominatedBySecondAddresses_iff
          (cut₁ := cut₁) (cut₂ := cut₂) (a := a)).1 ha))
  have hsubInsideDom :
      List.Subperm
        (firstStageInsideSecondAddresses cut₁ cut₂)
        (firstStageDominatedBySecondAddresses cut₁ cut₂) :=
    hinsNodup.subperm (by
      intro a ha
      exact (mem_firstStageDominatedBySecondAddresses_iff
        (cut₁ := cut₁) (cut₂ := cut₂) (a := a)).2
        ((mem_firstStageInsideSecondAddresses_iff_dominated
          (cut₁ := cut₁) (cut₂ := cut₂) (a := a)).1 ha))
  exact hsubDomInside.antisymm hsubInsideDom

theorem firstStageDominatedBySecondForest_perm_inside_of_address_perm
    {t : PTree} {cut₁ cut₂ : List Address}
    (hvalid₂ : ∀ b : Address, b ∈ cut₂ → ∃ u, PTree.subtreeAt t b = some u)
    (haddr :
      List.Perm
        (firstStageDominatedBySecondAddresses cut₁ cut₂)
        (firstStageInsideSecondAddresses cut₁ cut₂)) :
    List.Perm
      (firstStageDominatedBySecondForest t cut₁ cut₂)
      (firstStageInsideSecondForest t cut₁ cut₂) := by
  rw [firstStageDominatedBySecondForest_eq_filterMap_addresses,
    firstStageInsideSecondForest_eq_filterMap_addresses hvalid₂]
  exact haddr.filterMap (PTree.subtreeAt t)

theorem stageAmbientCut_filterMap_subtreeAt_eq_outside_append_secondOriginal
    (t : PTree) (cut₁ cut₂ : List Address) :
    (stageAmbientCut cut₁ cut₂).filterMap (PTree.subtreeAt t) =
      firstStageOutsideSecondForest t cut₁ cut₂ ++
        secondStageOriginalSubtreeForest t cut₂ := by
  classical
  unfold stageAmbientCut firstStageOutsideSecondForest
    secondStageOriginalSubtreeForest
  rw [List.filterMap_append]
  congr 1
  exact filter_filterMap_eq_filterMap_if cut₁
    (fun a => ∀ b : Address, b ∈ cut₂ → ¬ PTree.isAncestorOf b a)
    (PTree.subtreeAt t)

theorem nodeCanonicalAmbientDetachedForest_perm_outside_append_secondOriginal
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address}
    (hstage :
      List.Perm
        (nodeRootFreeCutDetachedForest cs
          (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂))
        ((stageAmbientCut cut₁ cut₂).filterMap
          (PTree.subtreeAt (PTree.node r s cs)))) :
    List.Perm
      (nodeRootFreeCutDetachedForest cs
        (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂))
      (firstStageOutsideSecondForest (PTree.node r s cs) cut₁ cut₂ ++
        secondStageOriginalSubtreeForest (PTree.node r s cs) cut₂) := by
  exact hstage.trans (by
    rw [stageAmbientCut_filterMap_subtreeAt_eq_outside_append_secondOriginal])

theorem nodeCanonicalAmbientCut_perm_stageAmbientCut
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))) :
    List.Perm
      (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂)
      (stageAmbientCut cut₁ cut₂) := by
  have hcanonInternal :
      nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂ ∈
        internalCoalgebraAdmissibleCuts (PTree.node r s cs) :=
    nodeCanonicalAmbientCut_mem_internalCoalgebraAdmissibleCuts
      (r := r) (s := s) (cs := cs)
      (cut₁ := cut₁) (cut₂ := cut₂) hcut₁ hcut₂
  have hcanonNodup :
      (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂).Nodup :=
    nodup_of_mem_internalCoalgebraAdmissibleCuts hcanonInternal
  have hstageNodup :
      (stageAmbientCut cut₁ cut₂).Nodup :=
    stageAmbientCut_nodup_of_internal_node_witness
      (r := r) (s := s) (cs := cs)
      (cut₁ := cut₁) (cut₂ := cut₂) hcut₁ hcut₂
  have hsubCanon :
      List.Subperm
        (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂)
        (stageAmbientCut cut₁ cut₂) :=
    hcanonNodup.subperm (by
      intro a ha
      simpa [nodeAmbientCutOfRightWitness] using
        (mem_nodeCanonicalAmbientCutOfRightWitness_iff
          (r := r) (s := s) (cs := cs)
          (cut₁ := cut₁) (cut₂ := cut₂)
          hcut₁ hcut₂).1 ha)
  have hsubStage :
      List.Subperm
        (stageAmbientCut cut₁ cut₂)
        (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂) :=
    hstageNodup.subperm (by
      intro a ha
      exact (mem_nodeCanonicalAmbientCutOfRightWitness_iff
        (r := r) (s := s) (cs := cs)
        (cut₁ := cut₁) (cut₂ := cut₂)
        hcut₁ hcut₂).2 (by
          simpa [nodeAmbientCutOfRightWitness] using ha))
  exact hsubCanon.antisymm hsubStage

theorem nodeCanonicalAmbientDetachedForest_perm_stage
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))) :
    List.Perm
      (nodeRootFreeCutDetachedForest cs
        (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂))
      ((stageAmbientCut cut₁ cut₂).filterMap
        (PTree.subtreeAt (PTree.node r s cs))) := by
  have hcanonInternal :
      nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂ ∈
        internalCoalgebraAdmissibleCuts (PTree.node r s cs) :=
    nodeCanonicalAmbientCut_mem_internalCoalgebraAdmissibleCuts
      (r := r) (s := s) (cs := cs)
      (cut₁ := cut₁) (cut₂ := cut₂) hcut₁ hcut₂
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcanonInternal with
    ⟨hcanonCoal, hcanonInt⟩
  have hrawNode :
      List.Perm
        ((nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂).filterMap
          (PTree.subtreeAt (PTree.node r s cs)))
        (nodeRootFreeCutDetachedForest cs
          (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂)) :=
    by
      simpa [coalgebraDetachedForestOfCut, hcanonInt.1, hcanonInt.2] using
        nodeRootFreeCut_detachedForest_perm
          (r := r) (s := s) (cs := cs)
          (cut := nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂)
          hcanonCoal hcanonInt.2
  have hcutPerm :
      List.Perm
        (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂)
        (stageAmbientCut cut₁ cut₂) :=
    nodeCanonicalAmbientCut_perm_stageAmbientCut
      (r := r) (s := s) (cs := cs)
      (cut₁ := cut₁) (cut₂ := cut₂) hcut₁ hcut₂
  exact hrawNode.symm.trans
    (hcutPerm.filterMap (PTree.subtreeAt (PTree.node r s cs)))

theorem nodeRootFreeCutDetachedForest_perm_outside_append_dominated
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs)) :
    List.Perm
      (nodeRootFreeCutDetachedForest cs cut₁)
      (firstStageOutsideSecondForest (PTree.node r s cs) cut₁ cut₂ ++
        firstStageDominatedBySecondForest (PTree.node r s cs) cut₁ cut₂) := by
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₁ with
    ⟨hcoal₁, hint₁⟩
  have hraw :
      List.Perm
        (cut₁.filterMap (PTree.subtreeAt (PTree.node r s cs)))
        (nodeRootFreeCutDetachedForest cs cut₁) := by
    simpa [coalgebraDetachedForestOfCut, hint₁.1, hint₁.2] using
      nodeRootFreeCut_detachedForest_perm
      (r := r) (s := s) (cs := cs)
      (cut := cut₁) hcoal₁ hint₁.2
  exact hraw.symm.trans
    (firstStageForest_perm_outside_append_dominated
      (PTree.node r s cs) cut₁ cut₂)

theorem nodeRootFreeCutDetachedForest_perm_outside_append_inside_of_dominated
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (hdom :
      List.Perm
        (firstStageDominatedBySecondForest (PTree.node r s cs) cut₁ cut₂)
        (firstStageInsideSecondForest (PTree.node r s cs) cut₁ cut₂)) :
    List.Perm
      (nodeRootFreeCutDetachedForest cs cut₁)
      (firstStageOutsideSecondForest (PTree.node r s cs) cut₁ cut₂ ++
        firstStageInsideSecondForest (PTree.node r s cs) cut₁ cut₂) := by
  exact (nodeRootFreeCutDetachedForest_perm_outside_append_dominated
    (r := r) (s := s) (cs := cs)
    (cut₁ := cut₁) (cut₂ := cut₂) hcut₁).trans
      (List.Perm.append_left
        (firstStageOutsideSecondForest (PTree.node r s cs) cut₁ cut₂)
        hdom)

theorem coalgebraDetachedForestOfCut_second_internal_eq_restrictedRemainderForest
    {t : PTree} {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ coalgebraAdmissibleCuts t)
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.remainderGo cut₁ [] t)) :
    coalgebraDetachedForestOfCut (PTree.remainderGo cut₁ [] t) cut₂ =
      secondStageRestrictedRemainderForest t cut₁ cut₂ := by
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₂ with
    ⟨hcoal₂, hint₂⟩
  simp [coalgebraDetachedForestOfCut, hint₂.1, hint₂.2,
    secondStageRestrictedRemainderForest]
  apply List.filterMap_congr
  intro b hb
  rcases node_addresses_of_mem_remainder_coalgebraAdmissibleCuts_of_internal
      (t := t) (cut₁ := cut₁) (cut₂ := cut₂)
      hcoal₂ hint₂ b hb with
    ⟨r, s, cs, hsub⟩
  have hdesc :
      PTree.subtreeAt (PTree.remainderGo cut₁ [] t) b =
        some
          (PTree.remainderGo (PTree.restrictCutAt cut₁ b) []
            (PTree.node r s cs)) :=
    subtreeAt_first_remainder_second_internal_cut_eq_restricted
      (t := t) (cut₁ := cut₁) (cut₂ := cut₂)
      (b := b) (u := PTree.node r s cs)
      hcut₁ hcut₂ hb hsub
  simp [hsub, hdesc]

theorem ofForest_coalgebraDetachedForestOfCut_second_internal_eq_restrictedRemainderForest
    {t : PTree} {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ coalgebraAdmissibleCuts t)
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.remainderGo cut₁ [] t)) :
    HQ.ofForest
        (coalgebraDetachedForestOfCut (PTree.remainderGo cut₁ [] t) cut₂) =
      HQ.ofForest (secondStageRestrictedRemainderForest t cut₁ cut₂) := by
  rw [coalgebraDetachedForestOfCut_second_internal_eq_restrictedRemainderForest
    (t := t) (cut₁ := cut₁) (cut₂ := cut₂) hcut₁ hcut₂]

/--
The first-stage cut restricted below a second-stage internal address is a
coalgebra cut of the original subtree at that address.

This is the component-level cut used when an ambient detached tree is produced
by the second-stage cut: its left tensor factor is made from the first-stage
cuts strictly inside it, and its right tensor factor is the subtree visible in
the first remainder.
-/
theorem restrictCutAt_mem_coalgebraAdmissibleCuts_of_second_internal
    {t : PTree} {cut₁ cut₂ : List Address} {b : Address} {u : PTree}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts t)
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.remainderGo cut₁ [] t))
    (hb₂ : b ∈ cut₂)
    (hsub : PTree.subtreeAt t b = some u) :
    PTree.restrictCutAt cut₁ b ∈ coalgebraAdmissibleCuts u := by
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₁ with
    ⟨hcoal₁, hint₁⟩
  rcases (mem_coalgebraAdmissibleCuts_iff).1 hcoal₁ with
    ⟨hraw₁, _hcoalShape₁⟩
  refine (mem_coalgebraAdmissibleCuts_iff).2 ?_
  refine ⟨restrictCutAt_mem_allAdmissibleCuts_of_mem_subtreeAt
    (t := t) (u := u) (cut := cut₁) (a := b) hraw₁ hsub, ?_⟩
  classical
  by_cases hnil : PTree.restrictCutAt cut₁ b = []
  · exact Or.inl hnil
  · have hroot : ([] : Address) ∉ PTree.restrictCutAt cut₁ b := by
      intro hroot
      have hb₁ : b ∈ cut₁ := by
        simpa using
          (PTree.nil_mem_restrictCutAt_iff
            (cut := cut₁) (pfx := b)).1 hroot
      exact disjoint_previous_cut_second_internal_cut
        (t := t) (cut₁ := cut₁) (cut₂ := cut₂)
        hcoal₁ hcut₂ b hb₁ hb₂
    refine Or.inr (Or.inr ?_)
    intro addr haddr
    have hparent : b ++ addr ∈ cut₁ := by
      simpa using
        (PTree.mem_restrictCutAt_iff
          (cut := cut₁) (pfx := b) (addr := addr)).1 haddr
    have hnodeParent :
        IsNodeAddress t (b ++ addr) :=
      node_addresses_of_mem_coalgebraAdmissibleCuts_of_internal
        hcoal₁ hint₁ (b ++ addr) hparent
    exact (isNodeAddress_subtreeAt_append_iff
      (t := t) (u := u) (a := b) (b := addr) hsub).1 hnodeParent

theorem root_not_mem_restrictCutAt_of_second_internal
    {t : PTree} {cut₁ cut₂ : List Address} {b : Address}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts t)
