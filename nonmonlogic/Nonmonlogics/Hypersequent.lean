def hypersequentNormalizedHopfBasisAxioms_of_treeAntipodeCoassoc
    (K : Type) [CommRing K]
    (hBialg : HypersequentNormalizedBialgebraAxioms K)
    (T : NormalizedTreeAntipodeTarget K) :
    HypersequentNormalizedHopfBasisAxioms K hBialg
      (NormalizedTreeAntipodeTarget.linearization K T).linearMap where
  left_cancellation :=
    NormalizedTreeAntipodeTarget.left_convolution_monomial K T
  right_cancellation :=
    NormalizedTreeAntipodeTarget.right_convolution_monomial K T

noncomputable def hypersequentNormalizedHopfBasisAxioms_direct
    (K : Type) [CommRing K]
    [LeftDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    [RightDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))] :
