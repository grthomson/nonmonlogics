/--
Once the normalized bialgebra axioms and an antipode witness are supplied, the
normalized GL/CK route becomes a Mathlib `HopfAlgebra`.
-/
noncomputable def hypersequentNormalizedHopfAlgebra
    (hBialg : HypersequentNormalizedBialgebraAxioms R)
    (hHopf : HypersequentNormalizedHopfAxioms R hBialg) :
    HopfAlgebra R (HypersequentAlgebra R) where
  __ := hypersequentNormalizedBialgebra R hBialg
  antipode := hHopf.antipode
  mul_antipode_rTensor_comul := by
    change LinearMap.mul' R (HypersequentAlgebra R) ∘ₗ
        LinearMap.rTensor (HypersequentAlgebra R) hHopf.antipode ∘ₗ
          hypersequentCoalgebraComulTensorLinearMap R =
      Algebra.linearMap R (HypersequentAlgebra R) ∘ₗ
        (hypersequentCounitAlgHom R).toLinearMap
    exact hHopf.right_cancellation
  mul_antipode_lTensor_comul := by
    change LinearMap.mul' R (HypersequentAlgebra R) ∘ₗ
        LinearMap.lTensor (HypersequentAlgebra R) hHopf.antipode ∘ₗ
          hypersequentCoalgebraComulTensorLinearMap R =
      Algebra.linearMap R (HypersequentAlgebra R) ∘ₗ
        (hypersequentCounitAlgHom R).toLinearMap
    exact hHopf.left_cancellation

noncomputable def hypersequentNormalizedHopfAlgebra_direct
    (K : Type) [CommRing K]
    [LeftDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    [RightDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))] :
    HopfAlgebra K (HypersequentAlgebra K) :=
  hypersequentNormalizedHopfAlgebra K
    (hypersequentNormalizedBialgebraAxioms_direct (R := K))
    (hypersequentNormalizedHopfAxioms_direct K)

/-- Data completing the normalized Hopf algebra from a bialgebra completion. -/
structure HypersequentNormalizedHopfCompletionData where
  bialgebraData : HypersequentNormalizedBialgebraCompletionData R
  antipode : HypersequentAlgebra R →ₗ[R] HypersequentAlgebra R
  cancellation :
    HypersequentNormalizedHopfBasisAxioms R
      bialgebraData.bialgebraAxioms antipode

structure HypersequentNormalizedHopfDecompositionData where
  bialgebraData : HypersequentNormalizedBialgebraDecompositionData R
  antipode : HypersequentAlgebra R →ₗ[R] HypersequentAlgebra R
  cancellation :
    HypersequentNormalizedHopfBasisAxioms R
      bialgebraData.bialgebraAxioms antipode

namespace HypersequentNormalizedHopfCompletionData

def hopfAxioms
    (H : HypersequentNormalizedHopfCompletionData R) :
