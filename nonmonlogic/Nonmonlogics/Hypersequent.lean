theorem nodeRightWitnessAmbientProfile_zip_perm_staged
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))) :
    List.Perm
      (List.zip
        (nodeRootFreeCutDetachedForest cs
          (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂))
        (nodeRightWitnessAmbientProfile r s cs cut₁ cut₂))
      (stagedRightWitnessProfilePairs (PTree.node r s cs) cut₁ cut₂) := by
  let t := PTree.node r s cs
  let ambient := nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂
  let addrs := nodeRootFreeCutPrefixedRestrictions cs ambient
  let profile := nodeRightWitnessAmbientProfile r s cs cut₁ cut₂
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₁ with
    ⟨_hcoal₁, hint₁⟩
  have hfirstRem :
      PTree.remainderGo cut₁ [] t =
        PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁) := by
    simpa [t, nodeRootFreeCutRemainderChildren] using
      PTree.remainderGo_node_root_not_mem
        (r := r) (s := s) (cs := cs)
        (cut := cut₁) hint₁.2
  have hcut₂Rem :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.remainderGo cut₁ [] t) := by
    simpa [t, hfirstRem] using hcut₂
  have hambient :
      ambient ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs) := by
    simpa [ambient] using
      nodeCanonicalAmbientCut_mem_internalCoalgebraAdmissibleCuts
        (r := r) (s := s) (cs := cs)
        (cut₁ := cut₁) (cut₂ := cut₂) hcut₁ hcut₂
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hambient with
    ⟨hambientCoal, hambientInternal⟩
  have hall :
      ∀ a, a ∈ addrs →
        ∃ u, PTree.subtreeAt t a = some u := by
    intro a ha
    simpa [t, addrs, ambient] using
      subtreeAt_some_of_mem_nodeRootFreeCutPrefixedRestrictions
        (r := r) (s := s) (cs := cs)
        (cut := ambient) (a := a)
        hambientCoal hambientInternal.2 ha
  let pairFn : Address → Option (PTree × List Address) := fun a =>
    match PTree.subtreeAt t a with
    | some u =>
        some
          (u,
            if a ∈ cut₂ then
              PTree.restrictCutAt cut₁ a
            else
              [([] : Address)])
    | none => none
  have hzipEq :
      List.zip (addrs.filterMap (PTree.subtreeAt t)) profile =
        addrs.filterMap pairFn := by
    have hprofile :
        profile =
          addrs.map (fun a =>
            if a ∈ cut₂ then
              PTree.restrictCutAt cut₁ a
            else
              [([] : Address)]) := by
      simp [profile, addrs, ambient, nodeRightWitnessAmbientProfile]
    rw [hprofile]
    let g : Address → Option PTree := PTree.subtreeAt t
    let f : Address → List Address := fun a =>
      if a ∈ cut₂ then
        PTree.restrictCutAt cut₁ a
      else
        [([] : Address)]
    change
      List.zip (addrs.filterMap g) (addrs.map f) =
        addrs.filterMap (fun x =>
          match g x with
          | some y => some (y, f x)
          | none => none)
    have hzipAll :
        ∀ xs : List Address,
          (∀ x, x ∈ xs → ∃ y, g x = some y) →
            List.zip (xs.filterMap g) (xs.map f) =
              xs.filterMap (fun x =>
                match g x with
                | some y => some (y, f x)
                | none => none) := by
      intro xs
      induction xs with
      | nil =>
          intro _hxs
          simp
      | cons x xs ih =>
          intro hxs
          rcases hxs x (show x ∈ x :: xs from List.mem_cons.2 (Or.inl rfl)) with
            ⟨y, hy⟩
          have htail :
              List.zip (List.filterMap g xs) (List.map f xs) =
                List.filterMap
                  (fun x =>
                    match g x with
                    | some y => some (y, f x)
                    | none => none)
                  xs := by
            apply ih
            intro z hz
            exact hxs z (List.mem_cons.2 (Or.inr hz))
          rw [show List.filterMap g (x :: xs) =
                y :: List.filterMap g xs from by
                  simp [List.filterMap_cons, hy],
              List.map_cons]
          simp [List.filterMap_cons, hy, htail]
    exact hzipAll addrs hall
  have hleftEq :
      List.zip
          (nodeRootFreeCutDetachedForest cs ambient)
          profile =
        addrs.filterMap pairFn := by
    simpa [addrs, ambient, t, profile,
      nodeRootFreeCutPrefixedRestrictions_filterMap_subtreeAt] using hzipEq
  have hpref :
      List.Perm ambient addrs := by
    simpa [addrs, ambient] using
      nodeRootFreeCut_perm_prefixedRestrictions
        (r := r) (s := s) (cs := cs)
        (cut := ambient) hambientCoal hambientInternal.2
  have hstage :
      List.Perm ambient (stageAmbientCut cut₁ cut₂) := by
    simpa [ambient, nodeAmbientCutOfRightWitness] using
      nodeCanonicalAmbientCut_perm_stageAmbientCut
        (r := r) (s := s) (cs := cs)
        (cut₁ := cut₁) (cut₂ := cut₂) hcut₁ hcut₂
  have haddrStage :
      List.Perm addrs (stageAmbientCut cut₁ cut₂) :=
    hpref.symm.trans hstage
  have hpairPerm :
      List.Perm (addrs.filterMap pairFn)
        ((stageAmbientCut cut₁ cut₂).filterMap pairFn) :=
    haddrStage.filterMap pairFn
  have hstageEq :
      (stageAmbientCut cut₁ cut₂).filterMap pairFn =
        stagedRightWitnessProfilePairs t cut₁ cut₂ := by
    simpa [pairFn] using
      stageAmbientCut_profilePairs_eq_stagedRightWitnessProfilePairs
        (t := t) (cut₁ := cut₁) (cut₂ := cut₂)
        hcut₁ hcut₂Rem
  rw [hleftEq]
  exact hpairPerm.trans (by simpa [t, hstageEq])

