      NormalizedAntipodeRemainderBogoliubovPreviousFuel K T.stableAntipode)
    (hcompat :
      NormalizedAntipodeRemainderCutFuelCompatibility K T.stableAntipode) :
    HypersequentNormalizedHopfBasisAxioms K hBialg
      (NormalizedTreeAntipodeTarget.linearization K T).linearMap :=
  hypersequentNormalizedHopfBasisAxioms_of_treeAntipodeRemainderBogoliubov
    K hBialg T
    (NormalizedTreeAntipodeTarget.remainder_bogoliubov_of_previousFuel
      K T hprev hcompat)

def hypersequentNormalizedHopfBasisAxioms_of_treeAntipodeStableSymmetry
    (K : Type) [CommRing K]
    (hBialg : HypersequentNormalizedBialgebraAxioms K)
    (T : NormalizedTreeAntipodeTarget K)
    (hsym :
      NormalizedStableAntipodeProperCutRemainderSymmetry K T.stableAntipode) :
    HypersequentNormalizedHopfBasisAxioms K hBialg
      (NormalizedTreeAntipodeTarget.linearization K T).linearMap :=
  hypersequentNormalizedHopfBasisAxioms_of_treeAntipodeRemainderBogoliubov
    K hBialg T
    (by
      intro t
      exact
        NormalizedStableTreeAntipode.remainder_bogoliubov_of_stable_symmetry
