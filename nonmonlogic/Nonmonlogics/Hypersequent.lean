          (PTree.remainderGo (PTree.restrictCutAt cut₁ b) [] u)) := by
  exact coalgebraTensorTermOfCutList_of_ne_nil_of_root_not_mem
    (t := u) (cut := PTree.restrictCutAt cut₁ b)
