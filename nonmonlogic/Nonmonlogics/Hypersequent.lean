def hypersequentNormalizedHopfAxioms_of_basis
    (hBialg : HypersequentNormalizedBialgebraAxioms R)
    (S : HypersequentAlgebra R →ₗ[R] HypersequentAlgebra R)
    (hS : HypersequentNormalizedHopfBasisAxioms R hBialg S) :
    HypersequentNormalizedHopfAxioms R hBialg where
  antipode := S
  left_cancellation := by
    exact hypersequentAlgebra_linearMap_ext R _ _ hS.left_cancellation
  right_cancellation := by
    exact hypersequentAlgebra_linearMap_ext R _ _ hS.right_cancellation

noncomputable def hypersequentNormalizedHopfAxioms_direct
    (K : Type) [CommRing K]
    [LeftDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    [RightDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))] :
    HypersequentNormalizedHopfAxioms K
      (hypersequentNormalizedBialgebraAxioms_direct (R := K)) :=
  hypersequentNormalizedHopfAxioms_of_basis K
    (hypersequentNormalizedBialgebraAxioms_direct (R := K))
    (NormalizedTreeAntipodeTarget.linearization K
      (normalizedTreeAntipodeTargetOfSize K)).linearMap
    (hypersequentNormalizedHopfBasisAxioms_direct K)

@[simp]
theorem hypersequentNormalizedHopfAxioms_direct_antipode_tree
    (K : Type) [CommRing K]
    [LeftDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    [RightDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    (t : PTree) :
    (hypersequentNormalizedHopfAxioms_direct K).antipode
        (treeMonomial K t) =
      normalizedAntipodeTreeApprox K t.size t := by
  change
    (normalizedStableAntipodeAlgHom K
        (normalizedStableTreeAntipodeOfSize K)).toLinearMap
        (treeMonomial K t) =
      normalizedAntipodeTreeApprox K t.size t
  rw [show
      (normalizedStableAntipodeAlgHom K
          (normalizedStableTreeAntipodeOfSize K)).toLinearMap
          (treeMonomial K t) =
        normalizedStableAntipodeAlgHom K
          (normalizedStableTreeAntipodeOfSize K) (treeMonomial K t) from rfl]
  rw [normalizedStableAntipodeAlgHom_tree]
  rfl

