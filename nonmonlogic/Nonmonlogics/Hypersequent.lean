/-!
## Conditional normalized bialgebra and Hopf targets

For the normalized GL/CK route, the counit laws are now settled and the
coalgebra packaging is reduced to coassociativity.  The remaining algebraic
structure is therefore concentrated in the multiplicativity of the normalized
coproduct together with the eventual antipode cancellation identities.
-/

/-- The normalized tensor-product coproduct preserves the algebra unit. -/
def HypersequentNormalizedComulOne : Prop :=
  hypersequentCoalgebraComulTensorLinearMap R (1 : HypersequentAlgebra R) =
    (1 : TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))

theorem hypersequentNormalizedComulOne :
    HypersequentNormalizedComulOne R := by
  unfold HypersequentNormalizedComulOne
  exact hypersequentCoalgebraComulTensorLinearMap_one R

/--
The normalized tensor-product coproduct preserves multiplication.

This is the remaining algebra-hom part of the normalized bialgebra package.
Once proved, the normalized coalgebra data upgrades to a full Mathlib
`Bialgebra`.
-/
def HypersequentNormalizedComulMul : Prop :=
  ∀ x y : HypersequentAlgebra R,
    hypersequentCoalgebraComulTensorLinearMap R (x * y) =
      hypersequentCoalgebraComulTensorLinearMap R x *
        hypersequentCoalgebraComulTensorLinearMap R y

theorem hypersequentNormalizedComulMul
    [LeftDistribClass
      (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))]
    [RightDistribClass
      (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))] :
    HypersequentNormalizedComulMul R := by
  intro x
  refine AddMonoidAlgebra.induction_on
    (p := fun x =>
      ∀ y : HypersequentAlgebra R,
        hypersequentCoalgebraComulTensorLinearMap R (x * y) =
          hypersequentCoalgebraComulTensorLinearMap R x *
            hypersequentCoalgebraComulTensorLinearMap R y)
    x ?_ ?_ ?_
  · intro G
    intro y
    refine AddMonoidAlgebra.induction_on
      (p := fun y =>
        hypersequentCoalgebraComulTensorLinearMap R
            (hseqMonomial R G * y) =
          hypersequentCoalgebraComulTensorLinearMap R (hseqMonomial R G) *
            hypersequentCoalgebraComulTensorLinearMap R y)
      y ?_ ?_ ?_
    · intro H
      calc
        hypersequentCoalgebraComulTensorLinearMap R
            (hseqMonomial R G * hseqMonomial R H) =
          hypersequentCoalgebraComulTensorLinearMap R
            (hseqMonomial R (G + H)) := by
              rw [hseqMonomial_mul]
        _ =
          hypersequentCoalgebraComulTensorLinearMap R (hseqMonomial R G) *
            hypersequentCoalgebraComulTensorLinearMap R (hseqMonomial R H) := by
              exact hypersequentCoalgebraComulTensorLinearMap_monomial_mul
                (R := R) G H
        _ =
          hypersequentCoalgebraComulTensorLinearMap R (hseqMonomial R G) *
            hypersequentCoalgebraComulTensorLinearMap R (AddMonoidAlgebra.single H 1) := by
              rfl
    · intro y₁ y₂ hy₁ hy₂
      calc
        hypersequentCoalgebraComulTensorLinearMap R
            (hseqMonomial R G * (y₁ + y₂)) =
          hypersequentCoalgebraComulTensorLinearMap R
            (hseqMonomial R G * y₁ + hseqMonomial R G * y₂) := by
              rw [mul_add]
        _ =
          hypersequentCoalgebraComulTensorLinearMap R (hseqMonomial R G * y₁) +
            hypersequentCoalgebraComulTensorLinearMap R (hseqMonomial R G * y₂) := by
              rw [LinearMap.map_add]
        _ =
          hypersequentCoalgebraComulTensorLinearMap R (hseqMonomial R G) *
              hypersequentCoalgebraComulTensorLinearMap R y₁ +
            hypersequentCoalgebraComulTensorLinearMap R (hseqMonomial R G) *
              hypersequentCoalgebraComulTensorLinearMap R y₂ := by
              rw [hy₁, hy₂]
        _ =
          hypersequentCoalgebraComulTensorLinearMap R (hseqMonomial R G) *
            (hypersequentCoalgebraComulTensorLinearMap R y₁ +
              hypersequentCoalgebraComulTensorLinearMap R y₂) := by
              rw [left_distrib]
        _ =
          hypersequentCoalgebraComulTensorLinearMap R (hseqMonomial R G) *
            hypersequentCoalgebraComulTensorLinearMap R (y₁ + y₂) := by
              rw [LinearMap.map_add]
    · intro r y hy
      calc
        hypersequentCoalgebraComulTensorLinearMap R
            (hseqMonomial R G * (r • y)) =
          hypersequentCoalgebraComulTensorLinearMap R
            (r • (hseqMonomial R G * y)) := by
              rw [mul_smul_comm]
        _ =
          r • hypersequentCoalgebraComulTensorLinearMap R (hseqMonomial R G * y) := by
              rw [LinearMap.map_smul]
        _ =
          r • (hypersequentCoalgebraComulTensorLinearMap R (hseqMonomial R G) *
            hypersequentCoalgebraComulTensorLinearMap R y) := by
              rw [hy]
        _ =
          hypersequentCoalgebraComulTensorLinearMap R (hseqMonomial R G) *
            (r • hypersequentCoalgebraComulTensorLinearMap R y) := by
              rw [mul_smul_comm]
        _ =
          hypersequentCoalgebraComulTensorLinearMap R (hseqMonomial R G) *
            hypersequentCoalgebraComulTensorLinearMap R (r • y) := by
              rw [LinearMap.map_smul]
  · intro x₁ x₂ hx₁ hx₂
    intro y
    calc
      hypersequentCoalgebraComulTensorLinearMap R ((x₁ + x₂) * y) =
        hypersequentCoalgebraComulTensorLinearMap R (x₁ * y + x₂ * y) := by
          rw [add_mul]
      _ =
        hypersequentCoalgebraComulTensorLinearMap R (x₁ * y) +
          hypersequentCoalgebraComulTensorLinearMap R (x₂ * y) := by
            rw [LinearMap.map_add]
      _ =
        hypersequentCoalgebraComulTensorLinearMap R x₁ *
            hypersequentCoalgebraComulTensorLinearMap R y +
          hypersequentCoalgebraComulTensorLinearMap R x₂ *
            hypersequentCoalgebraComulTensorLinearMap R y := by
            rw [hx₁, hx₂]
      _ =
        (hypersequentCoalgebraComulTensorLinearMap R x₁ +
            hypersequentCoalgebraComulTensorLinearMap R x₂) *
          hypersequentCoalgebraComulTensorLinearMap R y := by
            rw [right_distrib]
      _ =
        hypersequentCoalgebraComulTensorLinearMap R (x₁ + x₂) *
          hypersequentCoalgebraComulTensorLinearMap R y := by
            rw [LinearMap.map_add]
  · intro r x hx
    intro y
    calc
      hypersequentCoalgebraComulTensorLinearMap R ((r • x) * y) =
        hypersequentCoalgebraComulTensorLinearMap R (r • (x * y)) := by
          rw [smul_mul_assoc]
      _ = r • hypersequentCoalgebraComulTensorLinearMap R (x * y) := by
          rw [LinearMap.map_smul]
      _ =
        r • (hypersequentCoalgebraComulTensorLinearMap R x *
          hypersequentCoalgebraComulTensorLinearMap R y) := by
            rw [hx]
      _ =
        (r • hypersequentCoalgebraComulTensorLinearMap R x) *
          hypersequentCoalgebraComulTensorLinearMap R y := by
            rw [smul_mul_assoc]
      _ =
        hypersequentCoalgebraComulTensorLinearMap R (r • x) *
          hypersequentCoalgebraComulTensorLinearMap R y := by
            rw [LinearMap.map_smul]

/-- Full normalized bialgebra axioms. -/
structure HypersequentNormalizedBialgebraAxioms : Prop extends
    HypersequentNormalizedCoalgebraAxioms R where
  comul_one : HypersequentNormalizedComulOne R
  comul_mul : HypersequentNormalizedComulMul R

theorem hypersequentNormalizedBialgebraAxioms_coalgebra
    (h : HypersequentNormalizedBialgebraAxioms R) :
    HypersequentNormalizedCoalgebraAxioms R :=
  h.toHypersequentNormalizedCoalgebraAxioms

/--
The normalized counit laws and unit-preservation are already available, so the
normalized bialgebra package only needs basis-level coassociativity and
multiplicativity of the normalized coproduct.
-/
theorem hypersequentNormalizedBialgebraAxioms_of_coassoc_and_comulMul
    (hcoassoc :
      ∀ G : Hypersequent,
        ((TensorProduct.assoc R
            (HypersequentAlgebra R)
            (HypersequentAlgebra R)
            (HypersequentAlgebra R)).toLinearMap ∘ₗ
            LinearMap.rTensor (HypersequentAlgebra R)
              (hypersequentCoalgebraComulTensorLinearMap R) ∘ₗ
              hypersequentCoalgebraComulTensorLinearMap R)
          (hseqMonomial R G) =
        (LinearMap.lTensor (HypersequentAlgebra R)
            (hypersequentCoalgebraComulTensorLinearMap R) ∘ₗ
          hypersequentCoalgebraComulTensorLinearMap R)
          (hseqMonomial R G))
    (hMul : HypersequentNormalizedComulMul R) :
    HypersequentNormalizedBialgebraAxioms R where
  coassoc :=
    (hypersequentNormalizedCoalgebraAxioms_of_coassoc R hcoassoc).coassoc
  rightCounit :=
    (hypersequentNormalizedCoalgebraAxioms_of_coassoc R hcoassoc).rightCounit
  leftCounit :=
    (hypersequentNormalizedCoalgebraAxioms_of_coassoc R hcoassoc).leftCounit
  comul_one := hypersequentNormalizedComulOne R
  comul_mul := hMul

/--
The normalized coproduct is now known to preserve multiplication, so a
normalized bialgebra package only needs basis-level coassociativity.
-/
theorem hypersequentNormalizedBialgebraAxioms_of_coassoc
    [LeftDistribClass
      (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))]
    [RightDistribClass
      (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))]
    (hcoassoc :
      ∀ G : Hypersequent,
        ((TensorProduct.assoc R
            (HypersequentAlgebra R)
            (HypersequentAlgebra R)
            (HypersequentAlgebra R)).toLinearMap ∘ₗ
            LinearMap.rTensor (HypersequentAlgebra R)
              (hypersequentCoalgebraComulTensorLinearMap R) ∘ₗ
              hypersequentCoalgebraComulTensorLinearMap R)
          (hseqMonomial R G) =
        (LinearMap.lTensor (HypersequentAlgebra R)
            (hypersequentCoalgebraComulTensorLinearMap R) ∘ₗ
          hypersequentCoalgebraComulTensorLinearMap R)
          (hseqMonomial R G)) :
    HypersequentNormalizedBialgebraAxioms R :=
  hypersequentNormalizedBialgebraAxioms_of_coassoc_and_comulMul R
    hcoassoc (hypersequentNormalizedComulMul R)

/--
Once the normalized coalgebra axioms and comultiplicativity are supplied, the
normalized GL/CK route is an actual Mathlib `Bialgebra`.
-/
noncomputable def hypersequentNormalizedBialgebra
    (h : HypersequentNormalizedBialgebraAxioms R) :
    Bialgebra R (HypersequentAlgebra R) := by
  let C : Coalgebra R (HypersequentAlgebra R) :=
    hypersequentNormalizedCoalgebra R
      (hypersequentNormalizedBialgebraAxioms_coalgebra R h)
  exact @Bialgebra.mk' R (HypersequentAlgebra R) _ _ _ C
    (by
      change (hypersequentCounitAlgHom R) (1 : HypersequentAlgebra R) = 1
      exact map_one (hypersequentCounitAlgHom R))
    (by
      intro x y
      change (hypersequentCounitAlgHom R) (x * y) =
        (hypersequentCounitAlgHom R) x *
          (hypersequentCounitAlgHom R) y
      exact map_mul (hypersequentCounitAlgHom R) x y)
    h.comul_one
    (by
      intro x y
      exact h.comul_mul x y)

/--
If basis-level coassociativity and normalized comultiplicativity are available,
the normalized GL/CK route already determines a Mathlib `Bialgebra`.
-/
noncomputable def hypersequentNormalizedBialgebra_of_coassoc_and_comulMul
    (hcoassoc :
      ∀ G : Hypersequent,
        ((TensorProduct.assoc R
            (HypersequentAlgebra R)
            (HypersequentAlgebra R)
            (HypersequentAlgebra R)).toLinearMap ∘ₗ
            LinearMap.rTensor (HypersequentAlgebra R)
              (hypersequentCoalgebraComulTensorLinearMap R) ∘ₗ
              hypersequentCoalgebraComulTensorLinearMap R)
          (hseqMonomial R G) =
        (LinearMap.lTensor (HypersequentAlgebra R)
            (hypersequentCoalgebraComulTensorLinearMap R) ∘ₗ
          hypersequentCoalgebraComulTensorLinearMap R)
          (hseqMonomial R G))
    (hMul : HypersequentNormalizedComulMul R) :
    Bialgebra R (HypersequentAlgebra R) :=
  hypersequentNormalizedBialgebra R
    (hypersequentNormalizedBialgebraAxioms_of_coassoc_and_comulMul
      R hcoassoc hMul)

/--
As soon as basis-level normalized coassociativity is available, the normalized
GL/CK route now determines a Mathlib `Bialgebra`.
-/
noncomputable def hypersequentNormalizedBialgebra_of_coassoc
    [LeftDistribClass
      (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))]
    [RightDistribClass
      (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))]
    (hcoassoc :
      ∀ G : Hypersequent,
        ((TensorProduct.assoc R
            (HypersequentAlgebra R)
            (HypersequentAlgebra R)
            (HypersequentAlgebra R)).toLinearMap ∘ₗ
            LinearMap.rTensor (HypersequentAlgebra R)
              (hypersequentCoalgebraComulTensorLinearMap R) ∘ₗ
              hypersequentCoalgebraComulTensorLinearMap R)
          (hseqMonomial R G) =
        (LinearMap.lTensor (HypersequentAlgebra R)
            (hypersequentCoalgebraComulTensorLinearMap R) ∘ₗ
          hypersequentCoalgebraComulTensorLinearMap R)
          (hseqMonomial R G)) :
    Bialgebra R (HypersequentAlgebra R) :=
  hypersequentNormalizedBialgebra R
    (hypersequentNormalizedBialgebraAxioms_of_coassoc R hcoassoc)

/--
The normalized GL/CK coproduct and external hypersequent product form a
Mathlib-shaped bialgebra axiom package.
-/
theorem hypersequentNormalizedBialgebraAxioms_direct
    [LeftDistribClass
      (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))]
    [RightDistribClass
      (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))] :
    HypersequentNormalizedBialgebraAxioms R :=
  hypersequentNormalizedBialgebraAxioms_of_coassoc R
    (hypersequentNormalizedCoalgebraCoassoc_basis_direct (R := R))

/-- Direct Mathlib `Bialgebra` for the normalized hypersequent coproduct. -/
noncomputable def hypersequentNormalizedBialgebra_direct
    [LeftDistribClass
      (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))]
    [RightDistribClass
      (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))] :
    Bialgebra R (HypersequentAlgebra R) :=
  hypersequentNormalizedBialgebra R
    (hypersequentNormalizedBialgebraAxioms_direct (R := R))

theorem hypersequentNormalizedBialgebraAxioms_of_decomposition
    [LeftDistribClass
      (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))]
    [RightDistribClass
      (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))]
    (hcompat : HypersequentNormalizedStageAlgebraCompatibility R) :
