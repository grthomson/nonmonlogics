    {t : PTree} {cut : List Address}
    (_hcut : cut ∈ coalgebraAdmissibleCuts t) :
    (coalgebraTensorTermOfCutList t cut).2 = 0 ↔
      ([] : Address) ∈ cut := by
  classical
  by_cases hnil : cut = []
  · simp [hnil, singleton_ne_zero]
  · by_cases hroot : ([] : Address) ∈ cut
    · simp [coalgebraTensorTermOfCutList, hnil, hroot]
    · rw [coalgebraTensorTermOfCutList_of_ne_nil_of_root_not_mem
        (t := t) (cut := cut) hnil hroot]
      simp [hroot, singleton_ne_zero]

theorem coalgebraForestTensorTermOfProfile_fst_nil_iff
    {f : Forest} {profile : List (List Address)}
    (hprofile : profile ∈ coalgebraForestCutProfiles f) :
    (coalgebraForestTensorTermOfProfile f profile).1 = 0 ↔
      ∀ cut ∈ profile, cut = [] := by
  induction f generalizing profile with
  | nil =>
      simp [coalgebraForestCutProfiles] at hprofile
      subst profile
      simp [coalgebraForestTensorTermOfProfile]
  | cons t ts ih =>
      rcases (mem_coalgebraForestCutProfiles_cons_iff
        (t := t) (ts := ts) (profile := profile)).1 hprofile with
        ⟨cut, hcut, rest, hrest, rfl⟩
      have htree :
          (coalgebraTensorTermOfCutList t cut).1 = 0 ↔ cut = [] :=
        coalgebraTensorTermOfCutList_fst_eq_zero_iff
          (t := t) (cut := cut) hcut
      have hrestZero :
          (coalgebraForestTensorTermOfProfile ts rest).1 = 0 ↔
            ∀ cut ∈ rest, cut = [] :=
        ih hrest
      simp [coalgebraForestTensorTermOfProfile,
        HypersequentTensorBasis.mul, htree, hrestZero]

theorem coalgebraForestTensorTermOfProfile_snd_nil_iff
    {f : Forest} {profile : List (List Address)}
    (hprofile : profile ∈ coalgebraForestCutProfiles f) :
    (coalgebraForestTensorTermOfProfile f profile).2 = 0 ↔
      ∀ cut ∈ profile, ([] : Address) ∈ cut := by
  induction f generalizing profile with
  | nil =>
