theorem coalgebraForestTensorTermOfPairs_secondStageRestricted
    {t : PTree} {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts t)
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.remainderGo cut₁ [] t)) :
    coalgebraForestTensorTermOfPairs
        (secondStageRestrictedProfilePairs t cut₁ cut₂) =
      (HQ.ofForest (firstStageInsideSecondForest t cut₁ cut₂),
        HQ.ofForest (secondStageRestrictedRemainderForest t cut₁ cut₂)) := by
  let full := cut₂
  have hrec :
      ∀ xs : List Address,
        (∀ b : Address, b ∈ xs → b ∈ full) →
          coalgebraForestTensorTermOfPairs
              (secondStageRestrictedProfilePairs t cut₁ xs) =
            (HQ.ofForest (firstStageInsideSecondForest t cut₁ xs),
              HQ.ofForest (secondStageRestrictedRemainderForest t cut₁ xs)) := by
    intro xs hxs
    induction xs with
    | nil =>
        simp [secondStageRestrictedProfilePairs,
          firstStageInsideSecondForest,
          secondStageRestrictedRemainderForest,
          HypersequentTensorBasis.one]
    | cons b rest ih =>
        have hbfull : b ∈ full := hxs b (by simp)
        have htail :
            coalgebraForestTensorTermOfPairs
                (secondStageRestrictedProfilePairs t cut₁ rest) =
              (HQ.ofForest (firstStageInsideSecondForest t cut₁ rest),
                HQ.ofForest (secondStageRestrictedRemainderForest t cut₁ rest)) := by
          apply ih
          intro c hc
          exact hxs c (by simp [hc])
        cases hsub : PTree.subtreeAt t b with
        | none =>
            simpa [secondStageRestrictedProfilePairs,
              firstStageInsideSecondForest,
              secondStageRestrictedRemainderForest, hsub] using htail
        | some u =>
            have hfst :
                (coalgebraTensorTermOfCutList u
                    (PTree.restrictCutAt cut₁ b)).1 =
                  HQ.ofForest
                    ((PTree.restrictCutAt cut₁ b).filterMap
                      (PTree.subtreeAt u)) :=
              coalgebraTensorTermOfCutList_restrictCutAt_second_internal_fst
                (t := t) (cut₁ := cut₁) (cut₂ := full)
                (b := b) (u := u) hcut₁ hcut₂ hbfull
            have hsnd :
                (coalgebraTensorTermOfCutList u
                    (PTree.restrictCutAt cut₁ b)).2 =
                  HQ.singleton
                    (PTree.remainderGo (PTree.restrictCutAt cut₁ b) [] u) :=
              coalgebraTensorTermOfCutList_restrictCutAt_second_internal_snd
                (t := t) (cut₁ := cut₁) (cut₂ := full)
                (b := b) (u := u) hcut₁ hcut₂ hbfull
            have htail_fst :
                (coalgebraForestTensorTermOfPairs
                    (secondStageRestrictedProfilePairs t cut₁ rest)).1 =
                  HQ.ofForest (firstStageInsideSecondForest t cut₁ rest) :=
              congrArg Prod.fst htail
            have htail_snd :
                (coalgebraForestTensorTermOfPairs
                    (secondStageRestrictedProfilePairs t cut₁ rest)).2 =
                  HQ.ofForest
                    (secondStageRestrictedRemainderForest t cut₁ rest) :=
              congrArg Prod.snd htail
            let headCut : List Address := PTree.restrictCutAt cut₁ b
            let headForest : Forest := headCut.filterMap (PTree.subtreeAt u)
            let headRem : PTree := PTree.remainderGo headCut [] u
            let tailPairs : List (PTree × List Address) :=
              secondStageRestrictedProfilePairs t cut₁ rest
            let tailForest : Forest :=
              firstStageInsideSecondForest t cut₁ rest
            let tailRemForest : Forest :=
              secondStageRestrictedRemainderForest t cut₁ rest
            have hhead :
                coalgebraTensorTermOfCutList u headCut =
                  (HQ.ofForest headForest, HQ.singleton headRem) := by
              apply Prod.ext
              · simpa [headCut, headForest] using hfst
              · simpa [headCut, headRem] using hsnd
            have htail' :
                coalgebraForestTensorTermOfPairs tailPairs =
                  (HQ.ofForest tailForest, HQ.ofForest tailRemForest) := by
              simpa [tailPairs, tailForest, tailRemForest] using htail
            have hcalc :
                coalgebraForestTensorTermOfPairs
                    ((u, headCut) :: tailPairs) =
                  (HQ.ofForest (headForest ++ tailForest),
                    HQ.ofForest (headRem :: tailRemForest)) := by
              calc
                coalgebraForestTensorTermOfPairs
                    ((u, headCut) :: tailPairs)
                    =
                    HypersequentTensorBasis.mul
                      (coalgebraTensorTermOfCutList u headCut)
                      (coalgebraForestTensorTermOfPairs tailPairs) := rfl
                _ =
                    HypersequentTensorBasis.mul
                      (HQ.ofForest headForest, HQ.singleton headRem)
                      (HQ.ofForest tailForest, HQ.ofForest tailRemForest) := by
                      rw [hhead, htail']
                _ =
                    (HQ.ofForest (headForest ++ tailForest),
                      HQ.ofForest (headRem :: tailRemForest)) := by
                      simp [HypersequentTensorBasis.mul,
                        HQ.ofForest_append, HQ.ofForest_cons]
            simpa [secondStageRestrictedProfilePairs,
              firstStageInsideSecondForest,
              secondStageRestrictedRemainderForest, hsub,
              headCut, headForest, headRem, tailPairs,
              tailForest, tailRemForest] using hcalc
  simpa [full] using hrec cut₂ (by intro b hb; exact hb)

theorem coalgebraForestTensorTermOfPairs_stagedRightWitness
    {t : PTree} {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts t)
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.remainderGo cut₁ [] t)) :
    coalgebraForestTensorTermOfPairs
        (stagedRightWitnessProfilePairs t cut₁ cut₂) =
      (HQ.ofForest
          (firstStageOutsideSecondForest t cut₁ cut₂ ++
            firstStageInsideSecondForest t cut₁ cut₂),
        HQ.ofForest (secondStageRestrictedRemainderForest t cut₁ cut₂)) := by
  rw [stagedRightWitnessProfilePairs,
    coalgebraForestTensorTermOfPairs_append]
  rw [coalgebraForestTensorTermOfPairs_firstStageOutsideSecond]
  rw [coalgebraForestTensorTermOfPairs_secondStageRestricted
    (t := t) (cut₁ := cut₁) (cut₂ := cut₂) hcut₁ hcut₂]
  simp [HypersequentTensorBasis.mul, HQ.ofForest_append]

/--
The subtree component selected by a second-stage internal address contributes
the normalized tree coproduct split induced by the first-stage cut restricted
below that address.
-/
theorem mem_coalgebraTreeSplittingTensorSupport_restrictCutAt_second_internal
    {t : PTree} {cut₁ cut₂ : List Address} {b : Address} {u : PTree}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts t)
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.remainderGo cut₁ [] t))
    (hb₂ : b ∈ cut₂)
    (hsub : PTree.subtreeAt t b = some u) :
    coalgebraTensorTermOfCutList u (PTree.restrictCutAt cut₁ b) ∈
      coalgebraTreeSplittingTensorSupport u := by
  exact (mem_coalgebraTreeSplittingTensorSupport_iff
    (t := u)
    (p := coalgebraTensorTermOfCutList u (PTree.restrictCutAt cut₁ b))).2
    ⟨PTree.restrictCutAt cut₁ b,
      restrictCutAt_mem_coalgebraAdmissibleCuts_of_second_internal
        (t := t) (cut₁ := cut₁) (cut₂ := cut₂)
        (b := b) (u := u) hcut₁ hcut₂ hb₂ hsub,
      rfl⟩

/--
The second-stage ambient subforest carries the product of the restricted
first-stage splits.

For each second-stage address `b`, the original subtree at `b` is split by the
first-stage cut restricted below `b`. Multiplying these tree splits over all
second-stage addresses gives a forest-coproduct atom whose left side is the
first-stage material inside those subtrees and whose right side is exactly the
second-stage detached forest seen in the first remainder.
-/
theorem mem_coalgebraForestSplittingTensorSupport_secondStageRestricted
    {t : PTree} {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts t)
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.remainderGo cut₁ [] t)) :
    (HQ.ofForest (firstStageInsideSecondForest t cut₁ cut₂),
      HQ.ofForest (secondStageRestrictedRemainderForest t cut₁ cut₂)) ∈
        coalgebraForestSplittingTensorSupport
          (secondStageOriginalSubtreeForest t cut₂) := by
  let full := cut₂
  have hrec :
      ∀ xs : List Address,
        (∀ b : Address, b ∈ xs → b ∈ full) →
          (HQ.ofForest (firstStageInsideSecondForest t cut₁ xs),
            HQ.ofForest (secondStageRestrictedRemainderForest t cut₁ xs)) ∈
              coalgebraForestSplittingTensorSupport
                (secondStageOriginalSubtreeForest t xs) := by
    intro xs hxs
    induction xs with
    | nil =>
        simp [firstStageInsideSecondForest,
          secondStageRestrictedRemainderForest,
          secondStageOriginalSubtreeForest,
          HypersequentTensorBasis.one]
    | cons b rest ih =>
        have hbfull : b ∈ full := hxs b (by simp)
        have htail :
            (HQ.ofForest (firstStageInsideSecondForest t cut₁ rest),
              HQ.ofForest (secondStageRestrictedRemainderForest t cut₁ rest)) ∈
                coalgebraForestSplittingTensorSupport
                  (secondStageOriginalSubtreeForest t rest) := by
          apply ih
          intro c hc
          exact hxs c (by simp [hc])
        cases hsub : PTree.subtreeAt t b with
        | none =>
            simpa [firstStageInsideSecondForest,
              secondStageRestrictedRemainderForest,
              secondStageOriginalSubtreeForest, hsub] using htail
        | some u =>
            have htree :
                coalgebraTensorTermOfCutList u
                    (PTree.restrictCutAt cut₁ b) ∈
                  coalgebraTreeSplittingTensorSupport u :=
              mem_coalgebraTreeSplittingTensorSupport_restrictCutAt_second_internal
                (t := t) (cut₁ := cut₁) (cut₂ := full)
                (b := b) (u := u) hcut₁ hcut₂ hbfull hsub
            have hfst :
                (coalgebraTensorTermOfCutList u
                    (PTree.restrictCutAt cut₁ b)).1 =
                  HQ.ofForest
                    ((PTree.restrictCutAt cut₁ b).filterMap
                      (PTree.subtreeAt u)) :=
              coalgebraTensorTermOfCutList_restrictCutAt_second_internal_fst
                (t := t) (cut₁ := cut₁) (cut₂ := full)
                (b := b) (u := u) hcut₁ hcut₂ hbfull
            have hsnd :
                (coalgebraTensorTermOfCutList u
                    (PTree.restrictCutAt cut₁ b)).2 =
                  HQ.singleton
                    (PTree.remainderGo (PTree.restrictCutAt cut₁ b) [] u) :=
              coalgebraTensorTermOfCutList_restrictCutAt_second_internal_snd
                (t := t) (cut₁ := cut₁) (cut₂ := full)
                (b := b) (u := u) hcut₁ hcut₂ hbfull
            have hmul :=
              mem_coalgebraForestSplittingTensorSupport_cons_of_mem
                (t := u)
                (ts := secondStageOriginalSubtreeForest t rest)
                (p := coalgebraTensorTermOfCutList u
                  (PTree.restrictCutAt cut₁ b))
                (q := (HQ.ofForest (firstStageInsideSecondForest t cut₁ rest),
                  HQ.ofForest (secondStageRestrictedRemainderForest t cut₁ rest)))
                htree htail
            simpa [firstStageInsideSecondForest,
              secondStageRestrictedRemainderForest,
              secondStageOriginalSubtreeForest, hsub,
              HypersequentTensorBasis.mul, hfst, hsnd,
              HQ.ofForest_append, HQ.ofForest_cons,
              add_assoc] using hmul
  simpa [full] using hrec cut₂ (by intro b hb; exact hb)

/--
Node-level ambient forest support from the two real forest permutations.

The ambient forest is decomposed as:

* first-stage components outside all second-stage cuts;
* original subtrees selected by the second-stage cut.

The first detached forest is decomposed as:

* the same outside components;
* first-stage components lying inside the second-stage subtrees.

The second-stage original subtrees then contribute the restricted coproduct
proved above.  This theorem is the support-level content needed by the
right-to-left internal/internal coassociativity inclusion.
-/
theorem nodeCanonicalAmbientForestSupport_of_outside_inside_perms
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁)))
    (hambient :
      List.Perm
        (nodeRootFreeCutDetachedForest cs
          (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂))
        (firstStageOutsideSecondForest (PTree.node r s cs) cut₁ cut₂ ++
          secondStageOriginalSubtreeForest (PTree.node r s cs) cut₂))
    (hfirst :
      List.Perm
        (nodeRootFreeCutDetachedForest cs cut₁)
        (firstStageOutsideSecondForest (PTree.node r s cs) cut₁ cut₂ ++
          firstStageInsideSecondForest (PTree.node r s cs) cut₁ cut₂)) :
    (HQ.ofForest (nodeRootFreeCutDetachedForest cs cut₁),
      HQ.ofForest
        (coalgebraDetachedForestOfCut
          (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))
          cut₂)) ∈
      coalgebraForestSplittingTensorSupport
        (nodeRootFreeCutDetachedForest cs
          (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂)) := by
  let t := PTree.node r s cs
  let outside := firstStageOutsideSecondForest t cut₁ cut₂
  let secondOrig := secondStageOriginalSubtreeForest t cut₂
  let inside := firstStageInsideSecondForest t cut₁ cut₂
  let secondRem := secondStageRestrictedRemainderForest t cut₁ cut₂
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₁ with
    ⟨hcoal₁, hint₁⟩
  have hfirstRem :
      PTree.remainderGo cut₁ [] t =
        PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁) := by
    simpa [t, nodeRootFreeCutRemainderChildren] using
      PTree.remainderGo_node_root_not_mem
        (r := r) (s := s) (cs := cs) (cut := cut₁) hint₁.2
  have hcut₂Rem :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.remainderGo cut₁ [] t) := by
    simpa [hfirstRem] using hcut₂
  have houtside :
      (HQ.ofForest outside, 0) ∈
        coalgebraForestSplittingTensorSupport outside := by
    exact coalgebraForestSplittingTensorSupport_contains_total_root outside
  have hsecond :
      (HQ.ofForest inside, HQ.ofForest secondRem) ∈
        coalgebraForestSplittingTensorSupport secondOrig := by
    simpa [outside, secondOrig, inside, secondRem, t] using
      mem_coalgebraForestSplittingTensorSupport_secondStageRestricted
        (t := t) (cut₁ := cut₁) (cut₂ := cut₂)
        hcut₁ hcut₂Rem
  have hbase :
      (HQ.ofForest (outside ++ inside), HQ.ofForest secondRem) ∈
        coalgebraForestSplittingTensorSupport (outside ++ secondOrig) := by
    have hmul :=
      mem_coalgebraForestSplittingTensorSupport_append_of_mem
        (f := outside) (g := secondOrig)
        (p := (HQ.ofForest outside, 0))
        (q := (HQ.ofForest inside, HQ.ofForest secondRem))
        houtside hsecond
    simpa [HypersequentTensorBasis.mul, HQ.ofForest_append,
      add_assoc] using hmul
  have hambient' :
      List.Perm
        (nodeRootFreeCutDetachedForest cs
          (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂))
        (outside ++ secondOrig) := by
    simpa [outside, secondOrig, t] using hambient
  have htransport :
      (HQ.ofForest (outside ++ inside), HQ.ofForest secondRem) ∈
        coalgebraForestSplittingTensorSupport
          (nodeRootFreeCutDetachedForest cs
            (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂)) := by
    exact ((coalgebraForestSplittingTensorSupport_perm_of_perm
      hambient').mem_iff).2 hbase
  have hleft :
      HQ.ofForest (nodeRootFreeCutDetachedForest cs cut₁) =
        HQ.ofForest (outside ++ inside) := by
    exact HQ.ofForest_eq_of_perm (by simpa [outside, inside, t] using hfirst)
  have hright :
      HQ.ofForest
          (coalgebraDetachedForestOfCut
            (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))
            cut₂) =
        HQ.ofForest secondRem := by
    calc
      HQ.ofForest
          (coalgebraDetachedForestOfCut
            (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))
            cut₂) =
        HQ.ofForest
          (coalgebraDetachedForestOfCut (PTree.remainderGo cut₁ [] t) cut₂) := by
          rw [hfirstRem]
    _ = HQ.ofForest secondRem := by
          simpa [secondRem] using
            ofForest_coalgebraDetachedForestOfCut_second_internal_eq_restrictedRemainderForest
              (t := t) (cut₁ := cut₁) (cut₂ := cut₂)
              hcoal₁ hcut₂Rem
  simpa [hleft, hright] using htransport

theorem nodeRightNormalSupport_subset_left_of_outside_inside_perms
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    (hambient :
      ∀ cut₁ cut₂ : List Address,
        cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs) →
        cut₂ ∈ internalCoalgebraAdmissibleCuts
          (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁)) →
        List.Perm
          (nodeRootFreeCutDetachedForest cs
            (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂))
          (firstStageOutsideSecondForest (PTree.node r s cs) cut₁ cut₂ ++
            secondStageOriginalSubtreeForest (PTree.node r s cs) cut₂))
    (hfirst :
      ∀ cut₁ cut₂ : List Address,
        cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs) →
        cut₂ ∈ internalCoalgebraAdmissibleCuts
          (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁)) →
