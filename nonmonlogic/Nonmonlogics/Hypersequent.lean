  apply nodeRightNormalSupport_subset_left_of_dominated_address_perm
      (r := r) (s := s) (cs := cs)
  · intro cut₁ cut₂ hcut₁ hcut₂
    have hnodup₁ :
        cut₁.Nodup :=
      nodup_of_mem_internalCoalgebraAdmissibleCuts hcut₁
    have hnodup₂ :
        cut₂.Nodup :=
      nodup_of_mem_internalCoalgebraAdmissibleCuts hcut₂
    rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₂ with
      ⟨hcoal₂, _hint₂⟩
    exact firstStageDominatedBySecondAddresses_perm_inside
      (cut₁ := cut₁) (cut₂ := cut₂)
      hnodup₁ hnodup₂
      (antichain_of_mem_coalgebraAdmissibleCuts hcoal₂)
  · exact hp

theorem not_comparable_surviving_previous_cut_second_internal_cut
    {t : PTree} {cut₁ cut₂ : List Address} {a b : Address}
    (hcut₁ : cut₁ ∈ coalgebraAdmissibleCuts t)
    (ha₁ : a ∈ cut₁)
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.remainderGo cut₁ [] t))
    (hsurvive : ∀ c : Address, c ∈ cut₂ → ¬ PTree.isAncestorOf c a)
    (hb₂ : b ∈ cut₂)
    (hne : a ≠ b) :
    ¬ PTree.comparable a b := by
  intro hcomp
  rcases hcomp with hab | hba
  · exact not_previous_cut_ancestor_of_second_internal_cut
      (t := t) (cut₁ := cut₁) (cut₂ := cut₂)
      hcut₁ ha₁ hcut₂ hb₂ hab
  · exact hsurvive b hb₂ hba

/--
Node/root-free normal form for the right internal/internal sector.

Every first cut in this sector is a nonempty root-free cut of the rule node,
so the detached forest and the remainder may be expressed childwise. This is
the coordinate system used by the node-local extension permutation.
-/
theorem coalgebraRightInternalInternalTripleSupport_node_rootFree
    (r : RuleTag) (s : MultiSequent) (cs : List PTree) :
    coalgebraRightInternalInternalTripleSupport (PTree.node r s cs) =
      nodeRightInternalInternalNormalSupport r s cs := by
  classical
  unfold nodeRightInternalInternalNormalSupport
  unfold coalgebraRightInternalInternalTripleSupport
  apply List.flatMap_congr
  intro cut hcut
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut with
    ⟨hcoal, hinternal⟩
  have hrem :
      PTree.remainderGo cut [] (PTree.node r s cs) =
        PTree.node r s (nodeRootFreeCutRemainderChildren cs cut) := by
    simpa [nodeRootFreeCutRemainderChildren] using
      PTree.remainderGo_node_root_not_mem
        (r := r) (s := s) (cs := cs) (cut := cut) hinternal.2
  rw [hrem]
  apply List.map_congr_left
  intro cut₂ _hcut₂
  exact coalgebraRightStageTripleOfCuts_node_rootFree_first
    (r := r) (s := s) (cs := cs)
    (cut₁ := cut) (cut₂ := cut₂)
    hcoal hinternal.1 hinternal.2

/--
Node/root-free remainder normal form for the left internal/internal sector.

This is the left-stage companion to
`coalgebraRightInternalInternalTripleSupport_node_rootFree`: the proper split
still occurs over the detached forest selected by `cut`, but the third
coordinate is rewritten as the childwise rule-node remainder.
-/
theorem coalgebraLeftInternalInternalTripleSupport_node_rootFree_remainder
    (r : RuleTag) (s : MultiSequent) (cs : List PTree) :
    coalgebraLeftInternalInternalTripleSupport (PTree.node r s cs) =
      (internalCoalgebraAdmissibleCuts (PTree.node r s cs)).flatMap
        (fun cut =>
          (coalgebraForestProperSplittingTensorSupport
              (cut.filterMap (PTree.subtreeAt (PTree.node r s cs)))).map
            (fun p =>
              (p.1, p.2,
                HQ.singleton
                  (PTree.node r s
                    (nodeRootFreeCutRemainderChildren cs cut))))) := by
  classical
  unfold coalgebraLeftInternalInternalTripleSupport
  apply List.flatMap_congr
  intro cut hcut
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut with
    ⟨_hcoal, hinternal⟩
  have hrem :
      PTree.remainderGo cut [] (PTree.node r s cs) =
        PTree.node r s (nodeRootFreeCutRemainderChildren cs cut) := by
    simpa [nodeRootFreeCutRemainderChildren] using
      PTree.remainderGo_node_root_not_mem
        (r := r) (s := s) (cs := cs) (cut := cut) hinternal.2
  apply List.map_congr_left
  intro p _hp
  simp [hrem]

/--
Left node/root-free normal form, conditional only on forest-support invariance
under the detached-forest permutation.

The previous theorem normalizes the remainder coordinate by equality. This
version also transports the proper split from the raw detached forest
`cut.filterMap subtreeAt` to the childwise detached forest.
-/
theorem coalgebraLeftInternalInternalTripleSupport_node_rootFree_perm_of_forest_support
    (r : RuleTag) (s : MultiSequent) (cs : List PTree)
    (hforest :
      ∀ cut ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs),
        List.Perm
          (coalgebraForestSplittingTensorSupport
            (cut.filterMap (PTree.subtreeAt (PTree.node r s cs))))
          (coalgebraForestSplittingTensorSupport
            (nodeRootFreeCutDetachedForest cs cut))) :
    List.Perm
      (coalgebraLeftInternalInternalTripleSupport (PTree.node r s cs))
      ((internalCoalgebraAdmissibleCuts (PTree.node r s cs)).flatMap
        (fun cut =>
          (coalgebraForestProperSplittingTensorSupport
              (nodeRootFreeCutDetachedForest cs cut)).map
            (fun p =>
              (p.1, p.2,
                HQ.singleton
                  (PTree.node r s
                    (nodeRootFreeCutRemainderChildren cs cut)))))) := by
  rw [coalgebraLeftInternalInternalTripleSupport_node_rootFree_remainder]
  apply List.Perm.flatMap_congr_left
  intro cut hcut
  have hproper :
      List.Perm
        (coalgebraForestProperSplittingTensorSupport
          (cut.filterMap (PTree.subtreeAt (PTree.node r s cs))))
        (coalgebraForestProperSplittingTensorSupport
          (nodeRootFreeCutDetachedForest cs cut)) :=
    coalgebraForestProperSplittingTensorSupport_perm_of_splitting_perm
      (hforest cut hcut)
  exact List.Perm.map
    (fun p =>
      (p.1, p.2,
        HQ.singleton
          (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut))))
    hproper

/--
Forest-permutation invariance is exactly enough to put the left
internal/internal node sector into childwise detached-forest coordinates.
-/
theorem coalgebraLeftInternalInternalTripleSupport_node_rootFree_perm_of_forest_perm
    (r : RuleTag) (s : MultiSequent) (cs : List PTree)
    (hperm :
      ∀ f g : Forest,
        List.Perm f g →
          List.Perm
            (coalgebraForestSplittingTensorSupport f)
            (coalgebraForestSplittingTensorSupport g)) :
    List.Perm
      (coalgebraLeftInternalInternalTripleSupport (PTree.node r s cs))
      (nodeLeftInternalInternalNormalSupport r s cs) := by
  unfold nodeLeftInternalInternalNormalSupport
  refine coalgebraLeftInternalInternalTripleSupport_node_rootFree_perm_of_forest_support
    (r := r) (s := s) (cs := cs) ?_
  intro cut hcut
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut with
    ⟨hcoal, hinternal⟩
  exact nodeRootFreeCut_coalgebraForestSplittingTensorSupport_perm
    (r := r) (s := s) (cs := cs) (cut := cut)
    hcoal hinternal.1 hinternal.2

/-- Left node/root-free normal form using the proved forest-support
permutation invariance. -/
theorem coalgebraLeftInternalInternalTripleSupport_node_rootFree_perm
    (r : RuleTag) (s : MultiSequent) (cs : List PTree) :
    List.Perm
      (coalgebraLeftInternalInternalTripleSupport (PTree.node r s cs))
      (nodeLeftInternalInternalNormalSupport r s cs) := by
  exact coalgebraLeftInternalInternalTripleSupport_node_rootFree_perm_of_forest_perm
    (r := r) (s := s) (cs := cs)
    (fun f g hfg => coalgebraForestSplittingTensorSupport_perm_of_perm hfg)

theorem coalgebraRightInternalInternalTripleSupport_subset_left_resolved
    (t : PTree) {p : HypersequentTripleBasis}
    (hp : p ∈ coalgebraRightInternalInternalTripleSupport t) :
    p ∈ coalgebraLeftInternalInternalTripleSupport t := by
  cases t with
  | leaf s =>
      simpa [coalgebraRightInternalInternalTripleSupport,
        coalgebraLeftInternalInternalTripleSupport,
        internalCoalgebraAdmissibleCuts, coalgebraAdmissibleCuts,
        PTree.allAdmissibleCuts, PTree.sublists, PTree.allAddresses,
        PTree.allAddressesGo, PTree.size, PTree.validAddress,
        PTree.subtreeAt, PTree.isAntichainBool] using hp
  | node r s cs =>
      have hpNorm :
          p ∈ nodeRightInternalInternalNormalSupport r s cs := by
        simpa [coalgebraRightInternalInternalTripleSupport_node_rootFree]
          using hp
      have hpLeftNorm :
          p ∈ nodeLeftInternalInternalNormalSupport r s cs :=
        nodeRightNormalSupport_subset_left_resolved hpNorm
      have hleftPerm :
          List.Perm
            (coalgebraLeftInternalInternalTripleSupport (PTree.node r s cs))
            (nodeLeftInternalInternalNormalSupport r s cs) :=
        coalgebraLeftInternalInternalTripleSupport_node_rootFree_perm r s cs
      exact (hleftPerm.mem_iff).2 hpLeftNorm

/--
Internal coalgebra cuts detach a nonempty forest.  This is where the
coalgebraic noise filter matters: every address in an internal cut points to a
genuine rule node, so `filterMap subtreeAt` cannot erase the whole cut.
-/
theorem coalgebraDetachedForest_nonempty_of_internal
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts t)
    (hinternal : InternalCut cut) :
    cut.filterMap (PTree.subtreeAt t) ≠ [] := by
  cases cut with
  | nil =>
      exact False.elim (hinternal.1 rfl)
  | cons a rest =>
      have ha : a ∈ a :: rest := by simp
      rcases node_addresses_of_mem_coalgebraAdmissibleCuts_of_internal
          hcut hinternal a ha with ⟨r, s, cs, hnode⟩
      simp [hnode]

/--
Forest boundary/proper permutation target for nonempty detached forests.

For nonempty forests, the normalized multiplicative forest coproduct should
split into the identity forest split, the total-root forest split, and the
proper sector where both tensor factors are nonzero.
-/
def HypersequentNormalizedForestBoundaryProperPerm : Prop :=
  ∀ f : Forest, f ≠ [] →
    List.Perm
      (coalgebraForestSplittingTensorSupport f)
      ([(0, HQ.ofForest f)] ++
        ([(HQ.ofForest f, 0)] ++
          coalgebraForestProperSplittingTensorSupport f))

/--
Assuming the nonempty forest boundary/proper permutation, a left internal
branch splits into its forest-identity boundary atom, its total-root boundary
atom, and the proper detached-forest sector.
-/
theorem coalgebraLeftStageTripleBranch_internal_perm_boundary_internal
    (hforest : HypersequentNormalizedForestBoundaryProperPerm)
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts t)
    (hinternal : InternalCut cut) :
    List.Perm
      (coalgebraLeftStageTripleBranch t cut)
      ([(0,
          HQ.ofForest (cut.filterMap (PTree.subtreeAt t)),
          HQ.singleton (PTree.remainderGo cut [] t))] ++
        ([(HQ.ofForest (cut.filterMap (PTree.subtreeAt t)),
            0,
            HQ.singleton (PTree.remainderGo cut [] t))] ++
          ((coalgebraForestProperSplittingTensorSupport
              (cut.filterMap (PTree.subtreeAt t))).map
            (fun p =>
              (p.1, p.2,
                HQ.singleton (PTree.remainderGo cut [] t)))))) := by
  classical
  let f := cut.filterMap (PTree.subtreeAt t)
  let rem := PTree.remainderGo cut [] t
  let F : HypersequentTensorBasis → HypersequentTripleBasis :=
    fun p => (p.1, p.2, HQ.singleton rem)
  have hbranch :
      coalgebraLeftStageTripleBranch t cut =
        (coalgebraForestSplittingTensorSupport f).map F := by
    rw [coalgebraLeftStageTripleBranch_of_ne_nil_of_root_not_mem
      (t := t) (cut := cut) hinternal.1 hinternal.2]
  rw [hbranch]
  have hfne : f ≠ [] :=
    coalgebraDetachedForest_nonempty_of_internal
      (t := t) (cut := cut) hcut hinternal
  have hmap := (hforest f hfne).map F
  simpa [F, f, rem] using hmap

/--
For a fixed internal first cut, the right staged branch splits, up to
permutation, into the second-empty boundary atom, the second-root boundary
atom, and the genuinely internal/internal second-cut sector.
-/
theorem coalgebraRightStageTripleBranch_internal_perm_boundary_internal
    {t : PTree} {cut : List Address}
    (hinternal : InternalCut cut) :
    List.Perm
      (coalgebraRightStageTripleBranch t cut)
      ([(HQ.ofForest (cut.filterMap (PTree.subtreeAt t)),
          0,
          HQ.singleton (PTree.remainderGo cut [] t))] ++
        ([(HQ.ofForest (cut.filterMap (PTree.subtreeAt t)),
            HQ.singleton (PTree.remainderGo cut [] t),
            0)] ++
          ((internalCoalgebraAdmissibleCuts
              (PTree.remainderGo cut [] t)).map
            (fun cut₂ => coalgebraRightStageTripleOfCuts t cut cut₂)))) := by
  classical
  let rem := PTree.remainderGo cut [] t
  let F : List Address → HypersequentTripleBasis :=
    fun cut₂ => coalgebraRightStageTripleOfCuts t cut cut₂
  have hbranch :
      coalgebraRightStageTripleBranch t cut =
        (coalgebraAdmissibleCuts rem).map F := by
    simp [F, rem,
      coalgebraRightStageTripleBranch_of_ne_nil_of_root_not_mem
        (t := t) (cut₁ := cut) hinternal.1 hinternal.2]
  rw [hbranch]
  have hperm :
      List.Perm (coalgebraAdmissibleCuts rem)
        ((coalgebraAdmissibleCuts rem).filter
            (fun cut₂ => decide (cut₂ = [])) ++
          (((coalgebraAdmissibleCuts rem).filter
              (fun cut₂ => !(decide (cut₂ = [])))).filter
              (fun cut₂ => decide (([] : Address) ∈ cut₂)) ++
            ((coalgebraAdmissibleCuts rem).filter
              (fun cut₂ => !(decide (cut₂ = [])))).filter
              (fun cut₂ => !(decide (([] : Address) ∈ cut₂))))) :=
    List.perm_filter_append_filter_filter_append_filter_filter_not
      (coalgebraAdmissibleCuts rem)
      (fun cut₂ => decide (cut₂ = []))
      (fun cut₂ => decide (([] : Address) ∈ cut₂))
  have hmap := hperm.map F
  have hempty :
      ((coalgebraAdmissibleCuts rem).filter
          (fun cut₂ => decide (cut₂ = []))).map F =
        [F []] := by
    rw [filter_eq_emptyCut_coalgebraAdmissibleCuts]
    simp
  have hroot :
      (((coalgebraAdmissibleCuts rem).filter
          (fun cut₂ => !(decide (cut₂ = [])))).filter
          (fun cut₂ => decide (([] : Address) ∈ cut₂))).map F =
        [F [([] : Address)]] := by
    rw [filter_ne_empty_eq_rootContainingCut_coalgebraAdmissibleCuts]
    simp
  have hinternalList :
      ((coalgebraAdmissibleCuts rem).filter
          (fun cut₂ => !(decide (cut₂ = [])))).filter
          (fun cut₂ => !(decide (([] : Address) ∈ cut₂))) =
        internalCoalgebraAdmissibleCuts rem := by
    rfl
  refine hmap.trans ?_
  rw [List.map_append, List.map_append, hempty, hroot, hinternalList]
  simp [F, rem,
    coalgebraRightStageTripleOfCuts_internal_second_empty
      (t := t) (cut := cut) hinternal,
    coalgebraRightStageTripleOfCuts_internal_second_root
      (t := t) (cut := cut) hinternal]

/--
The full right internal-first sector groups into the second-empty boundary
sector, the second-root boundary sector, and the proper internal/internal
sector.
-/
theorem coalgebraRightInternalFirstTripleSupport_perm_boundary_internal
    (t : PTree) :
    List.Perm
      (coalgebraRightInternalFirstTripleSupport t)
      (coalgebraInternalSecondEmptyTripleSupport t ++
        (coalgebraInternalSecondRootTripleSupport t ++
          coalgebraRightInternalInternalTripleSupport t)) := by
  classical
  let xs := internalCoalgebraAdmissibleCuts t
  let a : List Address → HypersequentTripleBasis :=
    fun cut =>
      (HQ.ofForest (cut.filterMap (PTree.subtreeAt t)),
        0,
        HQ.singleton (PTree.remainderGo cut [] t))
  let b : List Address → HypersequentTripleBasis :=
    fun cut =>
      (HQ.ofForest (cut.filterMap (PTree.subtreeAt t)),
        HQ.singleton (PTree.remainderGo cut [] t),
        0)
  let c : List Address → List HypersequentTripleBasis :=
    fun cut =>
      (internalCoalgebraAdmissibleCuts
        (PTree.remainderGo cut [] t)).map
        (fun cut₂ => coalgebraRightStageTripleOfCuts t cut cut₂)
  have hbranch :
      List.Perm
        (xs.flatMap (coalgebraRightStageTripleBranch t))
        (xs.flatMap (fun cut => [a cut] ++ ([b cut] ++ c cut))) := by
    apply List.Perm.flatMap_congr_left
    intro cut hcut
    have hinternal : InternalCut cut :=
      ((mem_internalCoalgebraAdmissibleCuts_iff).1 hcut).2
    simpa [a, b, c] using
      coalgebraRightStageTripleBranch_internal_perm_boundary_internal
        (t := t) (cut := cut) hinternal
  have hgroup := List.flatMap_two_boundary_perm xs a b c
  unfold coalgebraRightInternalFirstTripleSupport
  exact hbranch.trans (by
    simpa [xs, a, b, c, coalgebraInternalSecondEmptyTripleSupport,
      coalgebraInternalSecondRootTripleSupport,
      coalgebraRightInternalInternalTripleSupport] using hgroup)

/--
The full left internal-first sector groups into the forest-identity boundary
sector, the total-root boundary sector, and the proper detached-forest sector.
-/
theorem coalgebraLeftInternalFirstTripleSupport_perm_boundary_internal
    (hforest : HypersequentNormalizedForestBoundaryProperPerm)
    (t : PTree) :
    List.Perm
      (coalgebraLeftInternalFirstTripleSupport t)
      (coalgebraInternalIdentityTripleSupport t ++
        (coalgebraInternalSecondEmptyTripleSupport t ++
          coalgebraLeftInternalInternalTripleSupport t)) := by
  classical
  let xs := internalCoalgebraAdmissibleCuts t
  let a : List Address → HypersequentTripleBasis :=
    fun cut =>
      (0,
        HQ.ofForest (cut.filterMap (PTree.subtreeAt t)),
        HQ.singleton (PTree.remainderGo cut [] t))
  let b : List Address → HypersequentTripleBasis :=
    fun cut =>
      (HQ.ofForest (cut.filterMap (PTree.subtreeAt t)),
        0,
        HQ.singleton (PTree.remainderGo cut [] t))
  let c : List Address → List HypersequentTripleBasis :=
    fun cut =>
      (coalgebraForestProperSplittingTensorSupport
        (cut.filterMap (PTree.subtreeAt t))).map
        (fun p =>
          (p.1, p.2,
            HQ.singleton (PTree.remainderGo cut [] t)))
  have hbranch :
      List.Perm
        (xs.flatMap (coalgebraLeftStageTripleBranch t))
        (xs.flatMap (fun cut => [a cut] ++ ([b cut] ++ c cut))) := by
    apply List.Perm.flatMap_congr_left
    intro cut hcut
    have hcoal : cut ∈ coalgebraAdmissibleCuts t :=
      ((mem_internalCoalgebraAdmissibleCuts_iff).1 hcut).1
    have hinternal : InternalCut cut :=
      ((mem_internalCoalgebraAdmissibleCuts_iff).1 hcut).2
    simpa [a, b, c] using
      coalgebraLeftStageTripleBranch_internal_perm_boundary_internal
        hforest (t := t) (cut := cut) hcoal hinternal
  have hgroup := List.flatMap_two_boundary_perm xs a b c
  unfold coalgebraLeftInternalFirstTripleSupport
  exact hbranch.trans (by
    simpa [xs, a, b, c, coalgebraInternalIdentityTripleSupport,
      coalgebraInternalSecondEmptyTripleSupport,
      coalgebraLeftInternalInternalTripleSupport] using hgroup)

theorem coalgebraAdmissibleCuts_perm_empty_root_internal
    (t : PTree) :
    List.Perm
      (coalgebraAdmissibleCuts t)
      ([([] : List Address)] ++
        ([[([] : Address)]] ++ internalCoalgebraAdmissibleCuts t)) := by
  classical
  have hperm :
      List.Perm (coalgebraAdmissibleCuts t)
        ((coalgebraAdmissibleCuts t).filter
            (fun cut => decide (cut = [])) ++
          (((coalgebraAdmissibleCuts t).filter
              (fun cut => !(decide (cut = [])))).filter
              (fun cut => decide (([] : Address) ∈ cut)) ++
            ((coalgebraAdmissibleCuts t).filter
              (fun cut => !(decide (cut = [])))).filter
              (fun cut => !(decide (([] : Address) ∈ cut))))) :=
    List.perm_filter_append_filter_filter_append_filter_filter_not
      (coalgebraAdmissibleCuts t)
      (fun cut => decide (cut = []))
      (fun cut => decide (([] : Address) ∈ cut))
  have hempty :
      (coalgebraAdmissibleCuts t).filter
          (fun cut => decide (cut = [])) =
        [([] : List Address)] := by
    rw [filter_eq_emptyCut_coalgebraAdmissibleCuts]
  have hroot :
      ((coalgebraAdmissibleCuts t).filter
          (fun cut => !(decide (cut = [])))).filter
          (fun cut => decide (([] : Address) ∈ cut)) =
        [[([] : Address)]] := by
    rw [filter_ne_empty_eq_rootContainingCut_coalgebraAdmissibleCuts]
  have hinternal :
      ((coalgebraAdmissibleCuts t).filter
          (fun cut => !(decide (cut = [])))).filter
          (fun cut => !(decide (([] : Address) ∈ cut))) =
        internalCoalgebraAdmissibleCuts t := by
    rfl
  exact hperm.trans (by
    rw [hempty, hroot, hinternal])

theorem coalgebraRightStageTripleSupport_perm_empty_root_internal
    (t : PTree) :
    List.Perm
      (coalgebraRightStageTripleSupport t)
      (coalgebraRightEmptyFirstTripleSupport t ++
        (coalgebraRightRootFirstTripleSupport t ++
          coalgebraRightInternalFirstTripleSupport t)) := by
  classical
  unfold coalgebraRightStageTripleSupport
  unfold coalgebraRightEmptyFirstTripleSupport
  unfold coalgebraRightRootFirstTripleSupport
  unfold coalgebraRightInternalFirstTripleSupport
  have hcuts := coalgebraAdmissibleCuts_perm_empty_root_internal t
  have hflat :
      List.Perm
        ((coalgebraAdmissibleCuts t).flatMap
          (coalgebraRightStageTripleBranch t))
        (([([] : List Address)] ++
            ([[([] : Address)]] ++ internalCoalgebraAdmissibleCuts t)).flatMap
          (coalgebraRightStageTripleBranch t)) :=
    hcuts.flatMap (by
      intro cut _hcut
      exact List.Perm.refl _)
  simpa [List.flatMap_cons, List.flatMap_nil] using hflat

theorem coalgebraLeftStageTripleSupport_perm_empty_root_internal
    (t : PTree) :
    List.Perm
      (coalgebraLeftStageTripleSupport t)
      (coalgebraLeftEmptyFirstTripleSupport t ++
        (coalgebraLeftRootFirstTripleSupport t ++
          coalgebraLeftInternalFirstTripleSupport t)) := by
  classical
  unfold coalgebraLeftStageTripleSupport
  unfold coalgebraLeftEmptyFirstTripleSupport
  unfold coalgebraLeftRootFirstTripleSupport
  unfold coalgebraLeftInternalFirstTripleSupport
  have hcuts := coalgebraAdmissibleCuts_perm_empty_root_internal t
  have hflat :
      List.Perm
        ((coalgebraAdmissibleCuts t).flatMap
          (coalgebraLeftStageTripleBranch t))
        (([([] : List Address)] ++
            ([[([] : Address)]] ++ internalCoalgebraAdmissibleCuts t)).flatMap
          (coalgebraLeftStageTripleBranch t)) :=
    hcuts.flatMap (by
      intro cut _hcut
      exact List.Perm.refl _)
  simpa [List.flatMap_cons, List.flatMap_nil] using hflat

theorem coalgebraRightEmptyFirstTripleSupport_perm_boundary_internal
    (t : PTree) :
    List.Perm
      (coalgebraRightEmptyFirstTripleSupport t)
      ([(0, 0, HQ.singleton t)] ++
        ([(0, HQ.singleton t, 0)] ++
          coalgebraInternalIdentityTripleSupport t)) := by
  classical
  unfold coalgebraRightEmptyFirstTripleSupport
  rw [coalgebraRightStageTripleBranch_empty]
  let F : List Address → HypersequentTripleBasis :=
    fun cut => coalgebraRightStageTripleOfCuts t [] cut
  have hmap := (coalgebraAdmissibleCuts_perm_empty_root_internal t).map F
  have htail :
      (internalCoalgebraAdmissibleCuts t).map F =
        coalgebraInternalIdentityTripleSupport t := by
    unfold F coalgebraInternalIdentityTripleSupport
    apply List.map_congr_left
    intro cut hcut
    have hinternal : InternalCut cut :=
      ((mem_internalCoalgebraAdmissibleCuts_iff).1 hcut).2
    rw [coalgebraRightStageTripleOfCuts_empty_first]
    rw [coalgebraTensorTermOfCutList_of_ne_nil_of_root_not_mem
      hinternal.1 hinternal.2]
  refine hmap.trans ?_
  rw [List.map_append, List.map_append, htail]
  simp [F]

theorem coalgebraLeftRootFirstTripleSupport_perm_boundary_internal
    (t : PTree) :
    List.Perm
      (coalgebraLeftRootFirstTripleSupport t)
      ([(0, HQ.singleton t, 0)] ++
        ([(HQ.singleton t, 0, 0)] ++
          coalgebraInternalSecondRootTripleSupport t)) := by
  classical
  unfold coalgebraLeftRootFirstTripleSupport
  rw [coalgebraLeftStageTripleBranch_root]
  unfold coalgebraTreeSplittingTensorSupport
  let F : List Address → HypersequentTripleBasis :=
    fun cut =>
      let p := coalgebraTensorTermOfCutList t cut
      (p.1, p.2, (0 : Hypersequent))
  have hmap := (coalgebraAdmissibleCuts_perm_empty_root_internal t).map F
  have htail :
      (internalCoalgebraAdmissibleCuts t).map F =
        coalgebraInternalSecondRootTripleSupport t := by
    unfold F coalgebraInternalSecondRootTripleSupport
    apply List.map_congr_left
    intro cut hcut
    have hinternal : InternalCut cut :=
      ((mem_internalCoalgebraAdmissibleCuts_iff).1 hcut).2
    rw [coalgebraTensorTermOfCutList_of_ne_nil_of_root_not_mem
      hinternal.1 hinternal.2]
  have hboundary :
      List.Perm
        (([([] : List Address)] ++
            ([[([] : Address)]] ++ internalCoalgebraAdmissibleCuts t)).map F)
        ([(0, HQ.singleton t, 0)] ++
          ([(HQ.singleton t, 0, 0)] ++
            coalgebraInternalSecondRootTripleSupport t)) := by
    rw [List.map_append, List.map_append, htail]
    simp [F]
  simpa [F, List.map_map, Function.comp_def] using hmap.trans hboundary

theorem coalgebraRightRootFirstTripleSupport_perm_boundary
    (t : PTree) :
    List.Perm
      (coalgebraRightRootFirstTripleSupport t)
      [(HQ.singleton t, 0, 0)] := by
  simp [coalgebraRightRootFirstTripleSupport]

theorem coalgebraLeftEmptyFirstTripleSupport_perm_boundary
    (t : PTree) :
    List.Perm
      (coalgebraLeftEmptyFirstTripleSupport t)
      [(0, 0, HQ.singleton t)] := by
  simp [coalgebraLeftEmptyFirstTripleSupport]

theorem coalgebraInternalInternalExtensionPerm_leaf
    (s : MultiSequent) :
    List.Perm
      (coalgebraRightInternalInternalTripleSupport (PTree.leaf s))
      (coalgebraLeftInternalInternalTripleSupport (PTree.leaf s)) := by
  simp [coalgebraRightInternalInternalTripleSupport,
    coalgebraLeftInternalInternalTripleSupport,
    internalCoalgebraAdmissibleCuts, coalgebraAdmissibleCuts,
    PTree.allAdmissibleCuts, PTree.sublists, PTree.allAddresses,
    PTree.allAddressesGo, PTree.size, PTree.validAddress,
    PTree.subtreeAt, PTree.isAntichainBool]

/--
Nat-valued multiplicity form of the node-normal internal/internal comparison.

This is the count-balance target suggested by the proved grafting-side
permutation infrastructure: every triple-basis atom must occur with the same
multiplicity in the nested-remainder enumeration and in the proper
detached-forest enumeration.
-/
def NodeNormalInternalInternalNatCountBalanced
    (r : RuleTag) (s : MultiSequent) (cs : List PTree) : Prop :=
  ∀ p : HypersequentTripleBasis,
    @List.count HypersequentTripleBasis instBEqOfDecidableEq p
        (nodeRightInternalInternalNormalSupport r s cs) =
      @List.count HypersequentTripleBasis instBEqOfDecidableEq p
        (nodeLeftInternalInternalNormalSupport r s cs)

/-- Witness indices for the right node-normal internal/internal support. -/
noncomputable def nodeRightInternalInternalNormalWitnesses
    (r : RuleTag) (s : MultiSequent) (cs : List PTree) :
    List (List Address × List Address) :=
  (internalCoalgebraAdmissibleCuts (PTree.node r s cs)).flatMap
    (fun cut₁ =>
      (internalCoalgebraAdmissibleCuts
          (PTree.node r s
            (nodeRootFreeCutRemainderChildren cs cut₁))).map
        (fun cut₂ => (cut₁, cut₂)))

/-- The triple-basis atom indexed by a right node-normal witness. -/
noncomputable def nodeRightInternalInternalNormalWitnessTriple
    (r : RuleTag) (s : MultiSequent) (cs : List PTree)
    (w : List Address × List Address) : HypersequentTripleBasis :=
  let cut₁ := w.1
  let cut₂ := w.2
  let q :=
    coalgebraTensorTermOfCutList
      (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁)) cut₂
  (HQ.ofForest (nodeRootFreeCutDetachedForest cs cut₁), q.1, q.2)

/-- Witness indices for the left node-normal internal/internal support. -/
noncomputable def nodeLeftInternalInternalNormalWitnesses
    (r : RuleTag) (s : MultiSequent) (cs : List PTree) :
    List (List Address × HypersequentTensorBasis) :=
  (internalCoalgebraAdmissibleCuts (PTree.node r s cs)).flatMap
    (fun cut =>
      (coalgebraForestProperSplittingTensorSupport
          (nodeRootFreeCutDetachedForest cs cut)).map
        (fun q => (cut, q)))

/-- The triple-basis atom indexed by a left node-normal witness. -/
noncomputable def nodeLeftInternalInternalNormalWitnessTriple
    (r : RuleTag) (s : MultiSequent) (cs : List PTree)
    (w : List Address × HypersequentTensorBasis) :
    HypersequentTripleBasis :=
  let cut := w.1
  let q := w.2
  (q.1, q.2,
    HQ.singleton
      (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut)))

/--
Profile-expanded witnesses for the left node-normal internal/internal support.

The first component is the ambient internal cut of the original node.  The
second component records one coalgebra cut for each proof tree in the detached
forest of that ambient cut.
-/
noncomputable def nodeLeftInternalInternalNormalProfileWitnesses
    (r : RuleTag) (s : MultiSequent) (cs : List PTree) :
    List (List Address × List (List Address)) :=
  (internalCoalgebraAdmissibleCuts (PTree.node r s cs)).flatMap
    (fun cut =>
      (coalgebraForestProperCutProfiles
          (nodeRootFreeCutDetachedForest cs cut)).map
        (fun profile => (cut, profile)))

/-- The triple-basis atom indexed by a left profile witness. -/
noncomputable def nodeLeftInternalInternalNormalProfileWitnessTriple
    (r : RuleTag) (s : MultiSequent) (cs : List PTree)
    (w : List Address × List (List Address)) :
    HypersequentTripleBasis :=
  let cut := w.1
  let profile := w.2
  let q :=
    coalgebraForestTensorTermOfProfile
      (nodeRootFreeCutDetachedForest cs cut) profile
  (q.1, q.2,
    HQ.singleton
      (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut)))

/-- Candidate first-stage cut recovered from a left profile witness. -/
def nodeLeftProfileWitnessFirstCut
    (cs : List PTree) (w : List Address × List (List Address)) :
    List Address :=
  forestProfileFirstCut
    (nodeRootFreeCutPrefixedRestrictions cs w.1) w.2

/-- Candidate second-stage cut recovered from a left profile witness. -/
def nodeLeftProfileWitnessSecondCut
    (cs : List PTree) (w : List Address × List (List Address)) :
    List Address :=
  forestProfileSecondCut
    (nodeRootFreeCutPrefixedRestrictions cs w.1) w.2

/-- Candidate right witness recovered from a profile-expanded left witness. -/
def nodeLeftProfileWitnessToRightWitness
    (cs : List PTree) (w : List Address × List (List Address)) :
    List Address × List Address :=
  (nodeLeftProfileWitnessFirstCut cs w,
    nodeLeftProfileWitnessSecondCut cs w)

/-- Canonicalized first-stage cut recovered from a left profile witness. -/
def nodeLeftProfileWitnessCanonicalFirstCut
    (r : RuleTag) (s : MultiSequent) (cs : List PTree)
    (w : List Address × List (List Address)) :
    List Address :=
  PTree.canonicalCut (PTree.node r s cs)
    (nodeLeftProfileWitnessFirstCut cs w)

/--
Candidate right witness recovered from a profile-expanded left witness, using
the canonical enumeration of the recovered first antichain.
-/
def nodeLeftProfileWitnessCanonicalRightWitness
    (r : RuleTag) (s : MultiSequent) (cs : List PTree)
    (w : List Address × List (List Address)) :
    List Address × List Address :=
  (nodeLeftProfileWitnessCanonicalFirstCut r s cs w,
    nodeLeftProfileWitnessSecondCut cs w)

/--
Canonicalized second-stage cut recovered from a profile-expanded left witness,
after the first-stage cut has already been put in canonical tree order.
-/
def nodeLeftProfileWitnessCanonicalSecondCut
    (r : RuleTag) (s : MultiSequent) (cs : List PTree)
    (w : List Address × List (List Address)) :
    List Address :=
  PTree.canonicalCut
    (PTree.node r s
      (nodeRootFreeCutRemainderChildren cs
        (nodeLeftProfileWitnessCanonicalFirstCut r s cs w)))
    (nodeLeftProfileWitnessSecondCut cs w)

/--
Right witness recovered from a profile-expanded left witness, with both staged
cuts represented in canonical tree order.
-/
def nodeLeftProfileWitnessFullyCanonicalRightWitness
    (r : RuleTag) (s : MultiSequent) (cs : List PTree)
    (w : List Address × List (List Address)) :
    List Address × List Address :=
  (nodeLeftProfileWitnessCanonicalFirstCut r s cs w,
    nodeLeftProfileWitnessCanonicalSecondCut r s cs w)

theorem mem_nodeLeftProfileWitnessFirstCut_iff_exists_zip
    {cs : List PTree} {w : List Address × List (List Address)}
    {x : Address} :
    x ∈ nodeLeftProfileWitnessFirstCut cs w ↔
      ∃ a cut c,
        (a, cut) ∈
            List.zip (nodeRootFreeCutPrefixedRestrictions cs w.1) w.2 ∧
          c ∈ cut ∧ x = a ++ c := by
  simpa [nodeLeftProfileWitnessFirstCut] using
    (mem_forestProfileFirstCut_iff_exists_zip
      (ambient := nodeRootFreeCutPrefixedRestrictions cs w.1)
      (profile := w.2) (x := x))

theorem mem_nodeLeftProfileWitnessFirstCut_of_mem_zip
    {cs : List PTree} {w : List Address × List (List Address)}
    {a c : Address} {cut : List Address}
    (hzip :
      (a, cut) ∈
        List.zip (nodeRootFreeCutPrefixedRestrictions cs w.1) w.2)
    (hc : c ∈ cut) :
    a ++ c ∈ nodeLeftProfileWitnessFirstCut cs w := by
  exact (mem_nodeLeftProfileWitnessFirstCut_iff_exists_zip
    (cs := cs) (w := w) (x := a ++ c)).2
    ⟨a, cut, c, hzip, hc, rfl⟩

theorem mem_nodeLeftProfileWitnessSecondCut_iff_exists_zip_nonroot
    {cs : List PTree} {w : List Address × List (List Address)}
    {a : Address} :
    a ∈ nodeLeftProfileWitnessSecondCut cs w ↔
      ∃ cut,
        (a, cut) ∈
            List.zip (nodeRootFreeCutPrefixedRestrictions cs w.1) w.2 ∧
          cut ≠ [([] : Address)] := by
  simpa [nodeLeftProfileWitnessSecondCut] using
    (mem_forestProfileSecondCut_iff_exists_zip_nonroot
      (ambient := nodeRootFreeCutPrefixedRestrictions cs w.1)
      (profile := w.2) (a := a))

theorem mem_nodeLeftProfileWitnessSecondCut_of_mem_zip_nonroot
    {cs : List PTree} {w : List Address × List (List Address)}
    {a : Address} {cut : List Address}
    (hzip :
      (a, cut) ∈
        List.zip (nodeRootFreeCutPrefixedRestrictions cs w.1) w.2)
    (hroot : cut ≠ [([] : Address)]) :
    a ∈ nodeLeftProfileWitnessSecondCut cs w := by
  exact (mem_nodeLeftProfileWitnessSecondCut_iff_exists_zip_nonroot
    (cs := cs) (w := w) (a := a)).2
    ⟨cut, hzip, hroot⟩

/--
Profile attached to the canonical ambient cut of a right staged witness.

Ambient addresses that are second-stage cut addresses carry the restricted
first-stage cut beneath them.  Ambient addresses that survive from the first
stage are split at their root in the detached forest.
-/
noncomputable def nodeRightWitnessAmbientProfile
    (r : RuleTag) (s : MultiSequent) (cs : List PTree)
    (cut₁ cut₂ : List Address) : List (List Address) := by
  classical
  exact
    (nodeRootFreeCutPrefixedRestrictions cs
      (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂)).map
      (fun a =>
        if a ∈ cut₂ then
          PTree.restrictCutAt cut₁ a
        else
          [([] : Address)])

/-- Candidate profile-expanded left witness obtained from a right witness. -/
noncomputable def nodeRightWitnessToLeftProfileWitness
    (r : RuleTag) (s : MultiSequent) (cs : List PTree)
    (w : List Address × List Address) :
    List Address × List (List Address) :=
  (nodeCanonicalAmbientCutOfRightWitness r s cs w.1 w.2,
    nodeRightWitnessAmbientProfile r s cs w.1 w.2)

@[simp]
theorem nodeRightWitnessAmbientProfile_length
    (r : RuleTag) (s : MultiSequent) (cs : List PTree)
    (cut₁ cut₂ : List Address) :
    (nodeRightWitnessAmbientProfile r s cs cut₁ cut₂).length =
      (nodeRootFreeCutPrefixedRestrictions cs
        (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂)).length := by
  simp [nodeRightWitnessAmbientProfile]

theorem nodeRightWitnessAmbientProfile_length_eq_detachedForest
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))) :
    (nodeRightWitnessAmbientProfile r s cs cut₁ cut₂).length =
      (nodeRootFreeCutDetachedForest cs
        (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂)).length := by
  have hambient :
      nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂ ∈
        internalCoalgebraAdmissibleCuts (PTree.node r s cs) :=
    nodeCanonicalAmbientCut_mem_internalCoalgebraAdmissibleCuts
      (r := r) (s := s) (cs := cs)
      (cut₁ := cut₁) (cut₂ := cut₂) hcut₁ hcut₂
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hambient with
    ⟨hcoal, hint⟩
  rw [nodeRightWitnessAmbientProfile_length]
  exact nodeRootFreeCutPrefixedRestrictions_length_eq_detachedForest
    (r := r) (s := s) (cs := cs)
    (cut := nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂)
    hcoal hint.2

theorem nodeRightWitnessAmbientProfile_mem_coalgebraForestCutProfiles
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))) :
    nodeRightWitnessAmbientProfile r s cs cut₁ cut₂ ∈
      coalgebraForestCutProfiles
        (nodeRootFreeCutDetachedForest cs
          (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂)) := by
  let t := PTree.node r s cs
  let ambient := nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂
  let addrs := nodeRootFreeCutPrefixedRestrictions cs ambient
  let profile := nodeRightWitnessAmbientProfile r s cs cut₁ cut₂
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₁ with
    ⟨_hcoal₁, hint₁⟩
  have hfirstRem :
      PTree.remainderGo cut₁ [] t =
        PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁) := by
    simpa [t, nodeRootFreeCutRemainderChildren] using
      PTree.remainderGo_node_root_not_mem
        (r := r) (s := s) (cs := cs)
        (cut := cut₁) hint₁.2
  have hcut₂Rem :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.remainderGo cut₁ [] t) := by
    simpa [t, hfirstRem] using hcut₂
  have hambient :
      ambient ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs) := by
    simpa [ambient] using
      nodeCanonicalAmbientCut_mem_internalCoalgebraAdmissibleCuts
        (r := r) (s := s) (cs := cs)
        (cut₁ := cut₁) (cut₂ := cut₂) hcut₁ hcut₂
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hambient with
    ⟨hambientCoal, hambientInternal⟩
  have hlen : profile.length = addrs.length := by
    simp [profile, addrs, ambient, nodeRightWitnessAmbientProfile]
  have hzip :
      ∀ a cut, (a, cut) ∈ List.zip addrs profile →
        ∃ u, PTree.subtreeAt t a = some u ∧
          cut ∈ coalgebraAdmissibleCuts u := by
    intro a cut hmem
    have hpair :
        a ∈ addrs ∧
          cut =
            (if a ∈ cut₂ then
              PTree.restrictCutAt cut₁ a
            else
              [([] : Address)]) := by
