/--
Support-to-triple comparison map for the detached-forest-first staged
normalized coproduct.
-/
def hypersequentTensorAlgToLeftStageTripleLinearMap :
    HypersequentTensorAlgebra R →ₗ[R] HypersequentTripleTensor R :=
  (TensorProduct.assoc R
      (HypersequentAlgebra R)
      (HypersequentAlgebra R)
      (HypersequentAlgebra R)).toLinearMap ∘ₗ
      LinearMap.rTensor (HypersequentAlgebra R)
        (hypersequentCoalgebraComulTensorLinearMap R) ∘ₗ
      hypersequentTensorAlgToTensorProductLinearMap R

@[simp]
theorem hypersequentTripleBasisTmul_of_tensorBasis_right
    (p : HypersequentTensorBasis) (G : Hypersequent) :
    hypersequentTripleBasisTmul R (p.1, p.2, G) =
      (TensorProduct.assoc R
          (HypersequentAlgebra R)
          (HypersequentAlgebra R)
          (HypersequentAlgebra R)).toLinearMap
        ((LinearMap.rTensor (HypersequentAlgebra R)
            (hypersequentTensorAlgToTensorProductLinearMap R))
          (((TensorProduct.mk R
              (HypersequentTensorAlgebra R)
              (HypersequentAlgebra R)).flip
            (hseqMonomial R G)) (tensorBasisMonomial R p))) := by
  simp [hypersequentTripleBasisTmul, tensorBasisTmul, LinearMap.rTensor_tmul,
    hypersequentTensorAlgToTensorProductLinearMap_monomial]

theorem hypersequentTripleTensor_ofLast_tensorSupportElement
    (xs : List HypersequentTensorBasis) (G : Hypersequent) :
    ((TensorProduct.assoc R
        (HypersequentAlgebra R)
        (HypersequentAlgebra R)
        (HypersequentAlgebra R)).toLinearMap)
      ((LinearMap.rTensor (HypersequentAlgebra R)
          (hypersequentTensorAlgToTensorProductLinearMap R))
        ((((TensorProduct.mk R
            (HypersequentTensorAlgebra R)
            (HypersequentAlgebra R)).flip
          (hseqMonomial R G)) (tensorSupportElement R xs)))) =
    (xs.map (fun p => hypersequentTripleBasisTmul R (p.1, p.2, G))).sum := by
  let M : HypersequentTensorAlgebra R →ₗ[R]
      TensorProduct R (HypersequentTensorAlgebra R) (HypersequentAlgebra R) :=
    ((TensorProduct.mk R
        (HypersequentTensorAlgebra R)
        (HypersequentAlgebra R)).flip
      (hseqMonomial R G))
  let N :
      TensorProduct R (HypersequentTensorAlgebra R) (HypersequentAlgebra R) →ₗ[R]
        HypersequentTripleTensor R :=
    ((TensorProduct.assoc R
        (HypersequentAlgebra R)
        (HypersequentAlgebra R)
        (HypersequentAlgebra R)).toLinearMap).comp
      (LinearMap.rTensor (HypersequentAlgebra R)
        (hypersequentTensorAlgToTensorProductLinearMap R))
  let L : HypersequentTensorAlgebra R →ₗ[R] HypersequentTripleTensor R :=
    N.comp M
  simpa [L, M, N, LinearMap.comp_apply,
    hypersequentTripleBasisTmul_of_tensorBasis_right] using
    (linearMap_apply_tensorSupportElement R L xs)

theorem hypersequentTensorAlgToLeftStageTripleLinearMap_coalgebraCut
    (t : PTree) (cut₁ : List Address) :
    hypersequentTensorAlgToLeftStageTripleLinearMap R
        (tensorBasisMonomial R (coalgebraTensorTermOfCutList t cut₁)) =
      ((coalgebraLeftStageTripleBranch t cut₁).map
        (hypersequentTripleBasisTmul (R := R))).sum := by
  classical
  by_cases h₁ : cut₁ = []
  · subst cut₁
    unfold hypersequentTensorAlgToLeftStageTripleLinearMap coalgebraLeftStageTripleBranch
    simp only [LinearMap.comp_apply]
    rw [coalgebraTensorTermOfCutList_nil,
      hypersequentTensorAlgToTensorProductLinearMap_monomial, tensorBasisTmul,
      hseqMonomial_zero]
    simp only [LinearMap.rTensor_tmul]
    have hone :
        hypersequentCoalgebraComulTensorLinearMap R (1 : HypersequentAlgebra R) =
          hypersequentTensorAlgToTensorProductLinearMap R
            (coalgebraForestSplittingTensorElement R []) := by
      simpa using
        hypersequentCoalgebraComulTensorLinearMap_ofForest (R := R) ([] : Forest)
    rw [hone]
    simpa [coalgebraForestSplittingTensorElement, coalgebraForestSplittingTensorSupport,
      tensorSupportElement, hypersequentTripleBasisTmul, tensorBasisTmul,
      hseqMonomial_singleton_eq_treeMonomial] using
      (hypersequentTripleTensor_ofLast_tensorSupportElement
        (R := R)
        (xs := coalgebraForestSplittingTensorSupport [])
        (G := HQ.singleton t))
  · by_cases hroot : ([] : Address) ∈ cut₁
    · have hcut : coalgebraTensorTermOfCutList t cut₁ = (HQ.singleton t, 0) := by
        simp [coalgebraTensorTermOfCutList, h₁, hroot]
      unfold hypersequentTensorAlgToLeftStageTripleLinearMap coalgebraLeftStageTripleBranch
      simp only [LinearMap.comp_apply]
      rw [hcut, hypersequentTensorAlgToTensorProductLinearMap_monomial, tensorBasisTmul,
        hseqMonomial_singleton_eq_treeMonomial]
      simp only [LinearMap.rTensor_tmul]
      rw [hypersequentCoalgebraComulTensorLinearMap_tree]
      simpa [coalgebraDetachedForestOfCut, h₁, hroot, coalgebraRemainderOfCut,
        hcut] using
        (hypersequentTripleTensor_ofLast_tensorSupportElement
          (R := R)
          (xs := coalgebraForestSplittingTensorSupport [t])
          (G := (0 : Hypersequent)))
    · have hcut :
          coalgebraTensorTermOfCutList t cut₁ =
            (HQ.ofForest (cut₁.filterMap (PTree.subtreeAt t)),
              HQ.singleton (PTree.remainderGo cut₁ [] t)) := by
          exact coalgebraTensorTermOfCutList_of_ne_nil_of_root_not_mem h₁ hroot
      unfold hypersequentTensorAlgToLeftStageTripleLinearMap coalgebraLeftStageTripleBranch
      simp only [LinearMap.comp_apply]
      rw [hcut, hypersequentTensorAlgToTensorProductLinearMap_monomial, tensorBasisTmul,
        hseqMonomial_singleton_eq_treeMonomial]
      simp only [LinearMap.rTensor_tmul]
      rw [show hypersequentCoalgebraComulTensorLinearMap R
          (hseqMonomial R (HQ.ofForest (cut₁.filterMap (PTree.subtreeAt t)))) =
        hypersequentTensorAlgToTensorProductLinearMap R
          (coalgebraForestSplittingTensorElement R
            (cut₁.filterMap (PTree.subtreeAt t))) by
            exact hypersequentCoalgebraComulTensorLinearMap_ofForest
              (R := R) (cut₁.filterMap (PTree.subtreeAt t))]
      simpa [coalgebraDetachedForestOfCut, h₁, hroot, coalgebraRemainderOfCut,
        coalgebraTensorTermOfCutList, Function.comp_def] using
        (hypersequentTripleTensor_ofLast_tensorSupportElement
          (R := R)
          (xs := coalgebraForestSplittingTensorSupport
            (cut₁.filterMap (PTree.subtreeAt t)))
          (G := HQ.singleton (PTree.remainderGo cut₁ [] t)))

theorem hypersequentCoalgebraRightStageTensorLinearMap_eq_comp
    (x : HypersequentAlgebra R) :
    hypersequentCoalgebraRightStageTensorLinearMap R x =
      hypersequentTensorAlgToLeftStageTripleLinearMap R
        (hypersequentCoalgebraComulAlgHom R x) := by
  rfl

/--
Concrete left-stage expansion target for tree-level normalized coassociativity.

This is the detached-forest-first companion to
`HypersequentNormalizedCoalgebraRightTreeExpansion`.
-/
def HypersequentNormalizedCoalgebraLeftTreeExpansion : Prop :=
  ∀ t : PTree,
    hypersequentCoalgebraRightStageTensorLinearMap R
      (treeMonomial R t) =
    coalgebraLeftStageTripleElement R t

theorem hypersequentNormalizedCoalgebraLeftTreeExpansion :
    HypersequentNormalizedCoalgebraLeftTreeExpansion R := by
  intro t
  rw [hypersequentCoalgebraRightStageTensorLinearMap_eq_comp,
    hypersequentCoalgebraComulAlgHom_tree]
  unfold coalgebraTreeSplittingTensorElement coalgebraTreeSplittingTensorSupport
  rw [linearMap_apply_tensorSupportElement R
      (hypersequentTensorAlgToLeftStageTripleLinearMap R)
      ((coalgebraAdmissibleCuts t).map (coalgebraTensorTermOfCutList t))]
  rw [List.map_map]
  change (List.map
      (fun cut =>
        hypersequentTensorAlgToLeftStageTripleLinearMap R
          (tensorBasisMonomial R (coalgebraTensorTermOfCutList t cut)))
      (coalgebraAdmissibleCuts t)).sum =
    coalgebraLeftStageTripleElement R t
  simp_rw [hypersequentTensorAlgToLeftStageTripleLinearMap_coalgebraCut]
  unfold coalgebraLeftStageTripleElement coalgebraLeftStageTripleSupport
  simpa [Function.comp_def] using
    (List.sum_map_sum_eq_sum_flatMap
      (xs := coalgebraAdmissibleCuts t)
      (f := coalgebraLeftStageTripleBranch t)
      (g := hypersequentTripleBasisTmul (R := R)))

/--
Tree-level right counit law for the normalized GL/CK coproduct.

After applying the augmentation to the detached-forest factor, only the empty
cut survives, producing `1 ⊗ t`.
-/
theorem hypersequentNormalizedRightCounit_tree
    (t : PTree) :
    (LinearMap.rTensor (HypersequentAlgebra R)
        (hypersequentCounitAlgHom R).toLinearMap ∘ₗ
        hypersequentCoalgebraComulTensorLinearMap R)
      (treeMonomial R t) =
    ((TensorProduct.mk R R (HypersequentAlgebra R)) 1)
      (treeMonomial R t) := by
  classical
  let g : List Address → TensorProduct R R (HypersequentAlgebra R) :=
    fun cut =>
      (LinearMap.rTensor (HypersequentAlgebra R)
          (hypersequentCounitAlgHom R).toLinearMap)
        ((hypersequentTensorAlgToTensorProductLinearMap R)
          (tensorBasisMonomial R (coalgebraTensorTermOfCutList t cut)))
  change
    (LinearMap.rTensor (HypersequentAlgebra R)
        (hypersequentCounitAlgHom R).toLinearMap)
      (hypersequentCoalgebraComulTensorLinearMap R (treeMonomial R t)) =
    1 ⊗ₜ[R] treeMonomial R t
  rw [hypersequentCoalgebraComulTensorLinearMap_tree]
  unfold coalgebraTreeSplittingTensorElement coalgebraTreeSplittingTensorSupport
  change
    ((LinearMap.rTensor (HypersequentAlgebra R)
        (hypersequentCounitAlgHom R).toLinearMap).comp
      (hypersequentTensorAlgToTensorProductLinearMap R))
      (tensorSupportElement R ((coalgebraAdmissibleCuts t).map (coalgebraTensorTermOfCutList t))) =
    1 ⊗ₜ[R] treeMonomial R t
  rw [linearMap_apply_tensorSupportElement R
      (((LinearMap.rTensor (HypersequentAlgebra R)
        (hypersequentCounitAlgHom R).toLinearMap).comp
        (hypersequentTensorAlgToTensorProductLinearMap R)))
      ((coalgebraAdmissibleCuts t).map (coalgebraTensorTermOfCutList t))]
  simp only [List.map_map]
  change ((coalgebraAdmissibleCuts t).map g).sum = 1 ⊗ₜ[R] treeMonomial R t
  rw [List.sum_map_eq_filter_add_filter_not
      (xs := coalgebraAdmissibleCuts t)
      (p := fun cut => decide (cut = []))
      (f := g)]
  rw [filter_eq_emptyCut_coalgebraAdmissibleCuts]
  have hzero :
      (((coalgebraAdmissibleCuts t).filter (fun cut => !(decide (cut = [])))).map g).sum = 0 := by
    apply List.sum_map_eq_zero_of_forall
    intro cut hcut
    have hmemCoal : cut ∈ coalgebraAdmissibleCuts t := (List.mem_filter.1 hcut).1
    have hmem : cut ∈ PTree.allAdmissibleCuts t :=
      ((mem_coalgebraAdmissibleCuts_iff).1 hmemCoal).1
    have hne : cut ≠ [] := by
      intro hc
      subst cut
      simp at hcut
    simpa [g, hypersequentTensorAlgToTensorProductLinearMap_monomial] using
      rTensor_augmentationCounit_tensorBasisTmul_coalgebra_of_ne_nil
        (R := R) (t := t) (cut := cut) hmem hne
  have hempty : g [] = 1 ⊗ₜ[R] treeMonomial R t := by
    simp [g, hypersequentTensorAlgToTensorProductLinearMap_monomial,
      rTensor_augmentationCounit_coalgebraEmptyTensor]
  simp [hempty, hzero]

/--
Tree-level left counit law for the normalized GL/CK coproduct.

After applying the augmentation to the remainder factor, only the root cut
survives, producing `t ⊗ 1`.
-/
theorem hypersequentNormalizedLeftCounit_tree
    (t : PTree) :
    (LinearMap.lTensor (HypersequentAlgebra R)
        (hypersequentCounitAlgHom R).toLinearMap ∘ₗ
        hypersequentCoalgebraComulTensorLinearMap R)
      (treeMonomial R t) =
    (((TensorProduct.mk R (HypersequentAlgebra R) R).flip 1))
      (treeMonomial R t) := by
  classical
  let g : List Address → TensorProduct R (HypersequentAlgebra R) R :=
    fun cut =>
      (LinearMap.lTensor (HypersequentAlgebra R)
          (hypersequentCounitAlgHom R).toLinearMap)
        ((hypersequentTensorAlgToTensorProductLinearMap R)
          (tensorBasisMonomial R (coalgebraTensorTermOfCutList t cut)))
  change
    (LinearMap.lTensor (HypersequentAlgebra R)
        (hypersequentCounitAlgHom R).toLinearMap)
      (hypersequentCoalgebraComulTensorLinearMap R (treeMonomial R t)) =
    treeMonomial R t ⊗ₜ[R] 1
  rw [hypersequentCoalgebraComulTensorLinearMap_tree]
  unfold coalgebraTreeSplittingTensorElement coalgebraTreeSplittingTensorSupport
  change
    ((LinearMap.lTensor (HypersequentAlgebra R)
        (hypersequentCounitAlgHom R).toLinearMap).comp
      (hypersequentTensorAlgToTensorProductLinearMap R))
      (tensorSupportElement R ((coalgebraAdmissibleCuts t).map (coalgebraTensorTermOfCutList t))) =
    treeMonomial R t ⊗ₜ[R] 1
  rw [linearMap_apply_tensorSupportElement R
      (((LinearMap.lTensor (HypersequentAlgebra R)
        (hypersequentCounitAlgHom R).toLinearMap).comp
        (hypersequentTensorAlgToTensorProductLinearMap R)))
      ((coalgebraAdmissibleCuts t).map (coalgebraTensorTermOfCutList t))]
  simp only [List.map_map]
  change ((coalgebraAdmissibleCuts t).map g).sum = treeMonomial R t ⊗ₜ[R] 1
  rw [List.sum_map_eq_filter_add_filter_not
      (xs := coalgebraAdmissibleCuts t)
      (p := fun cut => decide (([] : Address) ∈ cut))
      (f := g)]
  rw [filter_eq_rootContainingCut_coalgebraAdmissibleCuts]
  have hzero :
      (((coalgebraAdmissibleCuts t).filter (fun cut => !(decide (([] : Address) ∈ cut)))).map g).sum = 0 := by
    apply List.sum_map_eq_zero_of_forall
    intro cut hcut
    have hmemCoal : cut ∈ coalgebraAdmissibleCuts t := (List.mem_filter.1 hcut).1
    have hmem : cut ∈ PTree.allAdmissibleCuts t :=
      ((mem_coalgebraAdmissibleCuts_iff).1 hmemCoal).1
    have hroot : ([] : Address) ∉ cut := by
      intro hc
      simp [hc] at hcut
    simpa [g, hypersequentTensorAlgToTensorProductLinearMap_monomial] using
      lTensor_augmentationCounit_tensorBasisTmul_coalgebra_of_root_not_mem
        (R := R) (t := t) (cut := cut) hmem hroot
  have hroot : g [[]] = treeMonomial R t ⊗ₜ[R] 1 := by
    simp [g, hypersequentTensorAlgToTensorProductLinearMap_monomial,
      lTensor_augmentationCounit_coalgebraRootTensor]
  simp [hroot, hzero]

@[simp]
theorem hypersequentNormalizedRightCounit_zero :
    (LinearMap.rTensor (HypersequentAlgebra R)
        (hypersequentCounitAlgHom R).toLinearMap ∘ₗ
        hypersequentCoalgebraComulTensorLinearMap R)
      (hseqMonomial R (0 : Hypersequent)) =
    ((TensorProduct.mk R R (HypersequentAlgebra R)) 1)
      (hseqMonomial R (0 : Hypersequent)) := by
  change
    (LinearMap.rTensor (HypersequentAlgebra R)
        (hypersequentCounitAlgHom R).toLinearMap)
      (hypersequentCoalgebraComulTensorLinearMap R (1 : HypersequentAlgebra R)) =
    1 ⊗ₜ[R] (1 : HypersequentAlgebra R)
  unfold hypersequentCoalgebraComulTensorLinearMap
  change
    (LinearMap.rTensor (HypersequentAlgebra R)
        (hypersequentCounitAlgHom R).toLinearMap)
      (hypersequentTensorAlgToTensorProductLinearMap R
        (hypersequentCoalgebraComulAlgHom R (1 : HypersequentAlgebra R))) =
    1 ⊗ₜ[R] (1 : HypersequentAlgebra R)
  rw [map_one]
  change
    (LinearMap.rTensor (HypersequentAlgebra R)
        (hypersequentCounitAlgHom R).toLinearMap)
      (hypersequentTensorAlgToTensorProductLinearMap R
        (AddMonoidAlgebra.single (0 : HypersequentTensorBasis) 1)) =
    1 ⊗ₜ[R] (1 : HypersequentAlgebra R)
  rw [hypersequentTensorAlgToTensorProductLinearMap_single]
  simpa [hseqMonomial_zero] using
    (rTensor_augmentationCounit_tensorBasisTmul
      (R := R) (0 : HypersequentTensorBasis))

@[simp]
theorem hypersequentNormalizedLeftCounit_zero :
    (LinearMap.lTensor (HypersequentAlgebra R)
        (hypersequentCounitAlgHom R).toLinearMap ∘ₗ
        hypersequentCoalgebraComulTensorLinearMap R)
      (hseqMonomial R (0 : Hypersequent)) =
