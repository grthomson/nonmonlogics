/-!
## Fuelled Bogoliubov/Takeuchi antipode target

The normalized coproduct is connected in the usual rooted-tree sense once the
empty and root cuts are separated:

`Δ(t) = 1 ⊗ t + t ⊗ 1 + Σ proper detached(t,C) ⊗ rem(t,C)`.

The eventual antipode is therefore determined by the Bogoliubov recursion

`S(t) = -t - Σ S(detached(t,C)) * rem(t,C)`.

The definitions below make that recursion executable with a fuel parameter.
This avoids pretending that the well-founded height argument is finished while
still turning the antipode side into concrete algebra.  The remaining theorem
after coassociativity is to prove that sufficiently much fuel is stable, using
the fact that every normalized proper cut removes only genuine rule-node
subproofs and strictly lowers the relevant size/height measure.
-/

section NormalizedTakeuchiAntipode

variable (K : Type) [CommRing K]

/--
A tree-level antipode approximant is just a function on proof trees.  The
linear-map antipode used by Mathlib will be obtained later by extending the
stable monomial action.
-/
abbrev NormalizedTreeAntipodeApprox :=
  PTree → HypersequentAlgebra K

/--
Extend a tree-level antipode approximant multiplicatively to an ordered forest.

This is deliberately stated on forests rather than hypersequents: the coproduct
support keeps an ordered list of detached components until the moment it is
interpreted in `Hypersequent = Multiset PTree`.  Since the target algebra is
commutative over a commutative ring, this forest product is compatible with
external exchange; the permutation lemmas below record the exact bridge.
-/
def normalizedAntipodeForestFromTree
    (S : NormalizedTreeAntipodeApprox K) : Forest → HypersequentAlgebra K
  | [] => 1
  | t :: ts => S t * normalizedAntipodeForestFromTree S ts

@[simp]
theorem normalizedAntipodeForestFromTree_nil
    (S : NormalizedTreeAntipodeApprox K) :
    normalizedAntipodeForestFromTree K S [] = 1 := rfl

@[simp]
theorem normalizedAntipodeForestFromTree_cons
    (S : NormalizedTreeAntipodeApprox K) (t : PTree) (ts : Forest) :
    normalizedAntipodeForestFromTree K S (t :: ts) =
      S t * normalizedAntipodeForestFromTree K S ts := rfl

theorem normalizedAntipodeForestFromTree_append
    (S : NormalizedTreeAntipodeApprox K) (f g : Forest) :
    normalizedAntipodeForestFromTree K S (f ++ g) =
      normalizedAntipodeForestFromTree K S f *
        normalizedAntipodeForestFromTree K S g := by
  induction f with
  | nil =>
      simp
  | cons t ts ih =>
      simp [ih, mul_assoc]

theorem normalizedAntipodeForestFromTree_eq_of_perm
    (S : NormalizedTreeAntipodeApprox K) {f g : Forest}
    (h : List.Perm f g) :
    normalizedAntipodeForestFromTree K S f =
      normalizedAntipodeForestFromTree K S g := by
  induction h with
  | nil =>
      simp
  | cons t h ih =>
      simp [ih]
  | swap a b xs =>
      simp [mul_assoc, mul_comm, mul_left_comm]
  | trans _ _ ih₁ ih₂ =>
      exact ih₁.trans ih₂

theorem normalizedAntipodeForestFromTree_congr_on
    {S T : NormalizedTreeAntipodeApprox K}
    {f : Forest}
    (h : ∀ u ∈ f, S u = T u) :
    normalizedAntipodeForestFromTree K S f =
      normalizedAntipodeForestFromTree K T f := by
  induction f with
  | nil =>
      simp
  | cons t ts ih =>
      have ht : S t = T t := h t (by simp)
      have htail :
          ∀ u ∈ ts, S u = T u := by
        intro u hu
        exact h u (by simp [hu])
      have hrec :
          normalizedAntipodeForestFromTree K S ts =
            normalizedAntipodeForestFromTree K T ts :=
        ih htail
      calc
        normalizedAntipodeForestFromTree K S (t :: ts)
            = S t * normalizedAntipodeForestFromTree K S ts := rfl
        _ = T t * normalizedAntipodeForestFromTree K S ts := by rw [ht]
        _ = T t * normalizedAntipodeForestFromTree K T ts := by rw [hrec]
        _ = normalizedAntipodeForestFromTree K T (t :: ts) := rfl

/-- The left Bogoliubov term attached to one normalized proper cut. -/
noncomputable def normalizedAntipodeProperCutLeftTerm
    (S : NormalizedTreeAntipodeApprox K)
    (t : PTree) (cut : List Address) : HypersequentAlgebra K :=
  normalizedAntipodeForestFromTree K S
      (coalgebraDetachedForestOfCut t cut) *
    treeMonomial K (PTree.remainderGo cut [] t)

/-- The right Bogoliubov term attached to one normalized proper cut. -/
noncomputable def normalizedAntipodeProperCutRightTerm
    (S : NormalizedTreeAntipodeApprox K)
    (t : PTree) (cut : List Address) : HypersequentAlgebra K :=
  treeMonomial K (PTree.remainderGo cut [] t) *
    normalizedAntipodeForestFromTree K S
      (coalgebraDetachedForestOfCut t cut)

theorem normalizedAntipodeProperCutRightTerm_eq_left
    (S : NormalizedTreeAntipodeApprox K)
    (t : PTree) (cut : List Address) :
    normalizedAntipodeProperCutRightTerm K S t cut =
      normalizedAntipodeProperCutLeftTerm K S t cut := by
  simp [normalizedAntipodeProperCutRightTerm,
    normalizedAntipodeProperCutLeftTerm, mul_comm]

/-- Sum of all left Bogoliubov proper-cut terms. -/
noncomputable def normalizedAntipodeProperCutLeftSum
    (S : NormalizedTreeAntipodeApprox K)
    (t : PTree) : HypersequentAlgebra K :=
  ((internalCoalgebraAdmissibleCuts t).map
    (fun cut => normalizedAntipodeProperCutLeftTerm K S t cut)).sum

/-- Sum of all right Bogoliubov proper-cut terms. -/
noncomputable def normalizedAntipodeProperCutRightSum
    (S : NormalizedTreeAntipodeApprox K)
    (t : PTree) : HypersequentAlgebra K :=
  ((internalCoalgebraAdmissibleCuts t).map
    (fun cut => normalizedAntipodeProperCutRightTerm K S t cut)).sum

/-- The remainder-side Bogoliubov term attached to one normalized proper cut. -/
noncomputable def normalizedAntipodeProperCutRemainderTerm
    (S : NormalizedTreeAntipodeApprox K)
    (t : PTree) (cut : List Address) : HypersequentAlgebra K :=
  hseqMonomial K (HQ.ofForest (coalgebraDetachedForestOfCut t cut)) *
    S (PTree.remainderGo cut [] t)

/-- Sum of all remainder-side Bogoliubov proper-cut terms. -/
noncomputable def normalizedAntipodeProperCutRemainderSum
    (S : NormalizedTreeAntipodeApprox K)
    (t : PTree) : HypersequentAlgebra K :=
  ((internalCoalgebraAdmissibleCuts t).map
    (fun cut => normalizedAntipodeProperCutRemainderTerm K S t cut)).sum

/--
Proper-cut symmetry needed for the second antipode cancellation.

For a fixed tree-level approximant `S`, the recursive definition directly
controls the sum where `S` is applied to detached components.  The missing
Hopf side asks for the sum where `S` is applied to the remainder.  This equality
is therefore the finite cut-combinatorics statement extracted from
coassociativity.
-/
def NormalizedAntipodeProperCutRemainderSymmetry
    (S : NormalizedTreeAntipodeApprox K) : Prop :=
  ∀ t : PTree,
    normalizedAntipodeProperCutLeftSum K S t =
      normalizedAntipodeProperCutRemainderSum K S t

theorem normalizedAntipodeProperCutRightSum_eq_left
    (S : NormalizedTreeAntipodeApprox K) (t : PTree) :
    normalizedAntipodeProperCutRightSum K S t =
      normalizedAntipodeProperCutLeftSum K S t := by
  unfold normalizedAntipodeProperCutRightSum
    normalizedAntipodeProperCutLeftSum
  apply congrArg List.sum
  apply List.map_congr_left
  intro cut _hcut
  exact normalizedAntipodeProperCutRightTerm_eq_left K S t cut

@[simp]
theorem normalizedAntipodeProperCutLeftSum_leaf
    (S : NormalizedTreeAntipodeApprox K) (s : MultiSequent) :
    normalizedAntipodeProperCutLeftSum K S (PTree.leaf s) = 0 := by
  simp [normalizedAntipodeProperCutLeftSum]

@[simp]
theorem normalizedAntipodeProperCutRightSum_leaf
    (S : NormalizedTreeAntipodeApprox K) (s : MultiSequent) :
    normalizedAntipodeProperCutRightSum K S (PTree.leaf s) = 0 := by
  simp [normalizedAntipodeProperCutRightSum]

@[simp]
theorem normalizedAntipodeProperCutRemainderSum_leaf
    (S : NormalizedTreeAntipodeApprox K) (s : MultiSequent) :
    normalizedAntipodeProperCutRemainderSum K S (PTree.leaf s) = 0 := by
  simp [normalizedAntipodeProperCutRemainderSum]

/--
Fuelled tree antipode approximants.

Fuel `0` is the primitive guess `-t`.  One successor step applies the
Bogoliubov recursion using the previous fuel on detached proper-cut forests.
-/
noncomputable def normalizedAntipodeTreeApprox :
    Nat → NormalizedTreeAntipodeApprox K
  | 0, t => - treeMonomial K t
  | n + 1, t =>
      - treeMonomial K t -
        normalizedAntipodeProperCutLeftSum K
          (normalizedAntipodeTreeApprox n) t

@[simp]
theorem normalizedAntipodeTreeApprox_zero
    (t : PTree) :
    normalizedAntipodeTreeApprox K 0 t =
      - treeMonomial K t := rfl

theorem normalizedAntipodeTreeApprox_succ
    (n : Nat) (t : PTree) :
    normalizedAntipodeTreeApprox K (n + 1) t =
      - treeMonomial K t -
        normalizedAntipodeProperCutLeftSum K
          (normalizedAntipodeTreeApprox K n) t := rfl

@[simp]
theorem normalizedAntipodeTreeApprox_leaf_succ
    (n : Nat) (s : MultiSequent) :
    normalizedAntipodeTreeApprox K (n + 1) (PTree.leaf s) =
      - treeMonomial K (PTree.leaf s) := by
  simp [normalizedAntipodeTreeApprox_succ]

/--
The successor approximant satisfies the left Bogoliubov cancellation equation
by definition.
-/
theorem normalizedAntipodeTreeApprox_left_bogoliubov
    (n : Nat) (t : PTree) :
    normalizedAntipodeTreeApprox K (n + 1) t +
        treeMonomial K t +
        normalizedAntipodeProperCutLeftSum K
          (normalizedAntipodeTreeApprox K n) t =
      0 := by
  rw [normalizedAntipodeTreeApprox_succ]
  simp [sub_eq_add_neg, add_assoc, add_comm, add_left_comm]

theorem normalizedAntipodeTreeApprox_remainder_bogoliubov
    (n : Nat)
    (hsym :
      NormalizedAntipodeProperCutRemainderSymmetry K
        (normalizedAntipodeTreeApprox K n))
    (t : PTree) :
    normalizedAntipodeTreeApprox K (n + 1) t +
        treeMonomial K t +
        normalizedAntipodeProperCutRemainderSum K
          (normalizedAntipodeTreeApprox K n) t =
      0 := by
  rw [← hsym t]
  exact normalizedAntipodeTreeApprox_left_bogoliubov K n t

/--
The same successor approximant satisfies the right Bogoliubov cancellation
equation because the external hypersequent algebra is commutative.
-/
theorem normalizedAntipodeTreeApprox_right_bogoliubov
    (n : Nat) (t : PTree) :
    normalizedAntipodeTreeApprox K (n + 1) t +
        treeMonomial K t +
        normalizedAntipodeProperCutRightSum K
          (normalizedAntipodeTreeApprox K n) t =
      0 := by
  rw [normalizedAntipodeProperCutRightSum_eq_left]
  exact normalizedAntipodeTreeApprox_left_bogoliubov K n t

/-- Left boundary-plus-proper expression appearing in convolution cancellation. -/
noncomputable def normalizedLeftBogoliubovBoundaryExpression
    (Sprev Snext : NormalizedTreeAntipodeApprox K)
    (t : PTree) : HypersequentAlgebra K :=
  Snext t + treeMonomial K t +
    normalizedAntipodeProperCutLeftSum K Sprev t

/-- Right boundary-plus-proper expression appearing in convolution cancellation. -/
noncomputable def normalizedRightBogoliubovBoundaryExpression
    (Sprev Snext : NormalizedTreeAntipodeApprox K)
    (t : PTree) : HypersequentAlgebra K :=
  Snext t + treeMonomial K t +
    normalizedAntipodeProperCutRightSum K Sprev t

@[simp]
theorem normalizedLeftBogoliubovBoundaryExpression_approx
    (n : Nat) (t : PTree) :
    normalizedLeftBogoliubovBoundaryExpression K
      (normalizedAntipodeTreeApprox K n)
      (normalizedAntipodeTreeApprox K (n + 1)) t = 0 := by
  simp [normalizedLeftBogoliubovBoundaryExpression,
    normalizedAntipodeTreeApprox_left_bogoliubov]

@[simp]
theorem normalizedRightBogoliubovBoundaryExpression_approx
    (n : Nat) (t : PTree) :
    normalizedRightBogoliubovBoundaryExpression K
      (normalizedAntipodeTreeApprox K n)
      (normalizedAntipodeTreeApprox K (n + 1)) t = 0 := by
  simp [normalizedRightBogoliubovBoundaryExpression,
    normalizedAntipodeTreeApprox_right_bogoliubov]

/--
The leaf case of the antipode cancellation boundary expression: no proper
normalized cuts remain, so the usual primitive identity `S(leaf)+leaf=0`
is already visible at every successor fuel.
-/
theorem normalizedLeftBogoliubovBoundaryExpression_leaf
    (n : Nat) (s : MultiSequent) :
    normalizedLeftBogoliubovBoundaryExpression K
      (normalizedAntipodeTreeApprox K n)
      (normalizedAntipodeTreeApprox K (n + 1))
      (PTree.leaf s) = 0 := by
  simp

theorem normalizedRightBogoliubovBoundaryExpression_leaf
    (n : Nat) (s : MultiSequent) :
    normalizedRightBogoliubovBoundaryExpression K
      (normalizedAntipodeTreeApprox K n)
      (normalizedAntipodeTreeApprox K (n + 1))
      (PTree.leaf s) = 0 := by
  simp

/--
A stability predicate for the fuelled approximants.  Proving this from a
height/size measure is the constructive version of the connected graded Hopf
argument.
-/
def NormalizedAntipodeFuelStableAt (n : Nat) (t : PTree) : Prop :=
  normalizedAntipodeTreeApprox K (n + 1) t =
    normalizedAntipodeTreeApprox K n t

/-- Global stability from a chosen fuel onward. -/
def NormalizedAntipodeFuelStableFrom (n : Nat) : Prop :=
  ∀ t : PTree, NormalizedAntipodeFuelStableAt K n t

/--
Tree-level stable antipode data, separated from the eventual linear-map
packaging.  This is the exact theorem one expects from the connected graded
argument: choose a fuel assignment large enough for each tree and prove that
successor fuel no longer changes the value.
-/
structure NormalizedStableTreeAntipode where
  fuel : PTree → Nat
  stable :
    ∀ t : PTree, NormalizedAntipodeFuelStableAt K (fuel t) t

/-- The value of a stable fuelled tree antipode. -/
noncomputable def NormalizedStableTreeAntipode.value
    (S : NormalizedStableTreeAntipode K) (t : PTree) :
    HypersequentAlgebra K :=
  normalizedAntipodeTreeApprox K (S.fuel t) t

theorem NormalizedStableTreeAntipode.value_succ
    (S : NormalizedStableTreeAntipode K) (t : PTree) :
    normalizedAntipodeTreeApprox K (S.fuel t + 1) t =
      NormalizedStableTreeAntipode.value K S t := by
  exact S.stable t

/--
Once the fuel is at least the tree size, one more Bogoliubov step does not
change the approximant.
-/
theorem normalizedAntipodeTreeApprox_stable_from_size
    {t : PTree} {n : Nat}
    (hn : t.size ≤ n) :
    NormalizedAntipodeFuelStableAt K n t := by
  have hstable :
      ∀ t : PTree, ∀ n : Nat, t.size ≤ n →
        NormalizedAntipodeFuelStableAt K n t :=
    PTree_size_induction
      (motive := fun t =>
        ∀ n : Nat, t.size ≤ n →
          NormalizedAntipodeFuelStableAt K n t)
      (by
        intro t ih n hn
        unfold NormalizedAntipodeFuelStableAt
        cases n with
        | zero =>
            exact False.elim
              (PTree.size_ne_zero t (Nat.eq_zero_of_le_zero hn))
        | succ m =>
            rw [normalizedAntipodeTreeApprox_succ K (m + 1) t]
            rw [normalizedAntipodeTreeApprox_succ K m t]
            congr 1
            unfold normalizedAntipodeProperCutLeftSum
            apply congrArg List.sum
            apply List.map_congr_left
            intro cut hcut
            unfold normalizedAntipodeProperCutLeftTerm
            congr 1
            apply normalizedAntipodeForestFromTree_congr_on
            intro u hu
            have hlt :
                u.size < t.size :=
              coalgebraDetachedForestOfCut_mem_size_lt_of_internal
                hcut hu
            have hum : u.size ≤ m := by
              omega
            exact ih u hlt m hum)
  exact hstable t n hn

theorem normalizedAntipodeTreeApprox_eq_size_of_size_le
    (t : PTree) {n : Nat}
    (hn : t.size ≤ n) :
    normalizedAntipodeTreeApprox K n t =
      normalizedAntipodeTreeApprox K t.size t := by
  refine Nat.le_induction ?base ?step n hn
  · rfl
  · intro m hm ih
    have hstable :
        NormalizedAntipodeFuelStableAt K m t :=
      normalizedAntipodeTreeApprox_stable_from_size
        (K := K) (t := t) hm
    unfold NormalizedAntipodeFuelStableAt at hstable
    rw [hstable, ih]

noncomputable def normalizedStableTreeAntipodeOfSize :
    NormalizedStableTreeAntipode K where
  fuel := PTree.size
  stable := by
    intro t
    exact normalizedAntipodeTreeApprox_stable_from_size
      (K := K) (t := t) (le_rfl)

/--
The stable value inherits the Bogoliubov equation with the previous fuel.  The
remaining upgrade is to replace the previous-fuel values on detached subtrees
by stable values, using strict size decrease of proper cuts.
-/
theorem NormalizedStableTreeAntipode.value_bogoliubov_previousFuel
    (S : NormalizedStableTreeAntipode K) (t : PTree) :
    NormalizedStableTreeAntipode.value K S t + treeMonomial K t +
        normalizedAntipodeProperCutLeftSum K
          (normalizedAntipodeTreeApprox K (S.fuel t - 1)) t =
      0 := by
  cases hfuel : S.fuel t with
  | zero =>
      have hstable := S.stable t
      rw [hfuel] at hstable
      change normalizedAntipodeTreeApprox K (0 + 1) t =
        normalizedAntipodeTreeApprox K 0 t at hstable
      have hbog := normalizedAntipodeTreeApprox_left_bogoliubov K 0 t
      rw [hstable] at hbog
      simp [NormalizedStableTreeAntipode.value, hfuel] at hbog ⊢
      exact hbog
  | succ n =>
      have hbog := normalizedAntipodeTreeApprox_left_bogoliubov K n t
      simp [NormalizedStableTreeAntipode.value, hfuel] at hbog ⊢
      exact hbog

/--
Formula target for replacing previous-fuel detached-forest terms by stable
terms.  This is the height-decrease theorem needed to turn the fuelled
Bogoliubov approximants into a genuine antipode.
-/
def NormalizedAntipodeProperCutFuelCompatibility
    (S : NormalizedStableTreeAntipode K) : Prop :=
  ∀ t : PTree, ∀ cut : List Address,
    cut ∈ internalCoalgebraAdmissibleCuts t →
      normalizedAntipodeForestFromTree K
          (normalizedAntipodeTreeApprox K (S.fuel t - 1))
          (coalgebraDetachedForestOfCut t cut) =
        normalizedAntipodeForestFromTree K
          (fun u => NormalizedStableTreeAntipode.value K S u)
          (coalgebraDetachedForestOfCut t cut)

theorem normalizedStableTreeAntipodeOfSize_fuelCompatibility :
    NormalizedAntipodeProperCutFuelCompatibility K
      (normalizedStableTreeAntipodeOfSize K) := by
  intro t cut hcut
  apply normalizedAntipodeForestFromTree_congr_on
  intro u hu
  have hlt :
      u.size < t.size :=
    coalgebraDetachedForestOfCut_mem_size_lt_of_internal
      hcut hu
  have hle : u.size ≤ t.size - 1 := by
    omega
  simpa [normalizedStableTreeAntipodeOfSize,
    NormalizedStableTreeAntipode.value] using
    (normalizedAntipodeTreeApprox_eq_size_of_size_le
      (K := K) u hle)

/--
Fuel compatibility for the remainder-side cancellation equation.

This is the mirror of `NormalizedAntipodeProperCutFuelCompatibility`: instead
of replacing previous-fuel values on the detached forest, it replaces the
previous-fuel value on the remainder tree.
-/
def NormalizedAntipodeRemainderCutFuelCompatibility
    (S : NormalizedStableTreeAntipode K) : Prop :=
  ∀ t : PTree, ∀ cut : List Address,
    cut ∈ internalCoalgebraAdmissibleCuts t →
      normalizedAntipodeTreeApprox K (S.fuel t - 1)
          (PTree.remainderGo cut [] t) =
        NormalizedStableTreeAntipode.value K S
          (PTree.remainderGo cut [] t)

/--
Previous-fuel remainder-side Bogoliubov equation.

This is the exact pre-stable equation supplied by the coassociativity/nested-cut
argument for the missing Hopf cancellation side.
-/
def NormalizedAntipodeRemainderBogoliubovPreviousFuel
    (S : NormalizedStableTreeAntipode K) : Prop :=
  ∀ t : PTree,
    NormalizedStableTreeAntipode.value K S t + treeMonomial K t +
        normalizedAntipodeProperCutRemainderSum K
          (normalizedAntipodeTreeApprox K (S.fuel t - 1)) t =
      0

/--
Fuel-indexed version of proper-cut remainder symmetry.

This is the exact shape needed by a stable antipode: each tree may stabilize at
a different fuel, so the symmetry is required at that tree's previous fuel.
-/
def NormalizedAntipodePreviousFuelRemainderSymmetry
    (S : NormalizedStableTreeAntipode K) : Prop :=
  ∀ t : PTree,
    normalizedAntipodeProperCutLeftSum K
        (normalizedAntipodeTreeApprox K (S.fuel t - 1)) t =
      normalizedAntipodeProperCutRemainderSum K
        (normalizedAntipodeTreeApprox K (S.fuel t - 1)) t

/--
Uniform proper-cut remainder symmetry for every fuelled approximant.

This is now the clean induction target: prove the symmetry for all fuel levels,
then every stable fuel assignment inherits the previous-fuel version it needs.
-/
def NormalizedAntipodeApproxRemainderSymmetry : Prop :=
  ∀ n : Nat,
    NormalizedAntipodeProperCutRemainderSymmetry K
      (normalizedAntipodeTreeApprox K n)

theorem NormalizedAntipodePreviousFuelRemainderSymmetry_of_approx
    (S : NormalizedStableTreeAntipode K)
    (hsym : NormalizedAntipodeApproxRemainderSymmetry K) :
    NormalizedAntipodePreviousFuelRemainderSymmetry K S := by
  intro t
  exact hsym (S.fuel t - 1) t

/-- Stable proper-cut sum using the final stable tree values. -/
noncomputable def normalizedStableAntipodeProperCutLeftSum
    (S : NormalizedStableTreeAntipode K)
    (t : PTree) : HypersequentAlgebra K :=
  ((internalCoalgebraAdmissibleCuts t).map
    (fun cut =>
      normalizedAntipodeForestFromTree K
          (fun u => NormalizedStableTreeAntipode.value K S u)
          (coalgebraDetachedForestOfCut t cut) *
        treeMonomial K (PTree.remainderGo cut [] t))).sum

/-- Stable proper-cut sum in the opposite multiplication order. -/
noncomputable def normalizedStableAntipodeProperCutRightSum
    (S : NormalizedStableTreeAntipode K)
    (t : PTree) : HypersequentAlgebra K :=
  ((internalCoalgebraAdmissibleCuts t).map
    (fun cut =>
      treeMonomial K (PTree.remainderGo cut [] t) *
        normalizedAntipodeForestFromTree K
          (fun u => NormalizedStableTreeAntipode.value K S u)
          (coalgebraDetachedForestOfCut t cut))).sum

theorem normalizedStableAntipodeProperCutRightSum_eq_left
    (S : NormalizedStableTreeAntipode K) (t : PTree) :
    normalizedStableAntipodeProperCutRightSum K S t =
      normalizedStableAntipodeProperCutLeftSum K S t := by
  unfold normalizedStableAntipodeProperCutRightSum
    normalizedStableAntipodeProperCutLeftSum
  apply congrArg List.sum
  apply List.map_congr_left
  intro cut _hcut
  simp [mul_comm]

theorem normalizedStableAntipodeProperCutLeftSum_eq_previousFuel
    (S : NormalizedStableTreeAntipode K)
    (hcompat : NormalizedAntipodeProperCutFuelCompatibility K S)
    (t : PTree) :
    normalizedStableAntipodeProperCutLeftSum K S t =
      normalizedAntipodeProperCutLeftSum K
        (normalizedAntipodeTreeApprox K (S.fuel t - 1)) t := by
  unfold normalizedStableAntipodeProperCutLeftSum
    normalizedAntipodeProperCutLeftSum
  apply congrArg List.sum
  apply List.map_congr_left
  intro cut hcut
  simp [normalizedAntipodeProperCutLeftTerm, hcompat t cut hcut]

@[simp]
theorem normalizedStableAntipodeProperCutLeftSum_leaf
    (S : NormalizedStableTreeAntipode K) (s : MultiSequent) :
    normalizedStableAntipodeProperCutLeftSum K S (PTree.leaf s) = 0 := by
  simp [normalizedStableAntipodeProperCutLeftSum]

/-- Stable Bogoliubov cancellation once fuel compatibility is known. -/
theorem NormalizedStableTreeAntipode.left_bogoliubov
    (S : NormalizedStableTreeAntipode K)
    (hcompat : NormalizedAntipodeProperCutFuelCompatibility K S)
    (t : PTree) :
    NormalizedStableTreeAntipode.value K S t + treeMonomial K t +
        normalizedStableAntipodeProperCutLeftSum K S t =
      0 := by
  rw [normalizedStableAntipodeProperCutLeftSum_eq_previousFuel K S hcompat t]
  exact NormalizedStableTreeAntipode.value_bogoliubov_previousFuel K S t

theorem NormalizedStableTreeAntipode.remainder_bogoliubov_previousFuel
    (S : NormalizedStableTreeAntipode K)
    (hsym : NormalizedAntipodePreviousFuelRemainderSymmetry K S) :
    NormalizedAntipodeRemainderBogoliubovPreviousFuel K S := by
  intro t
  rw [← hsym t]
  exact NormalizedStableTreeAntipode.value_bogoliubov_previousFuel K S t

/-- Stable Bogoliubov cancellation in the opposite multiplication order. -/
theorem NormalizedStableTreeAntipode.right_bogoliubov
    (S : NormalizedStableTreeAntipode K)
    (hcompat : NormalizedAntipodeProperCutFuelCompatibility K S)
    (t : PTree) :
    NormalizedStableTreeAntipode.value K S t + treeMonomial K t +
        normalizedStableAntipodeProperCutRightSum K S t =
      0 := by
  rw [normalizedStableAntipodeProperCutRightSum_eq_left]
  exact NormalizedStableTreeAntipode.left_bogoliubov K S hcompat t

/--
This is the concrete tree-level antipode theorem target left after
coassociativity: prove stable fuel and compatibility, then the standard
Bogoliubov cancellation identity follows without any more tensor plumbing.
-/
structure NormalizedTreeAntipodeTarget where
  stableAntipode : NormalizedStableTreeAntipode K
  fuelCompatibility :
    NormalizedAntipodeProperCutFuelCompatibility K stableAntipode

noncomputable def normalizedTreeAntipodeTargetOfSize :
    NormalizedTreeAntipodeTarget K where
  stableAntipode := normalizedStableTreeAntipodeOfSize K
  fuelCompatibility :=
    normalizedStableTreeAntipodeOfSize_fuelCompatibility K

theorem NormalizedTreeAntipodeTarget.left_bogoliubov
    (T : NormalizedTreeAntipodeTarget K) (t : PTree) :
    NormalizedStableTreeAntipode.value K T.stableAntipode t +
        treeMonomial K t +
        normalizedStableAntipodeProperCutLeftSum K T.stableAntipode t =
      0 :=
  NormalizedStableTreeAntipode.left_bogoliubov K
    T.stableAntipode T.fuelCompatibility t

theorem NormalizedTreeAntipodeTarget.right_bogoliubov
    (T : NormalizedTreeAntipodeTarget K) (t : PTree) :
    NormalizedStableTreeAntipode.value K T.stableAntipode t +
        treeMonomial K t +
        normalizedStableAntipodeProperCutRightSum K T.stableAntipode t =
      0 :=
  NormalizedStableTreeAntipode.right_bogoliubov K
    T.stableAntipode T.fuelCompatibility t

/--
The stable tree antipode extended multiplicatively to hypersequents.

This is the algebraic bridge needed for convolution cancellation: detached
forests are hypersequent monomials, so the antipode candidate must evaluate
them as the product of the stable values of their tree components.
-/
noncomputable def normalizedStableAntipodeHypersequent
    (S : NormalizedStableTreeAntipode K)
    (G : Hypersequent) : HypersequentAlgebra K :=
  (G.map (fun t => NormalizedStableTreeAntipode.value K S t)).prod

@[simp]
theorem normalizedStableAntipodeHypersequent_zero
    (S : NormalizedStableTreeAntipode K) :
    normalizedStableAntipodeHypersequent K S 0 = 1 := by
  simp [normalizedStableAntipodeHypersequent]

@[simp]
theorem normalizedStableAntipodeHypersequent_singleton
    (S : NormalizedStableTreeAntipode K) (t : PTree) :
    normalizedStableAntipodeHypersequent K S (HQ.singleton t) =
      NormalizedStableTreeAntipode.value K S t := by
  simp [normalizedStableAntipodeHypersequent, HQ.singleton]

theorem normalizedStableAntipodeHypersequent_add
    (S : NormalizedStableTreeAntipode K) (G H : Hypersequent) :
    normalizedStableAntipodeHypersequent K S (G + H) =
      normalizedStableAntipodeHypersequent K S G *
        normalizedStableAntipodeHypersequent K S H := by
  simp [normalizedStableAntipodeHypersequent, Multiset.map_add,
    Multiset.prod_add]

theorem normalizedStableAntipodeHypersequent_ofForest
    (S : NormalizedStableTreeAntipode K) :
    ∀ f : Forest,
      normalizedStableAntipodeHypersequent K S (HQ.ofForest f) =
        normalizedAntipodeForestFromTree K
          (fun t => NormalizedStableTreeAntipode.value K S t) f
  | [] => by
      simp [HQ.ofForest]
  | t :: ts => by
      rw [HQ.ofForest_cons, normalizedStableAntipodeHypersequent_add,
        normalizedStableAntipodeHypersequent_singleton,
        normalizedStableAntipodeHypersequent_ofForest S ts]
      rfl

/-- Monoid hom underlying the stable antipode extension. -/
noncomputable def normalizedStableAntipodeMonoidHom
    (S : NormalizedStableTreeAntipode K) :
    Multiplicative Hypersequent →* HypersequentAlgebra K where
  toFun G := normalizedStableAntipodeHypersequent K S G.toAdd
  map_one' := by
    simp
  map_mul' G H := by
    exact normalizedStableAntipodeHypersequent_add K S G.toAdd H.toAdd

/-- Algebra-map extension of the stable tree antipode to the hypersequent algebra. -/
noncomputable def normalizedStableAntipodeAlgHom
    (S : NormalizedStableTreeAntipode K) :
    HypersequentAlgebra K →ₐ[K] HypersequentAlgebra K :=
  AddMonoidAlgebra.lift K (HypersequentAlgebra K) Hypersequent
    (normalizedStableAntipodeMonoidHom K S)

@[simp]
theorem normalizedStableAntipodeAlgHom_single
    (S : NormalizedStableTreeAntipode K) (G : Hypersequent) :
    normalizedStableAntipodeAlgHom K S (AddMonoidAlgebra.single G 1) =
      normalizedStableAntipodeHypersequent K S G := by
  rw [normalizedStableAntipodeAlgHom]
  simp [normalizedStableAntipodeMonoidHom]

@[simp]
theorem normalizedStableAntipodeAlgHom_tree
    (S : NormalizedStableTreeAntipode K) (t : PTree) :
    normalizedStableAntipodeAlgHom K S (treeMonomial K t) =
      NormalizedStableTreeAntipode.value K S t := by
  simp [treeMonomial, hseqMonomial]

theorem normalizedStableAntipodeAlgHom_ofForest
    (S : NormalizedStableTreeAntipode K) (f : Forest) :
    normalizedStableAntipodeAlgHom K S
        (hseqMonomial K (HQ.ofForest f)) =
      normalizedAntipodeForestFromTree K
        (fun t => NormalizedStableTreeAntipode.value K S t) f := by
  rw [hseqMonomial, normalizedStableAntipodeAlgHom_single,
    normalizedStableAntipodeHypersequent_ofForest]

/--
The corresponding Hopf-level target: a stable tree antipode plus a theorem
that its monomial extension agrees with an actual linear map.
-/
structure NormalizedTakeuchiAntipodeLinearization
    (T : NormalizedTreeAntipodeTarget K) where
  linearMap : HypersequentAlgebra K →ₗ[K] HypersequentAlgebra K
  map_tree :
    ∀ t : PTree,
      linearMap (treeMonomial K t) =
        NormalizedStableTreeAntipode.value K T.stableAntipode t

/-- Canonical linearization supplied by the stable tree antipode itself. -/
noncomputable def NormalizedTreeAntipodeTarget.linearization
    (T : NormalizedTreeAntipodeTarget K) :
    NormalizedTakeuchiAntipodeLinearization K T where
  linearMap := (normalizedStableAntipodeAlgHom K T.stableAntipode).toLinearMap
  map_tree := by
    intro t
    exact normalizedStableAntipodeAlgHom_tree K T.stableAntipode t

/-- The `m (id ⊗ S)` convolution map for the stable antipode extension. -/
noncomputable def normalizedStableLeftConvolutionTensorMap
    (S : NormalizedStableTreeAntipode K) :
    TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K) →ₗ[K]
      HypersequentAlgebra K :=
  LinearMap.mul' K (HypersequentAlgebra K) ∘ₗ
    LinearMap.lTensor (HypersequentAlgebra K)
      (normalizedStableAntipodeAlgHom K S).toLinearMap

/-- The `m (S ⊗ id)` convolution map for the stable antipode extension. -/
noncomputable def normalizedStableRightConvolutionTensorMap
    (S : NormalizedStableTreeAntipode K) :
    TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K) →ₗ[K]
      HypersequentAlgebra K :=
  LinearMap.mul' K (HypersequentAlgebra K) ∘ₗ
    LinearMap.rTensor (HypersequentAlgebra K)
      (normalizedStableAntipodeAlgHom K S).toLinearMap

@[simp]
theorem normalizedStableLeftConvolutionTensorMap_tmul
    (S : NormalizedStableTreeAntipode K)
    (x y : HypersequentAlgebra K) :
    normalizedStableLeftConvolutionTensorMap K S (x ⊗ₜ[K] y) =
      x * normalizedStableAntipodeAlgHom K S y := by
  simp [normalizedStableLeftConvolutionTensorMap, LinearMap.lTensor_tmul]
  rfl

@[simp]
theorem normalizedStableRightConvolutionTensorMap_tmul
    (S : NormalizedStableTreeAntipode K)
    (x y : HypersequentAlgebra K) :
    normalizedStableRightConvolutionTensorMap K S (x ⊗ₜ[K] y) =
      normalizedStableAntipodeAlgHom K S x * y := by
  simp [normalizedStableRightConvolutionTensorMap, LinearMap.rTensor_tmul]
  rfl

@[simp]
theorem normalizedStableLeftConvolutionTensorMap_tensorBasisTmul
    (S : NormalizedStableTreeAntipode K) (p : HypersequentTensorBasis) :
    normalizedStableLeftConvolutionTensorMap K S (tensorBasisTmul K p) =
      hseqMonomial K p.1 *
        normalizedStableAntipodeAlgHom K S (hseqMonomial K p.2) := by
  simp [tensorBasisTmul]

@[simp]
theorem normalizedStableRightConvolutionTensorMap_tensorBasisTmul
    (S : NormalizedStableTreeAntipode K) (p : HypersequentTensorBasis) :
    normalizedStableRightConvolutionTensorMap K S (tensorBasisTmul K p) =
      normalizedStableAntipodeAlgHom K S (hseqMonomial K p.1) *
        hseqMonomial K p.2 := by
  simp [tensorBasisTmul]

theorem normalizedStableLeftConvolutionTensorMap_tensorSupportElement
    (S : NormalizedStableTreeAntipode K)
    (xs : List HypersequentTensorBasis) :
    normalizedStableLeftConvolutionTensorMap K S
        (hypersequentTensorAlgToTensorProductLinearMap K
          (tensorSupportElement K xs)) =
      (xs.map fun p =>
        normalizedStableLeftConvolutionTensorMap K S
          (tensorBasisTmul K p)).sum := by
  let L :=
    (normalizedStableLeftConvolutionTensorMap K S).comp
      (hypersequentTensorAlgToTensorProductLinearMap K)
  simpa [L] using linearMap_apply_tensorSupportElement K L xs

theorem normalizedStableRightConvolutionTensorMap_tensorSupportElement
    (S : NormalizedStableTreeAntipode K)
    (xs : List HypersequentTensorBasis) :
    normalizedStableRightConvolutionTensorMap K S
        (hypersequentTensorAlgToTensorProductLinearMap K
          (tensorSupportElement K xs)) =
      (xs.map fun p =>
        normalizedStableRightConvolutionTensorMap K S
          (tensorBasisTmul K p)).sum := by
  let L :=
    (normalizedStableRightConvolutionTensorMap K S).comp
      (hypersequentTensorAlgToTensorProductLinearMap K)
  simpa [L] using linearMap_apply_tensorSupportElement K L xs

/--
Collapse a right-associated triple tensor by applying the stable antipode to
the middle component:

`A ⊗ (B ⊗ C) ↦ A * S(B) * C`.

This is the exact linear map used in the standard connected-bialgebra proof:
on the right-associated coassociativity side it contains the already-proved
right convolution `S * id`, while on the left-associated side it contains the
missing left convolution `id * S` on detached forests.
-/
noncomputable def normalizedStableMiddleConvolutionTripleMap
    (S : NormalizedStableTreeAntipode K) :
    HypersequentTripleTensor K →ₗ[K] HypersequentAlgebra K :=
  LinearMap.mul' K (HypersequentAlgebra K) ∘ₗ
    LinearMap.lTensor (HypersequentAlgebra K)
      (normalizedStableRightConvolutionTensorMap K S)

@[simp]
theorem normalizedStableMiddleConvolutionTripleMap_tmul
    (S : NormalizedStableTreeAntipode K)
    (x y z : HypersequentAlgebra K) :
    normalizedStableMiddleConvolutionTripleMap K S
        (x ⊗ₜ[K] (y ⊗ₜ[K] z)) =
      x * (normalizedStableAntipodeAlgHom K S y * z) := by
  simp [normalizedStableMiddleConvolutionTripleMap]

@[simp]
theorem normalizedStableMiddleConvolutionTripleMap_tripleBasisTmul
    (S : NormalizedStableTreeAntipode K)
    (p : HypersequentTripleBasis) :
    normalizedStableMiddleConvolutionTripleMap K S
        (hypersequentTripleBasisTmul K p) =
      hseqMonomial K p.1 *
        (normalizedStableAntipodeAlgHom K S
            (hseqMonomial K p.2.1) *
          hseqMonomial K p.2.2) := by
  simp [hypersequentTripleBasisTmul]

theorem normalizedStableMiddleConvolutionTripleMap_sum
    (S : NormalizedStableTreeAntipode K)
    (xs : List HypersequentTripleBasis) :
    normalizedStableMiddleConvolutionTripleMap K S
        ((xs.map (hypersequentTripleBasisTmul (R := K))).sum) =
      (xs.map fun p =>
        hseqMonomial K p.1 *
          (normalizedStableAntipodeAlgHom K S
              (hseqMonomial K p.2.1) *
            hseqMonomial K p.2.2)).sum := by
  rw [map_list_sum]
  simp [Function.comp_def]

noncomputable def normalizedStableAntipodeRemainderCutSum
    (S : NormalizedStableTreeAntipode K)
    (t : PTree) : HypersequentAlgebra K :=
  ((internalCoalgebraAdmissibleCuts t).map
    (fun cut =>
      hseqMonomial K (HQ.ofForest (coalgebraDetachedForestOfCut t cut)) *
        NormalizedStableTreeAntipode.value K S
          (PTree.remainderGo cut [] t))).sum

theorem normalizedStableAntipodeRemainderCutSum_eq_previousFuel
    (S : NormalizedStableTreeAntipode K)
    (hcompat : NormalizedAntipodeRemainderCutFuelCompatibility K S)
    (t : PTree) :
    normalizedStableAntipodeRemainderCutSum K S t =
      normalizedAntipodeProperCutRemainderSum K
        (normalizedAntipodeTreeApprox K (S.fuel t - 1)) t := by
  unfold normalizedStableAntipodeRemainderCutSum
    normalizedAntipodeProperCutRemainderSum
    normalizedAntipodeProperCutRemainderTerm
  apply congrArg List.sum
  apply List.map_congr_left
  intro cut hcut
  simp [hcompat t cut hcut]

@[simp]
theorem normalizedStableAntipodeRemainderCutSum_leaf
    (S : NormalizedStableTreeAntipode K) (s : MultiSequent) :
    normalizedStableAntipodeRemainderCutSum K S (PTree.leaf s) = 0 := by
  simp [normalizedStableAntipodeRemainderCutSum]

/--
Stable proper-cut symmetry for the final antipode values.

This is the direct Hopf-side target: after fuel has stabilized, the proper-cut
sum where the antipode is applied to the detached forest agrees with the
proper-cut sum where it is applied to the remainder.
-/
def NormalizedStableAntipodeProperCutRemainderSymmetry
    (S : NormalizedStableTreeAntipode K) : Prop :=
  ∀ t : PTree,
    normalizedStableAntipodeProperCutLeftSum K S t =
      normalizedStableAntipodeRemainderCutSum K S t

theorem NormalizedStableAntipodeProperCutRemainderSymmetry_of_previousFuel
    (S : NormalizedStableTreeAntipode K)
    (hleft : NormalizedAntipodeProperCutFuelCompatibility K S)
    (hright : NormalizedAntipodeRemainderCutFuelCompatibility K S)
    (hsym : NormalizedAntipodePreviousFuelRemainderSymmetry K S) :
    NormalizedStableAntipodeProperCutRemainderSymmetry K S := by
  intro t
  rw [normalizedStableAntipodeProperCutLeftSum_eq_previousFuel K S hleft t]
  rw [normalizedStableAntipodeRemainderCutSum_eq_previousFuel K S hright t]
  exact hsym t

theorem NormalizedStableTreeAntipode.remainder_bogoliubov
    (S : NormalizedStableTreeAntipode K)
    (hprev : NormalizedAntipodeRemainderBogoliubovPreviousFuel K S)
    (hcompat : NormalizedAntipodeRemainderCutFuelCompatibility K S)
    (t : PTree) :
    NormalizedStableTreeAntipode.value K S t + treeMonomial K t +
        normalizedStableAntipodeRemainderCutSum K S t =
      0 := by
  rw [normalizedStableAntipodeRemainderCutSum_eq_previousFuel K S hcompat t]
  exact hprev t

theorem NormalizedStableTreeAntipode.remainder_bogoliubov_of_stable_symmetry
    (S : NormalizedStableTreeAntipode K)
    (hcompat : NormalizedAntipodeProperCutFuelCompatibility K S)
    (hsym : NormalizedStableAntipodeProperCutRemainderSymmetry K S)
    (t : PTree) :
    NormalizedStableTreeAntipode.value K S t + treeMonomial K t +
        normalizedStableAntipodeRemainderCutSum K S t =
      0 := by
  rw [← hsym t]
  exact NormalizedStableTreeAntipode.left_bogoliubov K S hcompat t

theorem normalizedStableLeftConvolutionTensorMap_internalCut
    (S : NormalizedStableTreeAntipode K)
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ internalCoalgebraAdmissibleCuts t) :
    normalizedStableLeftConvolutionTensorMap K S
        (tensorBasisTmul K (coalgebraTensorTermOfCutList t cut)) =
      hseqMonomial K (HQ.ofForest (coalgebraDetachedForestOfCut t cut)) *
        NormalizedStableTreeAntipode.value K S
          (PTree.remainderGo cut [] t) := by
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut with
    ⟨_hcoal, hinternal⟩
  rw [coalgebraTensorTermOfCutList_of_ne_nil_of_root_not_mem
    (t := t) (cut := cut) hinternal.1 hinternal.2]
  rw [normalizedStableLeftConvolutionTensorMap_tensorBasisTmul]
  rw [hseqMonomial_singleton_eq_treeMonomial]
  rw [normalizedStableAntipodeAlgHom_tree]
  simp [coalgebraDetachedForestOfCut, hinternal.1, hinternal.2]

theorem normalizedStableLeftConvolutionTensorMap_treeComul
    (S : NormalizedStableTreeAntipode K) (t : PTree) :
    normalizedStableLeftConvolutionTensorMap K S
        (hypersequentCoalgebraComulTensorLinearMap K (treeMonomial K t)) =
      NormalizedStableTreeAntipode.value K S t +
        (treeMonomial K t +
          normalizedStableAntipodeRemainderCutSum K S t) := by
  rw [hypersequentCoalgebraComulTensorLinearMap_tree]
  unfold coalgebraTreeSplittingTensorElement coalgebraTreeSplittingTensorSupport
  rw [normalizedStableLeftConvolutionTensorMap_tensorSupportElement]
  rw [List.map_map]
  let F : List Address → HypersequentAlgebra K :=
    fun cut =>
      normalizedStableLeftConvolutionTensorMap K S
        (tensorBasisTmul K (coalgebraTensorTermOfCutList t cut))
  have hperm :=
    (coalgebraAdmissibleCuts_perm_empty_root_internal t).map F
  have hsum :
      ((coalgebraAdmissibleCuts t).map F).sum =
        (([([] : List Address)] ++
          ([[([] : Address)]] ++ internalCoalgebraAdmissibleCuts t)).map F).sum :=
    List.sum_eq_of_perm hperm
  change ((coalgebraAdmissibleCuts t).map F).sum =
    NormalizedStableTreeAntipode.value K S t +
      (treeMonomial K t +
        normalizedStableAntipodeRemainderCutSum K S t)
  rw [hsum]
  have hinternal :
      ((internalCoalgebraAdmissibleCuts t).map F).sum =
        normalizedStableAntipodeRemainderCutSum K S t := by
    unfold normalizedStableAntipodeRemainderCutSum
    apply congrArg List.sum
    apply List.map_congr_left
    intro cut hcut
    exact normalizedStableLeftConvolutionTensorMap_internalCut K S hcut
  have hempty :
      F [] = NormalizedStableTreeAntipode.value K S t := by
    dsimp [F]
    rw [coalgebraTensorTermOfCutList_nil]
    rw [normalizedStableLeftConvolutionTensorMap_tensorBasisTmul]
    rw [hseqMonomial_zero]
    rw [hseqMonomial_singleton_eq_treeMonomial]
    rw [normalizedStableAntipodeAlgHom_tree]
    simp
  have hroot : F [([] : Address)] = treeMonomial K t := by
    dsimp [F]
    rw [coalgebraTensorTermOfCutList_root]
    rw [normalizedStableLeftConvolutionTensorMap_tensorBasisTmul]
    rw [hseqMonomial_zero]
    rw [hseqMonomial_singleton_eq_treeMonomial]
    simp
  simpa [hempty, hroot, hinternal]

def NormalizedTreeAntipodeTarget.remainder_bogoliubov
    (T : NormalizedTreeAntipodeTarget K) : Prop :=
  ∀ t : PTree,
    NormalizedStableTreeAntipode.value K T.stableAntipode t +
        treeMonomial K t +
        normalizedStableAntipodeRemainderCutSum K T.stableAntipode t =
      0

theorem NormalizedTreeAntipodeTarget.remainder_bogoliubov_of_previousFuel
    (T : NormalizedTreeAntipodeTarget K)
    (hprev :
      NormalizedAntipodeRemainderBogoliubovPreviousFuel K T.stableAntipode)
    (hcompat :
      NormalizedAntipodeRemainderCutFuelCompatibility K T.stableAntipode) :
    NormalizedTreeAntipodeTarget.remainder_bogoliubov K T := by
  intro t
  exact NormalizedStableTreeAntipode.remainder_bogoliubov K
    T.stableAntipode hprev hcompat t

theorem NormalizedTreeAntipodeTarget.stable_symmetry_of_remainder_bogoliubov
    (T : NormalizedTreeAntipodeTarget K)
    (hrem : NormalizedTreeAntipodeTarget.remainder_bogoliubov K T) :
    NormalizedStableAntipodeProperCutRemainderSymmetry K T.stableAntipode := by
  intro t
  have hleft := NormalizedTreeAntipodeTarget.left_bogoliubov K T t
  have hright := hrem t
  refine add_left_cancel (a :=
    NormalizedStableTreeAntipode.value K T.stableAntipode t +
      treeMonomial K t) ?_
  simpa [add_assoc] using hleft.trans hright.symm

theorem NormalizedTreeAntipodeTarget.remainder_bogoliubov_of_stable_symmetry
    (T : NormalizedTreeAntipodeTarget K)
    (hsym :
      NormalizedStableAntipodeProperCutRemainderSymmetry K T.stableAntipode) :
    NormalizedTreeAntipodeTarget.remainder_bogoliubov K T := by
  intro t
  exact NormalizedStableTreeAntipode.remainder_bogoliubov_of_stable_symmetry
    K T.stableAntipode T.fuelCompatibility hsym t

theorem NormalizedTreeAntipodeTarget.remainder_bogoliubov_iff_stable_symmetry
    (T : NormalizedTreeAntipodeTarget K) :
    NormalizedTreeAntipodeTarget.remainder_bogoliubov K T ↔
      NormalizedStableAntipodeProperCutRemainderSymmetry K T.stableAntipode :=
  ⟨NormalizedTreeAntipodeTarget.stable_symmetry_of_remainder_bogoliubov K T,
    NormalizedTreeAntipodeTarget.remainder_bogoliubov_of_stable_symmetry K T⟩

theorem NormalizedTreeAntipodeTarget.left_convolution_tree_of_remainder_bogoliubov
    (T : NormalizedTreeAntipodeTarget K)
    (hrem : NormalizedTreeAntipodeTarget.remainder_bogoliubov K T)
    (t : PTree) :
    (LinearMap.mul' K (HypersequentAlgebra K) ∘ₗ
        LinearMap.lTensor (HypersequentAlgebra K)
          (NormalizedTreeAntipodeTarget.linearization K T).linearMap ∘ₗ
        hypersequentCoalgebraComulTensorLinearMap K)
        (treeMonomial K t) =
      0 := by
  change
    normalizedStableLeftConvolutionTensorMap K T.stableAntipode
        (hypersequentCoalgebraComulTensorLinearMap K (treeMonomial K t)) =
      0
  rw [normalizedStableLeftConvolutionTensorMap_treeComul]
  have h := hrem t
  simpa [add_assoc, add_comm, add_left_comm] using h

theorem normalizedStableRightConvolutionTensorMap_internalCut
    (S : NormalizedStableTreeAntipode K)
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ internalCoalgebraAdmissibleCuts t) :
    normalizedStableRightConvolutionTensorMap K S
        (tensorBasisTmul K (coalgebraTensorTermOfCutList t cut)) =
      normalizedAntipodeForestFromTree K
          (fun u => NormalizedStableTreeAntipode.value K S u)
          (coalgebraDetachedForestOfCut t cut) *
        treeMonomial K (PTree.remainderGo cut [] t) := by
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut with
    ⟨_hcoal, hinternal⟩
  rw [coalgebraTensorTermOfCutList_of_ne_nil_of_root_not_mem
    (t := t) (cut := cut) hinternal.1 hinternal.2]
  rw [normalizedStableRightConvolutionTensorMap_tensorBasisTmul]
  rw [normalizedStableAntipodeAlgHom_ofForest]
  rw [hseqMonomial_singleton_eq_treeMonomial]
  simp [coalgebraDetachedForestOfCut, hinternal.1, hinternal.2]

theorem normalizedStableRightConvolutionTensorMap_treeComul
    (S : NormalizedStableTreeAntipode K) (t : PTree) :
    normalizedStableRightConvolutionTensorMap K S
        (hypersequentCoalgebraComulTensorLinearMap K (treeMonomial K t)) =
      treeMonomial K t +
        (NormalizedStableTreeAntipode.value K S t +
          normalizedStableAntipodeProperCutLeftSum K S t) := by
  rw [hypersequentCoalgebraComulTensorLinearMap_tree]
  unfold coalgebraTreeSplittingTensorElement coalgebraTreeSplittingTensorSupport
  rw [normalizedStableRightConvolutionTensorMap_tensorSupportElement]
  rw [List.map_map]
  let F : List Address → HypersequentAlgebra K :=
    fun cut =>
      normalizedStableRightConvolutionTensorMap K S
        (tensorBasisTmul K (coalgebraTensorTermOfCutList t cut))
  have hperm :=
    (coalgebraAdmissibleCuts_perm_empty_root_internal t).map F
  have hsum :
      ((coalgebraAdmissibleCuts t).map F).sum =
        (([([] : List Address)] ++
          ([[([] : Address)]] ++ internalCoalgebraAdmissibleCuts t)).map F).sum :=
    List.sum_eq_of_perm hperm
  change ((coalgebraAdmissibleCuts t).map F).sum =
    treeMonomial K t +
      (NormalizedStableTreeAntipode.value K S t +
        normalizedStableAntipodeProperCutLeftSum K S t)
  rw [hsum]
  have hinternal :
      ((internalCoalgebraAdmissibleCuts t).map F).sum =
        normalizedStableAntipodeProperCutLeftSum K S t := by
    unfold normalizedStableAntipodeProperCutLeftSum
    apply congrArg List.sum
    apply List.map_congr_left
    intro cut hcut
    exact normalizedStableRightConvolutionTensorMap_internalCut K S hcut
  have hempty : F [] = treeMonomial K t := by
    dsimp [F]
    rw [coalgebraTensorTermOfCutList_nil]
    rw [normalizedStableRightConvolutionTensorMap_tensorBasisTmul]
    rw [hseqMonomial_zero]
    rw [hseqMonomial_singleton_eq_treeMonomial]
    simp
  have hroot :
      F [([] : Address)] =
        NormalizedStableTreeAntipode.value K S t := by
    dsimp [F]
    rw [coalgebraTensorTermOfCutList_root]
    rw [normalizedStableRightConvolutionTensorMap_tensorBasisTmul]
    rw [hseqMonomial_zero]
    rw [hseqMonomial_singleton_eq_treeMonomial]
    rw [normalizedStableAntipodeAlgHom_tree]
    simp
  simpa [hempty, hroot, hinternal]

theorem NormalizedTreeAntipodeTarget.right_convolution_tree
    (T : NormalizedTreeAntipodeTarget K) (t : PTree) :
    (LinearMap.mul' K (HypersequentAlgebra K) ∘ₗ
        LinearMap.rTensor (HypersequentAlgebra K)
          (NormalizedTreeAntipodeTarget.linearization K T).linearMap ∘ₗ
        hypersequentCoalgebraComulTensorLinearMap K)
        (treeMonomial K t) =
      0 := by
  change
    normalizedStableRightConvolutionTensorMap K T.stableAntipode
        (hypersequentCoalgebraComulTensorLinearMap K (treeMonomial K t)) =
      0
  rw [normalizedStableRightConvolutionTensorMap_treeComul]
  have h := NormalizedTreeAntipodeTarget.left_bogoliubov K T t
  simpa [add_assoc, add_comm, add_left_comm] using h

theorem NormalizedTreeAntipodeTarget.middleConvolution_rightStageBranch_empty_eq_rightConvolution_tree
    (T : NormalizedTreeAntipodeTarget K) (t : PTree) :
    normalizedStableMiddleConvolutionTripleMap K T.stableAntipode
        (((coalgebraRightStageTripleBranch t []).map
          (hypersequentTripleBasisTmul (R := K))).sum) =
      normalizedStableRightConvolutionTensorMap K T.stableAntipode
        (hypersequentCoalgebraComulTensorLinearMap K (treeMonomial K t)) := by
  rw [coalgebraRightStageTripleBranch_empty_sum]
  rw [hypersequentCoalgebraComulTensorLinearMap_tree]
  unfold coalgebraTreeSplittingTensorElement coalgebraTreeSplittingTensorSupport
  rw [map_list_sum]
  rw [normalizedStableRightConvolutionTensorMap_tensorSupportElement]
  rw [List.map_map]
  apply congrArg List.sum
  apply List.map_congr_left
  intro cut _hcut
  simp only [Function.comp_apply,
    normalizedStableMiddleConvolutionTripleMap_tripleBasisTmul,
    normalizedStableRightConvolutionTensorMap_tensorBasisTmul,
    hseqMonomial_zero, one_mul]

theorem NormalizedTreeAntipodeTarget.middleConvolution_rightStageBranch_empty
    (T : NormalizedTreeAntipodeTarget K) (t : PTree) :
    normalizedStableMiddleConvolutionTripleMap K T.stableAntipode
        (((coalgebraRightStageTripleBranch t []).map
          (hypersequentTripleBasisTmul (R := K))).sum) = 0 := by
  rw [NormalizedTreeAntipodeTarget.middleConvolution_rightStageBranch_empty_eq_rightConvolution_tree
    K T t]
  exact NormalizedTreeAntipodeTarget.right_convolution_tree K T t

theorem NormalizedTreeAntipodeTarget.middleConvolution_rightStageBranch_root
    (T : NormalizedTreeAntipodeTarget K) (t : PTree) :
    normalizedStableMiddleConvolutionTripleMap K T.stableAntipode
        (((coalgebraRightStageTripleBranch t [([] : Address)]).map
          (hypersequentTripleBasisTmul (R := K))).sum) =
      treeMonomial K t := by
  rw [coalgebraRightStageTripleBranch_root_sum]
  simp

theorem NormalizedTreeAntipodeTarget.middleConvolution_leftStageBranch_empty
    (T : NormalizedTreeAntipodeTarget K) (t : PTree) :
    normalizedStableMiddleConvolutionTripleMap K T.stableAntipode
        (((coalgebraLeftStageTripleBranch t []).map
          (hypersequentTripleBasisTmul (R := K))).sum) =
      treeMonomial K t := by
  rw [coalgebraLeftStageTripleBranch_empty_sum]
  simp

theorem NormalizedTreeAntipodeTarget.middleConvolution_leftStageBranch_root_eq_leftConvolution_tree
    (T : NormalizedTreeAntipodeTarget K) (t : PTree) :
    normalizedStableMiddleConvolutionTripleMap K T.stableAntipode
        (((coalgebraLeftStageTripleBranch t [([] : Address)]).map
          (hypersequentTripleBasisTmul (R := K))).sum) =
      normalizedStableLeftConvolutionTensorMap K T.stableAntipode
        (hypersequentCoalgebraComulTensorLinearMap K (treeMonomial K t)) := by
  rw [coalgebraLeftStageTripleBranch_root_sum]
  rw [hypersequentCoalgebraComulTensorLinearMap_tree]
  unfold coalgebraTreeSplittingTensorElement coalgebraTreeSplittingTensorSupport
  rw [map_list_sum]
  rw [normalizedStableLeftConvolutionTensorMap_tensorSupportElement]
  rw [List.map_map]
  apply congrArg List.sum
  apply List.map_congr_left
  intro cut _hcut
  simp only [Function.comp_apply,
    normalizedStableMiddleConvolutionTripleMap_tripleBasisTmul,
    normalizedStableLeftConvolutionTensorMap_tensorBasisTmul,
    hseqMonomial_zero, mul_one]

theorem NormalizedTreeAntipodeTarget.middleConvolution_rightStageBranch_internal_eq_mul_rightConvolution_remainder
    (T : NormalizedTreeAntipodeTarget K)
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ internalCoalgebraAdmissibleCuts t) :
    normalizedStableMiddleConvolutionTripleMap K T.stableAntipode
        (((coalgebraRightStageTripleBranch t cut).map
          (hypersequentTripleBasisTmul (R := K))).sum) =
      hseqMonomial K (HQ.ofForest (coalgebraDetachedForestOfCut t cut)) *
        normalizedStableRightConvolutionTensorMap K T.stableAntipode
          (hypersequentCoalgebraComulTensorLinearMap K
            (treeMonomial K (PTree.remainderGo cut [] t))) := by
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut with
    ⟨_hcoal, hinternal⟩
  rw [coalgebraRightStageTripleBranch_of_internalCut hinternal]
  rw [hypersequentCoalgebraComulTensorLinearMap_tree]
  unfold coalgebraTreeSplittingTensorElement coalgebraTreeSplittingTensorSupport
  rw [map_list_sum]
  rw [normalizedStableRightConvolutionTensorMap_tensorSupportElement]
  rw [List.map_map]
  rw [List.map_map]
  let A := hseqMonomial K (HQ.ofForest (coalgebraDetachedForestOfCut t cut))
  have hmul :
      hseqMonomial K (HQ.ofForest (coalgebraDetachedForestOfCut t cut)) *
          ((coalgebraAdmissibleCuts (PTree.remainderGo cut [] t)).map
            (fun cut₂ =>
              normalizedStableRightConvolutionTensorMap K T.stableAntipode
                (tensorBasisTmul K
                  (coalgebraTensorTermOfCutList
                    (PTree.remainderGo cut [] t) cut₂)))).sum =
        ((coalgebraAdmissibleCuts (PTree.remainderGo cut [] t)).map
          (fun cut₂ =>
            hseqMonomial K
                (HQ.ofForest (coalgebraDetachedForestOfCut t cut)) *
            normalizedStableRightConvolutionTensorMap K T.stableAntipode
              (tensorBasisTmul K
                (coalgebraTensorTermOfCutList
                  (PTree.remainderGo cut [] t) cut₂)))).sum := by
    simpa [A] using
      (map_list_sum (LinearMap.mulLeft K A)
        ((coalgebraAdmissibleCuts (PTree.remainderGo cut [] t)).map
          (fun cut₂ =>
            normalizedStableRightConvolutionTensorMap K T.stableAntipode
              (tensorBasisTmul K
                (coalgebraTensorTermOfCutList
                  (PTree.remainderGo cut [] t) cut₂)))))
  rw [show
    hseqMonomial K (HQ.ofForest (coalgebraDetachedForestOfCut t cut)) *
        (List.map
          (fun p =>
            normalizedStableRightConvolutionTensorMap K T.stableAntipode
              (tensorBasisTmul K p))
          (List.map
            (coalgebraTensorTermOfCutList (PTree.remainderGo cut [] t))
            (coalgebraAdmissibleCuts (PTree.remainderGo cut [] t)))).sum =
      ((coalgebraAdmissibleCuts (PTree.remainderGo cut [] t)).map
        (fun cut₂ =>
          hseqMonomial K (HQ.ofForest (coalgebraDetachedForestOfCut t cut)) *
            normalizedStableRightConvolutionTensorMap K T.stableAntipode
              (tensorBasisTmul K
                (coalgebraTensorTermOfCutList
                  (PTree.remainderGo cut [] t) cut₂)))).sum by
    simpa [Function.comp_def, List.map_map] using hmul]
  apply congrArg List.sum
  apply List.map_congr_left
  intro cut₂ _hcut₂
  simp only [Function.comp_apply]
  rw [coalgebraRightStageTripleOfCuts_of_ne_nil_of_root_not_mem
    hinternal.1 hinternal.2]
  simp [coalgebraDetachedForestOfCut, hinternal.1, hinternal.2,
    normalizedStableMiddleConvolutionTripleMap_tripleBasisTmul,
    normalizedStableRightConvolutionTensorMap_tensorBasisTmul]

theorem NormalizedTreeAntipodeTarget.middleConvolution_rightStageBranch_internal
    (T : NormalizedTreeAntipodeTarget K)
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ internalCoalgebraAdmissibleCuts t) :
    normalizedStableMiddleConvolutionTripleMap K T.stableAntipode
        (((coalgebraRightStageTripleBranch t cut).map
          (hypersequentTripleBasisTmul (R := K))).sum) = 0 := by
  rw [NormalizedTreeAntipodeTarget.middleConvolution_rightStageBranch_internal_eq_mul_rightConvolution_remainder
    K T hcut]
  have hright :
      normalizedStableRightConvolutionTensorMap K T.stableAntipode
        (hypersequentCoalgebraComulTensorLinearMap K
          (treeMonomial K (PTree.remainderGo cut [] t))) = 0 := by
    exact NormalizedTreeAntipodeTarget.right_convolution_tree K T
      (PTree.remainderGo cut [] t)
  rw [hright]
  simp

theorem NormalizedTreeAntipodeTarget.middleConvolution_rightStageTripleElement
    (T : NormalizedTreeAntipodeTarget K) (t : PTree) :
    normalizedStableMiddleConvolutionTripleMap K T.stableAntipode
        (coalgebraRightStageTripleElement K t) =
      treeMonomial K t := by
  rw [coalgebraRightStageTripleElement_eq_empty_root_internal]
  rw [map_add, map_add]
  rw [NormalizedTreeAntipodeTarget.middleConvolution_rightStageBranch_empty K T t]
  rw [NormalizedTreeAntipodeTarget.middleConvolution_rightStageBranch_root K T t]
  have hinternal :
      normalizedStableMiddleConvolutionTripleMap K T.stableAntipode
          (((internalCoalgebraAdmissibleCuts t).map
            (fun cut =>
              ((coalgebraRightStageTripleBranch t cut).map
                (hypersequentTripleBasisTmul (R := K))).sum)).sum) = 0 := by
    rw [map_list_sum]
    rw [List.map_map]
    apply List.sum_map_eq_zero_of_forall
    intro cut hcut
    exact
      NormalizedTreeAntipodeTarget.middleConvolution_rightStageBranch_internal
        K T hcut
  rw [hinternal]
  simp

theorem NormalizedTreeAntipodeTarget.middleConvolution_leftStageBranch_internal_of_detached_leftConvolution_zero
    (T : NormalizedTreeAntipodeTarget K)
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ internalCoalgebraAdmissibleCuts t)
    (hzero :
      normalizedStableLeftConvolutionTensorMap K T.stableAntipode
        (hypersequentCoalgebraComulTensorLinearMap K
          (hseqMonomial K (HQ.ofForest (coalgebraDetachedForestOfCut t cut)))) = 0) :
    normalizedStableMiddleConvolutionTripleMap K T.stableAntipode
        (((coalgebraLeftStageTripleBranch t cut).map
          (hypersequentTripleBasisTmul (R := K))).sum) = 0 := by
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut with
    ⟨_hcoal, hinternal⟩
  let det := coalgebraDetachedForestOfCut t cut
  let rem := PTree.remainderGo cut [] t
  let C := treeMonomial K rem
  have hrem :
      coalgebraRemainderOfCut t cut = HQ.singleton rem := by
    rw [coalgebraRemainderOfCut]
    rw [coalgebraTensorTermOfCutList_of_ne_nil_of_root_not_mem
      hinternal.1 hinternal.2]
  have hleftSum :
      ((coalgebraForestSplittingTensorSupport det).map
        (fun p =>
          hseqMonomial K p.1 *
            normalizedStableAntipodeAlgHom K T.stableAntipode
              (hseqMonomial K p.2))).sum = 0 := by
    have h := hzero
    rw [hypersequentCoalgebraComulTensorLinearMap_ofForest] at h
    unfold coalgebraForestSplittingTensorElement at h
    rw [normalizedStableLeftConvolutionTensorMap_tensorSupportElement] at h
    simpa [det, normalizedStableLeftConvolutionTensorMap_tensorBasisTmul] using h
  rw [coalgebraLeftStageTripleBranch]
  simp only [hrem]
  rw [List.map_map]
  change
    normalizedStableMiddleConvolutionTripleMap K T.stableAntipode
        (((coalgebraForestSplittingTensorSupport det).map
          (fun p =>
            hypersequentTripleBasisTmul K
              (p.1, p.2, HQ.singleton rem))).sum) = 0
  rw [map_list_sum]
  rw [List.map_map]
  change
    ((coalgebraForestSplittingTensorSupport det).map
      (fun p =>
        normalizedStableMiddleConvolutionTripleMap K T.stableAntipode
          (hypersequentTripleBasisTmul K
            (p.1, p.2, HQ.singleton rem)))).sum = 0
  have hnormalize :
      ((coalgebraForestSplittingTensorSupport det).map
        (fun p =>
          normalizedStableMiddleConvolutionTripleMap K T.stableAntipode
            (hypersequentTripleBasisTmul K
              (p.1, p.2, HQ.singleton rem)))).sum =
        ((coalgebraForestSplittingTensorSupport det).map
          (fun p =>
            hseqMonomial K p.1 *
              (normalizedStableAntipodeAlgHom K T.stableAntipode
                  (hseqMonomial K p.2) * C))).sum := by
    apply congrArg List.sum
    apply List.map_congr_left
    intro p _hp
    rw [normalizedStableMiddleConvolutionTripleMap_tripleBasisTmul]
    simp [hseqMonomial_singleton_eq_treeMonomial, C]
  rw [hnormalize]
  have hassoc :
      ((coalgebraForestSplittingTensorSupport det).map
        (fun p =>
          hseqMonomial K p.1 *
            (normalizedStableAntipodeAlgHom K T.stableAntipode
                (hseqMonomial K p.2) * C))).sum =
        ((coalgebraForestSplittingTensorSupport det).map
          (fun p =>
            (hseqMonomial K p.1 *
              normalizedStableAntipodeAlgHom K T.stableAntipode
                (hseqMonomial K p.2)) * C)).sum := by
    apply congrArg List.sum
    apply List.map_congr_left
    intro p _hp
    simp [mul_assoc, C]
  rw [hassoc]
  have hmul :
      ((coalgebraForestSplittingTensorSupport det).map
        (fun p =>
          (hseqMonomial K p.1 *
            normalizedStableAntipodeAlgHom K T.stableAntipode
              (hseqMonomial K p.2)) * C)).sum =
        ((coalgebraForestSplittingTensorSupport det).map
          (fun p =>
            hseqMonomial K p.1 *
              normalizedStableAntipodeAlgHom K T.stableAntipode
                (hseqMonomial K p.2))).sum * C := by
    simpa [C] using
      (map_list_sum (LinearMap.mulRight K C)
        ((coalgebraForestSplittingTensorSupport det).map
          (fun p =>
            hseqMonomial K p.1 *
              normalizedStableAntipodeAlgHom K T.stableAntipode
                (hseqMonomial K p.2)))).symm
  rw [hmul, hleftSum]
  simp

theorem NormalizedTreeAntipodeTarget.middleConvolution_leftStageTripleElement_of_internal_detached_leftConvolution_zero
    (T : NormalizedTreeAntipodeTarget K) (t : PTree)
    (hdet :
      ∀ cut ∈ internalCoalgebraAdmissibleCuts t,
        normalizedStableLeftConvolutionTensorMap K T.stableAntipode
          (hypersequentCoalgebraComulTensorLinearMap K
            (hseqMonomial K (HQ.ofForest (coalgebraDetachedForestOfCut t cut)))) = 0) :
    normalizedStableMiddleConvolutionTripleMap K T.stableAntipode
        (coalgebraLeftStageTripleElement K t) =
      treeMonomial K t +
        normalizedStableLeftConvolutionTensorMap K T.stableAntipode
          (hypersequentCoalgebraComulTensorLinearMap K (treeMonomial K t)) := by
  rw [coalgebraLeftStageTripleElement_eq_empty_root_internal]
  rw [map_add, map_add]
  rw [NormalizedTreeAntipodeTarget.middleConvolution_leftStageBranch_empty K T t]
  rw [NormalizedTreeAntipodeTarget.middleConvolution_leftStageBranch_root_eq_leftConvolution_tree K T t]
  have hinternal :
      normalizedStableMiddleConvolutionTripleMap K T.stableAntipode
          (((internalCoalgebraAdmissibleCuts t).map
            (fun cut =>
              ((coalgebraLeftStageTripleBranch t cut).map
                (hypersequentTripleBasisTmul (R := K))).sum)).sum) = 0 := by
    rw [map_list_sum]
    rw [List.map_map]
    apply List.sum_map_eq_zero_of_forall
    intro cut hcut
    exact
      NormalizedTreeAntipodeTarget.middleConvolution_leftStageBranch_internal_of_detached_leftConvolution_zero
        K T hcut (hdet cut hcut)
  rw [hinternal]
  simp [add_assoc, add_comm, add_left_comm]

theorem NormalizedTreeAntipodeTarget.left_convolution_tree_of_coassoc_and_internal_detached
    (T : NormalizedTreeAntipodeTarget K) (t : PTree)
    (hcoassoc :
      coalgebraRightStageTripleElement K t =
        coalgebraLeftStageTripleElement K t)
    (hdet :
      ∀ cut ∈ internalCoalgebraAdmissibleCuts t,
        normalizedStableLeftConvolutionTensorMap K T.stableAntipode
          (hypersequentCoalgebraComulTensorLinearMap K
            (hseqMonomial K (HQ.ofForest (coalgebraDetachedForestOfCut t cut)))) = 0) :
    normalizedStableLeftConvolutionTensorMap K T.stableAntipode
      (hypersequentCoalgebraComulTensorLinearMap K (treeMonomial K t)) = 0 := by
  have hright :=
    NormalizedTreeAntipodeTarget.middleConvolution_rightStageTripleElement K T t
  rw [hcoassoc] at hright
  rw [NormalizedTreeAntipodeTarget.middleConvolution_leftStageTripleElement_of_internal_detached_leftConvolution_zero
    K T t hdet] at hright
  have hz :
      treeMonomial K t +
          normalizedStableLeftConvolutionTensorMap K T.stableAntipode
            (hypersequentCoalgebraComulTensorLinearMap K (treeMonomial K t)) =
        treeMonomial K t + 0 := by
    simpa using hright
  exact add_left_cancel hz

/-- The support-algebra version of the left convolution map. -/
noncomputable def normalizedStableLeftConvolutionTensorAlgMap
    (S : NormalizedStableTreeAntipode K) :
    HypersequentTensorAlgebra K →ₗ[K] HypersequentAlgebra K :=
  (normalizedStableLeftConvolutionTensorMap K S).comp
    (hypersequentTensorAlgToTensorProductLinearMap K)

@[simp]
theorem normalizedStableLeftConvolutionTensorAlgMap_monomial
    (S : NormalizedStableTreeAntipode K)
    (p : HypersequentTensorBasis) :
    normalizedStableLeftConvolutionTensorAlgMap K S
        (tensorBasisMonomial K p) =
      hseqMonomial K p.1 *
        normalizedStableAntipodeAlgHom K S (hseqMonomial K p.2) := by
  simp [normalizedStableLeftConvolutionTensorAlgMap]

theorem normalizedStableLeftConvolutionTensorAlgMap_mul
    (S : NormalizedStableTreeAntipode K)
    (x y : HypersequentTensorAlgebra K) :
    normalizedStableLeftConvolutionTensorAlgMap K S (x * y) =
      normalizedStableLeftConvolutionTensorAlgMap K S x *
        normalizedStableLeftConvolutionTensorAlgMap K S y := by
  classical
  refine AddMonoidAlgebra.induction_on
    (p := fun x =>
      normalizedStableLeftConvolutionTensorAlgMap K S (x * y) =
        normalizedStableLeftConvolutionTensorAlgMap K S x *
          normalizedStableLeftConvolutionTensorAlgMap K S y)
    x ?_ ?_ ?_
  · intro p
    refine AddMonoidAlgebra.induction_on
      (p := fun y =>
        normalizedStableLeftConvolutionTensorAlgMap K S
            (tensorBasisMonomial K p * y) =
          normalizedStableLeftConvolutionTensorAlgMap K S
              (tensorBasisMonomial K p) *
            normalizedStableLeftConvolutionTensorAlgMap K S y)
      y ?_ ?_ ?_
    · intro q
      change
        normalizedStableLeftConvolutionTensorAlgMap K S
            (tensorBasisMonomial K p * tensorBasisMonomial K q) =
          normalizedStableLeftConvolutionTensorAlgMap K S
              (tensorBasisMonomial K p) *
            normalizedStableLeftConvolutionTensorAlgMap K S
              (tensorBasisMonomial K q)
      rw [tensorBasisMonomial_mul]
      simp only [normalizedStableLeftConvolutionTensorAlgMap_monomial,
        HypersequentTensorBasis.mul]
      rw [← hseqMonomial_mul, ← hseqMonomial_mul]
      rw [map_mul]
      ac_rfl
    · intro y₁ y₂ hy₁ hy₂
      rw [mul_add, map_add, hy₁, hy₂]
      rw [map_add]
      exact (left_distrib
        (normalizedStableLeftConvolutionTensorAlgMap K S
          (tensorBasisMonomial K p))
        (normalizedStableLeftConvolutionTensorAlgMap K S y₁)
        (normalizedStableLeftConvolutionTensorAlgMap K S y₂)).symm
    · intro r y hy
      rw [mul_smul_comm, map_smul, hy, map_smul]
      simp [smul_mul_assoc, mul_smul_comm]
  · intro x₁ x₂ hx₁ hx₂
    rw [add_mul, map_add, hx₁, hx₂]
    rw [map_add]
    exact (right_distrib
      (normalizedStableLeftConvolutionTensorAlgMap K S x₁)
      (normalizedStableLeftConvolutionTensorAlgMap K S x₂)
      (normalizedStableLeftConvolutionTensorAlgMap K S y)).symm
  · intro r x hx
    rw [smul_mul_assoc, map_smul, hx, map_smul]
    simp [smul_mul_assoc]

theorem normalizedStableLeftConvolutionTensorMap_comul_mul
    (S : NormalizedStableTreeAntipode K)
    (x y : HypersequentAlgebra K) :
    normalizedStableLeftConvolutionTensorMap K S
        (hypersequentCoalgebraComulTensorLinearMap K (x * y)) =
      normalizedStableLeftConvolutionTensorMap K S
          (hypersequentCoalgebraComulTensorLinearMap K x) *
        normalizedStableLeftConvolutionTensorMap K S
          (hypersequentCoalgebraComulTensorLinearMap K y) := by
  unfold hypersequentCoalgebraComulTensorLinearMap
  change
    normalizedStableLeftConvolutionTensorAlgMap K S
        (hypersequentCoalgebraComulAlgHom K (x * y)) =
      normalizedStableLeftConvolutionTensorAlgMap K S
          (hypersequentCoalgebraComulAlgHom K x) *
        normalizedStableLeftConvolutionTensorAlgMap K S
          (hypersequentCoalgebraComulAlgHom K y)
  rw [map_mul, normalizedStableLeftConvolutionTensorAlgMap_mul]

theorem normalizedStableLeftConvolutionTensorMap_ofForest_of_nonempty_of_forall_tree_zero
    (S : NormalizedStableTreeAntipode K)
    {f : Forest}
    (hne : f ≠ [])
    (hzero :
      ∀ u ∈ f,
        normalizedStableLeftConvolutionTensorMap K S
          (hypersequentCoalgebraComulTensorLinearMap K
            (treeMonomial K u)) = 0) :
    normalizedStableLeftConvolutionTensorMap K S
      (hypersequentCoalgebraComulTensorLinearMap K
        (hseqMonomial K (HQ.ofForest f))) = 0 := by
  cases f with
  | nil =>
      exact False.elim (hne rfl)
  | cons t ts =>
      have hmon :
          hseqMonomial K (HQ.ofForest (t :: ts)) =
            treeMonomial K t *
              hseqMonomial K (HQ.ofForest ts) := by
        rw [HQ.ofForest_cons]
        rw [← hseqMonomial_mul (R := K)
          (HQ.singleton t) (HQ.ofForest ts)]
        rfl
      rw [hmon]
      rw [normalizedStableLeftConvolutionTensorMap_comul_mul]
      have htree :
          normalizedStableLeftConvolutionTensorMap K S
            (hypersequentCoalgebraComulTensorLinearMap K
              (treeMonomial K t)) = 0 := by
        exact hzero t (by simp)
      rw [htree]
      simp

theorem NormalizedTreeAntipodeTarget.left_convolution_detachedForest_of_internal_of_forall_mem_zero
    (T : NormalizedTreeAntipodeTarget K)
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ internalCoalgebraAdmissibleCuts t)
    (hzero :
      ∀ u ∈ coalgebraDetachedForestOfCut t cut,
        normalizedStableLeftConvolutionTensorMap K T.stableAntipode
          (hypersequentCoalgebraComulTensorLinearMap K
            (treeMonomial K u)) = 0) :
    normalizedStableLeftConvolutionTensorMap K T.stableAntipode
      (hypersequentCoalgebraComulTensorLinearMap K
        (hseqMonomial K
          (HQ.ofForest (coalgebraDetachedForestOfCut t cut)))) = 0 :=
  normalizedStableLeftConvolutionTensorMap_ofForest_of_nonempty_of_forall_tree_zero
    K T.stableAntipode
    (coalgebraDetachedForestOfCut_nonempty_of_internal hcut)
    hzero

theorem NormalizedTreeAntipodeTarget.left_convolution_tree_of_coassoc_and_internal_detached_tree_zero
    (T : NormalizedTreeAntipodeTarget K)
    (hcoassoc : HypersequentNormalizedCoalgebraTreeCoassocSupport K)
    (t : PTree)
    (hdet :
      ∀ cut ∈ internalCoalgebraAdmissibleCuts t,
        ∀ u ∈ coalgebraDetachedForestOfCut t cut,
          normalizedStableLeftConvolutionTensorMap K T.stableAntipode
            (hypersequentCoalgebraComulTensorLinearMap K
              (treeMonomial K u)) = 0) :
    normalizedStableLeftConvolutionTensorMap K T.stableAntipode
      (hypersequentCoalgebraComulTensorLinearMap K (treeMonomial K t)) = 0 :=
  NormalizedTreeAntipodeTarget.left_convolution_tree_of_coassoc_and_internal_detached
    K T t (hcoassoc t)
    (fun cut hcut =>
      NormalizedTreeAntipodeTarget.left_convolution_detachedForest_of_internal_of_forall_mem_zero
        K T hcut (hdet cut hcut))

theorem NormalizedTreeAntipodeTarget.left_convolution_tree_of_internal_detached_tree_zero
    (T : NormalizedTreeAntipodeTarget K)
    (t : PTree)
    (hdet :
      ∀ cut ∈ internalCoalgebraAdmissibleCuts t,
        ∀ u ∈ coalgebraDetachedForestOfCut t cut,
          normalizedStableLeftConvolutionTensorMap K T.stableAntipode
            (hypersequentCoalgebraComulTensorLinearMap K
              (treeMonomial K u)) = 0) :
    normalizedStableLeftConvolutionTensorMap K T.stableAntipode
      (hypersequentCoalgebraComulTensorLinearMap K (treeMonomial K t)) = 0 := by
  have hcoassoc : HypersequentNormalizedCoalgebraTreeCoassocSupport K :=
    hypersequentNormalizedCoalgebraTreeCoassocSupport_of_perm (R := K)
      hypersequentNormalizedCoalgebraTreeCoassocSupportPerm_of_decomposition
  exact
    NormalizedTreeAntipodeTarget.left_convolution_tree_of_coassoc_and_internal_detached_tree_zero
      K T hcoassoc t hdet

/--
Tree-generator form of the missing left convolution cancellation.

The induction is now exactly the connected Hopf-algebra induction: every
internal detached component is strictly smaller than the original tree.
-/
theorem NormalizedTreeAntipodeTarget.left_convolution_tree
    (T : NormalizedTreeAntipodeTarget K)
    (t : PTree) :
    normalizedStableLeftConvolutionTensorMap K T.stableAntipode
      (hypersequentCoalgebraComulTensorLinearMap K (treeMonomial K t)) = 0 := by
  exact
    PTree_size_induction
      (motive := fun t =>
        normalizedStableLeftConvolutionTensorMap K T.stableAntipode
          (hypersequentCoalgebraComulTensorLinearMap K
            (treeMonomial K t)) = 0)
      (by
        intro t ih
        exact
          NormalizedTreeAntipodeTarget.left_convolution_tree_of_internal_detached_tree_zero
            K T t
            (fun cut hcut u hu =>
              ih u
                (coalgebraDetachedForestOfCut_mem_size_lt_of_internal
                  hcut hu)))
      t

/-- The support-algebra version of the right convolution map. -/
noncomputable def normalizedStableRightConvolutionTensorAlgMap
    (S : NormalizedStableTreeAntipode K) :
    HypersequentTensorAlgebra K →ₗ[K] HypersequentAlgebra K :=
  (normalizedStableRightConvolutionTensorMap K S).comp
    (hypersequentTensorAlgToTensorProductLinearMap K)

@[simp]
theorem normalizedStableRightConvolutionTensorAlgMap_monomial
    (S : NormalizedStableTreeAntipode K)
    (p : HypersequentTensorBasis) :
    normalizedStableRightConvolutionTensorAlgMap K S
        (tensorBasisMonomial K p) =
      normalizedStableAntipodeAlgHom K S (hseqMonomial K p.1) *
        hseqMonomial K p.2 := by
  simp [normalizedStableRightConvolutionTensorAlgMap]

theorem normalizedStableRightConvolutionTensorAlgMap_mul
    (S : NormalizedStableTreeAntipode K)
    (x y : HypersequentTensorAlgebra K) :
    normalizedStableRightConvolutionTensorAlgMap K S (x * y) =
      normalizedStableRightConvolutionTensorAlgMap K S x *
        normalizedStableRightConvolutionTensorAlgMap K S y := by
  classical
  refine AddMonoidAlgebra.induction_on
    (p := fun x =>
      normalizedStableRightConvolutionTensorAlgMap K S (x * y) =
        normalizedStableRightConvolutionTensorAlgMap K S x *
          normalizedStableRightConvolutionTensorAlgMap K S y)
    x ?_ ?_ ?_
  · intro p
    refine AddMonoidAlgebra.induction_on
      (p := fun y =>
        normalizedStableRightConvolutionTensorAlgMap K S
            (tensorBasisMonomial K p * y) =
          normalizedStableRightConvolutionTensorAlgMap K S
              (tensorBasisMonomial K p) *
            normalizedStableRightConvolutionTensorAlgMap K S y)
      y ?_ ?_ ?_
    · intro q
      change
        normalizedStableRightConvolutionTensorAlgMap K S
            (tensorBasisMonomial K p * tensorBasisMonomial K q) =
          normalizedStableRightConvolutionTensorAlgMap K S
              (tensorBasisMonomial K p) *
            normalizedStableRightConvolutionTensorAlgMap K S
              (tensorBasisMonomial K q)
      rw [tensorBasisMonomial_mul]
      simp only [normalizedStableRightConvolutionTensorAlgMap_monomial,
        HypersequentTensorBasis.mul]
      rw [← hseqMonomial_mul, ← hseqMonomial_mul]
      rw [map_mul]
      ac_rfl
    · intro y₁ y₂ hy₁ hy₂
      rw [mul_add, map_add, hy₁, hy₂]
      rw [map_add]
      exact (left_distrib
        (normalizedStableRightConvolutionTensorAlgMap K S
          (tensorBasisMonomial K p))
        (normalizedStableRightConvolutionTensorAlgMap K S y₁)
        (normalizedStableRightConvolutionTensorAlgMap K S y₂)).symm
    · intro r y hy
      rw [mul_smul_comm, map_smul, hy, map_smul]
      simp [smul_mul_assoc, mul_smul_comm]
  · intro x₁ x₂ hx₁ hx₂
    rw [add_mul, map_add, hx₁, hx₂]
    rw [map_add]
    exact (right_distrib
      (normalizedStableRightConvolutionTensorAlgMap K S x₁)
      (normalizedStableRightConvolutionTensorAlgMap K S x₂)
      (normalizedStableRightConvolutionTensorAlgMap K S y)).symm
  · intro r x hx
    rw [smul_mul_assoc, map_smul, hx, map_smul]
    simp [smul_mul_assoc]

theorem normalizedStableRightConvolutionTensorMap_comul_mul
    (S : NormalizedStableTreeAntipode K)
    (x y : HypersequentAlgebra K) :
    normalizedStableRightConvolutionTensorMap K S
        (hypersequentCoalgebraComulTensorLinearMap K (x * y)) =
      normalizedStableRightConvolutionTensorMap K S
          (hypersequentCoalgebraComulTensorLinearMap K x) *
        normalizedStableRightConvolutionTensorMap K S
          (hypersequentCoalgebraComulTensorLinearMap K y) := by
  unfold hypersequentCoalgebraComulTensorLinearMap
  change
    normalizedStableRightConvolutionTensorAlgMap K S
        (hypersequentCoalgebraComulAlgHom K (x * y)) =
      normalizedStableRightConvolutionTensorAlgMap K S
          (hypersequentCoalgebraComulAlgHom K x) *
        normalizedStableRightConvolutionTensorAlgMap K S
          (hypersequentCoalgebraComulAlgHom K y)
  rw [map_mul, normalizedStableRightConvolutionTensorAlgMap_mul]

@[simp]
theorem NormalizedTreeAntipodeTarget.left_convolution_zero
    (T : NormalizedTreeAntipodeTarget K) :
    (LinearMap.mul' K (HypersequentAlgebra K) ∘ₗ
        LinearMap.lTensor (HypersequentAlgebra K)
          (NormalizedTreeAntipodeTarget.linearization K T).linearMap ∘ₗ
        hypersequentCoalgebraComulTensorLinearMap K)
        (hseqMonomial K (0 : Hypersequent)) =
      (Algebra.linearMap K (HypersequentAlgebra K) ∘ₗ
          (hypersequentCounitAlgHom K).toLinearMap)
        (hseqMonomial K (0 : Hypersequent)) := by
  change
    normalizedStableLeftConvolutionTensorMap K T.stableAntipode
        (hypersequentCoalgebraComulTensorLinearMap K
          (1 : HypersequentAlgebra K)) =
      algebraMap K (HypersequentAlgebra K)
        ((hypersequentCounitAlgHom K) (1 : HypersequentAlgebra K))
  rw [hypersequentCoalgebraComulTensorLinearMap_one]
  rw [show
      (1 : TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K)) =
        (1 : HypersequentAlgebra K) ⊗ₜ[K]
          (1 : HypersequentAlgebra K) by
        exact Algebra.TensorProduct.one_def
          (R := K) (A := HypersequentAlgebra K)
          (B := HypersequentAlgebra K)]
  rw [normalizedStableLeftConvolutionTensorMap_tmul]
  rw [map_one (normalizedStableAntipodeAlgHom K T.stableAntipode)]
  rw [map_one (hypersequentCounitAlgHom K)]
  rw [mul_one]
  rw [map_one (algebraMap K (HypersequentAlgebra K))]

theorem NormalizedTreeAntipodeTarget.left_convolution_singleton_of_remainder_bogoliubov
    (T : NormalizedTreeAntipodeTarget K)
    (hrem : NormalizedTreeAntipodeTarget.remainder_bogoliubov K T)
    (t : PTree) :
    (LinearMap.mul' K (HypersequentAlgebra K) ∘ₗ
        LinearMap.lTensor (HypersequentAlgebra K)
          (NormalizedTreeAntipodeTarget.linearization K T).linearMap ∘ₗ
        hypersequentCoalgebraComulTensorLinearMap K)
        (hseqMonomial K (HQ.singleton t)) =
      (Algebra.linearMap K (HypersequentAlgebra K) ∘ₗ
          (hypersequentCounitAlgHom K).toLinearMap)
        (hseqMonomial K (HQ.singleton t)) := by
  rw [hseqMonomial_singleton_eq_treeMonomial]
  rw [NormalizedTreeAntipodeTarget.left_convolution_tree_of_remainder_bogoliubov
    K T hrem]
  change
    0 =
      (Algebra.linearMap K (HypersequentAlgebra K))
        ((hypersequentCounitAlgHom K) (treeMonomial K t))
  rw [hypersequentCounitAlgHom_tree]
  exact (LinearMap.map_zero
    (Algebra.linearMap K (HypersequentAlgebra K))).symm

theorem NormalizedTreeAntipodeTarget.left_convolution_monomial_of_remainder_bogoliubov
    (T : NormalizedTreeAntipodeTarget K)
    (hrem : NormalizedTreeAntipodeTarget.remainder_bogoliubov K T)
    (G : Hypersequent) :
    (LinearMap.mul' K (HypersequentAlgebra K) ∘ₗ
        LinearMap.lTensor (HypersequentAlgebra K)
          (NormalizedTreeAntipodeTarget.linearization K T).linearMap ∘ₗ
        hypersequentCoalgebraComulTensorLinearMap K)
        (hseqMonomial K G) =
      (Algebra.linearMap K (HypersequentAlgebra K) ∘ₗ
          (hypersequentCounitAlgHom K).toLinearMap)
        (hseqMonomial K G) := by
  classical
  refine Multiset.induction_on G ?_ ?_
  · simpa using NormalizedTreeAntipodeTarget.left_convolution_zero K T
  · intro t G ih
    have hinsert :
        hseqMonomial K (t ::ₘ G) =
          treeMonomial K t * hseqMonomial K G := by
      rw [← hseqMonomial_singleton_eq_treeMonomial]
      exact (hseqMonomial_mul (R := K) (HQ.singleton t) G).symm
    rw [hinsert]
    change
      normalizedStableLeftConvolutionTensorMap K T.stableAntipode
          (hypersequentCoalgebraComulTensorLinearMap K
            (treeMonomial K t * hseqMonomial K G)) =
        (Algebra.linearMap K (HypersequentAlgebra K))
          ((hypersequentCounitAlgHom K)
            (treeMonomial K t * hseqMonomial K G))
    rw [normalizedStableLeftConvolutionTensorMap_comul_mul]
    have htree :
        normalizedStableLeftConvolutionTensorMap K T.stableAntipode
            (hypersequentCoalgebraComulTensorLinearMap K
              (treeMonomial K t)) =
          0 := by
      exact
        NormalizedTreeAntipodeTarget.left_convolution_tree_of_remainder_bogoliubov
          K T hrem t
    rw [htree]
    rw [zero_mul]
    have hcounit :
        (hypersequentCounitAlgHom K)
            (treeMonomial K t * hseqMonomial K G) =
          0 := by
      simp [hypersequentCounitAlgHom_mul, hypersequentCounitAlgHom_tree]
    rw [hcounit]
    exact (LinearMap.map_zero
      (Algebra.linearMap K (HypersequentAlgebra K))).symm

/--
On a single proof tree, the missing `m(id ⊗ S)` cancellation is exactly the
stable proper-cut symmetry.  This is the sharp local form of the remaining
Hopf-side combinatorics.
-/
theorem NormalizedTreeAntipodeTarget.left_convolution_tree_zero_iff_stable_symmetry_at
    (T : NormalizedTreeAntipodeTarget K) (t : PTree) :
    normalizedStableLeftConvolutionTensorMap K T.stableAntipode
        (hypersequentCoalgebraComulTensorLinearMap K (treeMonomial K t)) = 0 ↔
      normalizedStableAntipodeProperCutLeftSum K T.stableAntipode t =
        normalizedStableAntipodeRemainderCutSum K T.stableAntipode t := by
  rw [normalizedStableLeftConvolutionTensorMap_treeComul]
  constructor
  · intro hzero
    have hleft := NormalizedTreeAntipodeTarget.left_bogoliubov K T t
    refine add_left_cancel (a :=
      NormalizedStableTreeAntipode.value K T.stableAntipode t +
        treeMonomial K t) ?_
    simpa [add_assoc] using hleft.trans hzero.symm
  · intro hsym
    rw [← hsym]
    simpa [add_assoc] using
      NormalizedTreeAntipodeTarget.left_bogoliubov K T t

/--
Tree-generator `m(id ⊗ S)` cancellation for all trees is equivalent to the
stable proper-cut symmetry.
-/
theorem NormalizedTreeAntipodeTarget.left_convolution_tree_zero_iff_stable_symmetry
    (T : NormalizedTreeAntipodeTarget K) :
    (∀ t : PTree,
      normalizedStableLeftConvolutionTensorMap K T.stableAntipode
        (hypersequentCoalgebraComulTensorLinearMap K (treeMonomial K t)) = 0) ↔
      NormalizedStableAntipodeProperCutRemainderSymmetry K T.stableAntipode := by
  constructor
  · intro hzero t
    exact
      (NormalizedTreeAntipodeTarget.left_convolution_tree_zero_iff_stable_symmetry_at
        K T t).1 (hzero t)
  · intro hsym t
    exact
      (NormalizedTreeAntipodeTarget.left_convolution_tree_zero_iff_stable_symmetry_at
        K T t).2 (hsym t)

/--
The basis-level left Hopf cancellation is no stronger and no weaker than the
stable proper-cut symmetry.  The reverse direction is multiplicativity of the
coproduct plus the tree-generator calculation above; the forward direction is
obtained by testing on singleton hypersequents.
-/
theorem NormalizedTreeAntipodeTarget.left_convolution_monomial_iff_stable_symmetry
    (T : NormalizedTreeAntipodeTarget K) :
    (∀ G : Hypersequent,
      (LinearMap.mul' K (HypersequentAlgebra K) ∘ₗ
          LinearMap.lTensor (HypersequentAlgebra K)
            (NormalizedTreeAntipodeTarget.linearization K T).linearMap ∘ₗ
          hypersequentCoalgebraComulTensorLinearMap K)
          (hseqMonomial K G) =
        (Algebra.linearMap K (HypersequentAlgebra K) ∘ₗ
          (hypersequentCounitAlgHom K).toLinearMap)
          (hseqMonomial K G)) ↔
      NormalizedStableAntipodeProperCutRemainderSymmetry K T.stableAntipode := by
  constructor
  · intro hleft t
    have hsingle := hleft (HQ.singleton t)
    rw [hseqMonomial_singleton_eq_treeMonomial] at hsingle
    change
      normalizedStableLeftConvolutionTensorMap K T.stableAntipode
          (hypersequentCoalgebraComulTensorLinearMap K (treeMonomial K t)) =
        (Algebra.linearMap K (HypersequentAlgebra K))
          ((hypersequentCounitAlgHom K) (treeMonomial K t)) at hsingle
    rw [hypersequentCounitAlgHom_tree] at hsingle
    exact
      (NormalizedTreeAntipodeTarget.left_convolution_tree_zero_iff_stable_symmetry_at
        K T t).1 (by simpa using hsingle)
  · intro hsym
    exact
      NormalizedTreeAntipodeTarget.left_convolution_monomial_of_remainder_bogoliubov
        K T
        (NormalizedTreeAntipodeTarget.remainder_bogoliubov_of_stable_symmetry
          K T hsym)

theorem NormalizedTreeAntipodeTarget.stable_symmetry_of_coassoc
    (T : NormalizedTreeAntipodeTarget K) :
    NormalizedStableAntipodeProperCutRemainderSymmetry
      K T.stableAntipode := by
  exact
    (NormalizedTreeAntipodeTarget.left_convolution_tree_zero_iff_stable_symmetry
      K T).1
      (NormalizedTreeAntipodeTarget.left_convolution_tree K T)

theorem normalizedStableTreeAntipodeOfSize_stable_symmetry :
    NormalizedStableAntipodeProperCutRemainderSymmetry K
      (normalizedStableTreeAntipodeOfSize K) := by
  exact
    NormalizedTreeAntipodeTarget.stable_symmetry_of_coassoc K
      (normalizedTreeAntipodeTargetOfSize K)

theorem NormalizedTreeAntipodeTarget.left_convolution_monomial
    (T : NormalizedTreeAntipodeTarget K) (G : Hypersequent) :
    (LinearMap.mul' K (HypersequentAlgebra K) ∘ₗ
        LinearMap.lTensor (HypersequentAlgebra K)
          (NormalizedTreeAntipodeTarget.linearization K T).linearMap ∘ₗ
        hypersequentCoalgebraComulTensorLinearMap K)
        (hseqMonomial K G) =
      (Algebra.linearMap K (HypersequentAlgebra K) ∘ₗ
          (hypersequentCounitAlgHom K).toLinearMap)
        (hseqMonomial K G) := by
  exact
    (NormalizedTreeAntipodeTarget.left_convolution_monomial_iff_stable_symmetry
      K T).2
      (NormalizedTreeAntipodeTarget.stable_symmetry_of_coassoc K T)
      G

@[simp]
theorem NormalizedTreeAntipodeTarget.right_convolution_zero
    (T : NormalizedTreeAntipodeTarget K) :
    (LinearMap.mul' K (HypersequentAlgebra K) ∘ₗ
        LinearMap.rTensor (HypersequentAlgebra K)
          (NormalizedTreeAntipodeTarget.linearization K T).linearMap ∘ₗ
        hypersequentCoalgebraComulTensorLinearMap K)
        (hseqMonomial K (0 : Hypersequent)) =
      (Algebra.linearMap K (HypersequentAlgebra K) ∘ₗ
          (hypersequentCounitAlgHom K).toLinearMap)
        (hseqMonomial K (0 : Hypersequent)) := by
  change
    normalizedStableRightConvolutionTensorMap K T.stableAntipode
        (hypersequentCoalgebraComulTensorLinearMap K
          (1 : HypersequentAlgebra K)) =
      algebraMap K (HypersequentAlgebra K)
        ((hypersequentCounitAlgHom K) (1 : HypersequentAlgebra K))
  rw [hypersequentCoalgebraComulTensorLinearMap_one]
  rw [show
      (1 : TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K)) =
        (1 : HypersequentAlgebra K) ⊗ₜ[K]
          (1 : HypersequentAlgebra K) by
        exact Algebra.TensorProduct.one_def
          (R := K) (A := HypersequentAlgebra K)
          (B := HypersequentAlgebra K)]
  rw [normalizedStableRightConvolutionTensorMap_tmul]
  rw [map_one (normalizedStableAntipodeAlgHom K T.stableAntipode)]
  rw [map_one (hypersequentCounitAlgHom K)]
  rw [one_mul]
  rw [map_one (algebraMap K (HypersequentAlgebra K))]

@[simp]
theorem NormalizedTreeAntipodeTarget.right_convolution_singleton
    (T : NormalizedTreeAntipodeTarget K) (t : PTree) :
    (LinearMap.mul' K (HypersequentAlgebra K) ∘ₗ
        LinearMap.rTensor (HypersequentAlgebra K)
          (NormalizedTreeAntipodeTarget.linearization K T).linearMap ∘ₗ
        hypersequentCoalgebraComulTensorLinearMap K)
        (hseqMonomial K (HQ.singleton t)) =
      (Algebra.linearMap K (HypersequentAlgebra K) ∘ₗ
          (hypersequentCounitAlgHom K).toLinearMap)
        (hseqMonomial K (HQ.singleton t)) := by
  rw [hseqMonomial_singleton_eq_treeMonomial]
  rw [NormalizedTreeAntipodeTarget.right_convolution_tree]
  change
    0 =
      (Algebra.linearMap K (HypersequentAlgebra K))
        ((hypersequentCounitAlgHom K) (treeMonomial K t))
  rw [hypersequentCounitAlgHom_tree]
  exact (LinearMap.map_zero
    (Algebra.linearMap K (HypersequentAlgebra K))).symm

theorem NormalizedTreeAntipodeTarget.right_convolution_monomial
    (T : NormalizedTreeAntipodeTarget K) (G : Hypersequent) :
    (LinearMap.mul' K (HypersequentAlgebra K) ∘ₗ
        LinearMap.rTensor (HypersequentAlgebra K)
          (NormalizedTreeAntipodeTarget.linearization K T).linearMap ∘ₗ
        hypersequentCoalgebraComulTensorLinearMap K)
        (hseqMonomial K G) =
      (Algebra.linearMap K (HypersequentAlgebra K) ∘ₗ
          (hypersequentCounitAlgHom K).toLinearMap)
        (hseqMonomial K G) := by
  classical
  refine Multiset.induction_on G ?_ ?_
  · simpa using NormalizedTreeAntipodeTarget.right_convolution_zero K T
  · intro t G ih
    have hinsert :
        hseqMonomial K (t ::ₘ G) =
          treeMonomial K t * hseqMonomial K G := by
      rw [← hseqMonomial_singleton_eq_treeMonomial]
      exact (hseqMonomial_mul (R := K) (HQ.singleton t) G).symm
    rw [hinsert]
    change
      normalizedStableRightConvolutionTensorMap K T.stableAntipode
          (hypersequentCoalgebraComulTensorLinearMap K
            (treeMonomial K t * hseqMonomial K G)) =
        (Algebra.linearMap K (HypersequentAlgebra K))
          ((hypersequentCounitAlgHom K)
            (treeMonomial K t * hseqMonomial K G))
    rw [normalizedStableRightConvolutionTensorMap_comul_mul]
    have htree :
        normalizedStableRightConvolutionTensorMap K T.stableAntipode
            (hypersequentCoalgebraComulTensorLinearMap K
              (treeMonomial K t)) =
          0 := by
      exact NormalizedTreeAntipodeTarget.right_convolution_tree K T t
    rw [htree]
    rw [zero_mul]
    have hcounit :
        (hypersequentCounitAlgHom K)
            (treeMonomial K t * hseqMonomial K G) =
          0 := by
      simp [hypersequentCounitAlgHom_mul, hypersequentCounitAlgHom_tree]
    rw [hcounit]
    exact (LinearMap.map_zero
      (Algebra.linearMap K (HypersequentAlgebra K))).symm

end NormalizedTakeuchiAntipode

/--
The normalized antipode data still has to be supplied after the bialgebra is
available.  For the rooted-tree target this should be the usual connected
graded recursive antipode, now interpreted through admissible splitting.
-/
structure HypersequentNormalizedHopfAxioms
    (hBialg : HypersequentNormalizedBialgebraAxioms R) where
  antipode : HypersequentAlgebra R →ₗ[R] HypersequentAlgebra R
  left_cancellation :
    LinearMap.mul' R (HypersequentAlgebra R) ∘ₗ
        LinearMap.lTensor (HypersequentAlgebra R) antipode ∘ₗ
          hypersequentCoalgebraComulTensorLinearMap R =
      Algebra.linearMap R (HypersequentAlgebra R) ∘ₗ
        (hypersequentCounitAlgHom R).toLinearMap
  right_cancellation :
    LinearMap.mul' R (HypersequentAlgebra R) ∘ₗ
        LinearMap.rTensor (HypersequentAlgebra R) antipode ∘ₗ
          hypersequentCoalgebraComulTensorLinearMap R =
      Algebra.linearMap R (HypersequentAlgebra R) ∘ₗ
        (hypersequentCounitAlgHom R).toLinearMap

/--
Basis-level form of the normalized antipode cancellation equations.

This is the practical theorem target for the Bogoliubov/Takeuchi recursion: it
is enough to prove convolution cancellation on hypersequent monomials and then
promote the result by linearity.
-/
structure HypersequentNormalizedHopfBasisAxioms
    (hBialg : HypersequentNormalizedBialgebraAxioms R)
    (S : HypersequentAlgebra R →ₗ[R] HypersequentAlgebra R) : Prop where
  left_cancellation :
    ∀ G : Hypersequent,
      (LinearMap.mul' R (HypersequentAlgebra R) ∘ₗ
          LinearMap.lTensor (HypersequentAlgebra R) S ∘ₗ
            hypersequentCoalgebraComulTensorLinearMap R)
        (hseqMonomial R G) =
      (Algebra.linearMap R (HypersequentAlgebra R) ∘ₗ
          (hypersequentCounitAlgHom R).toLinearMap)
        (hseqMonomial R G)
  right_cancellation :
    ∀ G : Hypersequent,
      (LinearMap.mul' R (HypersequentAlgebra R) ∘ₗ
          LinearMap.rTensor (HypersequentAlgebra R) S ∘ₗ
            hypersequentCoalgebraComulTensorLinearMap R)
        (hseqMonomial R G) =
      (Algebra.linearMap R (HypersequentAlgebra R) ∘ₗ
          (hypersequentCounitAlgHom R).toLinearMap)
        (hseqMonomial R G)

def hypersequentNormalizedHopfBasisAxioms_of_treeAntipodeRemainderBogoliubov
    (K : Type) [CommRing K]
    (hBialg : HypersequentNormalizedBialgebraAxioms K)
    (T : NormalizedTreeAntipodeTarget K)
    (hrem : NormalizedTreeAntipodeTarget.remainder_bogoliubov K T) :
    HypersequentNormalizedHopfBasisAxioms K hBialg
      (NormalizedTreeAntipodeTarget.linearization K T).linearMap where
  left_cancellation :=
    NormalizedTreeAntipodeTarget.left_convolution_monomial_of_remainder_bogoliubov
      K T hrem
  right_cancellation :=
    NormalizedTreeAntipodeTarget.right_convolution_monomial K T

def hypersequentNormalizedHopfBasisAxioms_of_treeAntipodePreviousFuelRemainder
    (K : Type) [CommRing K]
    (hBialg : HypersequentNormalizedBialgebraAxioms K)
    (T : NormalizedTreeAntipodeTarget K)
