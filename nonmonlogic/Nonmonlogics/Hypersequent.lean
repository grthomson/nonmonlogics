  have htail :
      List.Perm
        (cut₁.filter (fun a => ! decide (survive a)))
        (firstStageInsideSecondAddresses cut₁ cut₂) := by
    rw [hdomEq]
    exact hdomInside
  have hcut₁Perm :
      List.Perm cut₁
        (cut₁.filter
            (fun a =>
              decide (∀ b : Address, b ∈ cut₂ → ¬ PTree.isAncestorOf b a)) ++
          firstStageInsideSecondAddresses cut₁ cut₂) := by
    simpa [survive] using hpart.trans
      (List.Perm.append_left
        (cut₁.filter (fun a => decide (survive a))) htail)
  rw [hfirstEq]
  exact hflatStage.trans (by
    rw [hstageFirst]
    exact hcut₁Perm.symm)

theorem nodeRightWitnessAmbientProfile_tensor_eq_of_zip_perm
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
