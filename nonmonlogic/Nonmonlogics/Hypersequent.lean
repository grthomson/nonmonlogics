  have hb₁ : b ∈ cut₁ := by
    simpa using
      (PTree.nil_mem_restrictCutAt_iff
        (cut := cut₁) (pfx := b)).1 hroot
  exact disjoint_previous_cut_second_internal_cut
    (t := t) (cut₁ := cut₁) (cut₂ := cut₂)
    hcoal₁ hcut₂ b hb₁ hb₂

/--
When the restricted first-stage cut below a second-stage address is nonempty,
its normalized tensor term has the ordinary root-free cut form.
-/
theorem coalgebraTensorTermOfCutList_restrictCutAt_second_internal_of_ne_nil
    {t : PTree} {cut₁ cut₂ : List Address} {b : Address} {u : PTree}
