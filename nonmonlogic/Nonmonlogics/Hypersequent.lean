theorem coalgebraTensorTermOfCutList_fst_eq_zero_iff
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts t) :
    (coalgebraTensorTermOfCutList t cut).1 = 0 ↔ cut = [] := by
  classical
  rcases (mem_coalgebraAdmissibleCuts_iff).1 hcut with ⟨hraw, _hcoal⟩
  by_cases hnil : cut = []
  · simp [hnil]
  · by_cases hroot : ([] : Address) ∈ cut
    · simp [coalgebraTensorTermOfCutList, hnil, hroot, singleton_ne_zero]
    · rw [coalgebraTensorTermOfCutList_of_ne_nil_of_root_not_mem
        (t := t) (cut := cut) hnil hroot]
      have hne :
          HQ.ofForest (cut.filterMap (PTree.subtreeAt t)) ≠ 0 :=
        pruned_hypersequent_ne_zero_of_cut_ne_nil
          (t := t) (cut := cut) hraw hnil
      simp [hnil, hne]

