  simpa [hseqMonomial_zero] using
    (lTensor_augmentationCounit_tensorBasisTmul
      (R := R) (0 : HypersequentTensorBasis))

@[simp]
theorem hypersequentNormalizedRightCounit_singleton
    (t : PTree) :
    (LinearMap.rTensor (HypersequentAlgebra R)
        (hypersequentCounitAlgHom R).toLinearMap ∘ₗ
        hypersequentCoalgebraComulTensorLinearMap R)
      (hseqMonomial R (HQ.singleton t)) =
    ((TensorProduct.mk R R (HypersequentAlgebra R)) 1)
      (hseqMonomial R (HQ.singleton t)) := by
  simpa [hseqMonomial_singleton_eq_treeMonomial] using
    hypersequentNormalizedRightCounit_tree (R := R) t

@[simp]
theorem hypersequentNormalizedLeftCounit_singleton
    (t : PTree) :
    (LinearMap.lTensor (HypersequentAlgebra R)
        (hypersequentCounitAlgHom R).toLinearMap ∘ₗ
        hypersequentCoalgebraComulTensorLinearMap R)
      (hseqMonomial R (HQ.singleton t)) =
    (((TensorProduct.mk R (HypersequentAlgebra R) R).flip 1))
      (hseqMonomial R (HQ.singleton t)) := by
  simpa [hseqMonomial_singleton_eq_treeMonomial] using
    hypersequentNormalizedLeftCounit_tree (R := R) t

theorem hypersequentNormalizedRightCounit_monomial
    (G : Hypersequent) :
    (LinearMap.rTensor (HypersequentAlgebra R)
        (hypersequentCounitAlgHom R).toLinearMap ∘ₗ
        hypersequentCoalgebraComulTensorLinearMap R)
      (hseqMonomial R G) =
    ((TensorProduct.mk R R (HypersequentAlgebra R)) 1)
      (hseqMonomial R G) := by
  classical
  refine Multiset.induction_on G ?_ ?_
  · simpa using hypersequentNormalizedRightCounit_zero (R := R)
  · intro t G ih
    have hinsert :
        hseqMonomial R (t ::ₘ G) = treeMonomial R t * hseqMonomial R G := by
      rw [← hseqMonomial_singleton_eq_treeMonomial]
      exact (hseqMonomial_mul (R := R) (HQ.singleton t) G).symm
    have ih' :
        hypersequentTensorAlgToRightCounitTensorLinearMap R
            (hypersequentCoalgebraComulAlgHom R (hseqMonomial R G)) =
          1 ⊗ₜ[R] hseqMonomial R G := by
      simpa [hypersequentTensorAlgToRightCounitTensorLinearMap_eq_comp,
        hypersequentCoalgebraComulTensorLinearMap, LinearMap.comp_apply,
        AlgHom.toLinearMap_apply] using ih
    rw [hinsert]
    change
      (LinearMap.rTensor (HypersequentAlgebra R)
          (hypersequentCounitAlgHom R).toLinearMap)
        (hypersequentTensorAlgToTensorProductLinearMap R
          (hypersequentCoalgebraComulAlgHom R
            (treeMonomial R t * hseqMonomial R G))) =
      1 ⊗ₜ[R] (treeMonomial R t * hseqMonomial R G)
    rw [hypersequentCoalgebraComulAlgHom_mul, hypersequentCoalgebraComulAlgHom_tree]
    have htree :=
      hypersequentNormalizedRightCounit_singleton (R := R) t
    rw [hseqMonomial_singleton_eq_treeMonomial] at htree
    have htree' :
        hypersequentTensorAlgToRightCounitTensorLinearMap R
            (coalgebraTreeSplittingTensorElement R t) =
          1 ⊗ₜ[R] treeMonomial R t := by
      have htree'' := htree
      simp only [LinearMap.comp_apply] at htree''
      have htree_map :=
        congrArg
          (LinearMap.rTensor (HypersequentAlgebra R)
            (hypersequentCounitAlgHom R).toLinearMap)
          (hypersequentCoalgebraComulTensorLinearMap_tree (R := R) t)
      have htree_tensor :
          (LinearMap.rTensor (HypersequentAlgebra R)
              (hypersequentCounitAlgHom R).toLinearMap)
            ((hypersequentTensorAlgToTensorProductLinearMap R)
              (coalgebraTreeSplittingTensorElement R t)) =
          1 ⊗ₜ[R] treeMonomial R t := by
        exact htree_map.symm.trans htree''
      simpa [hypersequentTensorAlgToRightCounitTensorLinearMap_eq_comp,
        LinearMap.comp_apply] using htree_tensor
    have hmul :
        (LinearMap.rTensor (HypersequentAlgebra R)
            (hypersequentCounitAlgHom R).toLinearMap)
          ((hypersequentTensorAlgToTensorProductLinearMap R)
            (coalgebraTreeSplittingTensorElement R t *
              (hypersequentCoalgebraComulAlgHom R) (hseqMonomial R G))) =
        hypersequentTensorAlgToRightCounitTensorLinearMap R
          (coalgebraTreeSplittingTensorElement R t *
            (hypersequentCoalgebraComulAlgHom R) (hseqMonomial R G)) := by
      exact (by
        simpa [LinearMap.comp_apply] using
        (hypersequentTensorAlgToRightCounitTensorLinearMap_eq_comp (R := R)
          (coalgebraTreeSplittingTensorElement R t *
            (hypersequentCoalgebraComulAlgHom R) (hseqMonomial R G))).symm)
    rw [hmul, hypersequentTensorAlgToRightCounitTensorLinearMap_mul]
    simpa [hseqMonomial_mul, Algebra.TensorProduct.tmul_mul_tmul,
      hseqMonomial_singleton_eq_treeMonomial, mul_assoc, mul_left_comm, mul_comm] using
      congrArg₂ HMul.hMul htree' ih'

theorem hypersequentNormalizedLeftCounit_monomial
    (G : Hypersequent) :
    (LinearMap.lTensor (HypersequentAlgebra R)
        (hypersequentCounitAlgHom R).toLinearMap ∘ₗ
        hypersequentCoalgebraComulTensorLinearMap R)
      (hseqMonomial R G) =
    (((TensorProduct.mk R (HypersequentAlgebra R) R).flip 1))
      (hseqMonomial R G) := by
  classical
  refine Multiset.induction_on G ?_ ?_
  · simpa using hypersequentNormalizedLeftCounit_zero (R := R)
  · intro t G ih
    have hinsert :
        hseqMonomial R (t ::ₘ G) = treeMonomial R t * hseqMonomial R G := by
      rw [← hseqMonomial_singleton_eq_treeMonomial]
      exact (hseqMonomial_mul (R := R) (HQ.singleton t) G).symm
    have ih' :
        hypersequentTensorAlgToLeftCounitTensorLinearMap R
            (hypersequentCoalgebraComulAlgHom R (hseqMonomial R G)) =
          hseqMonomial R G ⊗ₜ[R] 1 := by
      simpa [hypersequentTensorAlgToLeftCounitTensorLinearMap_eq_comp,
        hypersequentCoalgebraComulTensorLinearMap, LinearMap.comp_apply,
        AlgHom.toLinearMap_apply] using ih
    rw [hinsert]
    change
      (LinearMap.lTensor (HypersequentAlgebra R)
          (hypersequentCounitAlgHom R).toLinearMap)
        (hypersequentTensorAlgToTensorProductLinearMap R
          (hypersequentCoalgebraComulAlgHom R
            (treeMonomial R t * hseqMonomial R G))) =
      (treeMonomial R t * hseqMonomial R G) ⊗ₜ[R] 1
    rw [hypersequentCoalgebraComulAlgHom_mul, hypersequentCoalgebraComulAlgHom_tree]
    have htree := hypersequentNormalizedLeftCounit_singleton (R := R) t
    rw [hseqMonomial_singleton_eq_treeMonomial] at htree
    have htree' :
        hypersequentTensorAlgToLeftCounitTensorLinearMap R
            (coalgebraTreeSplittingTensorElement R t) =
          treeMonomial R t ⊗ₜ[R] 1 := by
      have htree'' := htree
      simp only [LinearMap.comp_apply] at htree''
      have htree_map :=
        congrArg
          (LinearMap.lTensor (HypersequentAlgebra R)
            (hypersequentCounitAlgHom R).toLinearMap)
          (hypersequentCoalgebraComulTensorLinearMap_tree (R := R) t)
      have htree_tensor :
          (LinearMap.lTensor (HypersequentAlgebra R)
              (hypersequentCounitAlgHom R).toLinearMap)
            ((hypersequentTensorAlgToTensorProductLinearMap R)
              (coalgebraTreeSplittingTensorElement R t)) =
          treeMonomial R t ⊗ₜ[R] 1 := by
        exact htree_map.symm.trans htree''
      simpa [hypersequentTensorAlgToLeftCounitTensorLinearMap_eq_comp,
        LinearMap.comp_apply] using htree_tensor
    have hmul :
        (LinearMap.lTensor (HypersequentAlgebra R)
            (hypersequentCounitAlgHom R).toLinearMap)
          ((hypersequentTensorAlgToTensorProductLinearMap R)
            (coalgebraTreeSplittingTensorElement R t *
              (hypersequentCoalgebraComulAlgHom R) (hseqMonomial R G))) =
        hypersequentTensorAlgToLeftCounitTensorLinearMap R
          (coalgebraTreeSplittingTensorElement R t *
            (hypersequentCoalgebraComulAlgHom R) (hseqMonomial R G)) := by
      exact (by
        simpa [LinearMap.comp_apply] using
        (hypersequentTensorAlgToLeftCounitTensorLinearMap_eq_comp (R := R)
          (coalgebraTreeSplittingTensorElement R t *
            (hypersequentCoalgebraComulAlgHom R) (hseqMonomial R G))).symm)
    rw [hmul, hypersequentTensorAlgToLeftCounitTensorLinearMap_mul]
    simpa [hseqMonomial_mul, Algebra.TensorProduct.tmul_mul_tmul,
      hseqMonomial_singleton_eq_treeMonomial, mul_assoc, mul_left_comm, mul_comm] using
      congrArg₂ HMul.hMul htree' ih'


/-- The normalized coproduct preserves the algebra unit. -/
theorem hypersequentCoalgebraComulTensorLinearMap_one :
    hypersequentCoalgebraComulTensorLinearMap R
        (1 : HypersequentAlgebra R) =
      (1 : TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R)) := by
  unfold hypersequentCoalgebraComulTensorLinearMap
  change
    hypersequentTensorAlgToTensorProductLinearMap R
      (hypersequentCoalgebraComulAlgHom R (1 : HypersequentAlgebra R)) =
    (1 : TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))
  rw [map_one]
  change
    hypersequentTensorAlgToTensorProductLinearMap R
      (AddMonoidAlgebra.single (0 : HypersequentTensorBasis) 1) =
    (1 : TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))
  rw [hypersequentTensorAlgToTensorProductLinearMap_single]
  exact tensorBasisTmul_zero R

/-- Componentwise multiplication on the triple tensor target. -/
def hypersequentTripleTensorMul
    (x y : HypersequentTripleTensor R) :
    HypersequentTripleTensor R :=
  (Algebra.TensorProduct.mul
    (R := R)
    (A := HypersequentAlgebra R)
    (B := TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))
    x) y

theorem hypersequentTripleTensorMul_add_left
    (x y z : HypersequentTripleTensor R) :
    hypersequentTripleTensorMul R (x + y) z =
      hypersequentTripleTensorMul R x z +
        hypersequentTripleTensorMul R y z := by
  unfold hypersequentTripleTensorMul
  simpa using congrArg (fun f => f z)
    ((Algebra.TensorProduct.mul
      (R := R)
      (A := HypersequentAlgebra R)
      (B := TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))).map_add x y)

theorem hypersequentTripleTensorMul_add_right
    (x y z : HypersequentTripleTensor R) :
    hypersequentTripleTensorMul R x (y + z) =
      hypersequentTripleTensorMul R x y +
        hypersequentTripleTensorMul R x z := by
  unfold hypersequentTripleTensorMul
  exact LinearMap.map_add
    ((Algebra.TensorProduct.mul
      (R := R)
      (A := HypersequentAlgebra R)
      (B := TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))) x) y z

@[simp]
theorem hypersequentTripleTensorMul_zero_left
    (x : HypersequentTripleTensor R) :
    hypersequentTripleTensorMul R 0 x = 0 := by
  unfold hypersequentTripleTensorMul
  simpa using congrArg (fun f => f x)
    ((Algebra.TensorProduct.mul
      (R := R)
      (A := HypersequentAlgebra R)
      (B := TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))).map_zero)

@[simp]
theorem hypersequentTripleTensorMul_zero_right
    (x : HypersequentTripleTensor R) :
    hypersequentTripleTensorMul R x 0 = 0 := by
  unfold hypersequentTripleTensorMul
  exact LinearMap.map_zero
    ((Algebra.TensorProduct.mul
      (R := R)
      (A := HypersequentAlgebra R)
      (B := TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))) x)

theorem hypersequentTripleTensorMul_smul_left
    (r : R) (x y : HypersequentTripleTensor R) :
    hypersequentTripleTensorMul R (r • x) y =
      r • hypersequentTripleTensorMul R x y := by
  unfold hypersequentTripleTensorMul
  simpa using congrArg (fun f => f y)
    ((Algebra.TensorProduct.mul
      (R := R)
      (A := HypersequentAlgebra R)
      (B := TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))).map_smul r x)

theorem hypersequentTripleTensorMul_smul_right
    (r : R) (x y : HypersequentTripleTensor R) :
    hypersequentTripleTensorMul R x (r • y) =
      r • hypersequentTripleTensorMul R x y := by
  unfold hypersequentTripleTensorMul
  exact LinearMap.map_smul
    ((Algebra.TensorProduct.mul
      (R := R)
      (A := HypersequentAlgebra R)
      (B := TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))) x) r y

theorem hypersequentTripleTensorMul_basis
    (p q : HypersequentTripleBasis) :
    hypersequentTripleTensorMul R
        (hypersequentTripleBasisTmul R p)
        (hypersequentTripleBasisTmul R q) =
      hypersequentTripleBasisTmul R (HypersequentTripleBasis.mul p q) := by
  unfold hypersequentTripleTensorMul hypersequentTripleBasisTmul
  rw [Algebra.TensorProduct.mul_apply]
  rw [Algebra.TensorProduct.tmul_mul_tmul]
  simp [HypersequentTripleBasis.mul, hseqMonomial_mul]

theorem hypersequentTensorAlgToRightStageTripleLinearMap_mul
    (x y : HypersequentTensorAlgebra R) :
    hypersequentTensorAlgToRightStageTripleLinearMap R (x * y) =
      hypersequentTripleTensorMul R
        (hypersequentTensorAlgToRightStageTripleLinearMap R x)
        (hypersequentTensorAlgToRightStageTripleLinearMap R y) := by
  classical
  refine AddMonoidAlgebra.induction_on
    (p := fun x =>
      hypersequentTensorAlgToRightStageTripleLinearMap R (x * y) =
        hypersequentTripleTensorMul R
          (hypersequentTensorAlgToRightStageTripleLinearMap R x)
          (hypersequentTensorAlgToRightStageTripleLinearMap R y))
    x ?_ ?_ ?_
  · intro p
    refine AddMonoidAlgebra.induction_on
      (p := fun y =>
        hypersequentTensorAlgToRightStageTripleLinearMap R
            (tensorBasisMonomial R p * y) =
          hypersequentTripleTensorMul R
            (hypersequentTensorAlgToRightStageTripleLinearMap R
              (tensorBasisMonomial R p))
            (hypersequentTensorAlgToRightStageTripleLinearMap R y))
      y ?_ ?_ ?_
    · intro q
      change hypersequentTensorAlgToRightStageTripleLinearMap R
          (tensorBasisMonomial R p * tensorBasisMonomial R q) =
        hypersequentTripleTensorMul R
          (hypersequentTensorAlgToRightStageTripleLinearMap R
            (tensorBasisMonomial R p))
          (hypersequentTensorAlgToRightStageTripleLinearMap R
            (tensorBasisMonomial R q))
      rw [tensorBasisMonomial_mul]
      simp only [hypersequentTensorAlgToRightStageTripleLinearMap_monomial]
      unfold hypersequentTripleTensorMul
      rw [Algebra.TensorProduct.mul_apply]
      letI :
          NonUnitalNonAssocSemiring
            (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R)) :=
        Algebra.TensorProduct.instNonUnitalNonAssocSemiring
      letI :
          LeftDistribClass
            (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R)) :=
        inferInstance
      letI :
          RightDistribClass
            (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R)) :=
        inferInstance
      rw [← hypersequentCoalgebraComulTensorLinearMap_monomial_mul
        (R := R) p.2 q.2]
      simp [HypersequentTensorBasis.mul, hseqMonomial_mul]
    · intro y₁ y₂ hy₁ hy₂
      rw [mul_add, map_add, hy₁, hy₂]
      simpa [map_add] using (hypersequentTripleTensorMul_add_right R
        (hypersequentTensorAlgToRightStageTripleLinearMap R
          (tensorBasisMonomial R p))
        (hypersequentTensorAlgToRightStageTripleLinearMap R y₁)
        (hypersequentTensorAlgToRightStageTripleLinearMap R y₂)).symm
    · intro r y hy
      rw [mul_smul_comm, map_smul, hy]
      simpa [map_smul] using
        (hypersequentTripleTensorMul_smul_right R r
          (hypersequentTensorAlgToRightStageTripleLinearMap R
            (tensorBasisMonomial R p))
          (hypersequentTensorAlgToRightStageTripleLinearMap R y)).symm
  · intro x₁ x₂ hx₁ hx₂
    rw [add_mul, map_add, hx₁, hx₂]
    simpa [map_add] using (hypersequentTripleTensorMul_add_left R
      (hypersequentTensorAlgToRightStageTripleLinearMap R x₁)
      (hypersequentTensorAlgToRightStageTripleLinearMap R x₂)
      (hypersequentTensorAlgToRightStageTripleLinearMap R y)).symm
  · intro r x hx
    rw [smul_mul_assoc, map_smul, hx]
    simpa [map_smul] using
      (hypersequentTripleTensorMul_smul_left R r
        (hypersequentTensorAlgToRightStageTripleLinearMap R x)
        (hypersequentTensorAlgToRightStageTripleLinearMap R y)).symm

theorem hypersequentTensorAlgToLeftStageTripleLinearMap_mul
    (x y : HypersequentTensorAlgebra R) :
    hypersequentTensorAlgToLeftStageTripleLinearMap R (x * y) =
      hypersequentTripleTensorMul R
        (hypersequentTensorAlgToLeftStageTripleLinearMap R x)
        (hypersequentTensorAlgToLeftStageTripleLinearMap R y) := by
  classical
  refine AddMonoidAlgebra.induction_on
    (p := fun x =>
      hypersequentTensorAlgToLeftStageTripleLinearMap R (x * y) =
        hypersequentTripleTensorMul R
          (hypersequentTensorAlgToLeftStageTripleLinearMap R x)
          (hypersequentTensorAlgToLeftStageTripleLinearMap R y))
    x ?_ ?_ ?_
  · intro p
    refine AddMonoidAlgebra.induction_on
      (p := fun y =>
        hypersequentTensorAlgToLeftStageTripleLinearMap R
            (tensorBasisMonomial R p * y) =
          hypersequentTripleTensorMul R
            (hypersequentTensorAlgToLeftStageTripleLinearMap R
              (tensorBasisMonomial R p))
            (hypersequentTensorAlgToLeftStageTripleLinearMap R y))
      y ?_ ?_ ?_
    · intro q
      change hypersequentTensorAlgToLeftStageTripleLinearMap R
          (tensorBasisMonomial R p * tensorBasisMonomial R q) =
        hypersequentTripleTensorMul R
          (hypersequentTensorAlgToLeftStageTripleLinearMap R
            (tensorBasisMonomial R p))
          (hypersequentTensorAlgToLeftStageTripleLinearMap R
            (tensorBasisMonomial R q))
      rw [tensorBasisMonomial_mul]
      unfold hypersequentTensorAlgToLeftStageTripleLinearMap
      simp only [LinearMap.comp_apply,
        hypersequentTensorAlgToTensorProductLinearMap_monomial,
        tensorBasisTmul, LinearMap.rTensor_tmul]
      letI :
          NonUnitalNonAssocSemiring
            (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R)) :=
        Algebra.TensorProduct.instNonUnitalNonAssocSemiring
      letI :
          LeftDistribClass
            (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R)) :=
        inferInstance
      letI :
          RightDistribClass
            (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R)) :=
        inferInstance
      letI :
          NonUnitalNonAssocSemiring
            (TensorProduct R
              (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))
              (HypersequentAlgebra R)) :=
        Algebra.TensorProduct.instNonUnitalNonAssocSemiring
      letI :
          NonUnitalNonAssocSemiring
            (TensorProduct R
              (HypersequentAlgebra R)
              (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))) :=
        Algebra.TensorProduct.instNonUnitalNonAssocSemiring
      change
        (Algebra.TensorProduct.assoc R R R
          (HypersequentAlgebra R)
          (HypersequentAlgebra R)
          (HypersequentAlgebra R))
          ((hypersequentCoalgebraComulTensorLinearMap R
              (hseqMonomial R (HypersequentTensorBasis.mul p q).1)) ⊗ₜ[R]
            hseqMonomial R (HypersequentTensorBasis.mul p q).2) =
        hypersequentTripleTensorMul R
          ((Algebra.TensorProduct.assoc R R R
            (HypersequentAlgebra R)
            (HypersequentAlgebra R)
            (HypersequentAlgebra R))
            ((hypersequentCoalgebraComulTensorLinearMap R
                (hseqMonomial R p.1)) ⊗ₜ[R]
              hseqMonomial R p.2))
          ((Algebra.TensorProduct.assoc R R R
            (HypersequentAlgebra R)
            (HypersequentAlgebra R)
            (HypersequentAlgebra R))
            ((hypersequentCoalgebraComulTensorLinearMap R
                (hseqMonomial R q.1)) ⊗ₜ[R]
              hseqMonomial R q.2))
      unfold hypersequentTripleTensorMul
      change
        (Algebra.TensorProduct.assoc R R R
          (HypersequentAlgebra R)
          (HypersequentAlgebra R)
          (HypersequentAlgebra R))
          ((hypersequentCoalgebraComulTensorLinearMap R
              (hseqMonomial R (HypersequentTensorBasis.mul p q).1)) ⊗ₜ[R]
            hseqMonomial R (HypersequentTensorBasis.mul p q).2) =
        ((Algebra.TensorProduct.assoc R R R
          (HypersequentAlgebra R)
          (HypersequentAlgebra R)
          (HypersequentAlgebra R))
          ((hypersequentCoalgebraComulTensorLinearMap R
              (hseqMonomial R p.1)) ⊗ₜ[R]
            hseqMonomial R p.2)) *
        ((Algebra.TensorProduct.assoc R R R
          (HypersequentAlgebra R)
          (HypersequentAlgebra R)
          (HypersequentAlgebra R))
          ((hypersequentCoalgebraComulTensorLinearMap R
              (hseqMonomial R q.1)) ⊗ₜ[R]
            hseqMonomial R q.2))
      calc
        (Algebra.TensorProduct.assoc R R R
          (HypersequentAlgebra R)
          (HypersequentAlgebra R)
          (HypersequentAlgebra R))
          ((hypersequentCoalgebraComulTensorLinearMap R
              (hseqMonomial R (HypersequentTensorBasis.mul p q).1)) ⊗ₜ[R]
            hseqMonomial R (HypersequentTensorBasis.mul p q).2) =
          (Algebra.TensorProduct.assoc R R R
            (HypersequentAlgebra R)
            (HypersequentAlgebra R)
            (HypersequentAlgebra R))
            (((hypersequentCoalgebraComulTensorLinearMap R
                (hseqMonomial R p.1)) ⊗ₜ[R]
              hseqMonomial R p.2) *
            ((hypersequentCoalgebraComulTensorLinearMap R
                (hseqMonomial R q.1)) ⊗ₜ[R]
              hseqMonomial R q.2)) := by
              congr 1
              rw [Algebra.TensorProduct.tmul_mul_tmul]
              rw [← hypersequentCoalgebraComulTensorLinearMap_monomial_mul
                (R := R) p.1 q.1]
              simp [HypersequentTensorBasis.mul, hseqMonomial_mul]
              rfl
        _ =
          ((Algebra.TensorProduct.assoc R R R
            (HypersequentAlgebra R)
            (HypersequentAlgebra R)
            (HypersequentAlgebra R))
            ((hypersequentCoalgebraComulTensorLinearMap R
                (hseqMonomial R p.1)) ⊗ₜ[R]
              hseqMonomial R p.2)) *
          ((Algebra.TensorProduct.assoc R R R
            (HypersequentAlgebra R)
            (HypersequentAlgebra R)
            (HypersequentAlgebra R))
            ((hypersequentCoalgebraComulTensorLinearMap R
                (hseqMonomial R q.1)) ⊗ₜ[R]
              hseqMonomial R q.2)) := by
              exact map_mul
                (Algebra.TensorProduct.assoc R R R
                  (HypersequentAlgebra R)
                  (HypersequentAlgebra R)
                  (HypersequentAlgebra R))
                ((hypersequentCoalgebraComulTensorLinearMap R
                    (hseqMonomial R p.1)) ⊗ₜ[R]
                  hseqMonomial R p.2)
                ((hypersequentCoalgebraComulTensorLinearMap R
                    (hseqMonomial R q.1)) ⊗ₜ[R]
                  hseqMonomial R q.2)
    · intro y₁ y₂ hy₁ hy₂
      rw [mul_add, map_add, hy₁, hy₂]
      simpa [map_add] using (hypersequentTripleTensorMul_add_right R
        (hypersequentTensorAlgToLeftStageTripleLinearMap R
          (tensorBasisMonomial R p))
        (hypersequentTensorAlgToLeftStageTripleLinearMap R y₁)
        (hypersequentTensorAlgToLeftStageTripleLinearMap R y₂)).symm
    · intro r y hy
      rw [mul_smul_comm, map_smul, hy]
      simpa [map_smul] using
        (hypersequentTripleTensorMul_smul_right R r
          (hypersequentTensorAlgToLeftStageTripleLinearMap R
            (tensorBasisMonomial R p))
          (hypersequentTensorAlgToLeftStageTripleLinearMap R y)).symm
  · intro x₁ x₂ hx₁ hx₂
    rw [add_mul, map_add, hx₁, hx₂]
    simpa [map_add] using (hypersequentTripleTensorMul_add_left R
      (hypersequentTensorAlgToLeftStageTripleLinearMap R x₁)
      (hypersequentTensorAlgToLeftStageTripleLinearMap R x₂)
      (hypersequentTensorAlgToLeftStageTripleLinearMap R y)).symm
  · intro r x hx
    rw [smul_mul_assoc, map_smul, hx]
    simpa [map_smul] using
      (hypersequentTripleTensorMul_smul_left R r
        (hypersequentTensorAlgToLeftStageTripleLinearMap R x)
        (hypersequentTensorAlgToLeftStageTripleLinearMap R y)).symm

/--
The actual Mathlib-shaped splitting comultiplication as a linear map.

This is `Δ_split` as an algebra hom into `A ⊗ A`, obtained by composing the
support coproduct with the canonical support-to-tensor comparison map.
-/
def hypersequentComulTensorLinearMap :
    HypersequentAlgebra R →ₗ[R]
      TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R) :=
  (hypersequentTensorAlgToTensorProductLinearMap R).comp
    (hypersequentComulAlgHom R).toLinearMap

@[simp]
theorem hypersequentComulTensorLinearMap_tree (t : PTree) :
    hypersequentComulTensorLinearMap R (treeMonomial R t) =
      (hypersequentTensorAlgToTensorProductLinearMap R)
        (treeSplittingTensorElement R t) := by
  exact congrArg (hypersequentTensorAlgToTensorProductLinearMap R)
    (hypersequentComulAlgHom_tree R t)

/--
The splitting coproduct and counit in exactly the shape required by
Mathlib's `CoalgebraStruct`.

This is not yet a `Coalgebra`: the remaining obligations are coassociativity
and the two counit laws.  The value of this structure is that those obligations
are now expressed against the actual Mathlib tensor product, not our temporary
support-index algebra.
-/
structure HypersequentSplittingCoalgebraData where
  comul :
    HypersequentAlgebra R →ₗ[R]
      TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R) :=
    hypersequentComulTensorLinearMap R
  counit : HypersequentAlgebra R →ₗ[R] R :=
    (hypersequentSplittingCounitAlgHom R).toLinearMap

noncomputable def hypersequentSplittingCoalgebraData :
    HypersequentSplittingCoalgebraData R := {}

@[simp]
theorem hypersequentSplittingCoalgebraData_comul :
    (hypersequentSplittingCoalgebraData R).comul =
      hypersequentComulTensorLinearMap R := rfl

@[simp]
theorem hypersequentSplittingCoalgebraData_counit :
    (hypersequentSplittingCoalgebraData R).counit =
      (hypersequentSplittingCounitAlgHom R).toLinearMap := rfl

/-- Coassociativity obligation for the splitting coproduct. -/
def HypersequentSplittingCoassoc : Prop :=
  (TensorProduct.assoc R
      (HypersequentAlgebra R) (HypersequentAlgebra R) (HypersequentAlgebra R)).toLinearMap ∘ₗ
      LinearMap.rTensor (HypersequentAlgebra R)
        (hypersequentComulTensorLinearMap R) ∘ₗ
        hypersequentComulTensorLinearMap R =
    LinearMap.lTensor (HypersequentAlgebra R)
        (hypersequentComulTensorLinearMap R) ∘ₗ
      hypersequentComulTensorLinearMap R

/-- Right counit obligation for the splitting coproduct. -/
def HypersequentSplittingRightCounit : Prop :=
  LinearMap.rTensor (HypersequentAlgebra R)
      (hypersequentSplittingCounitAlgHom R).toLinearMap ∘ₗ
      hypersequentComulTensorLinearMap R =
    (TensorProduct.mk R R (HypersequentAlgebra R)) 1

/-- Left counit obligation for the splitting coproduct. -/
def HypersequentSplittingLeftCounit : Prop :=
  LinearMap.lTensor (HypersequentAlgebra R)
      (hypersequentSplittingCounitAlgHom R).toLinearMap ∘ₗ
      hypersequentComulTensorLinearMap R =
    ((TensorProduct.mk R (HypersequentAlgebra R) R).flip 1)

/--
The exact remaining coalgebra axioms for the hypersequent splitting route.

The big combinatorial theorem is `coassoc`: two-stage admissible splitting can
be read in either order.  The counit laws should be much smaller once the
identity/root split behavior is pushed through the tensor bridge.
-/
structure HypersequentSplittingCoalgebraAxioms : Prop where
  coassoc : HypersequentSplittingCoassoc R
  rightCounit : HypersequentSplittingRightCounit R
  leftCounit : HypersequentSplittingLeftCounit R

/--
Basis-level form of the splitting coalgebra axioms.

This is the practical proof target: because the hypersequent algebra is free on
hypersequent monomials, each linear-map equation is determined by what it does
to `hseqMonomial R G`.
-/
structure HypersequentSplittingCoalgebraBasisAxioms : Prop where
  coassoc :
    ∀ G : Hypersequent,
      ((TensorProduct.assoc R
          (HypersequentAlgebra R)
          (HypersequentAlgebra R)
          (HypersequentAlgebra R)).toLinearMap ∘ₗ
          LinearMap.rTensor (HypersequentAlgebra R)
            (hypersequentComulTensorLinearMap R) ∘ₗ
            hypersequentComulTensorLinearMap R)
        (hseqMonomial R G) =
      (LinearMap.lTensor (HypersequentAlgebra R)
          (hypersequentComulTensorLinearMap R) ∘ₗ
        hypersequentComulTensorLinearMap R)
        (hseqMonomial R G)
  rightCounit :
    ∀ G : Hypersequent,
      (LinearMap.rTensor (HypersequentAlgebra R)
          (hypersequentSplittingCounitAlgHom R).toLinearMap ∘ₗ
          hypersequentComulTensorLinearMap R)
        (hseqMonomial R G) =
      ((TensorProduct.mk R R (HypersequentAlgebra R)) 1)
        (hseqMonomial R G)
  leftCounit :
    ∀ G : Hypersequent,
      (LinearMap.lTensor (HypersequentAlgebra R)
          (hypersequentSplittingCounitAlgHom R).toLinearMap ∘ₗ
          hypersequentComulTensorLinearMap R)
        (hseqMonomial R G) =
      (((TensorProduct.mk R (HypersequentAlgebra R) R).flip 1))
        (hseqMonomial R G)

theorem hypersequentSplittingCoassoc_of_basis
    (h :
      ∀ G : Hypersequent,
        ((TensorProduct.assoc R
            (HypersequentAlgebra R)
            (HypersequentAlgebra R)
            (HypersequentAlgebra R)).toLinearMap ∘ₗ
            LinearMap.rTensor (HypersequentAlgebra R)
              (hypersequentComulTensorLinearMap R) ∘ₗ
              hypersequentComulTensorLinearMap R)
          (hseqMonomial R G) =
        (LinearMap.lTensor (HypersequentAlgebra R)
            (hypersequentComulTensorLinearMap R) ∘ₗ
          hypersequentComulTensorLinearMap R)
          (hseqMonomial R G)) :
    HypersequentSplittingCoassoc R := by
  unfold HypersequentSplittingCoassoc
  exact hypersequentAlgebra_linearMap_ext R _ _ h

theorem hypersequentSplittingRightCounit_of_basis
    (h :
      ∀ G : Hypersequent,
        (LinearMap.rTensor (HypersequentAlgebra R)
            (hypersequentSplittingCounitAlgHom R).toLinearMap ∘ₗ
            hypersequentComulTensorLinearMap R)
          (hseqMonomial R G) =
        ((TensorProduct.mk R R (HypersequentAlgebra R)) 1)
          (hseqMonomial R G)) :
    HypersequentSplittingRightCounit R := by
  unfold HypersequentSplittingRightCounit
  exact hypersequentAlgebra_linearMap_ext R _ _ h

theorem hypersequentSplittingLeftCounit_of_basis
    (h :
      ∀ G : Hypersequent,
        (LinearMap.lTensor (HypersequentAlgebra R)
            (hypersequentSplittingCounitAlgHom R).toLinearMap ∘ₗ
            hypersequentComulTensorLinearMap R)
          (hseqMonomial R G) =
        (((TensorProduct.mk R (HypersequentAlgebra R) R).flip 1))
          (hseqMonomial R G)) :
    HypersequentSplittingLeftCounit R := by
  unfold HypersequentSplittingLeftCounit
  exact hypersequentAlgebra_linearMap_ext R _ _ h

theorem hypersequentSplittingCoalgebraAxioms_of_basis
    (h : HypersequentSplittingCoalgebraBasisAxioms R) :
    HypersequentSplittingCoalgebraAxioms R where
  coassoc := hypersequentSplittingCoassoc_of_basis R h.coassoc
  rightCounit := hypersequentSplittingRightCounit_of_basis R h.rightCounit
  leftCounit := hypersequentSplittingLeftCounit_of_basis R h.leftCounit

/-!
## Normalized GL/CK coalgebra target

The preceding `HypersequentSplitting*` target uses the proof-theoretic split
map and the leaf-sensitive splitting counit.  The normalized GL/CK coalgebra
target instead uses:

* `hypersequentCoalgebraComulTensorLinearMap`, where empty/root cuts are tensor
  units;
* `hypersequentCounitAlgHom`, the ordinary augmentation of the external forest
  algebra.

This is the package whose counit laws match the usual rooted-tree coalgebra
shape.
-/

/--
Coassociativity obligation for the normalized GL/CK coproduct.

Proof-theoretically, this is the statement that two-stage admissible splitting
is independent of staging: a cut of the remainder obtained after a first cut is
equivalent to an extension of the original cut.  The key point for NMMS is
that admissibility is controlled by the absence of weakening, so the extension
bijection is not merely set-theoretic; it is constrained by the same rigid
interfaces that govern matching-leaf grafting and external splitting.
-/
def HypersequentNormalizedCoalgebraCoassoc : Prop :=
  (TensorProduct.assoc R
      (HypersequentAlgebra R) (HypersequentAlgebra R) (HypersequentAlgebra R)).toLinearMap ∘ₗ
      LinearMap.rTensor (HypersequentAlgebra R)
        (hypersequentCoalgebraComulTensorLinearMap R) ∘ₗ
        hypersequentCoalgebraComulTensorLinearMap R =
    LinearMap.lTensor (HypersequentAlgebra R)
        (hypersequentCoalgebraComulTensorLinearMap R) ∘ₗ
      hypersequentCoalgebraComulTensorLinearMap R

/--
Tree-level form of normalized coassociativity.

This isolates the genuine cut-extension combinatorics on single proof trees.
It is the most honest remaining theorem target: before any global lifting, one
must show that a second admissible cut of the remainder is equivalent to an
extension of the original cut.
-/
def HypersequentNormalizedCoalgebraTreeCoassoc : Prop :=
  ∀ t : PTree,
    ((TensorProduct.assoc R
        (HypersequentAlgebra R)
        (HypersequentAlgebra R)
        (HypersequentAlgebra R)).toLinearMap ∘ₗ
        LinearMap.rTensor (HypersequentAlgebra R)
          (hypersequentCoalgebraComulTensorLinearMap R) ∘ₗ
          hypersequentCoalgebraComulTensorLinearMap R)
      (treeMonomial R t) =
    (LinearMap.lTensor (HypersequentAlgebra R)
        (hypersequentCoalgebraComulTensorLinearMap R) ∘ₗ
      hypersequentCoalgebraComulTensorLinearMap R)
      (treeMonomial R t)

/--
One cut extends another when it contains all of the original cut addresses.

This is the set-theoretic shadow of the coassociativity combinatorics: after a
first admissible cut `C₁`, a second cut of the remainder should correspond to a
global admissible cut extending `C₁`.
-/
def CutExtends (C₁ C₂ : List Address) : Prop :=
  ∀ a : Address, a ∈ C₁ → a ∈ C₂

/--
Reattach a cut of a subtree/remainder under a fixed address prefix.

This is the address-level operation behind all later extension maps: once a
second-stage cut has been chosen in a smaller tree, its addresses must be
placed back into the ambient tree by reattaching the host prefix.
-/
def prefixCutAt (a : Address) (cut : List Address) : List Address :=
  cut.map (fun c => a ++ c)

/--
Extend a first-stage cut by adding a prefixed second-stage cut.

This is the obvious list-level candidate for the coassociativity extension
operation.  The substantive theorem will later specify which prefix is induced
by the first cut and prove admissibility/injectivity for the resulting map.
-/
def extendCutByPrefix
    (C₁ : List Address) (a : Address) (C₂ : List Address) : List Address :=
  C₁ ++ prefixCutAt a C₂

/--
The internal admissible cuts of a tree: exactly the nonempty admissible cuts
that do not contain the root.

This is the finite list on which the eventual cut-extension bijection should
act.  It isolates the genuinely nontrivial part of tree-level coassociativity
after the empty/root boundary contributions are split off.
-/
noncomputable def internalAdmissibleCuts (t : PTree) : List (List Address) :=
  ((PTree.allAdmissibleCuts t).filter (fun cut => !(decide (cut = [])))).filter
    (fun cut => !(decide (([] : Address) ∈ cut)))

/--
Core combinatorial target for normalized coassociativity.

For a fixed first admissible cut `C₁` of `t`, admissible cuts of the remainder
tree `PTree.remainderGo C₁ [] t` should correspond exactly to internal
admissible cuts of `t` extending `C₁`.  This packages the target in a form
that does not commit yet to a particular implementation of the extension map.
-/
def HypersequentAdmissibleCutRemainderExtensionBijection : Prop :=
  ∀ t : PTree, ∀ C₁ : List Address,
    C₁ ∈ PTree.allAdmissibleCuts t →
    ∃ extendCut : List Address → List Address,
      (∀ C₂ : List Address,
          C₂ ∈ PTree.allAdmissibleCuts (PTree.remainderGo C₁ [] t) →
          extendCut C₂ ∈ PTree.allAdmissibleCuts t ∧
            CutExtends C₁ (extendCut C₂) ∧
            InternalCut (extendCut C₂)) ∧
      (∀ D : List Address,
          D ∈ PTree.allAdmissibleCuts t →
          CutExtends C₁ D →
          InternalCut D →
          ∃! C₂ : List Address,
            C₂ ∈ PTree.allAdmissibleCuts (PTree.remainderGo C₁ [] t) ∧
              extendCut C₂ = D)

/--
Reusable data for the cut-extension comparison behind coassociativity.

This is the boundary-inclusive version: it does not require the resulting
ambient cut to be internal, so it is suitable for the empty and root cases as
well as for the eventual internal bijection.
-/
structure AdmissibleCutRemainderExtensionData
    (t : PTree) (C1 : List Address) where
  extendCut : List Address → List Address
  maps_admissible :
    ∀ C2 : List Address,
      C2 ∈ PTree.allAdmissibleCuts (PTree.remainderGo C1 [] t) →
        extendCut C2 ∈ PTree.allAdmissibleCuts t
  extends_first :
    ∀ C2 : List Address,
      C2 ∈ PTree.allAdmissibleCuts (PTree.remainderGo C1 [] t) →
        CutExtends C1 (extendCut C2)
  complete_unique :
    ∀ D : List Address,
      D ∈ PTree.allAdmissibleCuts t →
      CutExtends C1 D →
        ∃! C2 : List Address,
          C2 ∈ PTree.allAdmissibleCuts (PTree.remainderGo C1 [] t) ∧
            extendCut C2 = D

/--
Internal-cut version of the extension data.

This is the shape needed by the nontrivial coassociativity sector after the
empty/root branches have been separated.
-/
structure InternalAdmissibleCutRemainderExtensionData
    (t : PTree) (C1 : List Address) where
  extendCut : List Address → List Address
  maps_internal :
    ∀ C2 : List Address,
      C2 ∈ internalCoalgebraAdmissibleCuts (PTree.remainderGo C1 [] t) →
        extendCut C2 ∈ internalCoalgebraAdmissibleCuts t ∧
          CutExtends C1 (extendCut C2)
  complete_unique :
    ∀ D : List Address,
      D ∈ internalCoalgebraAdmissibleCuts t →
      CutExtends C1 D →
        ∃! C2 : List Address,
          C2 ∈ internalCoalgebraAdmissibleCuts (PTree.remainderGo C1 [] t) ∧
            extendCut C2 = D

/--
Coalgebra-cut version of the remainder-extension data.

The raw admissible-cut formulation is useful for connecting to the recursive
tree definitions, but normalized coassociativity is phrased over
`coalgebraAdmissibleCuts`, where proper leaf-cut noise has already been
removed.  This is therefore the filtered version of the same bijection target.
-/
structure CoalgebraCutRemainderExtensionData
    (t : PTree) (C1 : List Address) where
  extendCut : List Address → List Address
  maps_coalgebra :
    ∀ C2 : List Address,
      C2 ∈ coalgebraAdmissibleCuts (PTree.remainderGo C1 [] t) →
        extendCut C2 ∈ coalgebraAdmissibleCuts t ∧
          CutExtends C1 (extendCut C2)
  complete_unique :
    ∀ D : List Address,
      D ∈ coalgebraAdmissibleCuts t →
      CutExtends C1 D →
        ∃! C2 : List Address,
          C2 ∈ coalgebraAdmissibleCuts (PTree.remainderGo C1 [] t) ∧
            extendCut C2 = D

/--
Internal-sector refinement of `CoalgebraCutRemainderExtensionData`.

For coassociativity the boundary pieces are handled separately.  The remaining
sector must preserve and reflect internality, so that the filtered bijection
restricts to the non-boundary lists appearing in the internal/internal support
comparison.
-/
structure CoalgebraCutInternalExtensionData
    (t : PTree) (C1 : List Address) extends
      CoalgebraCutRemainderExtensionData t C1 where
  maps_internal :
    ∀ C2 : List Address,
      C2 ∈ internalCoalgebraAdmissibleCuts (PTree.remainderGo C1 [] t) →
        extendCut C2 ∈ internalCoalgebraAdmissibleCuts t ∧
          CutExtends C1 (extendCut C2)
  reflects_internal :
    ∀ C2 : List Address,
      C2 ∈ coalgebraAdmissibleCuts (PTree.remainderGo C1 [] t) →
      InternalCut (extendCut C2) →
        InternalCut C2

/--
Node-local filtered extension target.

This is the exact shape expected from the proof-theoretic extension bijection:
for every internal first cut of a rule node, second-stage coalgebra cuts of the
remainder are in bijection with filtered ambient extensions.
-/
def HypersequentNormalizedNodeCoalgebraExtensionData : Prop :=
  ∀ r : RuleTag, ∀ s : MultiSequent, ∀ cs : List PTree,
    ∀ C1 : List Address,
      C1 ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs) →
        Nonempty (CoalgebraCutInternalExtensionData (PTree.node r s cs) C1)

/--
For the empty first cut, the remainder is the original tree and the extension
map is just the identity.
-/
def emptyFirstCutRemainderExtensionData
    (t : PTree) :
    AdmissibleCutRemainderExtensionData t [] where
  extendCut := id
  maps_admissible := by
    intro C2 hC2
    simpa [PTree.remainderGo_nil] using hC2
  extends_first := by
    intro C2 _hC2
    intro a ha
    cases ha
  complete_unique := by
    intro D hD _hExt
    refine ⟨D, ?_, ?_⟩
    · exact ⟨by simpa [PTree.remainderGo_nil] using hD, rfl⟩
    · intro C2 hC2
      exact hC2.2

/--
The same identity extension controls the internal sector above the empty first
cut.  This packages the boundary normalization used by the later support
comparison.
-/
def emptyFirstCutInternalRemainderExtensionData
    (t : PTree) :
    InternalAdmissibleCutRemainderExtensionData t [] where
  extendCut := id
  maps_internal := by
    intro C2 hC2
    exact ⟨by simpa [PTree.remainderGo_nil] using hC2, by
      intro a ha
      cases ha⟩
  complete_unique := by
    intro D hD _hExt
    refine ⟨D, ?_, ?_⟩
    · exact ⟨by simpa [PTree.remainderGo_nil] using hD, rfl⟩
    · intro C2 hC2
      exact hC2.2

/--
The identity extension also gives filtered coalgebra extension data above the
empty first cut.
-/
def emptyFirstCoalgebraCutRemainderExtensionData
    (t : PTree) :
    CoalgebraCutRemainderExtensionData t [] where
  extendCut := id
  maps_coalgebra := by
    intro C2 hC2
    exact ⟨by simpa [PTree.remainderGo_nil] using hC2, by
      intro a ha
      cases ha⟩
  complete_unique := by
    intro D hD _hExt
    refine ⟨D, ?_, ?_⟩
    · exact ⟨by simpa [PTree.remainderGo_nil] using hD, rfl⟩
    · intro C2 hC2
      exact hC2.2

/--
The identity extension restricts to the filtered internal sector above the
empty first cut.
-/
def emptyFirstCoalgebraCutInternalExtensionData
    (t : PTree) :
    CoalgebraCutInternalExtensionData t [] where
  extendCut := id
  maps_coalgebra := by
    intro C2 hC2
    exact ⟨by simpa [PTree.remainderGo_nil] using hC2, by
      intro a ha
      cases ha⟩
  complete_unique := by
    intro D hD _hExt
    refine ⟨D, ?_, ?_⟩
    · exact ⟨by simpa [PTree.remainderGo_nil] using hD, rfl⟩
    · intro C2 hC2
      exact hC2.2
  maps_internal := by
    intro C2 hC2
    exact ⟨by simpa [PTree.remainderGo_nil] using hC2, by
      intro a ha
      cases ha⟩
  reflects_internal := by
    intro C2 _hC2 hInt
    exact hInt

@[simp]
theorem cutExtends_refl (cut : List Address) :
    CutExtends cut cut := by
  intro a ha
  exact ha

theorem cutExtends_trans
    {C1 C2 C3 : List Address}
    (h12 : CutExtends C1 C2)
    (h23 : CutExtends C2 C3) :
    CutExtends C1 C3 := by
  intro a ha
  exact h23 a (h12 a ha)

theorem cutExtends_append_left
    (C1 C2 : List Address) :
    CutExtends C1 (C1 ++ C2) := by
  intro a ha
  exact List.mem_append.2 (Or.inl ha)

theorem cutExtends_append_right
    (C1 C2 : List Address) :
    CutExtends C2 (C1 ++ C2) := by
  intro a ha
  exact List.mem_append.2 (Or.inr ha)

theorem cutExtends_of_subset_append
    {C1 C2 D : List Address}
    (h : CutExtends C1 D) :
    CutExtends C1 (D ++ C2) := by
  exact cutExtends_trans h (cutExtends_append_left D C2)

theorem cutExtends_of_mem_singleton
    {a : Address} {C : List Address}
    (ha : a ∈ C) :
    CutExtends [a] C := by
  intro b hb
  have hba : b = a := by
    simpa using hb
  subst b
  exact ha

theorem cutExtends_right_stageAmbientCut
    (cut₁ cut₂ : List Address) :
    CutExtends cut₂ (stageAmbientCut cut₁ cut₂) := by
  intro a ha
  exact mem_stageAmbientCut_right (cut₁ := cut₁) (cut₂ := cut₂) ha

theorem cutExtends_stageAmbientCut_of_no_domination
    {cut₁ cut₂ : List Address}
    (hnd :
      ∀ a : Address, a ∈ cut₁ →
        ∀ b : Address, b ∈ cut₂ → ¬ PTree.isAncestorOf b a) :
    CutExtends cut₁ (stageAmbientCut cut₁ cut₂) := by
  intro a ha
  exact mem_stageAmbientCut_left_of_not_dominated
    (cut₁ := cut₁) (cut₂ := cut₂) ha (hnd a ha)

theorem cutExtends_stageAmbientCut_iff_no_domination
    {cut₁ cut₂ : List Address}
    (hdisj : ∀ a : Address, a ∈ cut₁ → a ∉ cut₂)
    (hanti :
      ∀ a : Address, a ∈ cut₁ →
        ∀ b : Address, b ∈ cut₂ →
          a ≠ b → ¬ PTree.comparable a b) :
    CutExtends cut₁ (stageAmbientCut cut₁ cut₂) ↔
      ∀ a : Address, a ∈ cut₁ →
        ∀ b : Address, b ∈ cut₂ → ¬ PTree.isAncestorOf b a := by
  constructor
  · intro hext a ha b hb hba
    have hastage := hext a ha
    rcases (mem_stageAmbientCut_iff
      (cut₁ := cut₁) (cut₂ := cut₂) (a := a)).1 hastage with
      hleft | hright
    · exact hleft.2 b hb hba
    · by_cases hab : a = b
      · subst b
        exact hdisj a ha hb
      · exact hanti a ha b hb hab (Or.inr hba)
  · exact cutExtends_stageAmbientCut_of_no_domination

theorem mem_prefixCutAt_iff
    {a b : Address} {cut : List Address} :
    b ∈ prefixCutAt a cut ↔ ∃ c ∈ cut, b = a ++ c := by
  unfold prefixCutAt
  constructor
  · intro hb
    rcases List.mem_map.1 hb with ⟨c, hc, hbc⟩
    exact ⟨c, hc, hbc.symm⟩
  · rintro ⟨c, hc, rfl⟩
    exact List.mem_map.2 ⟨c, hc, rfl⟩

theorem mem_extendCutByPrefix_left
    {C₁ C₂ : List Address} {a b : Address}
    (hb : b ∈ C₁) :
    b ∈ extendCutByPrefix C₁ a C₂ := by
  exact List.mem_append.2 <| Or.inl hb

theorem cutExtends_extendCutByPrefix
    (C₁ C₂ : List Address) (a : Address) :
    CutExtends C₁ (extendCutByPrefix C₁ a C₂) := by
  intro b hb
  exact mem_extendCutByPrefix_left hb

theorem mem_extendCutByPrefix_right_iff
    {C₁ C₂ : List Address} {a b : Address} :
    b ∈ extendCutByPrefix C₁ a C₂ ↔
      Or (b ∈ C₁) (Exists fun c => And (c ∈ C₂) (b = a ++ c)) := by
  unfold extendCutByPrefix
  rw [List.mem_append, mem_prefixCutAt_iff]

@[simp]
theorem prefixCutAt_nil
    (a : Address) :
    prefixCutAt a [] = [] := by
  simp [prefixCutAt]

@[simp]
theorem extendCutByPrefix_nil_right
    (C₁ : List Address) (a : Address) :
    extendCutByPrefix C₁ a [] = C₁ := by
  simp [extendCutByPrefix]

theorem prefixCutAt_nonempty_of_nonempty
    {a : Address} {cut : List Address}
    (hcut : cut ≠ []) :
    prefixCutAt a cut ≠ [] := by
  cases cut with
  | nil =>
      exact False.elim (hcut rfl)
  | cons c cs =>
      simp [prefixCutAt]

@[simp]
theorem root_mem_prefixCutAt_iff
    {a : Address} {cut : List Address} :
    ([] : Address) ∈ prefixCutAt a cut ↔ a = [] ∧ ([] : Address) ∈ cut := by
  constructor
  · intro hroot
    rcases (mem_prefixCutAt_iff (a := a) (b := []) (cut := cut)).1 hroot with
      ⟨c, hc, hnil⟩
    have ha : a = [] := by
      cases a with
      | nil =>
          rfl
      | cons i as =>
          simp at hnil
    subst a
    simp at hnil
    subst c
    exact ⟨rfl, hc⟩
  · rintro ⟨rfl, hcut⟩
    exact (mem_prefixCutAt_iff (a := []) (b := []) (cut := cut)).2 ⟨[], hcut, by simp⟩

theorem root_mem_extendCutByPrefix_iff
    {C₁ C₂ : List Address} {a : Address} :
    ([] : Address) ∈ extendCutByPrefix C₁ a C₂ ↔
      Or (([] : Address) ∈ C₁) (And (a = []) (([] : Address) ∈ C₂)) := by
  rw [mem_extendCutByPrefix_right_iff]
  constructor
  · intro h
    rcases h with hleft | ⟨c, hc, hroot⟩
    · exact Or.inl hleft
    · have ha : a = [] := by
        cases a with
        | nil =>
            rfl
        | cons i as =>
            simp at hroot
      subst a
      simp at hroot
      subst c
      exact Or.inr ⟨rfl, hc⟩
  · intro h
    rcases h with hleft | ⟨ha, hright⟩
    · exact Or.inl hleft
    · subst a
      exact Or.inr ⟨[], hright, by simp⟩

theorem internalCut_extendCutByPrefix_of_internal
    {C₁ C₂ : List Address} {a : Address}
    (hC₁ : ([] : Address) ∉ C₁)
    (ha : a ≠ [])
    (hC₂ : C₂ ≠ []) :
    InternalCut (extendCutByPrefix C₁ a C₂) := by
  refine And.intro ?_ ?_
  · intro hnil
    have hprefix : prefixCutAt a C₂ = [] := by
      cases C₁ with
      | nil =>
          simpa [extendCutByPrefix] using hnil
      | cons d ds =>
          simp [extendCutByPrefix] at hnil
    exact prefixCutAt_nonempty_of_nonempty hC₂ hprefix
  · intro hroot
    rcases (root_mem_extendCutByPrefix_iff (C₁ := C₁) (C₂ := C₂) (a := a)).1 hroot with
      hleft | ⟨ha0, _⟩
    · exact hC₁ hleft
    · exact ha ha0

theorem internalCut_ne_nil
    {cut : List Address}
    (hcut : InternalCut cut) :
    cut ≠ [] :=
  hcut.1

theorem internalCut_root_not_mem
    {cut : List Address}
    (hcut : InternalCut cut) :
    ([] : Address) ∉ cut :=
  hcut.2

theorem mem_internalAdmissibleCuts_iff
    {t : PTree} {cut : List Address} :
    cut ∈ internalAdmissibleCuts t ↔
      cut ∈ PTree.allAdmissibleCuts t ∧ InternalCut cut := by
  unfold internalAdmissibleCuts InternalCut
  simpa [and_assoc, and_left_comm, and_comm]

theorem coalgebraRightStageTripleBranch_of_internalCut
    {t : PTree} {cut₁ : List Address}
    (hcut : InternalCut cut₁) :
    coalgebraRightStageTripleBranch t cut₁ =
      (coalgebraAdmissibleCuts (PTree.remainderGo cut₁ [] t)).map
        (fun cut₂ => coalgebraRightStageTripleOfCuts t cut₁ cut₂) := by
  exact coalgebraRightStageTripleBranch_of_ne_nil_of_root_not_mem
    (internalCut_ne_nil hcut) (internalCut_root_not_mem hcut)

theorem coalgebraLeftStageTripleBranch_of_internalCut
    {t : PTree} {cut : List Address}
    (hcut : InternalCut cut) :
    coalgebraLeftStageTripleBranch t cut =
      (coalgebraForestSplittingTensorSupport (cut.filterMap (PTree.subtreeAt t))).map
        (fun p => (p.1, p.2, HQ.singleton (PTree.remainderGo cut [] t))) := by
  exact coalgebraLeftStageTripleBranch_of_ne_nil_of_root_not_mem
    (internalCut_ne_nil hcut) (internalCut_root_not_mem hcut)

@[simp]
theorem coalgebraRightStageTripleBranch_root_sum
    (t : PTree) :
    ((coalgebraRightStageTripleBranch t [([] : Address)]).map
      (hypersequentTripleBasisTmul (R := R))).sum =
    treeMonomial R t ⊗ₜ[R] (1 ⊗ₜ[R] (1 : HypersequentAlgebra R)) := by
  simp [coalgebraRightStageTripleBranch_root, hypersequentTripleBasisTmul_root_unit]

@[simp]
theorem coalgebraLeftStageTripleBranch_empty_sum
    (t : PTree) :
    ((coalgebraLeftStageTripleBranch t []).map
      (hypersequentTripleBasisTmul (R := R))).sum =
    1 ⊗ₜ[R] (1 ⊗ₜ[R] treeMonomial R t) := by
  simp [coalgebraLeftStageTripleBranch_empty, hypersequentTripleBasisTmul_empty_empty_tree]

theorem coalgebraRightStageTripleBranch_empty_sum
    (t : PTree) :
    ((coalgebraRightStageTripleBranch t []).map
      (hypersequentTripleBasisTmul (R := R))).sum =
    ((coalgebraTreeSplittingTensorSupport t).map
      (fun p => hypersequentTripleBasisTmul R (0, p.1, p.2))).sum := by
  simp [coalgebraRightStageTripleBranch_empty, coalgebraTreeSplittingTensorSupport,
    coalgebraRightStageTripleOfCuts_empty_first, hypersequentTripleBasisTmul,
    hseqMonomial_zero, Function.comp_def]

theorem coalgebraLeftStageTripleBranch_root_sum
    (t : PTree) :
    ((coalgebraLeftStageTripleBranch t [([] : Address)]).map
      (hypersequentTripleBasisTmul (R := R))).sum =
    ((coalgebraTreeSplittingTensorSupport t).map
      (fun p => hypersequentTripleBasisTmul R (p.1, p.2, (0 : Hypersequent)))).sum := by
  simp [coalgebraLeftStageTripleBranch_root, coalgebraTreeSplittingTensorSupport,
    hypersequentTripleBasisTmul, hseqMonomial_zero, Function.comp_def]

theorem coalgebraRightStageTripleElement_eq_empty_root_internal
    (t : PTree) :
    coalgebraRightStageTripleElement R t =
      (((coalgebraRightStageTripleBranch t []).map
          (hypersequentTripleBasisTmul (R := R))).sum +
        (((coalgebraRightStageTripleBranch t [([] : Address)]).map
            (hypersequentTripleBasisTmul (R := R))).sum +
          ((internalCoalgebraAdmissibleCuts t).map
            (fun cut =>
              ((coalgebraRightStageTripleBranch t cut).map
                (hypersequentTripleBasisTmul (R := R))).sum)).sum)) := by
  let g : List Address → HypersequentTripleTensor R :=
    fun cut =>
      ((coalgebraRightStageTripleBranch t cut).map
        (hypersequentTripleBasisTmul (R := R))).sum
  unfold coalgebraRightStageTripleElement coalgebraRightStageTripleSupport
  rw [← List.sum_map_sum_eq_sum_flatMap
      (xs := coalgebraAdmissibleCuts t)
      (f := coalgebraRightStageTripleBranch t)
      (g := hypersequentTripleBasisTmul (R := R))]
  rw [List.sum_map_eq_filter_add_filter_not
      (xs := coalgebraAdmissibleCuts t)
      (p := fun cut => decide (cut = []))
      (f := g)]
  rw [filter_eq_emptyCut_coalgebraAdmissibleCuts]
  simp only [List.map_singleton, List.sum_singleton]
  rw [List.sum_map_eq_filter_add_filter_not
      (xs := (coalgebraAdmissibleCuts t).filter (fun cut => !(decide (cut = []))))
      (p := fun cut => decide (([] : Address) ∈ cut))
      (f := g)]
  have hrootFilter :
      ((coalgebraAdmissibleCuts t).filter (fun cut => !(decide (cut = [])))).filter
        (fun cut => decide (([] : Address) ∈ cut)) =
      [[([] : Address)]] := by
    calc
      ((coalgebraAdmissibleCuts t).filter (fun cut => !(decide (cut = [])))).filter
          (fun cut => decide (([] : Address) ∈ cut)) =
        (coalgebraAdmissibleCuts t).filter
          (fun cut => !(decide (cut = [])) && decide (([] : Address) ∈ cut)) := by
            rw [List.filter_filter]
            simp [Bool.and_comm]
      _ =
        (coalgebraAdmissibleCuts t).filter
          (fun cut => decide (([] : Address) ∈ cut)) := by
            apply List.filter_congr
            intro cut hcut
            by_cases hroot : ([] : Address) ∈ cut
            · have hneq : cut ≠ [] := by
                intro hnil
                subst cut
                simpa using hroot
              simp [hroot, hneq]
            · simp [hroot]
      _ = [[([] : Address)]] := by
            rw [filter_eq_rootContainingCut_coalgebraAdmissibleCuts]
  rw [hrootFilter]
  simp only [List.map_singleton, List.sum_singleton]
  have hinternal :
      ((coalgebraAdmissibleCuts t).filter (fun cut => !(decide (cut = [])))).filter
        (fun cut => !decide (([] : Address) ∈ cut)) =
      internalCoalgebraAdmissibleCuts t := by
    rfl
  rw [hinternal]

theorem coalgebraLeftStageTripleElement_eq_empty_root_internal
    (t : PTree) :
    coalgebraLeftStageTripleElement R t =
      (((coalgebraLeftStageTripleBranch t []).map
          (hypersequentTripleBasisTmul (R := R))).sum +
        (((coalgebraLeftStageTripleBranch t [([] : Address)]).map
            (hypersequentTripleBasisTmul (R := R))).sum +
          ((internalCoalgebraAdmissibleCuts t).map
            (fun cut =>
              ((coalgebraLeftStageTripleBranch t cut).map
                (hypersequentTripleBasisTmul (R := R))).sum)).sum)) := by
  let g : List Address → HypersequentTripleTensor R :=
    fun cut =>
      ((coalgebraLeftStageTripleBranch t cut).map
        (hypersequentTripleBasisTmul (R := R))).sum
  unfold coalgebraLeftStageTripleElement coalgebraLeftStageTripleSupport
  rw [← List.sum_map_sum_eq_sum_flatMap
      (xs := coalgebraAdmissibleCuts t)
      (f := coalgebraLeftStageTripleBranch t)
      (g := hypersequentTripleBasisTmul (R := R))]
  rw [List.sum_map_eq_filter_add_filter_not
      (xs := coalgebraAdmissibleCuts t)
      (p := fun cut => decide (cut = []))
      (f := g)]
  rw [filter_eq_emptyCut_coalgebraAdmissibleCuts]
  simp only [List.map_singleton, List.sum_singleton]
  rw [List.sum_map_eq_filter_add_filter_not
      (xs := (coalgebraAdmissibleCuts t).filter (fun cut => !(decide (cut = []))))
      (p := fun cut => decide (([] : Address) ∈ cut))
      (f := g)]
  have hrootFilter :
      ((coalgebraAdmissibleCuts t).filter (fun cut => !(decide (cut = [])))).filter
        (fun cut => decide (([] : Address) ∈ cut)) =
      [[([] : Address)]] := by
    calc
      ((coalgebraAdmissibleCuts t).filter (fun cut => !(decide (cut = [])))).filter
          (fun cut => decide (([] : Address) ∈ cut)) =
        (coalgebraAdmissibleCuts t).filter
          (fun cut => !(decide (cut = [])) && decide (([] : Address) ∈ cut)) := by
            rw [List.filter_filter]
            simp [Bool.and_comm]
      _ =
        (coalgebraAdmissibleCuts t).filter
          (fun cut => decide (([] : Address) ∈ cut)) := by
            apply List.filter_congr
            intro cut _hcut
            by_cases hroot : ([] : Address) ∈ cut
            · have hneq : cut ≠ [] := by
                intro hnil
                subst cut
                simpa using hroot
              simp [hroot, hneq]
            · simp [hroot]
      _ = [[([] : Address)]] := by
            rw [filter_eq_rootContainingCut_coalgebraAdmissibleCuts]
  rw [hrootFilter]
  simp only [List.map_singleton, List.sum_singleton]
  have hinternal :
      ((coalgebraAdmissibleCuts t).filter (fun cut => !(decide (cut = [])))).filter
        (fun cut => !decide (([] : Address) ∈ cut)) =
      internalCoalgebraAdmissibleCuts t := by
    rfl
  rw [hinternal]

/--
For a primitive leaf, the noise-filtered coalgebra cuts are exactly the empty
cut and the root cut.
-/
@[simp]
theorem coalgebraAdmissibleCuts_leaf
    (s : MultiSequent) :
    coalgebraAdmissibleCuts (PTree.leaf s) =
      ([] : List Address) :: [([([] : Address)] : List Address)] := by
  have hraw :
      PTree.allAdmissibleCuts (PTree.leaf s) =
        ([] : List Address) :: [([([] : Address)] : List Address)] := by
    simp [PTree.allAdmissibleCuts, PTree.sublists, PTree.allAddresses,
      PTree.allAddressesGo, PTree.size, PTree.validAddress, PTree.subtreeAt,
      PTree.isAntichainBool]
  unfold coalgebraAdmissibleCuts
  rw [hraw]
  have hEmpty : IsCoalgebraCut (PTree.leaf s) ([] : List Address) := Or.inl rfl
  have hRoot : IsCoalgebraCut (PTree.leaf s) ([([] : Address)] : List Address) :=
    Or.inr (Or.inl (List.mem_singleton_self ([] : Address)))
  simp [hEmpty, hRoot]

/-- Primitive leaves have no non-boundary coalgebra cuts. -/
@[simp]
theorem internalCoalgebraAdmissibleCuts_leaf
    (s : MultiSequent) :
    internalCoalgebraAdmissibleCuts (PTree.leaf s) = [] := by
  simp [internalCoalgebraAdmissibleCuts]

theorem normalizedCoalgebraStableQuotientComulOnTree_leaf
    (s : MultiSequent) :
    normalizedCoalgebraStableQuotientComulOnTree (PTree.leaf s) =
      (0 : PreLieDifferenceStableQuotient) ⊗ₜ[ℤ]
          mkPreLieDifferenceStableQuotient (treeGen (PTree.leaf s)) +
        mkPreLieDifferenceStableQuotient (treeGen (PTree.leaf s)) ⊗ₜ[ℤ]
          (0 : PreLieDifferenceStableQuotient) := by
  rw [normalizedCoalgebraStableQuotientComulOnTree_eq_boundary_internal]
  simp [normalizedCoalgebraStableQuotientInternalComulOnTree]

/-- Every proper internal admissible cut of a leaf is exactly leaf-cut noise. -/
theorem leaf_internalCut_is_noise
    {s : MultiSequent} {cut : List Address}
    (hcut : cut ∈ PTree.allAdmissibleCuts (PTree.leaf s))
    (hinternal : InternalCut cut) :
    LeafCutNoise (PTree.leaf s) cut := by
  refine ⟨hinternal, ?_⟩
  cases cut with
  | nil =>
      exact False.elim (hinternal.1 rfl)
  | cons a rest =>
    have ha : a ∈ a :: rest := by simp
    let C : PTree.IsAdmissibleCut (PTree.leaf s) :=
      PTree.isAdmissibleCut_of_mem_allAdmissibleCuts hcut
    have hvalid : PTree.ValidAddress (PTree.leaf s) a := C.valid a ha
    have hroot : a = [] := by
      cases a with
      | nil =>
          rfl
      | cons i is =>
          simp [PTree.ValidAddress, PTree.validAddress, PTree.subtreeAt] at hvalid
    refine ⟨a, ha, s, ?_⟩
    subst a
    simp [PTree.subtreeAt]

/--
Leaf/base case for the normalized coassociativity support theorem.

This is the first non-placeholder coassociativity calculation after removing
proper leaf-cut noise: the leaf has the primitive coproduct
`1 ⊗ leaf + leaf ⊗ 1`, and the two staged expansions coincide.
-/
theorem coalgebraCoassoc_leaf_support
    (s : MultiSequent) :
    coalgebraRightStageTripleElement R (PTree.leaf s) =
      coalgebraLeftStageTripleElement R (PTree.leaf s) := by
  simp [coalgebraRightStageTripleElement, coalgebraRightStageTripleSupport,
    coalgebraRightStageTripleBranch, coalgebraRightStageTripleOfCuts,
    coalgebraLeftStageTripleElement, coalgebraLeftStageTripleSupport,
    coalgebraLeftStageTripleBranch, coalgebraDetachedForestOfCut,
    coalgebraRemainderOfCut, coalgebraTensorTermOfCutList,
    coalgebraTreeSplittingTensorSupport, coalgebraAdmissibleCuts_leaf,
    coalgebraForestSplittingTensorSupport, tensorSupportMul,
    HypersequentTensorBasis.mul, HypersequentTensorBasis.one,
    hypersequentTripleBasisTmul,
    hseqMonomial_singleton_eq_treeMonomial]

theorem coalgebraCoassoc_leaf_support_perm
    (s : MultiSequent) :
    List.Perm
      (coalgebraRightStageTripleSupport (PTree.leaf s))
      (coalgebraLeftStageTripleSupport (PTree.leaf s)) := by
  simp [coalgebraRightStageTripleSupport, coalgebraRightStageTripleBranch,
    coalgebraRightStageTripleOfCuts, coalgebraLeftStageTripleSupport,
    coalgebraLeftStageTripleBranch, coalgebraDetachedForestOfCut,
    coalgebraRemainderOfCut, coalgebraTensorTermOfCutList,
    coalgebraTreeSplittingTensorSupport, coalgebraAdmissibleCuts_leaf,
    coalgebraForestSplittingTensorSupport, tensorSupportMul,
    HypersequentTensorBasis.mul, HypersequentTensorBasis.one]

/--
Node-local support coassociativity.

After the leaf/base case is discharged, this is the genuine remaining
cut-extension theorem: a two-stage cut of a rule node must be reorganized as a
first split of the detached forest, and conversely.
-/
def HypersequentNormalizedCoalgebraNodeCoassocSupport : Prop :=
  ∀ r : RuleTag, ∀ s : MultiSequent, ∀ cs : List PTree,
    coalgebraRightStageTripleElement R (PTree.node r s cs) =
      coalgebraLeftStageTripleElement R (PTree.node r s cs)

/-- Node-local coassociativity implies tree-level support coassociativity. -/
theorem coalgebraCoassoc_tree_support_of_node
    (hnode : HypersequentNormalizedCoalgebraNodeCoassocSupport R)
    (t : PTree) :
    coalgebraRightStageTripleElement R t =
      coalgebraLeftStageTripleElement R t := by
  cases t with
  | leaf s =>
      exact coalgebraCoassoc_leaf_support (R := R) s
  | node r s cs =>
      exact hnode r s cs

/--
Decomposition-based tree support equality for normalized coassociativity.

The forest boundary/proper-sector permutation is now proved.  Thus this
tree-level equality is reduced to the single internal/internal support
permutation `coalgebraInternalInternalExtensionPerm`.
-/
theorem coalgebraCoassoc_tree_support
    (t : PTree) :
    coalgebraRightStageTripleElement R t =
      coalgebraLeftStageTripleElement R t := by
  exact coalgebraCoassoc_tree_support_of_internal_extension
    (R := R)
    hypersequentNormalizedForestBoundaryProperPerm
    coalgebraInternalInternalExtensionPerm
    t

theorem coalgebraCoassoc_tree_support_perm
    (t : PTree) :
    List.Perm
      (coalgebraRightStageTripleSupport t)
      (coalgebraLeftStageTripleSupport t) := by
  exact coalgebraCoassoc_tree_support_perm_of_internal_extension
    hypersequentNormalizedForestBoundaryProperPerm
    coalgebraInternalInternalExtensionPerm
    t

@[simp]
theorem not_internalCut_empty :
    ¬ InternalCut ([] : List Address) := by
  simp [InternalCut]

@[simp]
theorem not_internalCut_root :
    ¬ InternalCut [([] : Address)] := by
  simp [InternalCut]

/--
Explicit support-sum form of tree-level normalized coassociativity.

At this point all tensor-algebra plumbing has been discharged: the remaining
content is exactly that the nested-cut expansion and the detached-forest-first
expansion enumerate the same triple tensor sum.
-/
def HypersequentNormalizedCoalgebraTreeCoassocSupport : Prop :=
  ∀ t : PTree,
    coalgebraRightStageTripleElement R t =
      coalgebraLeftStageTripleElement R t

/--
Permutation-strengthened support form of normalized coassociativity.

Because the explicit staged expansions are finite sums of triple tensor basis
atoms, a permutation of the support lists is stronger than the tensor equality
and is the cleanest target for the cut-extension bijection.
-/
def HypersequentNormalizedCoalgebraTreeCoassocSupportPerm : Prop :=
  ∀ t : PTree,
    List.Perm
      (coalgebraRightStageTripleSupport t)
      (coalgebraLeftStageTripleSupport t)

theorem hypersequentNormalizedCoalgebraTreeCoassocSupportPerm_of_decomposition :
    HypersequentNormalizedCoalgebraTreeCoassocSupportPerm := by
  intro t
  exact coalgebraCoassoc_tree_support_perm t

theorem hypersequentNormalizedCoalgebraTreeCoassocSupport_of_perm
    (h : HypersequentNormalizedCoalgebraTreeCoassocSupportPerm) :
    HypersequentNormalizedCoalgebraTreeCoassocSupport R := by
  intro t
  unfold coalgebraRightStageTripleElement coalgebraLeftStageTripleElement
  exact List.sum_map_eq_of_perm
    (h t) (hypersequentTripleBasisTmul (R := R))

/-- Node-local permutation target for the normalized support bijection. -/
def HypersequentNormalizedCoalgebraNodeCoassocSupportPerm : Prop :=
  ∀ r : RuleTag, ∀ s : MultiSequent, ∀ cs : List PTree,
    List.Perm
      (coalgebraRightStageTripleSupport (PTree.node r s cs))
      (coalgebraLeftStageTripleSupport (PTree.node r s cs))

/--
Filtered extension data plus the support-level interpretation theorem is enough
to close the node-local permutation target.

The second field is intentionally stated as the support permutation, not as raw
list equality: the coproduct support is list-valued and may enumerate the same
finite family in a different order on the two staged sides.
-/
structure HypersequentNormalizedNodeExtensionEndgame : Prop where
  extension_data : HypersequentNormalizedNodeCoalgebraExtensionData
  support_perm : HypersequentNormalizedCoalgebraNodeCoassocSupportPerm

theorem HypersequentNormalizedNodeExtensionEndgame.node_perm
    (h : HypersequentNormalizedNodeExtensionEndgame) :
    HypersequentNormalizedCoalgebraNodeCoassocSupportPerm :=
  h.support_perm

theorem hypersequentNormalizedCoalgebraTreeCoassocSupportPerm_of_node
    (hleaf :
      ∀ s : MultiSequent,
        List.Perm
          (coalgebraRightStageTripleSupport (PTree.leaf s))
          (coalgebraLeftStageTripleSupport (PTree.leaf s)))
    (hnode : HypersequentNormalizedCoalgebraNodeCoassocSupportPerm) :
    HypersequentNormalizedCoalgebraTreeCoassocSupportPerm := by
  intro t
  cases t with
  | leaf s =>
      exact hleaf s
  | node r s cs =>
      exact hnode r s cs

theorem hypersequentNormalizedCoalgebraTreeCoassocSupport_of_node_perm
    (hleaf :
      ∀ s : MultiSequent,
        List.Perm
          (coalgebraRightStageTripleSupport (PTree.leaf s))
          (coalgebraLeftStageTripleSupport (PTree.leaf s)))
    (hnode : HypersequentNormalizedCoalgebraNodeCoassocSupportPerm) :
    HypersequentNormalizedCoalgebraTreeCoassocSupport R :=
  hypersequentNormalizedCoalgebraTreeCoassocSupport_of_perm (R := R)
    (hypersequentNormalizedCoalgebraTreeCoassocSupportPerm_of_node
      hleaf hnode)

/-- Node-local support coassociativity is exactly enough for tree support coassociativity. -/
theorem hypersequentNormalizedCoalgebraTreeCoassocSupport_of_node
    (hnode : HypersequentNormalizedCoalgebraNodeCoassocSupport R) :
    HypersequentNormalizedCoalgebraTreeCoassocSupport R := by
  intro t
  exact coalgebraCoassoc_tree_support_of_node (R := R) hnode t

theorem hypersequentNormalizedCoalgebraTreeCoassoc_of_support
    (h : HypersequentNormalizedCoalgebraTreeCoassocSupport R) :
    HypersequentNormalizedCoalgebraTreeCoassoc R := by
  intro t
  calc
    hypersequentCoalgebraRightStageTensorLinearMap R (treeMonomial R t) =
      coalgebraLeftStageTripleElement R t :=
        hypersequentNormalizedCoalgebraLeftTreeExpansion (R := R) t
    _ = coalgebraRightStageTripleElement R t := (h t).symm
    _ = hypersequentCoalgebraLeftStageTensorLinearMap R (treeMonomial R t) :=
      (hypersequentNormalizedCoalgebraRightTreeExpansion (R := R) t).symm

theorem hypersequentNormalizedCoalgebraTreeCoassoc_of_support_perm
    (h : HypersequentNormalizedCoalgebraTreeCoassocSupportPerm) :
    HypersequentNormalizedCoalgebraTreeCoassoc R :=
  hypersequentNormalizedCoalgebraTreeCoassoc_of_support (R := R)
    (hypersequentNormalizedCoalgebraTreeCoassocSupport_of_perm (R := R) h)

theorem hypersequentNormalizedCoalgebraTreeCoassoc_of_node_perm
    (hnode : HypersequentNormalizedCoalgebraNodeCoassocSupportPerm) :
    HypersequentNormalizedCoalgebraTreeCoassoc R :=
  hypersequentNormalizedCoalgebraTreeCoassoc_of_support (R := R)
    (hypersequentNormalizedCoalgebraTreeCoassocSupport_of_node_perm
      (R := R) coalgebraCoassoc_leaf_support_perm hnode)

theorem HypersequentNormalizedNodeExtensionEndgame.tree_coassoc
    (h : HypersequentNormalizedNodeExtensionEndgame) :
    HypersequentNormalizedCoalgebraTreeCoassoc R :=
  hypersequentNormalizedCoalgebraTreeCoassoc_of_node_perm (R := R)
    h.support_perm

theorem hypersequentNormalizedCoalgebraTreeCoassoc_iff_support :
    HypersequentNormalizedCoalgebraTreeCoassoc R ↔
      HypersequentNormalizedCoalgebraTreeCoassocSupport R := by
  constructor
  · intro h t
    have ht := h t
    calc
      coalgebraRightStageTripleElement R t =
        hypersequentCoalgebraLeftStageTensorLinearMap R (treeMonomial R t) :=
          (hypersequentNormalizedCoalgebraRightTreeExpansion (R := R) t).symm
      _ = hypersequentCoalgebraRightStageTensorLinearMap R (treeMonomial R t) :=
          ht.symm
      _ = coalgebraLeftStageTripleElement R t :=
          hypersequentNormalizedCoalgebraLeftTreeExpansion (R := R) t
  · exact hypersequentNormalizedCoalgebraTreeCoassoc_of_support (R := R)

/-- Node-local support coassociativity gives the tree-level linear-map equation. -/
theorem hypersequentNormalizedCoalgebraTreeCoassoc_of_node
    (hnode : HypersequentNormalizedCoalgebraNodeCoassocSupport R) :
    HypersequentNormalizedCoalgebraTreeCoassoc R :=
  hypersequentNormalizedCoalgebraTreeCoassoc_of_support (R := R)
    (hypersequentNormalizedCoalgebraTreeCoassocSupport_of_node (R := R) hnode)

/-!
### From tree coassociativity to hypersequent-monomial coassociativity

The tree-level theorem is the mathematical bottleneck, but the Mathlib
coalgebra axiom is a linear-map equation on the whole hypersequent algebra.
The bridge is an external-extension theorem for the two staged coproduct maps:
once the staged maps agree on each proof-tree component, they agree on every
hypersequent monomial.

The definitions below isolate those algebraic compatibility obligations and
prove the global monomial extension once they are available.  This keeps the
remaining combinatorics where it belongs: on single proof-tree components,
without adding an artificial multiplication to the triple-tensor target.
-/

/-- Left-associated stage map, abbreviated as a function for formulas. -/
abbrev normalizedLeftStageMap :
    HypersequentAlgebra R →ₗ[R] HypersequentTripleTensor R :=
  hypersequentCoalgebraLeftStageTensorLinearMap R

/-- Right-associated stage map, abbreviated as a function for formulas. -/
abbrev normalizedRightStageMap :
    HypersequentAlgebra R →ₗ[R] HypersequentTripleTensor R :=
  hypersequentCoalgebraRightStageTensorLinearMap R

/--
External-extension theorem for staged normalized coproducts.

This is the precise algebraic bridge needed for the coalgebra lift: if the two
staged coproducts agree on single proof trees, then they agree on the
hypersequent monomial attached to any finite external multiset of trees.
-/
def HypersequentNormalizedStageMonomialExtension : Prop :=
  ∀ _htree : HypersequentNormalizedCoalgebraTreeCoassoc R,
    ∀ G : Hypersequent,
      normalizedRightStageMap R (hseqMonomial R G) =
        normalizedLeftStageMap R (hseqMonomial R G)

/--
All algebraic extension data needed to lift tree coassociativity to
hypersequent monomials.
-/
structure HypersequentNormalizedStageAlgebraCompatibility : Prop where
  monomial_extension : HypersequentNormalizedStageMonomialExtension R

/--
Tree coassociativity plus the staged external-extension theorem implies
coassociativity on all hypersequent monomials.
-/
theorem hypersequentNormalizedCoalgebraCoassoc_monomial_of_tree
    (htree : HypersequentNormalizedCoalgebraTreeCoassoc R)
    (hcompat : HypersequentNormalizedStageAlgebraCompatibility R) :
    ∀ G : Hypersequent,
      normalizedRightStageMap R (hseqMonomial R G) =
        normalizedLeftStageMap R (hseqMonomial R G) := by
  exact hcompat.monomial_extension htree

/--
Version stated directly with the original staged linear maps.
-/
theorem hypersequentNormalizedCoalgebraCoassoc_basis_of_tree
    (htree : HypersequentNormalizedCoalgebraTreeCoassoc R)
    (hcompat : HypersequentNormalizedStageAlgebraCompatibility R) :
    ∀ G : Hypersequent,
      ((TensorProduct.assoc R
          (HypersequentAlgebra R)
          (HypersequentAlgebra R)
          (HypersequentAlgebra R)).toLinearMap ∘ₗ
          LinearMap.rTensor (HypersequentAlgebra R)
            (hypersequentCoalgebraComulTensorLinearMap R) ∘ₗ
            hypersequentCoalgebraComulTensorLinearMap R)
        (hseqMonomial R G) =
      (LinearMap.lTensor (HypersequentAlgebra R)
          (hypersequentCoalgebraComulTensorLinearMap R) ∘ₗ
        hypersequentCoalgebraComulTensorLinearMap R)
        (hseqMonomial R G) := by
  intro G
  exact hypersequentNormalizedCoalgebraCoassoc_monomial_of_tree
    (R := R) htree hcompat G

/--
Current decomposition-based reduction of tree-level normalized coassociativity.

At this point, all tensor-algebra plumbing has been discharged, and the whole
tree theorem is reduced to the single explicit support comparison
`coalgebraCoassoc_tree_support`.
-/
theorem hypersequentNormalizedCoalgebraTreeCoassoc_of_decomposition :
    HypersequentNormalizedCoalgebraTreeCoassoc R := by
  exact (hypersequentNormalizedCoalgebraTreeCoassoc_iff_support (R := R)).2
    (coalgebraCoassoc_tree_support (R := R))

theorem hypersequentNormalizedCoalgebraTreeCoassoc_of_decomposition_perm :
    HypersequentNormalizedCoalgebraTreeCoassoc R :=
  hypersequentNormalizedCoalgebraTreeCoassoc_of_support_perm
    (R := R)
    hypersequentNormalizedCoalgebraTreeCoassocSupportPerm_of_decomposition

theorem hypersequentNormalizedCoalgebraCoassoc_basis_of_decomposition
    (hcompat : HypersequentNormalizedStageAlgebraCompatibility R) :
    ∀ G : Hypersequent,
      ((TensorProduct.assoc R
          (HypersequentAlgebra R)
          (HypersequentAlgebra R)
          (HypersequentAlgebra R)).toLinearMap ∘ₗ
          LinearMap.rTensor (HypersequentAlgebra R)
            (hypersequentCoalgebraComulTensorLinearMap R) ∘ₗ
            hypersequentCoalgebraComulTensorLinearMap R)
        (hseqMonomial R G) =
      (LinearMap.lTensor (HypersequentAlgebra R)
          (hypersequentCoalgebraComulTensorLinearMap R) ∘ₗ
        hypersequentCoalgebraComulTensorLinearMap R)
        (hseqMonomial R G) :=
  hypersequentNormalizedCoalgebraCoassoc_basis_of_tree
    (R := R)
    (hypersequentNormalizedCoalgebraTreeCoassoc_of_decomposition (R := R))
    hcompat

/--
Tree-level normalized coassociativity.

This is now the direct theorem name for the support-permutation/decomposition
proof: all cut-extension bookkeeping has been absorbed into
`coalgebraCoassoc_tree_support_perm`.
-/
theorem hypersequentNormalizedCoalgebraTreeCoassoc :
    HypersequentNormalizedCoalgebraTreeCoassoc R :=
  hypersequentNormalizedCoalgebraTreeCoassoc_of_decomposition (R := R)

/--
Basis-level normalized coassociativity, assuming only the staged external
monomial-extension bridge from tree components to arbitrary hypersequents.
-/
theorem hypersequentNormalizedCoalgebraCoassoc_basis
    (hcompat : HypersequentNormalizedStageAlgebraCompatibility R) :
    ∀ G : Hypersequent,
      ((TensorProduct.assoc R
          (HypersequentAlgebra R)
          (HypersequentAlgebra R)
          (HypersequentAlgebra R)).toLinearMap ∘ₗ
          LinearMap.rTensor (HypersequentAlgebra R)
            (hypersequentCoalgebraComulTensorLinearMap R) ∘ₗ
            hypersequentCoalgebraComulTensorLinearMap R)
        (hseqMonomial R G) =
      (LinearMap.lTensor (HypersequentAlgebra R)
          (hypersequentCoalgebraComulTensorLinearMap R) ∘ₗ
        hypersequentCoalgebraComulTensorLinearMap R)
        (hseqMonomial R G) :=
  hypersequentNormalizedCoalgebraCoassoc_basis_of_decomposition
    (R := R) hcompat

/--
Full normalized coassociativity as a linear-map equation, modulo the staged
external monomial-extension bridge.
-/
theorem hypersequentNormalizedCoalgebraCoassoc
    (hcompat : HypersequentNormalizedStageAlgebraCompatibility R) :
    HypersequentNormalizedCoalgebraCoassoc R :=
by
  unfold HypersequentNormalizedCoalgebraCoassoc
  exact hypersequentAlgebra_linearMap_ext R _ _
    (hypersequentNormalizedCoalgebraCoassoc_basis
      (R := R) hcompat)

/--
Singleton-hypersequent form of normalized coassociativity, using the staged
map abbreviations that the global monomial-extension proof is phrased with.
-/
theorem hypersequentNormalizedCoalgebraCoassoc_singleton
    (t : PTree) :
    normalizedRightStageMap R (hseqMonomial R (HQ.singleton t)) =
      normalizedLeftStageMap R (hseqMonomial R (HQ.singleton t)) := by
  change
    hypersequentCoalgebraRightStageTensorLinearMap R (treeMonomial R t) =
      hypersequentCoalgebraLeftStageTensorLinearMap R (treeMonomial R t)
  exact hypersequentNormalizedCoalgebraTreeCoassoc (R := R) t

theorem normalizedRightStageMap_monomial_add
    (G H : Hypersequent) :
    normalizedRightStageMap R (hseqMonomial R (G + H)) =
      hypersequentTripleTensorMul R
        (normalizedRightStageMap R (hseqMonomial R G))
        (normalizedRightStageMap R (hseqMonomial R H)) := by
  rw [← hseqMonomial_mul]
  rw [hypersequentCoalgebraRightStageTensorLinearMap_eq_comp,
    hypersequentCoalgebraRightStageTensorLinearMap_eq_comp,
    hypersequentCoalgebraRightStageTensorLinearMap_eq_comp]
  rw [map_mul]
  exact hypersequentTensorAlgToLeftStageTripleLinearMap_mul
    (R := R)
    (hypersequentCoalgebraComulAlgHom R (hseqMonomial R G))
    (hypersequentCoalgebraComulAlgHom R (hseqMonomial R H))

theorem normalizedLeftStageMap_monomial_add
    (G H : Hypersequent) :
    normalizedLeftStageMap R (hseqMonomial R (G + H)) =
      hypersequentTripleTensorMul R
        (normalizedLeftStageMap R (hseqMonomial R G))
        (normalizedLeftStageMap R (hseqMonomial R H)) := by
  rw [← hseqMonomial_mul]
  rw [hypersequentCoalgebraLeftStageTensorLinearMap_eq_comp,
    hypersequentCoalgebraLeftStageTensorLinearMap_eq_comp,
    hypersequentCoalgebraLeftStageTensorLinearMap_eq_comp]
  rw [map_mul]
  exact hypersequentTensorAlgToRightStageTripleLinearMap_mul
    (R := R)
    (hypersequentCoalgebraComulAlgHom R (hseqMonomial R G))
    (hypersequentCoalgebraComulAlgHom R (hseqMonomial R H))

theorem hypersequentNormalizedCoalgebraCoassoc_zero :
    normalizedRightStageMap R (hseqMonomial R (0 : Hypersequent)) =
      normalizedLeftStageMap R (hseqMonomial R (0 : Hypersequent)) := by
  change
    hypersequentCoalgebraRightStageTensorLinearMap R
        (1 : HypersequentAlgebra R) =
      hypersequentCoalgebraLeftStageTensorLinearMap R
        (1 : HypersequentAlgebra R)
  unfold hypersequentCoalgebraRightStageTensorLinearMap
    hypersequentCoalgebraLeftStageTensorLinearMap
  simp only [LinearMap.comp_apply]
  rw [hypersequentCoalgebraComulTensorLinearMap_one]
  rw [show (1 : TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R)) =
      (1 : HypersequentAlgebra R) ⊗ₜ[R]
        (1 : HypersequentAlgebra R) by
        exact Algebra.TensorProduct.one_def (R := R)
          (A := HypersequentAlgebra R) (B := HypersequentAlgebra R)]
  simp only [LinearMap.rTensor_tmul, LinearMap.lTensor_tmul,
    hypersequentCoalgebraComulTensorLinearMap_one]
  change
    (TensorProduct.assoc R
      (HypersequentAlgebra R)
      (HypersequentAlgebra R)
      (HypersequentAlgebra R))
      (((1 : HypersequentAlgebra R) ⊗ₜ[R]
          (1 : HypersequentAlgebra R)) ⊗ₜ[R]
        (1 : HypersequentAlgebra R)) =
    (1 : HypersequentAlgebra R) ⊗ₜ[R]
      ((1 : HypersequentAlgebra R) ⊗ₜ[R]
        (1 : HypersequentAlgebra R))
  exact TensorProduct.assoc_tmul
    (R := R)
    (1 : HypersequentAlgebra R)
    (1 : HypersequentAlgebra R)
    (1 : HypersequentAlgebra R)

theorem hypersequentNormalizedStageMonomialExtension :
    HypersequentNormalizedStageMonomialExtension R := by
  intro htree G
  classical
  refine Multiset.induction_on G ?_ ?_
  · exact hypersequentNormalizedCoalgebraCoassoc_zero (R := R)
  · intro t G ih
    have hright := normalizedRightStageMap_monomial_add
      (R := R) (HQ.singleton t) G
    have hleft := normalizedLeftStageMap_monomial_add
      (R := R) (HQ.singleton t) G
    have hright' :
        normalizedRightStageMap R (hseqMonomial R (t ::ₘ G)) =
          hypersequentTripleTensorMul R
            (normalizedRightStageMap R (hseqMonomial R (HQ.singleton t)))
            (normalizedRightStageMap R (hseqMonomial R G)) := by
      simpa [HQ.singleton] using hright
    have hleft' :
        normalizedLeftStageMap R (hseqMonomial R (t ::ₘ G)) =
          hypersequentTripleTensorMul R
            (normalizedLeftStageMap R (hseqMonomial R (HQ.singleton t)))
            (normalizedLeftStageMap R (hseqMonomial R G)) := by
      simpa [HQ.singleton] using hleft
    calc
      normalizedRightStageMap R (hseqMonomial R (t ::ₘ G)) =
        hypersequentTripleTensorMul R
          (normalizedRightStageMap R (hseqMonomial R (HQ.singleton t)))
          (normalizedRightStageMap R (hseqMonomial R G)) := hright'
      _ =
        hypersequentTripleTensorMul R
          (normalizedLeftStageMap R (hseqMonomial R (HQ.singleton t)))
          (normalizedLeftStageMap R (hseqMonomial R G)) := by
            exact congrArg₂ (hypersequentTripleTensorMul R)
              (by
                change
                  hypersequentCoalgebraRightStageTensorLinearMap R
                      (treeMonomial R t) =
                    hypersequentCoalgebraLeftStageTensorLinearMap R
                      (treeMonomial R t)
                exact htree t)
              ih
      _ = normalizedLeftStageMap R (hseqMonomial R (t ::ₘ G)) := hleft'.symm

/-- The staged monomial-extension bridge is now discharged. -/
def hypersequentNormalizedStageAlgebraCompatibility :
    HypersequentNormalizedStageAlgebraCompatibility R where
  monomial_extension := hypersequentNormalizedStageMonomialExtension (R := R)

