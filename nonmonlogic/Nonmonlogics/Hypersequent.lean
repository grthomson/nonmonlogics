    simpa [nodeLeftProfileWitnessFirstCut,
      nodeRightWitnessToLeftProfileWitness, nodeRightWitnessAmbientProfile,
      addrs, ambient, profileAt, firstAt] using
      forestProfileFirstCut_map_rightProfileAt addrs cut₁ cut₂
  have hambient :
      ambient ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs) := by
    simpa [ambient] using
      nodeCanonicalAmbientCut_mem_internalCoalgebraAdmissibleCuts
        (r := r) (s := s) (cs := cs)
        (cut₁ := cut₁) (cut₂ := cut₂) hcut₁ hcut₂
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hambient with
    ⟨hambientCoal, hambientInternal⟩
  have hpref :
      List.Perm ambient addrs := by
    simpa [addrs, ambient] using
      nodeRootFreeCut_perm_prefixedRestrictions
        (r := r) (s := s) (cs := cs)
        (cut := ambient) hambientCoal hambientInternal.2
  have hstage :
      List.Perm ambient (stageAmbientCut cut₁ cut₂) := by
    simpa [ambient, nodeAmbientCutOfRightWitness] using
      nodeCanonicalAmbientCut_perm_stageAmbientCut
        (r := r) (s := s) (cs := cs)
        (cut₁ := cut₁) (cut₂ := cut₂) hcut₁ hcut₂
  have haddrStage :
      List.Perm addrs (stageAmbientCut cut₁ cut₂) :=
    hpref.symm.trans hstage
  have hflatStage :
      List.Perm (addrs.flatMap firstAt)
        ((stageAmbientCut cut₁ cut₂).flatMap firstAt) :=
    List.Perm.flatMap haddrStage (by
      intro a _ha
      exact List.Perm.refl (firstAt a))
  have hdisjoint : ∀ a ∈ cut₁, a ∉ cut₂ := by
    intro a ha₁
    exact disjoint_previous_cut_second_internal_cut
      (t := t) (cut₁ := cut₁) (cut₂ := cut₂)
      hcoal₁ hcut₂Rem a ha₁
  have hstageFirst :
      (stageAmbientCut cut₁ cut₂).flatMap firstAt =
        cut₁.filter
            (fun a =>
              decide (∀ b : Address, b ∈ cut₂ → ¬ PTree.isAncestorOf b a)) ++
          firstStageInsideSecondAddresses cut₁ cut₂ := by
    simpa [firstAt, firstStageSurvivingAddresses] using
      stageAmbientCut_flatMap_rightProfileAt_eq_outside_append_inside_of_disjoint
        (cut₁ := cut₁) (cut₂ := cut₂) hdisjoint
  let survive : Address → Prop :=
    fun a => ∀ b : Address, b ∈ cut₂ → ¬ PTree.isAncestorOf b a
  have hpart :
      List.Perm cut₁
        (cut₁.filter (fun a => decide (survive a)) ++
          cut₁.filter (fun a => ! decide (survive a))) :=
    List.perm_filter_append_filter_not cut₁ (fun a => decide (survive a))
  have hdomEq :
      cut₁.filter (fun a => ! decide (survive a)) =
        firstStageDominatedBySecondAddresses cut₁ cut₂ := by
    unfold firstStageDominatedBySecondAddresses
    apply List.filter_congr
    intro a _ha
    by_cases hs : survive a
    · have hnone :
          ¬ ∃ b : Address, b ∈ cut₂ ∧ PTree.isAncestorOf b a := by
        rintro ⟨b, hb, hba⟩
        exact hs b hb hba
      have hleft : (! decide (survive a)) = false := by
        simp [hs]
      have hright :
          decide (∃ b : Address, b ∈ cut₂ ∧ PTree.isAncestorOf b a) =
            false :=
        decide_eq_false hnone
      rw [hleft, hright]
    · have hex :
          ∃ b : Address, b ∈ cut₂ ∧ PTree.isAncestorOf b a :=
        (not_forall_not_isAncestorOf_iff_exists cut₂ a).1 hs
      have hleft : (! decide (survive a)) = true := by
        simp [hs]
      have hright :
          decide (∃ b : Address, b ∈ cut₂ ∧ PTree.isAncestorOf b a) =
            true :=
        decide_eq_true hex
      rw [hleft, hright]
  have hdomInside :
      List.Perm
        (firstStageDominatedBySecondAddresses cut₁ cut₂)
        (firstStageInsideSecondAddresses cut₁ cut₂) :=
    firstStageDominatedBySecondAddresses_perm_inside
      (cut₁ := cut₁) (cut₂ := cut₂)
      (nodup_of_mem_internalCoalgebraAdmissibleCuts hcut₁)
      (nodup_of_mem_internalCoalgebraAdmissibleCuts hcut₂Rem)
      (antichain_of_mem_coalgebraAdmissibleCuts
