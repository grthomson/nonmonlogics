      subst profile
      simp [coalgebraForestTensorTermOfProfile]
  | cons t ts ih =>
      rcases (mem_coalgebraForestCutProfiles_cons_iff
        (t := t) (ts := ts) (profile := profile)).1 hprofile with
        ⟨cut, hcut, rest, hrest, rfl⟩
      have htree :
          (coalgebraTensorTermOfCutList t cut).2 = 0 ↔
            ([] : Address) ∈ cut :=
        coalgebraTensorTermOfCutList_snd_eq_zero_iff
          (t := t) (cut := cut) hcut
      have hrestZero :
          (coalgebraForestTensorTermOfProfile ts rest).2 = 0 ↔
            ∀ cut ∈ rest, ([] : Address) ∈ cut :=
        ih hrest
      simp [coalgebraForestTensorTermOfProfile,
        HypersequentTensorBasis.mul, htree, hrestZero]

theorem coalgebraTreeSplittingTensorSupport_filter_fst_zero
    (t : PTree) :
    (coalgebraTreeSplittingTensorSupport t).filter
        (fun p => decide (p.1 = 0)) =
      [(0, HQ.singleton t)] := by
  classical
  unfold coalgebraTreeSplittingTensorSupport
  rw [List.filter_map]
  have hfilter :
      (coalgebraAdmissibleCuts t).filter
          (fun cut => decide ((coalgebraTensorTermOfCutList t cut).1 = 0)) =
        (coalgebraAdmissibleCuts t).filter
          (fun cut => decide (cut = [])) := by
    apply List.filter_congr
    intro cut hcut
    have hiff :=
      coalgebraTensorTermOfCutList_fst_eq_zero_iff
        (t := t) (cut := cut) hcut
    by_cases hzero : (coalgebraTensorTermOfCutList t cut).1 = 0
    · have hnil : cut = [] := hiff.1 hzero
      simp [hzero, hnil]
    · have hnil : cut ≠ [] := by
        intro h
        exact hzero (hiff.2 h)
      simp [hzero, hnil]
  rw [show
      (coalgebraAdmissibleCuts t).filter
          (((fun p => decide (p.1 = 0)) ∘
            coalgebraTensorTermOfCutList t)) =
        (coalgebraAdmissibleCuts t).filter
          (fun cut => decide (cut = [])) by
        simpa [Function.comp_def] using hfilter]
  rw [filter_eq_emptyCut_coalgebraAdmissibleCuts]
  simp

theorem coalgebraTreeSplittingTensorSupport_filter_snd_zero
    (t : PTree) :
    (coalgebraTreeSplittingTensorSupport t).filter
        (fun p => decide (p.2 = 0)) =
      [(HQ.singleton t, 0)] := by
  classical
  unfold coalgebraTreeSplittingTensorSupport
  rw [List.filter_map]
  have hfilter :
      (coalgebraAdmissibleCuts t).filter
          (fun cut => decide ((coalgebraTensorTermOfCutList t cut).2 = 0)) =
        (coalgebraAdmissibleCuts t).filter
          (fun cut => decide (([] : Address) ∈ cut)) := by
    apply List.filter_congr
    intro cut hcut
    have hiff :=
      coalgebraTensorTermOfCutList_snd_eq_zero_iff
        (t := t) (cut := cut) hcut
    by_cases hzero : (coalgebraTensorTermOfCutList t cut).2 = 0
    · have hroot : ([] : Address) ∈ cut := hiff.1 hzero
      simp [hzero, hroot]
    · have hroot : ([] : Address) ∉ cut := by
        intro h
        exact hzero (hiff.2 h)
      simp [hzero, hroot]
  rw [show
      (coalgebraAdmissibleCuts t).filter
          (((fun p => decide (p.2 = 0)) ∘
            coalgebraTensorTermOfCutList t)) =
        (coalgebraAdmissibleCuts t).filter
          (fun cut => decide (([] : Address) ∈ cut)) by
        simpa [Function.comp_def] using hfilter]
  rw [filter_eq_rootContainingCut_coalgebraAdmissibleCuts]
  simp

theorem tensorSupportMul_filter_fst_zero_map
    (x : HypersequentTensorBasis) (ys : List HypersequentTensorBasis) :
    (ys.map (fun y => HypersequentTensorBasis.mul x y)).filter
        (fun z => decide (z.1 = 0)) =
      if x.1 = 0 then
        (ys.filter (fun y => decide (y.1 = 0))).map
          (fun y => HypersequentTensorBasis.mul x y)
      else [] := by
  classical
  by_cases hx : x.1 = 0
  · rw [List.filter_map]
    simp [Function.comp_def, HypersequentTensorBasis.mul, hx]
  · rw [if_neg hx]
    apply List.eq_nil_iff_forall_not_mem.mpr
    intro z hz
    rcases List.mem_filter.1 hz with ⟨hzmap, hzzero⟩
    rcases List.mem_map.1 hzmap with ⟨y, _hy, rfl⟩
    have hsum : x.1 + y.1 ≠ 0 := by
      intro h
      exact hx ((hypersequent_add_eq_zero_iff x.1 y.1).1 h).1
    exact hsum (by
      simpa [HypersequentTensorBasis.mul] using hzzero)

theorem tensorSupportMul_filter_snd_zero_map
    (x : HypersequentTensorBasis) (ys : List HypersequentTensorBasis) :
    (ys.map (fun y => HypersequentTensorBasis.mul x y)).filter
        (fun z => decide (z.2 = 0)) =
      if x.2 = 0 then
        (ys.filter (fun y => decide (y.2 = 0))).map
          (fun y => HypersequentTensorBasis.mul x y)
      else [] := by
  classical
  by_cases hx : x.2 = 0
  · rw [List.filter_map]
    simp [Function.comp_def, HypersequentTensorBasis.mul, hx]
  · rw [if_neg hx]
    apply List.eq_nil_iff_forall_not_mem.mpr
    intro z hz
    rcases List.mem_filter.1 hz with ⟨hzmap, hzzero⟩
    rcases List.mem_map.1 hzmap with ⟨y, _hy, rfl⟩
    have hsum : x.2 + y.2 ≠ 0 := by
      intro h
      exact hx ((hypersequent_add_eq_zero_iff x.2 y.2).1 h).1
    exact hsum (by
      simpa [HypersequentTensorBasis.mul] using hzzero)

theorem tensorSupportMul_filter_fst_zero
    (xs ys : List HypersequentTensorBasis) :
    (tensorSupportMul xs ys).filter (fun z => decide (z.1 = 0)) =
      tensorSupportMul
        (xs.filter (fun x => decide (x.1 = 0)))
        (ys.filter (fun y => decide (y.1 = 0))) := by
  classical
  induction xs with
  | nil =>
      simp [tensorSupportMul]
  | cons x xs ih =>
      change
        ((ys.map (fun y => HypersequentTensorBasis.mul x y)) ++
            tensorSupportMul xs ys).filter
            (fun z => decide (z.1 = 0)) =
          tensorSupportMul
            ((x :: xs).filter (fun x => decide (x.1 = 0)))
            (ys.filter (fun y => decide (y.1 = 0)))
      rw [List.filter_append, tensorSupportMul_filter_fst_zero_map, ih]
      by_cases hx : x.1 = 0
      · simp [tensorSupportMul, hx]
      · simp [tensorSupportMul, hx]

theorem tensorSupportMul_filter_snd_zero
    (xs ys : List HypersequentTensorBasis) :
