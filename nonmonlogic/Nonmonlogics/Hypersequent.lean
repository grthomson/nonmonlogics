and the concrete normalized maps.
-/
noncomputable def toHopfTarget
    (H : HypersequentNormalizedHopfCompletionData R) :
    HypersequentNormalizedHopfTarget R where
  bialgebraAxioms :=
    HypersequentNormalizedBialgebraCompletionData.bialgebraAxioms R
      H.bialgebraData
  hopfAxioms :=
    HypersequentNormalizedHopfCompletionData.hopfAxioms R H

@[simp]
theorem toHopfTarget_bialgebraAxioms
    (H : HypersequentNormalizedHopfCompletionData R) :
    (HypersequentNormalizedHopfCompletionData.toHopfTarget R H).bialgebraAxioms =
      HypersequentNormalizedBialgebraCompletionData.bialgebraAxioms R
        H.bialgebraData := rfl

@[simp]
theorem toHopfTarget_antipode
    (H : HypersequentNormalizedHopfCompletionData R) :
    HypersequentNormalizedHopfTarget.antipode R
        (HypersequentNormalizedHopfCompletionData.toHopfTarget R H) =
      H.antipode := rfl

theorem toHopfTarget_coassoc
    (H : HypersequentNormalizedHopfCompletionData R) :
    HypersequentNormalizedCoalgebraCoassoc R :=
  HypersequentNormalizedHopfTarget.coassoc R
    (HypersequentNormalizedHopfCompletionData.toHopfTarget R H)

theorem toHopfTarget_comul_mul
    (H : HypersequentNormalizedHopfCompletionData R) :
    HypersequentNormalizedComulMul R :=
  HypersequentNormalizedHopfTarget.comul_mul R
    (HypersequentNormalizedHopfCompletionData.toHopfTarget R H)

noncomputable def toHopfAlgebra_viaTarget
    (H : HypersequentNormalizedHopfCompletionData R) :
    HopfAlgebra R (HypersequentAlgebra R) :=
  HypersequentNormalizedHopfTarget.toHopfAlgebra R
    (HypersequentNormalizedHopfCompletionData.toHopfTarget R H)

end HypersequentNormalizedHopfCompletionData

namespace HypersequentNormalizedHopfTarget

/--
Build the normalized Hopf target from the compact completion-data bundle.
-/
noncomputable def ofCompletionData
    (H : HypersequentNormalizedHopfCompletionData R) :
    HypersequentNormalizedHopfTarget R :=
  HypersequentNormalizedHopfCompletionData.toHopfTarget R H

@[simp]
theorem ofCompletionData_antipode
    (H : HypersequentNormalizedHopfCompletionData R) :
    HypersequentNormalizedHopfTarget.antipode R
        (HypersequentNormalizedHopfTarget.ofCompletionData R H) =
