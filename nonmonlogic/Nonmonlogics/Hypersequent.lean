theorem isCoalgebraCut_nodeCanonicalAmbientCutOfRightWitness
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))) :
    IsCoalgebraCut (PTree.node r s cs)
      (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂) := by
  refine Or.inr (Or.inr ?_)
  intro a ha
  have haStage :
      a ∈ nodeAmbientCutOfRightWitness cut₁ cut₂ :=
    (mem_nodeCanonicalAmbientCutOfRightWitness_iff
      (r := r) (s := s) (cs := cs)
      (cut₁ := cut₁) (cut₂ := cut₂)
      hcut₁ hcut₂).1 ha
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₁ with
    ⟨hcoal₁, hint₁⟩
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₂ with
    ⟨hcoal₂, hint₂⟩
  rcases (mem_stageAmbientCut_iff
    (cut₁ := cut₁) (cut₂ := cut₂) (a := a)).1
      (by simpa [nodeAmbientCutOfRightWitness] using haStage) with
    hleft | hright
  · exact node_addresses_of_mem_coalgebraAdmissibleCuts_of_internal
      hcoal₁ hint₁ a hleft.1
  · have hrem :
        PTree.remainderGo cut₁ [] (PTree.node r s cs) =
          PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁) := by
      simpa [nodeRootFreeCutRemainderChildren] using
        PTree.remainderGo_node_root_not_mem
          (r := r) (s := s) (cs := cs)
          (cut := cut₁) hint₁.2
    have hcoal₂' :
        cut₂ ∈ coalgebraAdmissibleCuts
          (PTree.remainderGo cut₁ [] (PTree.node r s cs)) := by
      simpa [hrem] using hcoal₂
    exact node_addresses_of_mem_remainder_coalgebraAdmissibleCuts_of_internal
      (t := PTree.node r s cs) (cut₁ := cut₁) (cut₂ := cut₂)
      hcoal₂' hint₂ a hright

