/-!
## Takeuchi data as a normalized Hopf target

The fuelled tree recursion above is intentionally lower-level than Mathlib's
`HopfAlgebra`: it speaks about proof trees, proper cuts, and stable fuel.  The
small bridge below records the final linearization step.  Once a stable tree
antipode has been extended to a linear map and the two convolution
cancellations have been checked on hypersequent monomials, the existing
normalized Hopf target is obtained with no further algebraic plumbing.
-/

section NormalizedTakeuchiPackaging

variable (K : Type) [CommRing K]

/--
Basis-level convolution cancellation for a linearized Takeuchi antipode.

This is separated from `NormalizedTakeuchiAntipodeLinearization`: linearization
only says what the map does on single proof-tree monomials, while cancellation
is the Hopf algebra equation to be proved from the stable Bogoliubov recursion
and multiplicativity over hypersequents.
-/
structure NormalizedTakeuchiBasisCancellation
    (hBialg : HypersequentNormalizedBialgebraAxioms K)
    (T : NormalizedTreeAntipodeTarget K)
    (L : NormalizedTakeuchiAntipodeLinearization K T) : Prop where
  left :
    ∀ G : Hypersequent,
      (LinearMap.mul' K (HypersequentAlgebra K) ∘ₗ
          LinearMap.lTensor (HypersequentAlgebra K) L.linearMap ∘ₗ
            hypersequentCoalgebraComulTensorLinearMap K)
        (hseqMonomial K G) =
      (Algebra.linearMap K (HypersequentAlgebra K) ∘ₗ
          (hypersequentCounitAlgHom K).toLinearMap)
        (hseqMonomial K G)
  right :
    ∀ G : Hypersequent,
      (LinearMap.mul' K (HypersequentAlgebra K) ∘ₗ
          LinearMap.rTensor (HypersequentAlgebra K) L.linearMap ∘ₗ
            hypersequentCoalgebraComulTensorLinearMap K)
        (hseqMonomial K G) =
      (Algebra.linearMap K (HypersequentAlgebra K) ∘ₗ
          (hypersequentCounitAlgHom K).toLinearMap)
        (hseqMonomial K G)

def NormalizedTakeuchiBasisCancellation.of_treeAntipodeStableSymmetry
    (hBialg : HypersequentNormalizedBialgebraAxioms K)
    (T : NormalizedTreeAntipodeTarget K)
    (hsym :
      NormalizedStableAntipodeProperCutRemainderSymmetry K T.stableAntipode) :
    NormalizedTakeuchiBasisCancellation K hBialg T
      (NormalizedTreeAntipodeTarget.linearization K T) where
  left :=
    (hypersequentNormalizedHopfBasisAxioms_of_treeAntipodeStableSymmetry
      K hBialg T hsym).left_cancellation
  right :=
    (hypersequentNormalizedHopfBasisAxioms_of_treeAntipodeStableSymmetry
      K hBialg T hsym).right_cancellation

def NormalizedTakeuchiBasisCancellation.of_treeAntipodeCoassoc
    (hBialg : HypersequentNormalizedBialgebraAxioms K)
    (T : NormalizedTreeAntipodeTarget K) :
    NormalizedTakeuchiBasisCancellation K hBialg T
      (NormalizedTreeAntipodeTarget.linearization K T) where
  left :=
    NormalizedTreeAntipodeTarget.left_convolution_monomial K T
  right :=
    NormalizedTreeAntipodeTarget.right_convolution_monomial K T

/--
All data needed to finish the normalized Takeuchi route once the bialgebra has
been constructed.
-/
structure NormalizedTakeuchiHopfData
    (hBialg : HypersequentNormalizedBialgebraAxioms K) where
  treeTarget : NormalizedTreeAntipodeTarget K
  linearization :
    NormalizedTakeuchiAntipodeLinearization K treeTarget
  cancellation :
    NormalizedTakeuchiBasisCancellation K hBialg treeTarget linearization

noncomputable def normalizedTakeuchiHopfData_of_treeAntipodeStableSymmetry
    (hBialg : HypersequentNormalizedBialgebraAxioms K)
    (T : NormalizedTreeAntipodeTarget K)
    (hsym :
      NormalizedStableAntipodeProperCutRemainderSymmetry K T.stableAntipode) :
    NormalizedTakeuchiHopfData K hBialg where
  treeTarget := T
  linearization := NormalizedTreeAntipodeTarget.linearization K T
  cancellation :=
    NormalizedTakeuchiBasisCancellation.of_treeAntipodeStableSymmetry
      K hBialg T hsym

noncomputable def normalizedTakeuchiHopfData_of_treeAntipodeCoassoc
    (hBialg : HypersequentNormalizedBialgebraAxioms K)
    (T : NormalizedTreeAntipodeTarget K) :
    NormalizedTakeuchiHopfData K hBialg where
  treeTarget := T
  linearization := NormalizedTreeAntipodeTarget.linearization K T
  cancellation :=
    NormalizedTakeuchiBasisCancellation.of_treeAntipodeCoassoc
      K hBialg T

namespace NormalizedTakeuchiHopfData

/-- The linear antipode supplied by Takeuchi data. -/
def antipode
    {hBialg : HypersequentNormalizedBialgebraAxioms K}
    (D : NormalizedTakeuchiHopfData K hBialg) :
    HypersequentAlgebra K →ₗ[K] HypersequentAlgebra K :=
  D.linearization.linearMap

@[simp]
theorem antipode_tree
    {hBialg : HypersequentNormalizedBialgebraAxioms K}
    (D : NormalizedTakeuchiHopfData K hBialg)
    (t : PTree) :
    NormalizedTakeuchiHopfData.antipode K D (treeMonomial K t) =
      NormalizedStableTreeAntipode.value K
        D.treeTarget.stableAntipode t :=
  D.linearization.map_tree t

/-- Convert Takeuchi cancellation data into the existing Hopf basis axioms. -/
def toHopfBasisAxioms
    {hBialg : HypersequentNormalizedBialgebraAxioms K}
    (D : NormalizedTakeuchiHopfData K hBialg) :
    HypersequentNormalizedHopfBasisAxioms K hBialg
      (NormalizedTakeuchiHopfData.antipode K D) where
  left_cancellation := D.cancellation.left
  right_cancellation := D.cancellation.right

/-- Convert Takeuchi data into normalized Hopf axioms. -/
def toHopfAxioms
    {hBialg : HypersequentNormalizedBialgebraAxioms K}
    (D : NormalizedTakeuchiHopfData K hBialg) :
    HypersequentNormalizedHopfAxioms K hBialg :=
  hypersequentNormalizedHopfAxioms_of_basis K hBialg
    (NormalizedTakeuchiHopfData.antipode K D)
    (NormalizedTakeuchiHopfData.toHopfBasisAxioms K D)

/-- Convert Takeuchi data into the complete normalized Hopf target. -/
noncomputable def toHopfTarget
    {hBialg : HypersequentNormalizedBialgebraAxioms K}
    (D : NormalizedTakeuchiHopfData K hBialg) :
    HypersequentNormalizedHopfTarget K where
  bialgebraAxioms := hBialg
  hopfAxioms := NormalizedTakeuchiHopfData.toHopfAxioms K D

/-- The Mathlib Hopf algebra produced by completed Takeuchi data. -/
noncomputable def toHopfAlgebra
    {hBialg : HypersequentNormalizedBialgebraAxioms K}
    (D : NormalizedTakeuchiHopfData K hBialg) :
    HopfAlgebra K (HypersequentAlgebra K) :=
  HypersequentNormalizedHopfTarget.toHopfAlgebra K
    (NormalizedTakeuchiHopfData.toHopfTarget K D)

theorem left_cancellation
    {hBialg : HypersequentNormalizedBialgebraAxioms K}
    (D : NormalizedTakeuchiHopfData K hBialg) :
    LinearMap.mul' K (HypersequentAlgebra K) ∘ₗ
        LinearMap.lTensor (HypersequentAlgebra K)
          (NormalizedTakeuchiHopfData.antipode K D) ∘ₗ
          hypersequentCoalgebraComulTensorLinearMap K =
      Algebra.linearMap K (HypersequentAlgebra K) ∘ₗ
        (hypersequentCounitAlgHom K).toLinearMap :=
  (NormalizedTakeuchiHopfData.toHopfAxioms K D).left_cancellation

theorem right_cancellation
    {hBialg : HypersequentNormalizedBialgebraAxioms K}
    (D : NormalizedTakeuchiHopfData K hBialg) :
    LinearMap.mul' K (HypersequentAlgebra K) ∘ₗ
        LinearMap.rTensor (HypersequentAlgebra K)
          (NormalizedTakeuchiHopfData.antipode K D) ∘ₗ
          hypersequentCoalgebraComulTensorLinearMap K =
      Algebra.linearMap K (HypersequentAlgebra K) ∘ₗ
        (hypersequentCounitAlgHom K).toLinearMap :=
  (NormalizedTakeuchiHopfData.toHopfAxioms K D).right_cancellation

end NormalizedTakeuchiHopfData

/--
Takeuchi data over a completed normalized bialgebra gives the compact Hopf
completion bundle.
-/
noncomputable def normalizedHopfCompletionData_of_takeuchi
    (B : HypersequentNormalizedBialgebraCompletionData K)
    (D :
      NormalizedTakeuchiHopfData K
        (HypersequentNormalizedBialgebraCompletionData.bialgebraAxioms K B)) :
    HypersequentNormalizedHopfCompletionData K where
  bialgebraData := B
  antipode := NormalizedTakeuchiHopfData.antipode K D
  cancellation := NormalizedTakeuchiHopfData.toHopfBasisAxioms K D

/--
Takeuchi data over a completed normalized bialgebra gives the full normalized
Hopf target.
-/
noncomputable def normalizedHopfTarget_of_bialgebraCompletion_takeuchi
    (B : HypersequentNormalizedBialgebraCompletionData K)
    (D :
      NormalizedTakeuchiHopfData K
        (HypersequentNormalizedBialgebraCompletionData.bialgebraAxioms K B)) :
    HypersequentNormalizedHopfTarget K :=
  HypersequentNormalizedHopfCompletionData.toHopfTarget K
    (normalizedHopfCompletionData_of_takeuchi K B D)

/--
Takeuchi data over a completed normalized bialgebra gives the actual Mathlib
`HopfAlgebra`.
-/
noncomputable def normalizedHopfAlgebra_of_bialgebraCompletion_takeuchi
    (B : HypersequentNormalizedBialgebraCompletionData K)
    (D :
      NormalizedTakeuchiHopfData K
        (HypersequentNormalizedBialgebraCompletionData.bialgebraAxioms K B)) :
    HopfAlgebra K (HypersequentAlgebra K) :=
  HypersequentNormalizedHopfTarget.toHopfAlgebra K
    (normalizedHopfTarget_of_bialgebraCompletion_takeuchi K B D)

/--
If the tensor-product multiplication is distributive, the proved normalized
comultiplicativity theorem fills the bialgebra field, so the remaining inputs
are exactly coalgebra completion and Takeuchi cancellation data.
-/
noncomputable def normalizedHopfTarget_of_coalgebraCompletion_takeuchi
    [LeftDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    [RightDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    (C : HypersequentNormalizedCoalgebraCompletionData K)
    (D :
      NormalizedTakeuchiHopfData K
        (HypersequentNormalizedBialgebraCompletionData.bialgebraAxioms K
          (hypersequentNormalizedBialgebraCompletionData_of_coalgebraCompletion
            (R := K) C))) :
    HypersequentNormalizedHopfTarget K :=
  normalizedHopfTarget_of_bialgebraCompletion_takeuchi K
    (hypersequentNormalizedBialgebraCompletionData_of_coalgebraCompletion
      (R := K) C)
    D

/--
Same constructor as `normalizedHopfTarget_of_coalgebraCompletion_takeuchi`, but
returning the Mathlib `HopfAlgebra` instance directly.
-/
noncomputable def normalizedHopfAlgebra_of_coalgebraCompletion_takeuchi
    [LeftDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    [RightDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    (C : HypersequentNormalizedCoalgebraCompletionData K)
    (D :
      NormalizedTakeuchiHopfData K
        (HypersequentNormalizedBialgebraCompletionData.bialgebraAxioms K
          (hypersequentNormalizedBialgebraCompletionData_of_coalgebraCompletion
            (R := K) C))) :
    HopfAlgebra K (HypersequentAlgebra K) :=
  HypersequentNormalizedHopfTarget.toHopfAlgebra K
    (normalizedHopfTarget_of_coalgebraCompletion_takeuchi K C D)

/--
Direct constructor from coassociativity, normalized comultiplicativity, and
Takeuchi data over the resulting bialgebra package.
-/
noncomputable def normalizedHopfTarget_of_takeuchi
    [LeftDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    [RightDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    (hcoassoc :
      ∀ G : Hypersequent,
        ((TensorProduct.assoc K
            (HypersequentAlgebra K)
            (HypersequentAlgebra K)
            (HypersequentAlgebra K)).toLinearMap ∘ₗ
            LinearMap.rTensor (HypersequentAlgebra K)
              (hypersequentCoalgebraComulTensorLinearMap K) ∘ₗ
              hypersequentCoalgebraComulTensorLinearMap K)
          (hseqMonomial K G) =
        (LinearMap.lTensor (HypersequentAlgebra K)
            (hypersequentCoalgebraComulTensorLinearMap K) ∘ₗ
          hypersequentCoalgebraComulTensorLinearMap K)
          (hseqMonomial K G))
    (D :
      NormalizedTakeuchiHopfData K
        (hypersequentNormalizedBialgebraAxioms_of_coassoc K hcoassoc)) :
    HypersequentNormalizedHopfTarget K :=
  NormalizedTakeuchiHopfData.toHopfTarget K D

/--
Direct normalized Hopf target from Takeuchi data over the bialgebra package
whose coalgebra and comultiplicativity have already been proved in this file.
-/
noncomputable def normalizedHopfTarget_direct_of_takeuchi
    [LeftDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    [RightDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    (D :
      NormalizedTakeuchiHopfData K
        (hypersequentNormalizedBialgebraAxioms_direct (R := K))) :
    HypersequentNormalizedHopfTarget K :=
  NormalizedTakeuchiHopfData.toHopfTarget K D

noncomputable def normalizedHopfTarget_direct_of_treeAntipodeStableSymmetry
    [LeftDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    [RightDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    (T : NormalizedTreeAntipodeTarget K)
    (hsym :
      NormalizedStableAntipodeProperCutRemainderSymmetry K T.stableAntipode) :
    HypersequentNormalizedHopfTarget K :=
  normalizedHopfTarget_direct_of_takeuchi K
    (normalizedTakeuchiHopfData_of_treeAntipodeStableSymmetry K
      (hypersequentNormalizedBialgebraAxioms_direct (R := K)) T hsym)

noncomputable def normalizedHopfTarget_direct_of_treeAntipodeCoassoc
    [LeftDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    [RightDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    (T : NormalizedTreeAntipodeTarget K) :
    HypersequentNormalizedHopfTarget K :=
  normalizedHopfTarget_direct_of_takeuchi K
    (normalizedTakeuchiHopfData_of_treeAntipodeCoassoc K
      (hypersequentNormalizedBialgebraAxioms_direct (R := K)) T)

noncomputable def normalizedHopfTarget_direct
    [LeftDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    [RightDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))] :
    HypersequentNormalizedHopfTarget K :=
  normalizedHopfTarget_direct_of_treeAntipodeCoassoc K
    (normalizedTreeAntipodeTargetOfSize K)

theorem normalizedHopfTarget_direct_left_cancellation
    [LeftDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    [RightDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))] :
    LinearMap.mul' K (HypersequentAlgebra K) ∘ₗ
        LinearMap.lTensor (HypersequentAlgebra K)
          (HypersequentNormalizedHopfTarget.antipode K
            (normalizedHopfTarget_direct K)) ∘ₗ
          hypersequentCoalgebraComulTensorLinearMap K =
      Algebra.linearMap K (HypersequentAlgebra K) ∘ₗ
        (hypersequentCounitAlgHom K).toLinearMap := by
  exact
    HypersequentNormalizedHopfTarget.antipode_left_cancellation K
      (normalizedHopfTarget_direct K)

theorem normalizedHopfTarget_direct_right_cancellation
    [LeftDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    [RightDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))] :
    LinearMap.mul' K (HypersequentAlgebra K) ∘ₗ
        LinearMap.rTensor (HypersequentAlgebra K)
          (HypersequentNormalizedHopfTarget.antipode K
            (normalizedHopfTarget_direct K)) ∘ₗ
          hypersequentCoalgebraComulTensorLinearMap K =
      Algebra.linearMap K (HypersequentAlgebra K) ∘ₗ
        (hypersequentCounitAlgHom K).toLinearMap := by
  exact
    HypersequentNormalizedHopfTarget.antipode_right_cancellation K
      (normalizedHopfTarget_direct K)

@[simp]
theorem normalizedHopfTarget_direct_antipode_tree
    [LeftDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    [RightDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    (t : PTree) :
    HypersequentNormalizedHopfTarget.antipode K
        (normalizedHopfTarget_direct K) (treeMonomial K t) =
      normalizedAntipodeTreeApprox K t.size t := by
  change
    (normalizedStableAntipodeAlgHom K
        (normalizedStableTreeAntipodeOfSize K)).toLinearMap
        (treeMonomial K t) =
      normalizedAntipodeTreeApprox K t.size t
  rw [show
      (normalizedStableAntipodeAlgHom K
          (normalizedStableTreeAntipodeOfSize K)).toLinearMap
          (treeMonomial K t) =
        normalizedStableAntipodeAlgHom K
          (normalizedStableTreeAntipodeOfSize K) (treeMonomial K t) from rfl]
  rw [normalizedStableAntipodeAlgHom_tree]
  rfl

/--
Direct Mathlib `HopfAlgebra` from the remaining Takeuchi antipode data.
The base is a commutative ring here because the Bogoliubov recursion uses
subtraction.
-/
noncomputable def normalizedHopfAlgebra_direct_of_takeuchi
    [LeftDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    [RightDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    (D :
      NormalizedTakeuchiHopfData K
        (hypersequentNormalizedBialgebraAxioms_direct (R := K))) :
    HopfAlgebra K (HypersequentAlgebra K) :=
  HypersequentNormalizedHopfTarget.toHopfAlgebra K
    (normalizedHopfTarget_direct_of_takeuchi K D)

noncomputable def normalizedHopfAlgebra_direct_of_treeAntipodeStableSymmetry
    [LeftDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    [RightDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    (T : NormalizedTreeAntipodeTarget K)
    (hsym :
      NormalizedStableAntipodeProperCutRemainderSymmetry K T.stableAntipode) :
    HopfAlgebra K (HypersequentAlgebra K) :=
  HypersequentNormalizedHopfTarget.toHopfAlgebra K
    (normalizedHopfTarget_direct_of_treeAntipodeStableSymmetry K T hsym)

noncomputable def normalizedHopfAlgebra_direct_of_treeAntipodeCoassoc
    [LeftDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    [RightDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    (T : NormalizedTreeAntipodeTarget K) :
    HopfAlgebra K (HypersequentAlgebra K) :=
  HypersequentNormalizedHopfTarget.toHopfAlgebra K
    (normalizedHopfTarget_direct_of_treeAntipodeCoassoc K T)

noncomputable def normalizedHopfAlgebra_direct
    [LeftDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    [RightDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))] :
    HopfAlgebra K (HypersequentAlgebra K) :=
  HypersequentNormalizedHopfTarget.toHopfAlgebra K
    (normalizedHopfTarget_direct K)

/--
The normalized Hopf algebra carried by the free `K`-algebra generated by
proof-tree hypersequents.

The carrier is not the bare tree type `PTree`, but the algebra
`HypersequentAlgebra K = AddMonoidAlgebra K (Multiset PTree)`: finite
linear combinations of finite forests of proof trees.  The one-tree basis
elements are `treeMonomial K t`.
-/
noncomputable def proofTreeNormalizedHopfAlgebra
    [LeftDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    [RightDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))] :
    HopfAlgebra K (HypersequentAlgebra K) :=
  normalizedHopfAlgebra_direct K

/-- Existence form of the normalized Hopf algebra on proof-tree forests. -/
theorem proofTreeNormalizedHopfAlgebra_exists
    [LeftDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    [RightDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))] :
    Nonempty (HopfAlgebra K (HypersequentAlgebra K)) :=
  ⟨proofTreeNormalizedHopfAlgebra K⟩

/--
On a one-tree generator, the antipode of the normalized proof-tree Hopf target
is the stable recursive Takeuchi/Bogoliubov value.
-/
theorem proofTreeNormalizedHopfAlgebra_antipode_tree
    [LeftDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    [RightDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    (t : PTree) :
    HypersequentNormalizedHopfTarget.antipode K
        (normalizedHopfTarget_direct K) (treeMonomial K t) =
      normalizedAntipodeTreeApprox K t.size t :=
  normalizedHopfTarget_direct_antipode_tree K t

end NormalizedTakeuchiPackaging

/--
Once the three named coalgebra axioms are proved, the hypersequent splitting
data becomes an actual Mathlib `Coalgebra`.
-/
noncomputable def hypersequentSplittingCoalgebra
    (h : HypersequentSplittingCoalgebraAxioms R) :
    Coalgebra R (HypersequentAlgebra R) where
  comul := hypersequentComulTensorLinearMap R
  counit := (hypersequentSplittingCounitAlgHom R).toLinearMap
  coassoc := h.coassoc
  rTensor_counit_comp_comul := h.rightCounit
  lTensor_counit_comp_comul := h.leftCounit

/-!
## Conditional Mathlib bialgebra and Hopf targets

The splitting coproduct is already multiplicative at the support-polynomial
level, and the splitting counit is already an algebra map.  After passing from
the support tensor algebra to Mathlib's actual tensor product, the remaining
bialgebra packaging is concentrated in the two equations below.
-/

/-- The tensor-product splitting coproduct preserves the algebra unit. -/
def HypersequentSplittingComulOne : Prop :=
  hypersequentComulTensorLinearMap R (1 : HypersequentAlgebra R) =
    (1 : TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))

theorem hypersequentSplittingComulOne :
    HypersequentSplittingComulOne R := by
  unfold HypersequentSplittingComulOne hypersequentComulTensorLinearMap
  change
    hypersequentTensorAlgToTensorProductLinearMap R
      (hypersequentComulAlgHom R (1 : HypersequentAlgebra R)) =
    (1 : TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))
  rw [map_one]
  change
    hypersequentTensorAlgToTensorProductLinearMap R
      (AddMonoidAlgebra.single (0 : HypersequentTensorBasis) 1) =
    (1 : TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))
  rw [hypersequentTensorAlgToTensorProductLinearMap_single]
  exact tensorBasisTmul_zero R

/-- The tensor-product splitting coproduct preserves multiplication. -/
def HypersequentSplittingComulMul : Prop :=
  ∀ x y : HypersequentAlgebra R,
    hypersequentComulTensorLinearMap R (x * y) =
      hypersequentComulTensorLinearMap R x *
        hypersequentComulTensorLinearMap R y

/--
The exact remaining axioms for a Mathlib `Bialgebra` on the hypersequent
splitting algebra.

The coalgebra fields are the cut coassociativity/counit laws.  The two
additional fields say that the tensor-product realization of the support
coproduct is an algebra hom.
-/
structure HypersequentSplittingBialgebraAxioms : Prop extends
    HypersequentSplittingCoalgebraAxioms R where
  comul_one : HypersequentSplittingComulOne R
  comul_mul : HypersequentSplittingComulMul R

theorem hypersequentSplittingBialgebraAxioms_coalgebra
    (h : HypersequentSplittingBialgebraAxioms R) :
    HypersequentSplittingCoalgebraAxioms R :=
  h.toHypersequentSplittingCoalgebraAxioms

/--
The unit part of comultiplicativity is now proved, so a bialgebra axiom package
only needs the coalgebra laws and preservation of multiplication.
-/
theorem hypersequentSplittingBialgebraAxioms_of_coalgebra_and_comulMul
    (hCoal : HypersequentSplittingCoalgebraAxioms R)
    (hMul : HypersequentSplittingComulMul R) :
    HypersequentSplittingBialgebraAxioms R where
  coassoc := hCoal.coassoc
  rightCounit := hCoal.rightCounit
  leftCounit := hCoal.leftCounit
  comul_one := hypersequentSplittingComulOne R
  comul_mul := hMul

/--
Once the named bialgebra axioms are proved, the hypersequent splitting algebra
is an actual Mathlib `Bialgebra`.
-/
noncomputable def hypersequentSplittingBialgebra
    (h : HypersequentSplittingBialgebraAxioms R) :
    Bialgebra R (HypersequentAlgebra R) := by
  let C : Coalgebra R (HypersequentAlgebra R) :=
    hypersequentSplittingCoalgebra R
      (hypersequentSplittingBialgebraAxioms_coalgebra R h)
  exact @Bialgebra.mk' R (HypersequentAlgebra R) _ _ _ C
    (by
      change (hypersequentSplittingCounitAlgHom R)
          (1 : HypersequentAlgebra R) = 1
      exact map_one (hypersequentSplittingCounitAlgHom R))
    (by
      intro x y
      change (hypersequentSplittingCounitAlgHom R) (x * y) =
        (hypersequentSplittingCounitAlgHom R) x *
          (hypersequentSplittingCounitAlgHom R) y
      exact map_mul (hypersequentSplittingCounitAlgHom R) x y)
    h.comul_one
    (by
      intro x y
      exact h.comul_mul x y)

/--
The antipode data still has to be supplied after the bialgebra is available.
For connected graded rooted-tree Hopf algebras this should be the usual
recursive/Takeuchi antipode; we keep the target explicit so the next phase has
a precise Mathlib-shaped landing zone.
-/
structure HypersequentSplittingHopfAxioms
    (hBialg : HypersequentSplittingBialgebraAxioms R) where
  antipode : HypersequentAlgebra R →ₗ[R] HypersequentAlgebra R
  left_cancellation :
    LinearMap.mul' R (HypersequentAlgebra R) ∘ₗ
        LinearMap.lTensor (HypersequentAlgebra R) antipode ∘ₗ
          hypersequentComulTensorLinearMap R =
      Algebra.linearMap R (HypersequentAlgebra R) ∘ₗ
        (hypersequentSplittingCounitAlgHom R).toLinearMap
  right_cancellation :
    LinearMap.mul' R (HypersequentAlgebra R) ∘ₗ
        LinearMap.rTensor (HypersequentAlgebra R) antipode ∘ₗ
          hypersequentComulTensorLinearMap R =
      Algebra.linearMap R (HypersequentAlgebra R) ∘ₗ
        (hypersequentSplittingCounitAlgHom R).toLinearMap

/--
Basis-level form of the antipode cancellation equations.

This is the useful target for the recursive/Takeuchi antipode: check the two
convolution cancellation identities on hypersequent monomials, then promote
them to the full linear-map equations.
-/
structure HypersequentSplittingHopfBasisAxioms
    (hBialg : HypersequentSplittingBialgebraAxioms R)
    (S : HypersequentAlgebra R →ₗ[R] HypersequentAlgebra R) : Prop where
  left_cancellation :
    ∀ G : Hypersequent,
      (LinearMap.mul' R (HypersequentAlgebra R) ∘ₗ
          LinearMap.lTensor (HypersequentAlgebra R) S ∘ₗ
            hypersequentComulTensorLinearMap R)
        (hseqMonomial R G) =
      (Algebra.linearMap R (HypersequentAlgebra R) ∘ₗ
          (hypersequentSplittingCounitAlgHom R).toLinearMap)
        (hseqMonomial R G)
  right_cancellation :
    ∀ G : Hypersequent,
      (LinearMap.mul' R (HypersequentAlgebra R) ∘ₗ
          LinearMap.rTensor (HypersequentAlgebra R) S ∘ₗ
            hypersequentComulTensorLinearMap R)
        (hseqMonomial R G) =
      (Algebra.linearMap R (HypersequentAlgebra R) ∘ₗ
          (hypersequentSplittingCounitAlgHom R).toLinearMap)
        (hseqMonomial R G)

def hypersequentSplittingHopfAxioms_of_basis
    (hBialg : HypersequentSplittingBialgebraAxioms R)
    (S : HypersequentAlgebra R →ₗ[R] HypersequentAlgebra R)
    (hS : HypersequentSplittingHopfBasisAxioms R hBialg S) :
    HypersequentSplittingHopfAxioms R hBialg where
  antipode := S
  left_cancellation := by
    exact hypersequentAlgebra_linearMap_ext R _ _ hS.left_cancellation
  right_cancellation := by
    exact hypersequentAlgebra_linearMap_ext R _ _ hS.right_cancellation

/--
Once the bialgebra axioms and an antipode witness are supplied, the
hypersequent splitting algebra is an actual Mathlib `HopfAlgebra`.
-/
noncomputable def hypersequentSplittingHopfAlgebra
    (hBialg : HypersequentSplittingBialgebraAxioms R)
    (hHopf : HypersequentSplittingHopfAxioms R hBialg) :
    HopfAlgebra R (HypersequentAlgebra R) where
  __ := hypersequentSplittingBialgebra R hBialg
  antipode := hHopf.antipode
  mul_antipode_rTensor_comul := by
    change LinearMap.mul' R (HypersequentAlgebra R) ∘ₗ
        LinearMap.rTensor (HypersequentAlgebra R) hHopf.antipode ∘ₗ
          hypersequentComulTensorLinearMap R =
      Algebra.linearMap R (HypersequentAlgebra R) ∘ₗ
        (hypersequentSplittingCounitAlgHom R).toLinearMap
    exact hHopf.right_cancellation
  mul_antipode_lTensor_comul := by
    change LinearMap.mul' R (HypersequentAlgebra R) ∘ₗ
        LinearMap.lTensor (HypersequentAlgebra R) hHopf.antipode ∘ₗ
          hypersequentComulTensorLinearMap R =
      Algebra.linearMap R (HypersequentAlgebra R) ∘ₗ
        (hypersequentSplittingCounitAlgHom R).toLinearMap
    exact hHopf.left_cancellation

/-!
## A packaged Hopf target for the hypersequent splitting route

This mirrors the existing OG target style in the older development: once the
coalgebra/bialgebra equations and the antipode equations are supplied, the
target exposes the Mathlib `Coalgebra`, `Bialgebra`, and `HopfAlgebra`
instances together with the concrete maps used in this file.
-/

/-- Complete theorem target for the hypersequent splitting Hopf algebra. -/
structure HypersequentSplittingHopfTarget where
  bialgebraAxioms : HypersequentSplittingBialgebraAxioms R
  hopfAxioms : HypersequentSplittingHopfAxioms R bialgebraAxioms

namespace HypersequentSplittingHopfTarget

/-- The coalgebra supplied by a completed hypersequent splitting Hopf target. -/
noncomputable def toCoalgebra
    (H : HypersequentSplittingHopfTarget R) :
    Coalgebra R (HypersequentAlgebra R) :=
  hypersequentSplittingCoalgebra R
    (hypersequentSplittingBialgebraAxioms_coalgebra R H.bialgebraAxioms)

/-- The bialgebra supplied by a completed hypersequent splitting Hopf target. -/
noncomputable def toBialgebra
    (H : HypersequentSplittingHopfTarget R) :
    Bialgebra R (HypersequentAlgebra R) :=
  hypersequentSplittingBialgebra R H.bialgebraAxioms

/-- The Hopf algebra supplied by a completed hypersequent splitting Hopf target. -/
noncomputable def toHopfAlgebra
    (H : HypersequentSplittingHopfTarget R) :
    HopfAlgebra R (HypersequentAlgebra R) :=
  hypersequentSplittingHopfAlgebra R H.bialgebraAxioms H.hopfAxioms

/-- The splitting comultiplication of the target. -/
def comul
    (_H : HypersequentSplittingHopfTarget R) :
    HypersequentAlgebra R →ₗ[R]
      TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R) :=
  hypersequentComulTensorLinearMap R

/-- The splitting counit of the target. -/
def counit
    (_H : HypersequentSplittingHopfTarget R) :
    HypersequentAlgebra R →ₗ[R] R :=
  (hypersequentSplittingCounitAlgHom R).toLinearMap

/-- The antipode supplied by the target. -/
def antipode
    (H : HypersequentSplittingHopfTarget R) :
    HypersequentAlgebra R →ₗ[R] HypersequentAlgebra R :=
  H.hopfAxioms.antipode

@[simp]
theorem comul_apply
    (H : HypersequentSplittingHopfTarget R)
    (x : HypersequentAlgebra R) :
    (HypersequentSplittingHopfTarget.comul R H) x =
      hypersequentComulTensorLinearMap R x := rfl

@[simp]
theorem counit_apply
    (H : HypersequentSplittingHopfTarget R)
    (x : HypersequentAlgebra R) :
    (HypersequentSplittingHopfTarget.counit R H) x =
      (hypersequentSplittingCounitAlgHom R).toLinearMap x := rfl

@[simp]
theorem antipode_apply
    (H : HypersequentSplittingHopfTarget R)
    (x : HypersequentAlgebra R) :
    (HypersequentSplittingHopfTarget.antipode R H) x =
      H.hopfAxioms.antipode x := rfl

theorem coassoc
    (H : HypersequentSplittingHopfTarget R) :
    HypersequentSplittingCoassoc R :=
  H.bialgebraAxioms.coassoc

theorem rightCounit
    (H : HypersequentSplittingHopfTarget R) :
    HypersequentSplittingRightCounit R :=
  H.bialgebraAxioms.rightCounit

theorem leftCounit
    (H : HypersequentSplittingHopfTarget R) :
    HypersequentSplittingLeftCounit R :=
  H.bialgebraAxioms.leftCounit

theorem comul_mul
    (H : HypersequentSplittingHopfTarget R) :
    HypersequentSplittingComulMul R :=
  H.bialgebraAxioms.comul_mul

theorem antipode_left_cancellation
    (H : HypersequentSplittingHopfTarget R) :
    LinearMap.mul' R (HypersequentAlgebra R) ∘ₗ
        LinearMap.lTensor (HypersequentAlgebra R)
          (HypersequentSplittingHopfTarget.antipode R H) ∘ₗ
          hypersequentComulTensorLinearMap R =
      Algebra.linearMap R (HypersequentAlgebra R) ∘ₗ
        (hypersequentSplittingCounitAlgHom R).toLinearMap :=
  H.hopfAxioms.left_cancellation

theorem antipode_right_cancellation
    (H : HypersequentSplittingHopfTarget R) :
    LinearMap.mul' R (HypersequentAlgebra R) ∘ₗ
        LinearMap.rTensor (HypersequentAlgebra R)
          (HypersequentSplittingHopfTarget.antipode R H) ∘ₗ
          hypersequentComulTensorLinearMap R =
      Algebra.linearMap R (HypersequentAlgebra R) ∘ₗ
        (hypersequentSplittingCounitAlgHom R).toLinearMap :=
  H.hopfAxioms.right_cancellation

/--
Build the full Hopf target from a bialgebra package and basis-level antipode
cancellation checks.
-/
noncomputable def ofBasisAntipode
    (hBialg : HypersequentSplittingBialgebraAxioms R)
    (S : HypersequentAlgebra R →ₗ[R] HypersequentAlgebra R)
    (hS : HypersequentSplittingHopfBasisAxioms R hBialg S) :
    HypersequentSplittingHopfTarget R where
  bialgebraAxioms := hBialg
  hopfAxioms := hypersequentSplittingHopfAxioms_of_basis R hBialg S hS

end HypersequentSplittingHopfTarget

