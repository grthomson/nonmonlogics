                  (nodeAmbientCutOfRightWitness cut₁ cut₂))))
    {p : HypersequentTripleBasis}
    (hp : p ∈ nodeRightInternalInternalNormalSupport r s cs) :
    p ∈ nodeLeftInternalInternalNormalSupport r s cs := by
  rcases (mem_nodeRightInternalInternalNormalSupport_iff
    (r := r) (s := s) (cs := cs) (p := p)).1 hp with
    ⟨cut₁, hcut₁, cut₂, hcut₂, hpEq⟩
  subst p
  exact nodeRightWitness_mem_leftNormalSupport_of_ambient
    (r := r) (s := s) (cs := cs)
    (cut₁ := cut₁) (cut₂ := cut₂)
    (hambient cut₁ cut₂ hcut₁ hcut₂)
    (hsplit cut₁ cut₂ hcut₁ hcut₂)
    (hrem cut₁ cut₂ hcut₁ hcut₂)

