  have haAmbient : a ∈ ambient := (hpref.mem_iff).2 haAddrs
  have hbAmbient : b ∈ ambient := (hpref.mem_iff).2 hbAddrs
  exact antichain_of_mem_coalgebraAdmissibleCuts hambientCoal
    a haAmbient b hbAmbient hne hcomp

theorem mem_stageAmbientCut_recovered_of_mem_nodeLeftProfileWitness_prefixed
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {w : List Address × List (List Address)} {a : Address}
    (hw : w ∈ nodeLeftInternalInternalNormalProfileWitnesses r s cs)
    (ha : a ∈ nodeRootFreeCutPrefixedRestrictions cs w.1) :
    a ∈ stageAmbientCut
      (nodeLeftProfileWitnessFirstCut cs w)
      (nodeLeftProfileWitnessSecondCut cs w) := by
  classical
  rcases (mem_nodeLeftInternalInternalNormalProfileWitnesses_iff
    (r := r) (s := s) (cs := cs) (w := w)).1 hw with
    ⟨ambient, hambient, profile, hprofile, hwEq⟩
  subst w
  let addrs := nodeRootFreeCutPrefixedRestrictions cs ambient
  have hlen : addrs.length = profile.length :=
    nodeLeftProfileWitness_prefixed_length_eq_profile
      (r := r) (s := s) (cs := cs)
      (cut := ambient) (profile := profile) hambient hprofile
  rcases List.exists_right_of_mem_left_zip_of_length
      (xs := addrs) (ys := profile) hlen (by simpa [addrs] using ha) with
    ⟨cutA, hzipA⟩
  rcases zip_admissibleCuts_of_mem_nodeLeftProfileWitness
      (r := r) (s := s) (cs := cs)
      (w := (ambient, profile))
      ((mem_nodeLeftInternalInternalNormalProfileWitnesses_iff
        (r := r) (s := s) (cs := cs)
        (w := (ambient, profile))).2
        ⟨ambient, hambient, profile, hprofile, rfl⟩)
      a cutA (by simpa [addrs] using hzipA) with
    ⟨uA, _hsubA, hcutA⟩
  by_cases hrootA : cutA = [([] : Address)]
  · have haFirst :
        a ∈ nodeLeftProfileWitnessFirstCut cs (ambient, profile) := by
      have hx :
          a ++ [] ∈ nodeLeftProfileWitnessFirstCut cs (ambient, profile) :=
        mem_nodeLeftProfileWitnessFirstCut_of_mem_zip
          (cs := cs) (w := (ambient, profile)) (a := a)
          (cut := cutA) (c := [])
          (by simpa [addrs] using hzipA)
          (by simp [hrootA])
      simpa using hx
    refine mem_stageAmbientCut_left_of_not_dominated haFirst ?_
    intro b hbSecond hba
    rcases (mem_nodeLeftProfileWitnessSecondCut_iff_exists_zip_nonroot
      (cs := cs) (w := (ambient, profile)) (a := b)).1 hbSecond with
      ⟨cutB, hzipB, hnonrootB⟩
    have hbAddrs : b ∈ addrs := by
      simpa [addrs] using
        List.left_mem_of_mem_zip
          (xs := nodeRootFreeCutPrefixedRestrictions cs ambient)
          (ys := profile) (a := b) (b := cutB) hzipB
    rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hambient with
      ⟨hambientCoal, hambientInternal⟩
    have hpref :
        List.Perm ambient addrs := by
      simpa [addrs] using
        nodeRootFreeCut_perm_prefixedRestrictions
          (r := r) (s := s) (cs := cs)
          (cut := ambient) hambientCoal hambientInternal.2
    have haAmbient : a ∈ ambient :=
      (hpref.mem_iff).2 (by simpa [addrs] using ha)
    have hbAmbient : b ∈ ambient := (hpref.mem_iff).2 hbAddrs
    by_cases hbaEq : b = a
    · subst b
      have hcutEq : cutA = cutB :=
        List.right_eq_of_mem_zip_same_left_of_nodup
          (xs := addrs) (ys := profile)
          (a := a) (b₁ := cutA) (b₂ := cutB)
          ((hpref.nodup_iff).1
            (nodup_of_mem_internalCoalgebraAdmissibleCuts hambient))
          hzipA (by simpa [addrs] using hzipB)
      exact hnonrootB (by simpa [hrootA] using hcutEq.symm)
    · exact antichain_of_mem_coalgebraAdmissibleCuts hambientCoal
        b hbAmbient a haAmbient hbaEq (Or.inl hba)
  · exact mem_stageAmbientCut_right
      (mem_nodeLeftProfileWitnessSecondCut_of_mem_zip_nonroot
        (cs := cs) (w := (ambient, profile)) (a := a)
        (cut := cutA) (by simpa [addrs] using hzipA) hrootA)

theorem mem_nodeLeftProfileWitness_prefixed_of_mem_stageAmbientCut_recovered
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {w : List Address × List (List Address)} {x : Address}
    (hx :
      x ∈ stageAmbientCut
        (nodeLeftProfileWitnessFirstCut cs w)
        (nodeLeftProfileWitnessSecondCut cs w)) :
    x ∈ nodeRootFreeCutPrefixedRestrictions cs w.1 := by
  classical
  rcases (mem_stageAmbientCut_iff
      (cut₁ := nodeLeftProfileWitnessFirstCut cs w)
      (cut₂ := nodeLeftProfileWitnessSecondCut cs w)
      (a := x)).1 hx with hxLeft | hxSecond
  · rcases hxLeft with ⟨hxFirst, hsurvive⟩
    rcases (mem_nodeLeftProfileWitnessFirstCut_iff_exists_zip
      (cs := cs) (w := w) (x := x)).1 hxFirst with
      ⟨a, cutA, c, hzipA, hc, rfl⟩
    have haAddrs :
        a ∈ nodeRootFreeCutPrefixedRestrictions cs w.1 :=
      List.left_mem_of_mem_zip hzipA
    by_cases hrootA : cutA = [([] : Address)]
    · have hcEq : c = ([] : Address) := by
        simpa [hrootA] using hc
      subst c
      simpa using haAddrs
    · have haSecond :
        a ∈ nodeLeftProfileWitnessSecondCut cs w :=
        mem_nodeLeftProfileWitnessSecondCut_of_mem_zip_nonroot
          (cs := cs) (w := w) (a := a) (cut := cutA) hzipA hrootA
      exact False.elim (hsurvive a haSecond ⟨c, rfl⟩)
  · rcases (mem_nodeLeftProfileWitnessSecondCut_iff_exists_zip_nonroot
      (cs := cs) (w := w) (a := x)).1 hxSecond with
      ⟨cutX, hzipX, _hnonrootX⟩
    exact List.left_mem_of_mem_zip hzipX

