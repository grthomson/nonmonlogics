/--
The exact nested split obligation for a staged right witness.

Unlike the append-permutation shortcut above, this statement is strong enough
for the genuinely nested case: an ambient detached tree may itself contribute
both first-stage detached components and the second-stage remainder.  The only
assumption is therefore the real support fact, namely that the normalized
forest coproduct of the ambient detached forest contains the two-stage
hypersequent split.
-/
theorem nodeAmbientSplit_mem_proper_of_canonical_forest_support
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address}
    (hfirstNonempty : nodeRootFreeCutDetachedForest cs cut₁ ≠ [])
    (hsecondNonempty :
      coalgebraDetachedForestOfCut
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))
        cut₂ ≠ [])
    (hfst :
      (coalgebraTensorTermOfCutList
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))
        cut₂).1 =
        HQ.ofForest
          (coalgebraDetachedForestOfCut
            (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))
            cut₂))
    (hsupport :
      (HQ.ofForest (nodeRootFreeCutDetachedForest cs cut₁),
        HQ.ofForest
          (coalgebraDetachedForestOfCut
            (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))
            cut₂)) ∈
        coalgebraForestSplittingTensorSupport
          (nodeRootFreeCutDetachedForest cs
            (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂))) :
    nodeAmbientSplitOfRightWitness r s cs cut₁ cut₂ ∈
      coalgebraForestProperSplittingTensorSupport
        (nodeRootFreeCutDetachedForest cs
          (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂)) := by
  let f₁ := nodeRootFreeCutDetachedForest cs cut₁
  let f₂ :=
    coalgebraDetachedForestOfCut
      (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))
      cut₂
  have hleft_ne_raw :
      HQ.ofForest (nodeRootFreeCutDetachedForest cs cut₁) ≠ 0 := by
    cases hF : nodeRootFreeCutDetachedForest cs cut₁ with
    | nil =>
        exact False.elim (hfirstNonempty hF)
    | cons t ts =>
        exact ofForest_ne_zero_of_mem (f := t :: ts) (u := t) (by simp)
  have hright_ne_raw :
      HQ.ofForest
        (coalgebraDetachedForestOfCut
          (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))
          cut₂) ≠ 0 := by
    cases hF :
        coalgebraDetachedForestOfCut
          (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))
          cut₂ with
    | nil =>
        exact False.elim (hsecondNonempty hF)
    | cons t ts =>
        exact ofForest_ne_zero_of_mem (f := t :: ts) (u := t) (by simp)
  have hleft_ne : HQ.ofForest f₁ ≠ 0 := by
    simpa [f₁] using hleft_ne_raw
  have hright_ne : HQ.ofForest f₂ ≠ 0 := by
    simpa [f₂] using hright_ne_raw
  have hproper :
      (HQ.ofForest f₁, HQ.ofForest f₂) ∈
        coalgebraForestProperSplittingTensorSupport
          (nodeRootFreeCutDetachedForest cs
            (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂)) := by
    exact (mem_coalgebraForestProperSplittingTensorSupport_iff
      (f := nodeRootFreeCutDetachedForest cs
        (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂))
      (p := (HQ.ofForest f₁, HQ.ofForest f₂))).2
      ⟨by simpa [f₁, f₂] using hsupport, hleft_ne, hright_ne⟩
  simpa [nodeAmbientSplitOfRightWitness, f₁, f₂, hfst] using hproper

