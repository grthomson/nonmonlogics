/--
One direction of the ambient witness comparison: once the three semantic
obligations for the ambient map are available, every right node-normal support
atom is present on the left node-normal support.
-/
theorem nodeRightNormalSupport_subset_left_of_ambient_sound
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    (hambient :
      ∀ cut₁ cut₂ : List Address,
        cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs) →
        cut₂ ∈ internalCoalgebraAdmissibleCuts
          (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁)) →
          nodeAmbientCutOfRightWitness cut₁ cut₂ ∈
            internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (hsplit :
      ∀ cut₁ cut₂ : List Address,
        cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs) →
        cut₂ ∈ internalCoalgebraAdmissibleCuts
          (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁)) →
