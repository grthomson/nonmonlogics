            (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂))
          (nodeRightWitnessAmbientProfile r s cs cut₁ cut₂))
        (stagedRightWitnessProfilePairs (PTree.node r s cs) cut₁ cut₂)) :
    coalgebraForestTensorTermOfProfile
        (nodeRootFreeCutDetachedForest cs
          (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂))
        (nodeRightWitnessAmbientProfile r s cs cut₁ cut₂) =
      (HQ.ofForest (nodeRootFreeCutDetachedForest cs cut₁),
        (coalgebraTensorTermOfCutList
          (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))
          cut₂).1) := by
  let t := PTree.node r s cs
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₁ with
    ⟨hcoal₁, hint₁⟩
  have hfirstRem :
      PTree.remainderGo cut₁ [] t =
        PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁) := by
    simpa [t, nodeRootFreeCutRemainderChildren] using
      PTree.remainderGo_node_root_not_mem
        (r := r) (s := s) (cs := cs)
        (cut := cut₁) hint₁.2
  have hcut₂Rem :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.remainderGo cut₁ [] t) := by
    simpa [t, hfirstRem] using hcut₂
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₂Rem with
    ⟨hcoal₂Rem, _hint₂Rem⟩
  have hlen :
      (nodeRightWitnessAmbientProfile r s cs cut₁ cut₂).length =
        (nodeRootFreeCutDetachedForest cs
          (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂)).length :=
    nodeRightWitnessAmbientProfile_length_eq_detachedForest
      (r := r) (s := s) (cs := cs)
      (cut₁ := cut₁) (cut₂ := cut₂) hcut₁ hcut₂
  have hvalid₂ :
      ∀ b : Address, b ∈ cut₂ →
        ∃ u, PTree.subtreeAt t b = some u := by
    intro b hb
    rcases node_addresses_of_mem_remainder_coalgebraAdmissibleCuts_of_internal
        (t := t) (cut₁ := cut₁) (cut₂ := cut₂)
        hcoal₂Rem ((mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₂Rem).2
        b hb with
      ⟨r', s', cs', hsub⟩
    exact ⟨PTree.node r' s' cs', hsub⟩
  have haddr :
      List.Perm
        (firstStageDominatedBySecondAddresses cut₁ cut₂)
        (firstStageInsideSecondAddresses cut₁ cut₂) :=
    firstStageDominatedBySecondAddresses_perm_inside
      (cut₁ := cut₁) (cut₂ := cut₂)
      (nodup_of_mem_internalCoalgebraAdmissibleCuts hcut₁)
      (nodup_of_mem_internalCoalgebraAdmissibleCuts hcut₂)
      (antichain_of_mem_coalgebraAdmissibleCuts hcoal₂Rem)
  have hdomForest :
      List.Perm
        (firstStageDominatedBySecondForest t cut₁ cut₂)
        (firstStageInsideSecondForest t cut₁ cut₂) :=
    firstStageDominatedBySecondForest_perm_inside_of_address_perm
      (t := t) (cut₁ := cut₁) (cut₂ := cut₂)
      hvalid₂ haddr
  have hfirstPerm :
      List.Perm
        (nodeRootFreeCutDetachedForest cs cut₁)
        (firstStageOutsideSecondForest t cut₁ cut₂ ++
          firstStageInsideSecondForest t cut₁ cut₂) := by
    simpa [t] using
      nodeRootFreeCutDetachedForest_perm_outside_append_inside_of_dominated
        (r := r) (s := s) (cs := cs)
        (cut₁ := cut₁) (cut₂ := cut₂) hcut₁ hdomForest
  have hfirstEq :
      HQ.ofForest
          (firstStageOutsideSecondForest t cut₁ cut₂ ++
            firstStageInsideSecondForest t cut₁ cut₂) =
        HQ.ofForest (nodeRootFreeCutDetachedForest cs cut₁) :=
    (HQ.ofForest_eq_of_perm hfirstPerm).symm
  have hdetEq :
      HQ.ofForest
          (coalgebraDetachedForestOfCut
            (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))
            cut₂) =
        HQ.ofForest (secondStageRestrictedRemainderForest t cut₁ cut₂) := by
    simpa [t, hfirstRem] using
      ofForest_coalgebraDetachedForestOfCut_second_internal_eq_restrictedRemainderForest
        (t := t) (cut₁ := cut₁) (cut₂ := cut₂)
        hcoal₁ hcut₂Rem
  have hqFst :
      (coalgebraTensorTermOfCutList
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))
        cut₂).1 =
        HQ.ofForest
          (coalgebraDetachedForestOfCut
            (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))
            cut₂) :=
    nodeRightWitness_fst_eq_detachedForestOfCut
      (r := r) (s := s) (cs := cs)
      (cut₁ := cut₁) (cut₂ := cut₂) hcut₂
  have hsecondEq :
      HQ.ofForest (secondStageRestrictedRemainderForest t cut₁ cut₂) =
        (coalgebraTensorTermOfCutList
          (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))
          cut₂).1 :=
    hdetEq.symm.trans hqFst.symm
  calc
    coalgebraForestTensorTermOfProfile
        (nodeRootFreeCutDetachedForest cs
          (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂))
        (nodeRightWitnessAmbientProfile r s cs cut₁ cut₂)
        =
      coalgebraForestTensorTermOfPairs
        (List.zip
          (nodeRootFreeCutDetachedForest cs
            (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂))
          (nodeRightWitnessAmbientProfile r s cs cut₁ cut₂)) := by
        exact coalgebraForestTensorTermOfProfile_eq_pairs hlen
    _ = coalgebraForestTensorTermOfPairs
        (stagedRightWitnessProfilePairs t cut₁ cut₂) := by
        exact coalgebraForestTensorTermOfPairs_perm hzip
    _ =
      (HQ.ofForest
          (firstStageOutsideSecondForest t cut₁ cut₂ ++
            firstStageInsideSecondForest t cut₁ cut₂),
        HQ.ofForest (secondStageRestrictedRemainderForest t cut₁ cut₂)) := by
        exact coalgebraForestTensorTermOfPairs_stagedRightWitness
          (t := t) (cut₁ := cut₁) (cut₂ := cut₂)
          hcut₁ hcut₂Rem
    _ =
      (HQ.ofForest (nodeRootFreeCutDetachedForest cs cut₁),
        (coalgebraTensorTermOfCutList
          (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))
          cut₂).1) := by
        simp [hfirstEq, hsecondEq]

theorem nodeRightWitnessAmbientProfile_tensor_eq
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))) :
    coalgebraForestTensorTermOfProfile
        (nodeRootFreeCutDetachedForest cs
          (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂))
        (nodeRightWitnessAmbientProfile r s cs cut₁ cut₂) =
      (HQ.ofForest (nodeRootFreeCutDetachedForest cs cut₁),
        (coalgebraTensorTermOfCutList
          (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))
          cut₂).1) := by
  exact nodeRightWitnessAmbientProfile_tensor_eq_of_zip_perm
    (r := r) (s := s) (cs := cs)
    (cut₁ := cut₁) (cut₂ := cut₂) hcut₁ hcut₂
    (nodeRightWitnessAmbientProfile_zip_perm_staged
      (r := r) (s := s) (cs := cs)
      (cut₁ := cut₁) (cut₂ := cut₂) hcut₁ hcut₂)

theorem nodeLeftProfileWitness_prefixed_length_eq_profile
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut : List Address} {profile : List (List Address)}
    (hcut : cut ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (hprofile :
      profile ∈ coalgebraForestProperCutProfiles
        (nodeRootFreeCutDetachedForest cs cut)) :
    (nodeRootFreeCutPrefixedRestrictions cs cut).length =
      profile.length := by
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut with
    ⟨hcoal, hinternal⟩
  have hpLen :
      profile.length =
        (nodeRootFreeCutDetachedForest cs cut).length :=
    coalgebraForestProperCutProfiles_length_eq hprofile
  have haLen :
      (nodeRootFreeCutPrefixedRestrictions cs cut).length =
        (nodeRootFreeCutDetachedForest cs cut).length :=
    nodeRootFreeCutPrefixedRestrictions_length_eq_detachedForest
      (r := r) (s := s) (cs := cs) (cut := cut)
      hcoal hinternal.2
  exact haLen.trans hpLen.symm

theorem mem_nodeRightInternalInternalNormalWitnesses_iff
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {w : List Address × List Address} :
    w ∈ nodeRightInternalInternalNormalWitnesses r s cs ↔
      ∃ cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs),
        ∃ cut₂ ∈ internalCoalgebraAdmissibleCuts
            (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁)),
          w = (cut₁, cut₂) := by
  unfold nodeRightInternalInternalNormalWitnesses
  constructor
  · intro hw
    rcases List.mem_flatMap.1 hw with ⟨cut₁, hcut₁, hmap⟩
    rcases List.mem_map.1 hmap with ⟨cut₂, hcut₂, hEq⟩
    exact ⟨cut₁, hcut₁, cut₂, hcut₂, hEq.symm⟩
  · rintro ⟨cut₁, hcut₁, cut₂, hcut₂, rfl⟩
    exact List.mem_flatMap.2
      ⟨cut₁, hcut₁, List.mem_map.2 ⟨cut₂, hcut₂, rfl⟩⟩

theorem mem_nodeLeftInternalInternalNormalProfileWitnesses_iff
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {w : List Address × List (List Address)} :
    w ∈ nodeLeftInternalInternalNormalProfileWitnesses r s cs ↔
      ∃ cut ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs),
        ∃ profile ∈ coalgebraForestProperCutProfiles
            (nodeRootFreeCutDetachedForest cs cut),
          w = (cut, profile) := by
  unfold nodeLeftInternalInternalNormalProfileWitnesses
  constructor
  · intro hw
    rcases List.mem_flatMap.1 hw with ⟨cut, hcut, hmap⟩
    rcases List.mem_map.1 hmap with ⟨profile, hprofile, hEq⟩
    exact ⟨cut, hcut, profile, hprofile, hEq.symm⟩
  · rintro ⟨cut, hcut, profile, hprofile, rfl⟩
    exact List.mem_flatMap.2
      ⟨cut, hcut, List.mem_map.2 ⟨profile, hprofile, rfl⟩⟩

theorem nodeRightInternalInternalNormalWitnesses_nodup
    (r : RuleTag) (s : MultiSequent) (cs : List PTree) :
    (nodeRightInternalInternalNormalWitnesses r s cs).Nodup := by
  unfold nodeRightInternalInternalNormalWitnesses
  apply List.nodup_flatMap_map_pair
  · exact internalCoalgebraAdmissibleCuts_nodup (PTree.node r s cs)
  · intro cut₁ _hcut₁
    exact internalCoalgebraAdmissibleCuts_nodup
      (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))

theorem nodeLeftInternalInternalNormalProfileWitnesses_nodup
    (r : RuleTag) (s : MultiSequent) (cs : List PTree) :
    (nodeLeftInternalInternalNormalProfileWitnesses r s cs).Nodup := by
  unfold nodeLeftInternalInternalNormalProfileWitnesses
  apply List.nodup_flatMap_map_pair
  · exact internalCoalgebraAdmissibleCuts_nodup (PTree.node r s cs)
  · intro cut _hcut
    exact coalgebraForestProperCutProfiles_nodup
      (nodeRootFreeCutDetachedForest cs cut)

/--
Every component of a left profile witness is a genuine coalgebra cut of the
original subtree selected by its ambient antichain address.
-/
theorem zip_admissibleCuts_of_mem_nodeLeftProfileWitness
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {w : List Address × List (List Address)}
    (hw : w ∈ nodeLeftInternalInternalNormalProfileWitnesses r s cs) :
    ∀ a cut,
      (a, cut) ∈
        List.zip (nodeRootFreeCutPrefixedRestrictions cs w.1) w.2 →
        ∃ u, (PTree.node r s cs).subtreeAt a = some u ∧
          cut ∈ coalgebraAdmissibleCuts u := by
  rcases (mem_nodeLeftInternalInternalNormalProfileWitnesses_iff
    (r := r) (s := s) (cs := cs) (w := w)).1 hw with
    ⟨cut, hcut, profile, hprofile, rfl⟩
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut with
    ⟨hcoal, hinternal⟩
  let addrs := nodeRootFreeCutPrefixedRestrictions cs cut
  have hall :
      ∀ a, a ∈ addrs →
        ∃ u, (PTree.node r s cs).subtreeAt a = some u := by
    intro a ha
    simpa [addrs] using
      subtreeAt_some_of_mem_nodeRootFreeCutPrefixedRestrictions
        (r := r) (s := s) (cs := cs)
        (cut := cut) (a := a) hcoal hinternal.2 ha
  have hlen :
      profile.length = addrs.length := by
    exact (nodeLeftProfileWitness_prefixed_length_eq_profile
      (r := r) (s := s) (cs := cs)
      (cut := cut) (profile := profile) hcut hprofile).symm
  have hprofile' :
      profile ∈ coalgebraForestCutProfiles
        (addrs.filterMap (PTree.subtreeAt (PTree.node r s cs))) := by
    have hbase :
        profile ∈ coalgebraForestCutProfiles
          (nodeRootFreeCutDetachedForest cs cut) :=
      ((mem_coalgebraForestProperCutProfiles_iff
        (f := nodeRootFreeCutDetachedForest cs cut)
        (profile := profile)).1 hprofile).1
    simpa [addrs,
      nodeRootFreeCutPrefixedRestrictions_filterMap_subtreeAt] using hbase
  exact
    zip_admissibleCuts_of_mem_coalgebraForestCutProfiles_filterMap
      (t := PTree.node r s cs) hall hlen hprofile'

theorem subtreeAt_some_of_mem_nodeLeftProfileWitnessFirstCut
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {w : List Address × List (List Address)} {x : Address}
    (hw : w ∈ nodeLeftInternalInternalNormalProfileWitnesses r s cs)
    (hx : x ∈ nodeLeftProfileWitnessFirstCut cs w) :
    ∃ u, (PTree.node r s cs).subtreeAt x = some u := by
  rcases (mem_nodeLeftProfileWitnessFirstCut_iff_exists_zip
    (cs := cs) (w := w) (x := x)).1 hx with
    ⟨a, cut, c, hzip, hc, rfl⟩
  rcases zip_admissibleCuts_of_mem_nodeLeftProfileWitness
      (r := r) (s := s) (cs := cs) (w := w) hw a cut hzip with
    ⟨u, hsub, hcut⟩
  rcases subtreeAt_some_of_mem_coalgebraAdmissibleCuts hcut hc with
    ⟨v, hv⟩
  exact ⟨v, by
    rw [PTree.subtreeAt_append_of_subtreeAt hsub]
    exact hv⟩

theorem exists_profileCut_of_mem_nodeLeftProfileWitnessFirstCut
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {w : List Address × List (List Address)} {x : Address}
    (hw : w ∈ nodeLeftInternalInternalNormalProfileWitnesses r s cs)
    (hx : x ∈ nodeLeftProfileWitnessFirstCut cs w) :
    ∃ a cut c u,
      (a, cut) ∈
          List.zip (nodeRootFreeCutPrefixedRestrictions cs w.1) w.2 ∧
        c ∈ cut ∧ x = a ++ c ∧
        (PTree.node r s cs).subtreeAt a = some u ∧
        cut ∈ coalgebraAdmissibleCuts u := by
  rcases (mem_nodeLeftProfileWitnessFirstCut_iff_exists_zip
    (cs := cs) (w := w) (x := x)).1 hx with
    ⟨a, cut, c, hzip, hc, hxEq⟩
  rcases zip_admissibleCuts_of_mem_nodeLeftProfileWitness
      (r := r) (s := s) (cs := cs) (w := w) hw a cut hzip with
    ⟨u, hsub, hcut⟩
  exact ⟨a, cut, c, u, hzip, hc, hxEq, hsub, hcut⟩

theorem exists_profileCut_of_mem_nodeLeftProfileWitnessSecondCut
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {w : List Address × List (List Address)} {a : Address}
    (hw : w ∈ nodeLeftInternalInternalNormalProfileWitnesses r s cs)
    (ha : a ∈ nodeLeftProfileWitnessSecondCut cs w) :
    ∃ cut u,
      (a, cut) ∈
          List.zip (nodeRootFreeCutPrefixedRestrictions cs w.1) w.2 ∧
        (PTree.node r s cs).subtreeAt a = some u ∧
        cut ∈ coalgebraAdmissibleCuts u ∧
        cut ≠ [([] : Address)] := by
  rcases (mem_nodeLeftProfileWitnessSecondCut_iff_exists_zip_nonroot
    (cs := cs) (w := w) (a := a)).1 ha with
    ⟨cut, hzip, hroot⟩
  rcases zip_admissibleCuts_of_mem_nodeLeftProfileWitness
      (r := r) (s := s) (cs := cs) (w := w) hw a cut hzip with
    ⟨u, hsub, hcut⟩
  exact ⟨cut, u, hzip, hsub, hcut, hroot⟩

theorem not_isAncestorOf_firstCut_of_mem_nodeLeftProfileWitnessSecondCut
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {w : List Address × List (List Address)} {a x : Address}
    (hw : w ∈ nodeLeftInternalInternalNormalProfileWitnesses r s cs)
    (hx : x ∈ nodeLeftProfileWitnessFirstCut cs w)
    (ha : a ∈ nodeLeftProfileWitnessSecondCut cs w) :
    ¬ PTree.isAncestorOf x a := by
  rcases (mem_nodeLeftInternalInternalNormalProfileWitnesses_iff
    (r := r) (s := s) (cs := cs) (w := w)).1 hw with
    ⟨ambient, hambient, profile, hprofile, hwEq⟩
  subst w
  rcases exists_profileCut_of_mem_nodeLeftProfileWitnessFirstCut
      (r := r) (s := s) (cs := cs)
      (w := (ambient, profile)) hw hx with
    ⟨b, cutB, c, _u, hzipB, hc, hxEq, _hsubB, _hcutB⟩
  rcases exists_profileCut_of_mem_nodeLeftProfileWitnessSecondCut
      (r := r) (s := s) (cs := cs)
      (w := (ambient, profile)) hw ha with
    ⟨cutA, _v, hzipA, _hsubA, hcutA, hnonrootA⟩
  let addrs := nodeRootFreeCutPrefixedRestrictions cs ambient
  have hbAddrs : b ∈ addrs := by
    simpa [addrs] using
      List.left_mem_of_mem_zip
        (xs := nodeRootFreeCutPrefixedRestrictions cs ambient)
        (ys := profile) (a := b) (b := cutB) hzipB
  have haAddrs : a ∈ addrs := by
    simpa [addrs] using
      List.left_mem_of_mem_zip
        (xs := nodeRootFreeCutPrefixedRestrictions cs ambient)
        (ys := profile) (a := a) (b := cutA) hzipA
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hambient with
    ⟨hambientCoal, hambientInternal⟩
  have hpref :
      List.Perm ambient addrs := by
    simpa [addrs] using
      nodeRootFreeCut_perm_prefixedRestrictions
        (r := r) (s := s) (cs := cs)
        (cut := ambient) hambientCoal hambientInternal.2
  have hbAmbient : b ∈ ambient := (hpref.mem_iff).2 hbAddrs
  have haAmbient : a ∈ ambient := (hpref.mem_iff).2 haAddrs
  by_cases hba : b = a
  · subst b
    have hnodupAddrs : addrs.Nodup := by
      exact (hpref.nodup_iff).1
        (nodup_of_mem_internalCoalgebraAdmissibleCuts hambient)
    have hcutEq : cutB = cutA :=
      List.right_eq_of_mem_zip_same_left_of_nodup
        (xs := addrs) (ys := profile) (a := a)
        (b₁ := cutB) (b₂ := cutA) hnodupAddrs
        (by simpa [addrs] using hzipB)
        (by simpa [addrs] using hzipA)
    subst cutB
    have hcne : c ≠ [] := by
      intro hcNil
      subst c
      have hrootMem : ([] : Address) ∈ cutA := by
        simpa using hc
      have hraw :
          cutA ∈ PTree.allAdmissibleCuts _ :=
        ((mem_coalgebraAdmissibleCuts_iff).1 hcutA).1
      have hsingle :
          cutA = [([] : Address)] :=
        PTree.eq_singleton_root_of_mem_allAdmissibleCuts_of_root_mem
          hraw hrootMem
      exact hnonrootA hsingle
    intro hxa
    exact not_isAncestorOf_append_left_of_ne_nil
      (a := a) (c := c) hcne
      (by simpa [hxEq] using hxa)
  · intro hxa
    have hbAncA : PTree.isAncestorOf b a := by
      rcases hxa with ⟨d, hd⟩
      refine ⟨c ++ d, ?_⟩
      rw [hxEq, List.append_assoc] at hd
      exact hd
    have hcomp : PTree.comparable b a := Or.inl hbAncA
    exact antichain_of_mem_coalgebraAdmissibleCuts hambientCoal
      b hbAmbient a haAmbient hba hcomp

theorem not_isAncestorOf_canonicalFirstCut_of_mem_nodeLeftProfileWitnessSecondCut
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {w : List Address × List (List Address)} {a x : Address}
    (hw : w ∈ nodeLeftInternalInternalNormalProfileWitnesses r s cs)
    (hx : x ∈ nodeLeftProfileWitnessCanonicalFirstCut r s cs w)
    (ha : a ∈ nodeLeftProfileWitnessSecondCut cs w) :
    ¬ PTree.isAncestorOf x a := by
  have hxFirst : x ∈ nodeLeftProfileWitnessFirstCut cs w := by
    exact (PTree.mem_canonicalCut_iff.1 hx).2
  exact not_isAncestorOf_firstCut_of_mem_nodeLeftProfileWitnessSecondCut
    (r := r) (s := s) (cs := cs) (w := w) hw hxFirst ha

theorem subtreeAt_canonicalFirst_remainder_of_mem_nodeLeftProfileWitnessSecondCut
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {w : List Address × List (List Address)} {a : Address} {u : PTree}
    (hw : w ∈ nodeLeftInternalInternalNormalProfileWitnesses r s cs)
    (ha : a ∈ nodeLeftProfileWitnessSecondCut cs w)
    (hsub : (PTree.node r s cs).subtreeAt a = some u) :
    PTree.subtreeAt
        (PTree.remainderGo
          (nodeLeftProfileWitnessCanonicalFirstCut r s cs w) []
          (PTree.node r s cs)) a =
      some
        (PTree.remainderGo
          (PTree.restrictCutAt
            (nodeLeftProfileWitnessCanonicalFirstCut r s cs w) a) [] u) := by
  apply PTree.subtreeAt_remainderGo_of_forall_not_ancestor
      (cut := nodeLeftProfileWitnessCanonicalFirstCut r s cs w)
      (a := a) (t := PTree.node r s cs) (u := u) hsub
  intro x hx
  exact not_isAncestorOf_canonicalFirstCut_of_mem_nodeLeftProfileWitnessSecondCut
    (r := r) (s := s) (cs := cs) (w := w) hw hx ha

theorem mem_allAddresses_of_mem_nodeLeftProfileWitnessFirstCut
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {w : List Address × List (List Address)} {x : Address}
    (hw : w ∈ nodeLeftInternalInternalNormalProfileWitnesses r s cs)
    (hx : x ∈ nodeLeftProfileWitnessFirstCut cs w) :
    x ∈ PTree.allAddresses (PTree.node r s cs) := by
  rcases subtreeAt_some_of_mem_nodeLeftProfileWitnessFirstCut
      (r := r) (s := s) (cs := cs) (w := w) hw hx with
    ⟨u, hsub⟩
  exact PTree.subtreeAt_some_implies_mem_allAddresses
    (PTree.node r s cs) u x hsub

theorem validAddress_of_mem_nodeLeftProfileWitnessFirstCut
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {w : List Address × List (List Address)} {x : Address}
    (hw : w ∈ nodeLeftInternalInternalNormalProfileWitnesses r s cs)
    (hx : x ∈ nodeLeftProfileWitnessFirstCut cs w) :
    PTree.ValidAddress (PTree.node r s cs) x := by
  rcases subtreeAt_some_of_mem_nodeLeftProfileWitnessFirstCut
      (r := r) (s := s) (cs := cs) (w := w) hw hx with
    ⟨u, hsub⟩
  exact (PTree.valid_iff_exists_subtree (PTree.node r s cs) x).2
    ⟨u, hsub⟩

theorem isNodeAddress_of_mem_nodeLeftProfileWitnessFirstCut
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {w : List Address × List (List Address)} {x : Address}
    (hw : w ∈ nodeLeftInternalInternalNormalProfileWitnesses r s cs)
    (hx : x ∈ nodeLeftProfileWitnessFirstCut cs w) :
    IsNodeAddress (PTree.node r s cs) x := by
  rcases (mem_nodeLeftInternalInternalNormalProfileWitnesses_iff
    (r := r) (s := s) (cs := cs) (w := w)).1 hw with
    ⟨ambient, hambient, profile, hprofile, hwEq⟩
  subst w
  rcases (mem_nodeLeftProfileWitnessFirstCut_iff_exists_zip
    (cs := cs) (w := (ambient, profile)) (x := x)).1 hx with
    ⟨a, cut, c, hzip, hc, hxEq⟩
  have hwPair :
      (ambient, profile) ∈
        nodeLeftInternalInternalNormalProfileWitnesses r s cs :=
    (mem_nodeLeftInternalInternalNormalProfileWitnesses_iff
      (r := r) (s := s) (cs := cs)
      (w := (ambient, profile))).2
      ⟨ambient, hambient, profile, hprofile, rfl⟩
  rcases zip_admissibleCuts_of_mem_nodeLeftProfileWitness
      (r := r) (s := s) (cs := cs)
      (w := (ambient, profile)) hwPair a cut hzip with
    ⟨u, hsub, hcut⟩
  let addrs := nodeRootFreeCutPrefixedRestrictions cs ambient
  have haAddrs : a ∈ addrs := by
    simpa [addrs] using
      List.left_mem_of_mem_zip
        (xs := nodeRootFreeCutPrefixedRestrictions cs ambient)
        (ys := profile) (a := a) (b := cut) hzip
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hambient with
    ⟨hambientCoal, hambientInternal⟩
  have hpref :
      List.Perm ambient addrs := by
    simpa [addrs] using
      nodeRootFreeCut_perm_prefixedRestrictions
        (r := r) (s := s) (cs := cs)
        (cut := ambient) hambientCoal hambientInternal.2
  have haAmbient : a ∈ ambient := (hpref.mem_iff).2 haAddrs
  have haNode :
      IsNodeAddress (PTree.node r s cs) a :=
    node_addresses_of_mem_coalgebraAdmissibleCuts_of_internal
      hambientCoal hambientInternal a haAmbient
  rcases (mem_coalgebraAdmissibleCuts_iff).1 hcut with
    ⟨_hraw, hcoal⟩
  rcases hcoal with hempty | hroot | hnodes
  · subst cut
    simp at hc
  · have hcroot : c = ([] : Address) :=
      eq_root_of_mem_coalgebraAdmissibleCuts_of_root_mem
        hcut hroot hc
    rw [hxEq, hcroot]
    simpa using haNode
  · have hcNode : IsNodeAddress u c := hnodes c hc
    rw [hxEq]
    exact (isNodeAddress_subtreeAt_append_iff hsub).2 hcNode

theorem isCoalgebraCut_nodeLeftProfileWitnessFirstCut
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {w : List Address × List (List Address)}
    (hw : w ∈ nodeLeftInternalInternalNormalProfileWitnesses r s cs) :
    IsCoalgebraCut (PTree.node r s cs)
      (nodeLeftProfileWitnessFirstCut cs w) := by
  by_cases hnil : nodeLeftProfileWitnessFirstCut cs w = []
  · exact Or.inl hnil
  · by_cases hroot : ([] : Address) ∈ nodeLeftProfileWitnessFirstCut cs w
    · exact Or.inr (Or.inl hroot)
    · exact Or.inr (Or.inr (by
        intro a ha
        exact isNodeAddress_of_mem_nodeLeftProfileWitnessFirstCut
          (r := r) (s := s) (cs := cs) (w := w) hw ha))

theorem antichain_nodeLeftProfileWitnessFirstCut
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {w : List Address × List (List Address)}
    (hw : w ∈ nodeLeftInternalInternalNormalProfileWitnesses r s cs) :
    ∀ a, a ∈ nodeLeftProfileWitnessFirstCut cs w →
      ∀ b, b ∈ nodeLeftProfileWitnessFirstCut cs w →
        a ≠ b → ¬ PTree.comparable a b := by
  intro x hx y hy hxy hcomp
  rcases (mem_nodeLeftInternalInternalNormalProfileWitnesses_iff
    (r := r) (s := s) (cs := cs) (w := w)).1 hw with
    ⟨ambient, hambient, profile, _hprofile, hwEq⟩
  subst w
  rcases exists_profileCut_of_mem_nodeLeftProfileWitnessFirstCut
      (r := r) (s := s) (cs := cs)
      (w := (ambient, profile)) hw hx with
    ⟨a, cutA, c, u, hzipA, hc, hxEq, _hsubA, hcutA⟩
  rcases exists_profileCut_of_mem_nodeLeftProfileWitnessFirstCut
      (r := r) (s := s) (cs := cs)
      (w := (ambient, profile)) hw hy with
    ⟨b, cutB, d, _v, hzipB, hd, hyEq, _hsubB, _hcutB⟩
  let addrs := nodeRootFreeCutPrefixedRestrictions cs ambient
  have haAddrs : a ∈ addrs := by
    simpa [addrs] using
      List.left_mem_of_mem_zip
        (xs := nodeRootFreeCutPrefixedRestrictions cs ambient)
        (ys := profile) (a := a) (b := cutA) hzipA
  have hbAddrs : b ∈ addrs := by
    simpa [addrs] using
      List.left_mem_of_mem_zip
        (xs := nodeRootFreeCutPrefixedRestrictions cs ambient)
        (ys := profile) (a := b) (b := cutB) hzipB
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hambient with
    ⟨hambientCoal, hambientInternal⟩
  have hpref :
      List.Perm ambient addrs := by
    simpa [addrs] using
      nodeRootFreeCut_perm_prefixedRestrictions
        (r := r) (s := s) (cs := cs)
        (cut := ambient) hambientCoal hambientInternal.2
  have haAmbient : a ∈ ambient := (hpref.mem_iff).2 haAddrs
  have hbAmbient : b ∈ ambient := (hpref.mem_iff).2 hbAddrs
  by_cases hab : a = b
  · subst b
    have hnodupAddrs : addrs.Nodup := by
      exact (hpref.nodup_iff).1
        (nodup_of_mem_internalCoalgebraAdmissibleCuts hambient)
    have hcutEq : cutB = cutA :=
      List.right_eq_of_mem_zip_same_left_of_nodup
        (xs := addrs) (ys := profile) (a := a)
        (b₁ := cutB) (b₂ := cutA) hnodupAddrs
        (by simpa [addrs] using hzipB)
        (by simpa [addrs] using hzipA)
    subst cutB
    have hcompLocal : PTree.comparable c d := by
      apply comparable_suffixes_of_comparable_same_prefix
        (p := a)
      simpa [hxEq, hyEq] using hcomp
    have hcd : c ≠ d := by
      intro hcd
      exact hxy (by simpa [hxEq, hyEq, hcd])
    exact antichain_of_mem_coalgebraAdmissibleCuts hcutA
      c hc d hd hcd hcompLocal
  · have hcompAmbient : PTree.comparable a b := by
      apply comparable_prefixes_of_comparable_appends
        (c := c) (d := d)
      simpa [hxEq, hyEq] using hcomp
    exact antichain_of_mem_coalgebraAdmissibleCuts hambientCoal
      a haAmbient b hbAmbient hab hcompAmbient

theorem nodeLeftProfileWitnessFirstCut_mem_coalgebraAdmissibleCuts_of_allAdmissible
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
