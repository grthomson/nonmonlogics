      (hypersequentNormalizedBialgebraAxioms_direct (R := K))
      (NormalizedTreeAntipodeTarget.linearization K
        (normalizedTreeAntipodeTargetOfSize K)).linearMap :=
  hypersequentNormalizedHopfBasisAxioms_of_treeAntipodeCoassoc K
    (hypersequentNormalizedBialgebraAxioms_direct (R := K))
    (normalizedTreeAntipodeTargetOfSize K)

def hypersequentNormalizedHopfBasisAxioms_of_treeAntipodePreviousFuelSymmetry
