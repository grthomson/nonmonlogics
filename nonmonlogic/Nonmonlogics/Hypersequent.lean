      (R := R) hcompat)

/-!
### Completion-data packages for the normalized route

The main theorem now has a clean dependency graph:

1. node-local internal extension permutation;
2. staged algebra compatibility;
3. normalized coproduct multiplicativity;
4. antipode cancellation.

The structures below package those dependencies so downstream declarations can
consume a single object instead of a long list of theorem arguments.
-/

/-- Data completing the normalized coalgebra through the node-permutation route. -/
structure HypersequentNormalizedCoalgebraCompletion where
  data : HypersequentNormalizedCoalgebraCompletionData R

namespace HypersequentNormalizedCoalgebraCompletion

theorem treeCoassoc
    (C : HypersequentNormalizedCoalgebraCompletion R) :
    HypersequentNormalizedCoalgebraTreeCoassoc R :=
  hypersequentNormalizedCoalgebraTreeCoassoc_of_node_perm
    (R := R) C.data.node_perm

theorem basisCoassoc
    (C : HypersequentNormalizedCoalgebraCompletion R) :
    ∀ G : Hypersequent,
      ((TensorProduct.assoc R
          (HypersequentAlgebra R)
          (HypersequentAlgebra R)
          (HypersequentAlgebra R)).toLinearMap ∘ₗ
          LinearMap.rTensor (HypersequentAlgebra R)
            (hypersequentCoalgebraComulTensorLinearMap R) ∘ₗ
            hypersequentCoalgebraComulTensorLinearMap R)
        (hseqMonomial R G) =
      (LinearMap.lTensor (HypersequentAlgebra R)
          (hypersequentCoalgebraComulTensorLinearMap R) ∘ₗ
        hypersequentCoalgebraComulTensorLinearMap R)
        (hseqMonomial R G) :=
  hypersequentNormalizedCoalgebraCoassoc_basis_of_tree
    (R := R) C.treeCoassoc C.data.stage_compat

def axioms
    (C : HypersequentNormalizedCoalgebraCompletion R) :
    HypersequentNormalizedCoalgebraAxioms R :=
  hypersequentNormalizedCoalgebraAxioms_of_completionData
    (R := R) C.data

noncomputable def toCoalgebra
