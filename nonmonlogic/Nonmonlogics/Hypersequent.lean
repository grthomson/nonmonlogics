/-!
# Hypersequents for NMMS

This file starts a new route for the coproduct story.

The central shift is conceptual:

- `PTree` remains the internal proof object;
- a hypersequent is a finite multiset of proof trees, i.e. a
  proof-labelled/tree-decorated hypersequent;
- forgetting each proof-tree decoration by `PTree.conclusion` projects this
  carrier to an ordinary sequent-level hypersequent;
- internal composition is still tree-level grafting;
- external decomposition is governed by admissible cuts, now re-read as
  hypersequent splitting data.

The goal here is not yet to close the full bialgebra coherence theorem. The
goal is to put the hypersequent carrier and the splitting rule on top of the
existing `PTree.IsAdmissibleCut`, `PTree.pruned`, `PTree.remainder`, and
`PTree.coproductData` infrastructure with as little reinvention as possible.
-/

/-- A hypersequent is a finite multiset of NMMS proof trees. -/
abbrev Hypersequent := Multiset PTree

/--
The ordinary sequent-level shadow of a proof-labelled hypersequent.

The hypersequent route works one proof-relevant level above Avron-style
hypersequents: components are proof trees, not bare sequents.  Forgetting the
proof-tree decorations sends each component to its conclusion sequent.
-/
abbrev SequentHypersequent := Multiset MultiSequent

namespace HQ

/-- Forget the order of a forest while retaining multiplicity. -/
def ofForest (f : Forest) : Hypersequent := (f : Multiset PTree)

/-- The one-component hypersequent. -/
def singleton (t : PTree) : Hypersequent := ({t} : Multiset PTree)

/--
Forget proof-tree decorations, retaining only the conclusion sequent of each
component.  This is the formal projection from proof-labelled hypersequents to
ordinary sequent-level hypersequents.
-/
def conclusions (G : Hypersequent) : SequentHypersequent :=
  G.map PTree.conclusion

@[simp] theorem ofForest_nil : ofForest ([] : Forest) = 0 := rfl

@[simp] theorem ofForest_cons (t : PTree) (f : Forest) :
    ofForest (t :: f) = singleton t + ofForest f := by
  simp [ofForest, singleton]

@[simp] theorem ofForest_append (f g : Forest) :
    ofForest (f ++ g) = ofForest f + ofForest g := by
  simp [ofForest]

theorem ofForest_eq_of_perm {f g : Forest} (h : List.Perm f g) :
    ofForest f = ofForest g := by
  change (f : Multiset PTree) = (g : Multiset PTree)
  exact Quot.sound h

@[simp] theorem singleton_leaf (s : MultiSequent) :
    singleton (PTree.leaf s) = ({PTree.leaf s} : Hypersequent) := rfl

@[simp] theorem conclusions_zero :
    conclusions (0 : Hypersequent) = (0 : SequentHypersequent) := by
  simp [conclusions]

@[simp] theorem conclusions_singleton (t : PTree) :
    conclusions (singleton t) =
      ({t.conclusion} : SequentHypersequent) := by
  simp [conclusions, singleton]

@[simp] theorem conclusions_leaf_singleton (s : MultiSequent) :
    conclusions (singleton (PTree.leaf s)) =
      ({s} : SequentHypersequent) := by
  simp [conclusions, singleton, PTree.conclusion]

@[simp] theorem conclusions_add (G H : Hypersequent) :
    conclusions (G + H) = conclusions G + conclusions H := by
  simp [conclusions, Multiset.map_add]

@[simp] theorem conclusions_ofForest_nil :
    conclusions (ofForest ([] : Forest)) = (0 : SequentHypersequent) := by
  simp

@[simp] theorem conclusions_ofForest_cons (t : PTree) (f : Forest) :
    conclusions (ofForest (t :: f)) =
      ({t.conclusion} : SequentHypersequent) + conclusions (ofForest f) := by
  simp [ofForest_cons]

@[simp] theorem conclusions_ofForest_append (f g : Forest) :
    conclusions (ofForest (f ++ g)) =
      conclusions (ofForest f) + conclusions (ofForest g) := by
  simp [ofForest_append]

end HQ

/-!
## External hypersequents as grafting/pre-Lie profiles

The normalized coalgebra route keeps two proof-theoretic directions separate:
external hypersequent multiplication is coexistence of proof trees, while
internal structure is supplied by admissible cuts and matching-leaf grafting.
This section connects the external carrier to the already-built
Oudom-Guin/pre-Lie quotient side over `ℤ`.
-/

/-- Sum the raw grafting-side tree generators over an ordered forest. -/
noncomputable def forestGLProfile : Forest → linearProofTreeCarrier
  | [] => 0
  | t :: ts => treeGen t + forestGLProfile ts

@[simp]
theorem forestGLProfile_nil :
    forestGLProfile ([] : Forest) = 0 := rfl

@[simp]
theorem forestGLProfile_cons (t : PTree) (f : Forest) :
    forestGLProfile (t :: f) = treeGen t + forestGLProfile f := rfl

theorem forestGLProfile_append (f g : Forest) :
    forestGLProfile (f ++ g) =
      forestGLProfile f + forestGLProfile g := by
  induction f with
  | nil =>
      simp
  | cons t ts ih =>
      simp [ih, add_assoc]

theorem forestGLProfile_eq_of_perm {f g : Forest}
    (h : List.Perm f g) :
    forestGLProfile f = forestGLProfile g := by
  induction h with
  | nil =>
      simp
  | cons t h ih =>
      simp [ih]
  | swap a b xs =>
      simp [add_assoc, add_comm, add_left_comm]
  | trans _ _ ih₁ ih₂ =>
      exact ih₁.trans ih₂

/--
The raw grafting-side profile of a hypersequent: add the tree generators of
all external components.
-/
noncomputable def hypersequentGLProfile
    (G : Hypersequent) : linearProofTreeCarrier :=
  (G.map treeGen).sum

@[simp]
theorem hypersequentGLProfile_zero :
    hypersequentGLProfile (0 : Hypersequent) = 0 := by
  simp [hypersequentGLProfile]

@[simp]
theorem hypersequentGLProfile_singleton (t : PTree) :
    hypersequentGLProfile (HQ.singleton t) = treeGen t := by
  simp [hypersequentGLProfile, HQ.singleton]

@[simp]
theorem hypersequentGLProfile_add (G H : Hypersequent) :
    hypersequentGLProfile (G + H) =
      hypersequentGLProfile G + hypersequentGLProfile H := by
  simp [hypersequentGLProfile, Multiset.map_add]

@[simp]
theorem hypersequentGLProfile_ofForest_nil :
    hypersequentGLProfile (HQ.ofForest ([] : Forest)) = 0 := by
  simp

@[simp]
theorem hypersequentGLProfile_ofForest_cons
    (t : PTree) (f : Forest) :
    hypersequentGLProfile (HQ.ofForest (t :: f)) =
      treeGen t + hypersequentGLProfile (HQ.ofForest f) := by
  simp [HQ.ofForest_cons]

theorem hypersequentGLProfile_ofForest
    (f : Forest) :
    hypersequentGLProfile (HQ.ofForest f) = forestGLProfile f := by
  induction f with
  | nil =>
      simp
  | cons t ts ih =>
      simp [ih]

theorem hypersequentGLProfile_eq_of_forest_perm
    {f g : Forest} (h : List.Perm f g) :
    hypersequentGLProfile (HQ.ofForest f) =
      hypersequentGLProfile (HQ.ofForest g) := by
  simp [hypersequentGLProfile_ofForest,
    forestGLProfile_eq_of_perm h]

/-- Hypersequent profile in the stable pre-Lie-difference quotient. -/
noncomputable def hypersequentStableQuotientProfile
    (G : Hypersequent) : PreLieDifferenceStableQuotient :=
  mkPreLieDifferenceStableQuotient (hypersequentGLProfile G)

@[simp]
theorem hypersequentStableQuotientProfile_zero :
    hypersequentStableQuotientProfile (0 : Hypersequent) = 0 := by
  simp [hypersequentStableQuotientProfile]

@[simp]
theorem hypersequentStableQuotientProfile_singleton
    (t : PTree) :
    hypersequentStableQuotientProfile (HQ.singleton t) =
      mkPreLieDifferenceStableQuotient (treeGen t) := by
  simp [hypersequentStableQuotientProfile]

@[simp]
theorem hypersequentStableQuotientProfile_add
    (G H : Hypersequent) :
    hypersequentStableQuotientProfile (G + H) =
      hypersequentStableQuotientProfile G +
        hypersequentStableQuotientProfile H := by
  simp [hypersequentStableQuotientProfile,
    hypersequentGLProfile_add]

theorem hypersequentStableQuotientProfile_ofForest
    (f : Forest) :
    hypersequentStableQuotientProfile (HQ.ofForest f) =
      mkPreLieDifferenceStableQuotient (forestGLProfile f) := by
  simp [hypersequentStableQuotientProfile,
    hypersequentGLProfile_ofForest]

theorem hypersequentStableQuotientProfile_eq_of_forest_perm
    {f g : Forest} (h : List.Perm f g) :
    hypersequentStableQuotientProfile (HQ.ofForest f) =
      hypersequentStableQuotientProfile (HQ.ofForest g) := by
  simp [hypersequentStableQuotientProfile_ofForest,
    forestGLProfile_eq_of_perm h]

/-- Hypersequent profile in the UEA attached to the stable pre-Lie quotient. -/
noncomputable def hypersequentStableUEAProfile
    (G : Hypersequent) : preLieDifferenceStableQuotientUEA :=
  preLieDifferenceStableQuotientToUEA
    (hypersequentGLProfile G)

@[simp]
theorem hypersequentStableUEAProfile_zero :
    hypersequentStableUEAProfile (0 : Hypersequent) = 0 := by
  simp [hypersequentStableUEAProfile]

@[simp]
theorem hypersequentStableUEAProfile_add
    (G H : Hypersequent) :
    hypersequentStableUEAProfile (G + H) =
      hypersequentStableUEAProfile G +
        hypersequentStableUEAProfile H := by
  simp [hypersequentStableUEAProfile]

@[simp]
theorem hypersequentStableUEAProfile_singleton
    (t : PTree) :
    hypersequentStableUEAProfile (HQ.singleton t) =
      preLieDifferenceStableQuotientToUEA (treeGen t) := by
  simp [hypersequentStableUEAProfile]

theorem hypersequentStableUEAProfile_ofForest
    (f : Forest) :
    hypersequentStableUEAProfile (HQ.ofForest f) =
      preLieDifferenceStableQuotientToUEA (forestGLProfile f) := by
  simp [hypersequentStableUEAProfile,
    hypersequentGLProfile_ofForest]

/--
Internal graftability: `u` may be inserted into `t` only at a leaf labelled by
the conclusion of `u`.
-/
def MatchingLeafGraftable (u t : PTree) : Prop :=
  ∃ a : Address, PTree.IsGraftableLeafAt u t a

/--
External weakening is constrained by graftability: an extra external component
is allowed only when it can actually participate as a matching subproof of an
existing component.
-/
def ExternalGraftWeakeningAllowed
    (G : Hypersequent) (u : PTree) : Prop :=
  ∃ t : PTree, t ∈ G ∧ MatchingLeafGraftable u t

/-- The explicit failure of arbitrary external weakening. -/
def ExternalGraftWeakeningBlocked
    (G : Hypersequent) (u : PTree) : Prop :=
  ¬ ExternalGraftWeakeningAllowed G u

theorem matchingLeafGraftable_of_graftable_at
    {u t : PTree} {a : Address}
    (h : PTree.IsGraftableLeafAt u t a) :
    MatchingLeafGraftable u t :=
  ⟨a, h⟩

theorem matchingLeafGraftable_iff_matchingLeafGraftings_nonempty
    (u t : PTree) :
    MatchingLeafGraftable u t ↔
      ∃ v : PTree, v ∈ PTree.matchingLeafGraftings u t := by
  constructor
  · rintro ⟨a, ha⟩
    rcases PTree.graftMatchingLeafAt_spec u t a ha with ⟨v, hv⟩
    refine ⟨v, ?_⟩
    unfold PTree.matchingLeafGraftings
    refine List.mem_filterMap.2 ?_
    refine ⟨a, ?_, hv⟩
    exact PTree.subtreeAt_some_implies_mem_allAddresses
      t (PTree.leaf u.conclusion) a ha
  · rintro ⟨v, hv⟩
    unfold PTree.matchingLeafGraftings at hv
    rcases List.mem_filterMap.1 hv with ⟨a, _ha, hsome⟩
    unfold PTree.graftMatchingLeafAt at hsome
    cases hsub : PTree.subtreeAt t a with
    | none =>
        simp [hsub] at hsome
    | some sub =>
        cases sub with
        | node r s cs =>
            simp [hsub] at hsome
        | leaf s =>
            by_cases hmatch : u.conclusion = s
            · exact ⟨a, by
                simp [PTree.IsGraftableLeafAt, hsub, hmatch]⟩
            · simp [hsub, hmatch] at hsome

theorem externalGraftWeakeningAllowed_of_mem
    {G : Hypersequent} {u t : PTree}
    (ht : t ∈ G)
    (hgraft : MatchingLeafGraftable u t) :
    ExternalGraftWeakeningAllowed G u :=
  ⟨t, ht, hgraft⟩

theorem externalGraftWeakeningAllowed_singleton_iff
    (u t : PTree) :
    ExternalGraftWeakeningAllowed (HQ.singleton t) u ↔
      MatchingLeafGraftable u t := by
  constructor
  · rintro ⟨v, hv, hgraft⟩
    simp [HQ.singleton] at hv
    subst v
    exact hgraft
  · intro h
    exact ⟨t, by simp [HQ.singleton], h⟩

theorem externalGraftWeakeningAllowed_iff_matching_graftings
    (G : Hypersequent) (u : PTree) :
    ExternalGraftWeakeningAllowed G u ↔
      ∃ t : PTree, t ∈ G ∧
        ∃ v : PTree, v ∈ PTree.matchingLeafGraftings u t := by
  constructor
  · rintro ⟨t, ht, hgraft⟩
    exact ⟨t, ht,
      (matchingLeafGraftable_iff_matchingLeafGraftings_nonempty u t).1
        hgraft⟩
  · rintro ⟨t, ht, houts⟩
    exact ⟨t, ht,
      (matchingLeafGraftable_iff_matchingLeafGraftings_nonempty u t).2
        houts⟩

theorem externalGraftWeakeningBlocked_iff
    (G : Hypersequent) (u : PTree) :
    ExternalGraftWeakeningBlocked G u ↔
      ∀ t : PTree, t ∈ G → ¬ MatchingLeafGraftable u t := by
  unfold ExternalGraftWeakeningBlocked ExternalGraftWeakeningAllowed
  constructor
  · intro h t ht hgraft
    exact h ⟨t, ht, hgraft⟩
  · intro h hall
    rcases hall with ⟨t, ht, hgraft⟩
    exact h t ht hgraft

theorem externalGraftWeakeningBlocked_iff_no_matching_graftings
    (G : Hypersequent) (u : PTree) :
    ExternalGraftWeakeningBlocked G u ↔
      ∀ t : PTree, t ∈ G →
        ¬ ∃ v : PTree, v ∈ PTree.matchingLeafGraftings u t := by
  rw [externalGraftWeakeningBlocked_iff]
  constructor
  · intro h t ht houts
    exact h t ht
      ((matchingLeafGraftable_iff_matchingLeafGraftings_nonempty u t).2
        houts)
  · intro h t ht hgraft
    exact h t ht
      ((matchingLeafGraftable_iff_matchingLeafGraftings_nonempty u t).1
        hgraft)

theorem externalGraftWeakeningBlocked_singleton_iff
    (u t : PTree) :
    ExternalGraftWeakeningBlocked (HQ.singleton t) u ↔
      ¬ MatchingLeafGraftable u t := by
  unfold ExternalGraftWeakeningBlocked
  rw [externalGraftWeakeningAllowed_singleton_iff]

theorem externalGraftWeakeningBlocked_zero
    (u : PTree) :
    ExternalGraftWeakeningBlocked (0 : Hypersequent) u := by
  rw [externalGraftWeakeningBlocked_iff]
  intro t ht
  simp at ht

theorem externalGraftWeakeningAllowed_not_blocked
    {G : Hypersequent} {u : PTree}
    (h : ExternalGraftWeakeningAllowed G u) :
    ¬ ExternalGraftWeakeningBlocked G u := by
  intro hblocked
  exact hblocked h

theorem externalGraftWeakeningBlocked_not_allowed
    {G : Hypersequent} {u : PTree}
    (h : ExternalGraftWeakeningBlocked G u) :
    ¬ ExternalGraftWeakeningAllowed G u :=
  h

theorem externalGraftWeakeningAllowed_of_output
    {G : Hypersequent} {u t v : PTree}
    (ht : t ∈ G)
    (hv : v ∈ PTree.matchingLeafGraftings u t) :
    ExternalGraftWeakeningAllowed G u := by
  exact
    (externalGraftWeakeningAllowed_iff_matching_graftings G u).2
      ⟨t, ht, v, hv⟩

theorem externalGraftWeakeningBlocked_no_output
    {G : Hypersequent} {u t v : PTree}
    (hblocked : ExternalGraftWeakeningBlocked G u)
    (ht : t ∈ G) :
    v ∉ PTree.matchingLeafGraftings u t := by
  intro hv
  exact externalGraftWeakeningAllowed_not_blocked
    (externalGraftWeakeningAllowed_of_output ht hv) hblocked

/-!
## Proof-relevant hypersequents over ordinary hypersequents

Avron-style hypersequents have sequent components.  The carrier used here is
one proof-relevant level above that: every component is a proof tree labelled by
its whole derivation history, and `HQ.conclusions` forgets those labels.

The small fiber object below lets us talk precisely about that relationship:
`ProofRelevantHypersequentOver S` is a labelled hypersequent whose ordinary
shadow is the sequent-level hypersequent `S`.
-/

/-- A proof-labelled hypersequent with fixed ordinary sequent-level shadow. -/
structure ProofRelevantHypersequentOver (S : SequentHypersequent) where
  carrier : Hypersequent
  shadow : HQ.conclusions carrier = S

namespace ProofRelevantHypersequentOver

/-- Forget the proof labels, retaining only the underlying labelled carrier. -/
def forget {S : SequentHypersequent}
    (G : ProofRelevantHypersequentOver S) : Hypersequent :=
  G.carrier

@[simp]
theorem forget_mk {S : SequentHypersequent}
    (G : Hypersequent) (hG : HQ.conclusions G = S) :
    forget (ProofRelevantHypersequentOver.mk G hG) = G := rfl

/-- The empty proof-labelled hypersequent lies over the empty sequent hypersequent. -/
def empty : ProofRelevantHypersequentOver (0 : SequentHypersequent) where
  carrier := 0
  shadow := by simp

@[simp]
theorem empty_carrier :
    (empty : ProofRelevantHypersequentOver (0 : SequentHypersequent)).carrier = 0 := rfl

/-- A proof tree is a one-component proof-labelled hypersequent over its conclusion. -/
def ofTree (t : PTree) :
    ProofRelevantHypersequentOver ({t.conclusion} : SequentHypersequent) where
  carrier := HQ.singleton t
  shadow := by simp

@[simp]
theorem ofTree_carrier (t : PTree) :
    (ofTree t).carrier = HQ.singleton t := rfl

/-- A bare sequent embeds as a one-component leaf-labelled hypersequent. -/
def ofSequent (s : MultiSequent) :
    ProofRelevantHypersequentOver ({s} : SequentHypersequent) where
  carrier := HQ.singleton (PTree.leaf s)
  shadow := by simp [HQ.conclusions, HQ.singleton, PTree.conclusion]

@[simp]
theorem ofSequent_carrier (s : MultiSequent) :
    (ofSequent s).carrier = HQ.singleton (PTree.leaf s) := rfl

/--
External juxtaposition of proof-relevant hypersequents refines ordinary
hypersequent juxtaposition.
-/
def add {S T : SequentHypersequent}
    (G : ProofRelevantHypersequentOver S)
    (H : ProofRelevantHypersequentOver T) :
    ProofRelevantHypersequentOver (S + T) where
  carrier := G.carrier + H.carrier
  shadow := by
    rw [HQ.conclusions_add, G.shadow, H.shadow]

@[simp]
theorem add_carrier {S T : SequentHypersequent}
    (G : ProofRelevantHypersequentOver S)
    (H : ProofRelevantHypersequentOver T) :
    (add G H).carrier = G.carrier + H.carrier := rfl

@[simp]
theorem add_empty_left {S : SequentHypersequent}
    (G : ProofRelevantHypersequentOver S) :
    (add empty G).carrier = G.carrier := by
  simp [add]

@[simp]
theorem add_empty_right {S : SequentHypersequent}
    (G : ProofRelevantHypersequentOver S) :
    (add G empty).carrier = G.carrier := by
  simp [add]

/-- Reindex a proof-relevant hypersequent along equality of shadows. -/
def castShadow {S T : SequentHypersequent}
    (h : S = T)
    (G : ProofRelevantHypersequentOver S) :
    ProofRelevantHypersequentOver T where
  carrier := G.carrier
  shadow := by
    rw [← h]
    exact G.shadow

@[simp]
theorem castShadow_carrier {S T : SequentHypersequent}
    (h : S = T)
    (G : ProofRelevantHypersequentOver S) :
    (castShadow h G).carrier = G.carrier := rfl

end ProofRelevantHypersequentOver

/-- Internal one-step grafting on proof trees. -/
def InternalGraft (u t v : PTree) : Prop :=
  ∃ a : Address, PTree.graftMatchingLeafAt u t a = some v

/--
An abstract policy controlling when external weakening is allowed.

This is intentionally lightweight. The current codebase already contains more
refined notions of monotonicity and admissible base update; the hypersequent
layer only needs to know which isolated components may be freely added as new
external resources.
-/
structure ExternalWeakeningPolicy where
  admissible : PTree → Prop

/--
The NMMS external weakening policy.

At the hypersequent level, NMMS does not allow arbitrary new proof-tree
components to be added as external resources.  Splitting, permutation, and
contraction are still structural rules, but weakening itself has no admissible
component under this minimal policy.
-/
def nmmsWeakeningPolicy : ExternalWeakeningPolicy where
  admissible := fun _ => False

@[simp]
theorem nmmsWeakeningPolicy_admissible (t : PTree) :
    nmmsWeakeningPolicy.admissible t = False := rfl

theorem nmmsWeakeningPolicy_no_admissible (t : PTree) :
    Not (nmmsWeakeningPolicy.admissible t) := by
  simp [nmmsWeakeningPolicy]

/--
Internal structural evolution acts within a single hypersequent component.

For now the only primitive internal step is replacing a host tree by a tree
obtained from it by one admissible graft.
-/
inductive InternalStep : Hypersequent → Hypersequent → Prop where
| graft
    (G : Hypersequent)
    (u t v : PTree)
    (hg : InternalGraft u t v) :
    InternalStep
      (G + HQ.singleton t)
      (G + HQ.singleton v)

/--
`[x]` is a sublist of `xs` whenever `x ∈ xs`.
-/
theorem singleton_sublist_of_mem {α : Type} {x : α} {xs : List α}
    (hx : x ∈ xs) :
    List.Sublist [x] xs := by
  induction xs with
  | nil =>
      cases hx
  | cons y ys ih =>
      simp at hx
      rcases hx with rfl | hx
      · simpa using (List.Sublist.cons₂ (List.Sublist.slnil : List.Sublist [] ys))
      · exact List.Sublist.cons _ (ih hx)

theorem List.eq_of_perm_of_sublist_of_sublist_nodup
    {α : Type} [DecidableEq α] {xs ys base : List α}
    (hperm : xs.Perm ys) (hxs : List.Sublist xs base) (hys : List.Sublist ys base)
    (hbase : base.Nodup) :
    xs = ys := by
  exact (List.Nodup.perm_iff_eq_of_sublist hbase hxs hys).1 hperm

theorem List.count_eq_count_of_lawfulBEq
    {α : Type} [BEq α] [LawfulBEq α] [DecidableEq α] (a : α) :
    ∀ xs : List α,
      @List.count α instBEqOfDecidableEq a xs =
        @List.count α (inferInstance : BEq α) a xs
  | [] => by simp
  | x :: xs => by
      have ih := List.count_eq_count_of_lawfulBEq a xs
      by_cases h : a = x
      · subst x
        rw [@List.count_cons_self α instBEqOfDecidableEq inferInstance,
          @List.count_cons_self α (inferInstance : BEq α) inferInstance]
        simpa [Nat.succ_eq_add_one] using congrArg Nat.succ ih
      · have hx : x ≠ a := h ∘ Eq.symm
        rw [@List.count_cons_of_ne α instBEqOfDecidableEq inferInstance
            (b := x) (a := a) hx,
          @List.count_cons_of_ne α (inferInstance : BEq α) inferInstance
            (b := x) (a := a) hx]
        exact ih

theorem List.nodup_flatMap_map_pair
    {α β : Type} [DecidableEq α] [DecidableEq β]
    {xs : List α} {ys : α → List β}
    (hxs : xs.Nodup)
    (hys : ∀ x, x ∈ xs → (ys x).Nodup) :
    (xs.flatMap (fun x => (ys x).map (fun y => (x, y)))).Nodup := by
  rw [List.nodup_flatMap]
  constructor
  · intro x hx
    exact (hys x hx).map
      (fun a b h => congrArg Prod.snd h)
  · refine hxs.imp ?_
    intro x y hxy z hzx hzy
    rcases List.mem_map.1 hzx with ⟨a, _ha, rfl⟩
    rcases List.mem_map.1 hzy with ⟨b, _hb, hEq⟩
    exact hxy (congrArg Prod.fst hEq).symm

/--
The singleton root cut is always admissible.

This is the proof-theoretic top split: prune off the whole component and leave
its conclusion leaf as the residual interface.
-/
theorem singleton_root_cut_mem_allAdmissibleCuts (t : PTree) :
    ([([] : Address)] : List Address) ∈ PTree.allAdmissibleCuts t := by
  apply PTree.mem_allAdmissibleCuts_of_sublist_valid_antichain
  · exact singleton_sublist_of_mem (PTree.root_mem_allAddresses t)
  · simp
  · intro a ha
    simp at ha
    simpa [ha] using PTree.validAddress_root t
  · intro a ha b hb hab
    simp at ha hb
    subst a
    subst b
    exact False.elim (hab rfl)

/-- The empty admissible cut. -/
noncomputable def emptyCut (t : PTree) : PTree.IsAdmissibleCut t :=
  PTree.isAdmissibleCut_of_mem_allAdmissibleCuts (PTree.empty_cut_mem_allAdmissibleCuts t)

/-- The top/root admissible cut. -/
noncomputable def rootCut (t : PTree) : PTree.IsAdmissibleCut t :=
  PTree.isAdmissibleCut_of_mem_allAdmissibleCuts (singleton_root_cut_mem_allAdmissibleCuts t)

@[simp] theorem emptyCut_nodes (t : PTree) : (emptyCut t).nodes = [] := rfl

@[simp] theorem rootCut_nodes (t : PTree) :
    (rootCut t).nodes = [([] : Address)] := rfl

/--
A tree splits externally into a hypersequent of pruned components and a single
remainder tree.
-/
def SplitsTo (t : PTree) (Γ : Hypersequent) (r : PTree) : Prop :=
  ∃ cut : PTree.IsAdmissibleCut t,
    HQ.ofForest (PTree.pruned t cut) = Γ ∧
    PTree.remainder t cut = r

/-- The empty split is the identity split. -/
theorem splitsTo_empty (t : PTree) :
    SplitsTo t 0 t := by
  refine ⟨emptyCut t, ?_, ?_⟩
  · rw [PTree.pruned, emptyCut_nodes]
    simp [HQ.ofForest]
  · rw [PTree.remainder, emptyCut_nodes]
    simp [PTree.remainderGo_nil]

/--
The root split removes the whole component and leaves its conclusion leaf as
interface.
-/
theorem splitsTo_root (t : PTree) :
    SplitsTo t (HQ.singleton t) (PTree.leaf t.conclusion) := by
  refine ⟨rootCut t, ?_, ?_⟩
  · cases t with
    | leaf s =>
        rw [PTree.pruned, rootCut_nodes]
        simp [HQ.ofForest, HQ.singleton, PTree.subtreeAt_root]
    | node r s cs =>
        rw [PTree.pruned, rootCut_nodes]
        simp [HQ.ofForest, HQ.singleton, PTree.subtreeAt_root]
  · cases t with
    | leaf s =>
        rw [PTree.remainder, rootCut_nodes]
        simp [PTree.remainderGo, PTree.conclusion]
    | node r s cs =>
        rw [PTree.remainder, rootCut_nodes]
        simp [PTree.remainderGo, PTree.conclusion]

/-- Node-specialized form of the root split. -/
theorem splitsTo_root_node
    (r : RuleTag) (s : MultiSequent) (cs : List PTree) :
    SplitsTo (PTree.node r s cs)
      (HQ.singleton (PTree.node r s cs))
      (PTree.leaf s) := by
  simpa using splitsTo_root (PTree.node r s cs)

/--
The explicit list support of the splitting coproduct, now read as a
hypersequent/tree support.
-/
def splittingSupport (t : PTree) : List (Hypersequent × PTree) :=
  (PTree.coproductData t).map (fun fr => (HQ.ofForest fr.1, fr.2))

/-- The identity split is always present in the support. -/
theorem splittingSupport_contains_identity (t : PTree) :
    (0, t) ∈ splittingSupport t := by
  unfold splittingSupport PTree.coproductData
  apply List.mem_map.2
  refine ⟨PTree.coproductTerm t [], ?_, ?_⟩
  · apply List.mem_map.2
    refine ⟨[], PTree.empty_cut_mem_allAdmissibleCuts t, ?_⟩
    simp
  · simp [HQ.ofForest, PTree.coproductTerm_nil]

/-- The root split is always present in the support. -/
theorem splittingSupport_contains_root (t : PTree) :
    (HQ.singleton t, PTree.leaf t.conclusion) ∈ splittingSupport t := by
  unfold splittingSupport PTree.coproductData
  apply List.mem_map.2
  refine ⟨PTree.coproductTerm t [[]], ?_, ?_⟩
  · apply List.mem_map.2
    refine ⟨[[]], singleton_root_cut_mem_allAdmissibleCuts t, ?_⟩
    simp
  · cases t with
    | leaf s =>
        simp [HQ.ofForest, HQ.singleton, PTree.coproductTerm, PTree.subtreeAt_root,
          PTree.remainderGo, PTree.conclusion]
    | node r s cs =>
        simp [HQ.ofForest, HQ.singleton, PTree.coproductTerm_singleton_root_node,
          PTree.conclusion]

theorem splittingSupport_nonempty (t : PTree) :
    0 < (splittingSupport t).length := by
  exact List.length_pos_of_mem (splittingSupport_contains_identity t)

/--
Finite support of the hypersequent splitting coproduct.

At this stage we keep only the support, not coefficients. The current
admissible-cut enumerator is already finite, so the natural first wrapper is a
`Finset` of hypersequent/tree split terms.
-/
noncomputable def splittingCoproductSupport (t : PTree) : Finset (Hypersequent × PTree) :=
  (splittingSupport t).toFinset

theorem mem_splittingCoproductSupport_iff
    {t : PTree} {p : Hypersequent × PTree} :
    p ∈ splittingCoproductSupport t ↔ p ∈ splittingSupport t := by
  simp [splittingCoproductSupport]

@[simp] theorem splittingCoproductSupport_contains_identity (t : PTree) :
    (0, t) ∈ splittingCoproductSupport t := by
  exact (mem_splittingCoproductSupport_iff).2 (splittingSupport_contains_identity t)

@[simp] theorem splittingCoproductSupport_contains_root (t : PTree) :
    (HQ.singleton t, PTree.leaf t.conclusion) ∈ splittingCoproductSupport t := by
  exact (mem_splittingCoproductSupport_iff).2 (splittingSupport_contains_root t)

/--
Every explicit support term of the splitting coproduct comes from a genuine
admissible split.
-/
theorem splitsTo_of_mem_splittingSupport
    {t : PTree} {p : Hypersequent × PTree}
    (hp : p ∈ splittingSupport t) :
    SplitsTo t p.1 p.2 := by
  unfold splittingSupport at hp
  rcases List.mem_map.mp hp with ⟨fr, hfr, rfl⟩
  unfold PTree.coproductData at hfr
  rcases List.mem_map.mp hfr with ⟨cut, hcut, rfl⟩
  refine ⟨PTree.isAdmissibleCut_of_mem_allAdmissibleCuts hcut, ?_, ?_⟩
  · have hnodes :
        (PTree.isAdmissibleCut_of_mem_allAdmissibleCuts hcut).nodes = cut := rfl
    simpa [HQ.ofForest, PTree.pruned, PTree.coproductTerm, hnodes]
  · change
      PTree.remainderGo
        (PTree.isAdmissibleCut_of_mem_allAdmissibleCuts hcut).nodes [] t =
      PTree.remainderGo cut [] t
    rfl

/--
Conversely, every enumerated admissible cut contributes its hypersequent split
term to the support.
-/
theorem mem_splittingSupport_of_mem_allAdmissibleCuts
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ PTree.allAdmissibleCuts t) :
    (HQ.ofForest (cut.filterMap (PTree.subtreeAt t)),
      PTree.remainderGo cut [] t) ∈ splittingSupport t := by
  unfold splittingSupport PTree.coproductData
  apply List.mem_map.2
  refine ⟨PTree.coproductTerm t cut, ?_, ?_⟩
  · apply List.mem_map.2
    exact ⟨cut, hcut, rfl⟩
  · simp [PTree.coproductTerm, HQ.ofForest]

/--
Finite-support version of the previous theorem.
-/
theorem mem_splittingCoproductSupport_of_mem_allAdmissibleCuts
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ PTree.allAdmissibleCuts t) :
    (HQ.ofForest (cut.filterMap (PTree.subtreeAt t)),
      PTree.remainderGo cut [] t) ∈ splittingCoproductSupport t := by
  exact (mem_splittingCoproductSupport_iff).2
    (mem_splittingSupport_of_mem_allAdmissibleCuts hcut)

/--
External structural evolution acts between hypersequent components.

- permutation is already built into the multiset carrier, but we still record it
  as a proof step;
- contraction is always allowed externally;
- weakening is controlled by an explicit policy;
- splitting is the new external rule induced by admissible cuts.
-/
inductive ExternalStep (W : ExternalWeakeningPolicy) :
    Hypersequent → Hypersequent → Prop where
| perm
    {G H : Hypersequent}
    (h : G = H) :
    ExternalStep W G H
| contraction
    (G : Hypersequent)
    (t : PTree) :
    ExternalStep W
      (G + HQ.singleton t + HQ.singleton t)
      (G + HQ.singleton t)
| weakening
    (G : Hypersequent)
    (t : PTree)
    (ht : W.admissible t) :
    ExternalStep W G (G + HQ.singleton t)
| split
    (G : Hypersequent)
    (t : PTree)
    (Γ : Hypersequent)
    (r : PTree)
    (hs : SplitsTo t Γ r) :
    ExternalStep W
      (G + HQ.singleton t)
      (G + Γ + HQ.singleton r)

/-- External structural evolution under the minimal NMMS weakening policy. -/
abbrev NMMSExternalStep : Hypersequent → Hypersequent → Prop :=
  ExternalStep nmmsWeakeningPolicy

/-- Cutting nothing yields a tautological external step. -/
theorem externalStep_split_empty
    (W : ExternalWeakeningPolicy)
    (G : Hypersequent)
    (t : PTree) :
    ExternalStep W
      (G + HQ.singleton t)
      (G + HQ.singleton t) := by
  simpa [add_assoc] using
    (ExternalStep.split (W := W) G t 0 t (splitsTo_empty t))

/--
The top split is always available externally: detach the whole component and
replace the original host by its interface leaf.
-/
theorem externalStep_split_root
    (W : ExternalWeakeningPolicy)
    (G : Hypersequent)
    (t : PTree) :
    ExternalStep W
      (G + HQ.singleton t)
      (G + HQ.singleton t + HQ.singleton (PTree.leaf t.conclusion)) := by
  exact
    ExternalStep.split (W := W)
      G t (HQ.singleton t) (PTree.leaf t.conclusion) (splitsTo_root t)

/-- Node-specialized top split. -/
theorem externalStep_split_root_node
    (W : ExternalWeakeningPolicy)
    (G : Hypersequent)
    (r : RuleTag) (s : MultiSequent) (cs : List PTree) :
    ExternalStep W
      (G + HQ.singleton (PTree.node r s cs))
      (G + HQ.singleton (PTree.node r s cs) + HQ.singleton (PTree.leaf s)) := by
  simpa using externalStep_split_root W G (PTree.node r s cs)

/--
Any explicit term of the splitting support induces an external splitting step on
the surrounding hypersequent.
-/
theorem externalStep_of_mem_splittingSupport
    (W : ExternalWeakeningPolicy)
    (G : Hypersequent)
    {t : PTree} {p : Hypersequent × PTree}
    (hp : p ∈ splittingSupport t) :
    ExternalStep W
      (G + HQ.singleton t)
      (G + p.1 + HQ.singleton p.2) := by
  exact ExternalStep.split (W := W) G t p.1 p.2
    (splitsTo_of_mem_splittingSupport hp)

/--
Finite-support version: any term in the splitting coproduct support gives an
external splitting step.
-/
theorem externalStep_of_mem_splittingCoproductSupport
    (W : ExternalWeakeningPolicy)
    (G : Hypersequent)
    {t : PTree} {p : Hypersequent × PTree}
    (hp : p ∈ splittingCoproductSupport t) :
    ExternalStep W
      (G + HQ.singleton t)
      (G + p.1 + HQ.singleton p.2) := by
  exact externalStep_of_mem_splittingSupport W G
    ((mem_splittingCoproductSupport_iff).1 hp)

/--
The identity and top-interface terms are always available in the finite support.
-/
theorem externalStep_split_identity_from_support
    (W : ExternalWeakeningPolicy)
    (G : Hypersequent)
    (t : PTree) :
    ExternalStep W
      (G + HQ.singleton t)
      (G + 0 + HQ.singleton t) := by
  exact externalStep_of_mem_splittingCoproductSupport W G
    (splittingCoproductSupport_contains_identity t)

theorem externalStep_split_root_from_support
    (W : ExternalWeakeningPolicy)
    (G : Hypersequent)
    (t : PTree) :
    ExternalStep W
      (G + HQ.singleton t)
      (G + HQ.singleton t + HQ.singleton (PTree.leaf t.conclusion)) := by
  exact externalStep_of_mem_splittingCoproductSupport W G
    (splittingCoproductSupport_contains_root t)

/--
The reduced splitting support removes the identity term `(0, t)` and retains
only genuinely detaching cuts.
-/
noncomputable def reducedSplittingSupport (t : PTree) : List (Hypersequent × PTree) :=
  (splittingSupport t).filter (fun p => p.1 ≠ 0)

theorem mem_reducedSplittingSupport_iff
    {t : PTree} {p : Hypersequent × PTree} :
    p ∈ reducedSplittingSupport t ↔ p ∈ splittingSupport t ∧ p.1 ≠ 0 := by
  unfold reducedSplittingSupport
  simp

theorem identity_not_mem_reducedSplittingSupport (t : PTree) :
    (0, t) ∉ reducedSplittingSupport t := by
  rw [mem_reducedSplittingSupport_iff]
  simp

theorem mem_reducedSplittingSupport_of_mem_splittingSupport_of_left_ne_zero
    {t : PTree} {p : Hypersequent × PTree}
    (hp : p ∈ splittingSupport t)
    (hΓ : p.1 ≠ 0) :
    p ∈ reducedSplittingSupport t := by
  exact (mem_reducedSplittingSupport_iff).2 ⟨hp, hΓ⟩

theorem mem_splittingSupport_of_mem_reducedSplittingSupport
    {t : PTree} {p : Hypersequent × PTree}
    (hp : p ∈ reducedSplittingSupport t) :
    p ∈ splittingSupport t := by
  exact (mem_reducedSplittingSupport_iff).1 hp |>.1

theorem left_ne_zero_of_mem_reducedSplittingSupport
    {t : PTree} {p : Hypersequent × PTree}
    (hp : p ∈ reducedSplittingSupport t) :
    p.1 ≠ 0 := by
  exact (mem_reducedSplittingSupport_iff).1 hp |>.2

@[simp] theorem singleton_ne_zero (t : PTree) :
    HQ.singleton t ≠ 0 := by
  simp [HQ.singleton]

theorem reducedSplittingSupport_contains_root (t : PTree) :
    (HQ.singleton t, PTree.leaf t.conclusion) ∈ reducedSplittingSupport t := by
  apply mem_reducedSplittingSupport_of_mem_splittingSupport_of_left_ne_zero
  · exact splittingSupport_contains_root t
  · simpa using (singleton_ne_zero t)

theorem reducedSplittingSupport_nonempty (t : PTree) :
    0 < (reducedSplittingSupport t).length := by
  exact List.length_pos_of_mem (reducedSplittingSupport_contains_root t)

theorem ofForest_ne_zero_of_mem
    {f : Forest} {u : PTree}
    (hu : u ∈ f) :
    HQ.ofForest f ≠ 0 := by
  intro hf
  have hnil : f = [] := by
    simpa [HQ.ofForest] using hf
  simpa [hnil] using hu

theorem pruned_hypersequent_ne_zero_of_cut_ne_nil
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ PTree.allAdmissibleCuts t)
    (hneq : cut ≠ []) :
    HQ.ofForest (cut.filterMap (PTree.subtreeAt t)) ≠ 0 := by
  cases cut with
  | nil =>
      cases (hneq rfl)
  | cons a rest =>
      have ha : a ∈ a :: rest := by simp
      have hvalid : PTree.ValidAddress t a := by
        exact (PTree.isAdmissibleCut_of_mem_allAdmissibleCuts hcut).valid a ha
      rcases (PTree.valid_iff_exists_subtree t a).1 hvalid with ⟨u, hu⟩
      have hmem : u ∈ (a :: rest).filterMap (PTree.subtreeAt t) := by
        exact List.mem_filterMap.2 ⟨a, ha, hu⟩
      exact ofForest_ne_zero_of_mem hmem

noncomputable def reducedSplittingCoproductSupport (t : PTree) :
    Finset (Hypersequent × PTree) :=
  (reducedSplittingSupport t).toFinset

theorem mem_reducedSplittingCoproductSupport_iff
    {t : PTree} {p : Hypersequent × PTree} :
    p ∈ reducedSplittingCoproductSupport t ↔ p ∈ reducedSplittingSupport t := by
  simp [reducedSplittingCoproductSupport]

theorem mem_splittingCoproductSupport_of_mem_reducedSplittingCoproductSupport
    {t : PTree} {p : Hypersequent × PTree}
    (hp : p ∈ reducedSplittingCoproductSupport t) :
    p ∈ splittingCoproductSupport t := by
  exact (mem_splittingCoproductSupport_iff).2
    (mem_splittingSupport_of_mem_reducedSplittingSupport
      ((mem_reducedSplittingCoproductSupport_iff).1 hp))

theorem identity_not_mem_reducedSplittingCoproductSupport (t : PTree) :
    (0, t) ∉ reducedSplittingCoproductSupport t := by
  intro h
  exact identity_not_mem_reducedSplittingSupport t
    ((mem_reducedSplittingCoproductSupport_iff).1 h)

theorem reducedSplittingCoproductSupport_contains_root (t : PTree) :
    (HQ.singleton t, PTree.leaf t.conclusion) ∈ reducedSplittingCoproductSupport t := by
  exact (mem_reducedSplittingCoproductSupport_iff).2
    (reducedSplittingSupport_contains_root t)

/--
A nontrivial split is an admissible split with a genuinely detached
hypersequent component.
-/
def NontrivialSplitsTo (t : PTree) (Γ : Hypersequent) (r : PTree) : Prop :=
  SplitsTo t Γ r ∧ Γ ≠ 0

theorem nontrivialSplitsTo_of_mem_reducedSplittingSupport
    {t : PTree} {p : Hypersequent × PTree}
    (hp : p ∈ reducedSplittingSupport t) :
    NontrivialSplitsTo t p.1 p.2 := by
  refine ⟨?_, ?_⟩
  · exact splitsTo_of_mem_splittingSupport
      (mem_splittingSupport_of_mem_reducedSplittingSupport hp)
  · exact left_ne_zero_of_mem_reducedSplittingSupport hp

theorem mem_reducedSplittingSupport_of_mem_allAdmissibleCuts_of_ne_nil
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ PTree.allAdmissibleCuts t)
    (hneq : cut ≠ []) :
    (HQ.ofForest (cut.filterMap (PTree.subtreeAt t)),
      PTree.remainderGo cut [] t) ∈ reducedSplittingSupport t := by
  apply mem_reducedSplittingSupport_of_mem_splittingSupport_of_left_ne_zero
  · exact mem_splittingSupport_of_mem_allAdmissibleCuts hcut
  · exact pruned_hypersequent_ne_zero_of_cut_ne_nil hcut hneq

theorem mem_reducedSplittingCoproductSupport_of_mem_allAdmissibleCuts_of_ne_nil
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ PTree.allAdmissibleCuts t)
    (hneq : cut ≠ []) :
    (HQ.ofForest (cut.filterMap (PTree.subtreeAt t)),
      PTree.remainderGo cut [] t) ∈ reducedSplittingCoproductSupport t := by
  exact (mem_reducedSplittingCoproductSupport_iff).2
    (mem_reducedSplittingSupport_of_mem_allAdmissibleCuts_of_ne_nil hcut hneq)

theorem externalStep_of_mem_reducedSplittingSupport
    (W : ExternalWeakeningPolicy)
    (G : Hypersequent)
    {t : PTree} {p : Hypersequent × PTree}
    (hp : p ∈ reducedSplittingSupport t) :
    ExternalStep W
      (G + HQ.singleton t)
      (G + p.1 + HQ.singleton p.2) := by
  exact externalStep_of_mem_splittingSupport W G
    (mem_splittingSupport_of_mem_reducedSplittingSupport hp)

theorem externalStep_of_mem_reducedSplittingCoproductSupport
    (W : ExternalWeakeningPolicy)
    (G : Hypersequent)
    {t : PTree} {p : Hypersequent × PTree}
    (hp : p ∈ reducedSplittingCoproductSupport t) :
    ExternalStep W
      (G + HQ.singleton t)
      (G + p.1 + HQ.singleton p.2) := by
  exact externalStep_of_mem_reducedSplittingSupport W G
    ((mem_reducedSplittingCoproductSupport_iff).1 hp)

theorem externalStep_of_mem_allAdmissibleCuts_of_ne_nil
    (W : ExternalWeakeningPolicy)
    (G : Hypersequent)
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ PTree.allAdmissibleCuts t)
    (hneq : cut ≠ []) :
    ExternalStep W
      (G + HQ.singleton t)
      (G + HQ.ofForest (cut.filterMap (PTree.subtreeAt t))
        + HQ.singleton (PTree.remainderGo cut [] t)) := by
  exact externalStep_of_mem_reducedSplittingCoproductSupport W G
    (mem_reducedSplittingCoproductSupport_of_mem_allAdmissibleCuts_of_ne_nil hcut hneq)

theorem externalStep_split_root_from_reduced_support
    (W : ExternalWeakeningPolicy)
    (G : Hypersequent)
    (t : PTree) :
    ExternalStep W
      (G + HQ.singleton t)
      (G + HQ.singleton t + HQ.singleton (PTree.leaf t.conclusion)) := by
  exact externalStep_of_mem_reducedSplittingCoproductSupport W G
    (reducedSplittingCoproductSupport_contains_root t)

/-!
## Graft-boundary cut geometry

The first coherence theorems need to separate a cut of a grafted tree into the
part that lives inside the inserted subtree and the part that stays in the host
away from the graft site.

The insert-side projection already exists in the base infrastructure as
`PTree.restrictCutAt`.  We therefore add only thin hypersequent-facing wrappers
and the first structural lemmas around them.
-/

/--
`BoundaryFreeAt cut a` means that no cut address lies on or above the graft
site `a`.

This is the exact extra hypothesis needed to turn the general address
trichotomy into the simpler host-vs-insert dichotomy used by the coherence
lemmas.
-/
def BoundaryFreeAt (cut : List Address) (a : Address) : Prop :=
  ∀ b ∈ cut, ¬ PTree.isAncestorOf b a

/--
The insert-side part of a cut at graft address `a`, stripped of the common
prefix `a`.

This is just the existing `restrictCutAt` operation.
-/
def cutInsertPart (cut : List Address) (a : Address) : List Address :=
  PTree.restrictCutAt cut a

/--
The host-side part of a cut at graft address `a`: addresses that are genuinely
away from the graft boundary, i.e. incomparable with `a`.
-/
def cutHostPart (cut : List Address) (a : Address) : List Address :=
  cut.filter (fun b => !PTree.comparableBool a b)

theorem mem_cutInsertPart_iff
    {cut : List Address} {a c : Address} :
    c ∈ cutInsertPart cut a ↔ a ++ c ∈ cut := by
  simpa [cutInsertPart] using
    (PTree.mem_restrictCutAt_iff (cut := cut) (pfx := a) (addr := c))

@[simp] theorem nil_mem_cutInsertPart_iff
    {cut : List Address} {a : Address} :
    [] ∈ cutInsertPart cut a ↔ a ∈ cut := by
  simpa [cutInsertPart] using
    (PTree.nil_mem_restrictCutAt_iff (cut := cut) (pfx := a))

theorem mem_cutHostPart_iff
    {cut : List Address} {a b : Address} :
    b ∈ cutHostPart cut a ↔ b ∈ cut ∧ ¬ PTree.comparable a b := by
  unfold cutHostPart
  rw [List.mem_filter]
  constructor
  · intro h
    rcases h with ⟨hb, hbool⟩
    refine ⟨hb, ?_⟩
    intro hcomp
    have : PTree.comparableBool a b = true :=
      (PTree.comparableBool_eq_true_iff_comparable a b).2 hcomp
    simp [this] at hbool
  · intro h
    rcases h with ⟨hb, hcomp⟩
    refine ⟨hb, ?_⟩
    cases hc : PTree.comparableBool a b <;> simp [hc]
    exfalso
    exact hcomp ((PTree.comparableBool_eq_true_iff_comparable a b).1 hc)

theorem cutHostPart_sublist (cut : List Address) (a : Address) :
    List.Sublist (cutHostPart cut a) cut := by
  induction cut with
  | nil =>
      simp [cutHostPart]
  | cons b bs ih =>
      by_cases hb : !PTree.comparableBool a b = true
      · simpa [cutHostPart, hb] using (List.Sublist.cons₂ ih)
      · simpa [cutHostPart, hb] using (List.Sublist.cons _ ih)

theorem mem_cutHostPart_of_mem_of_incomparable
    {cut : List Address} {a b : Address}
    (hb : b ∈ cut)
    (hinc : ¬ PTree.comparable a b) :
    b ∈ cutHostPart cut a := by
  exact (mem_cutHostPart_iff).2 ⟨hb, hinc⟩

theorem mem_cut_of_mem_cutHostPart
    {cut : List Address} {a b : Address}
    (hb : b ∈ cutHostPart cut a) :
    b ∈ cut := by
  exact (mem_cutHostPart_iff).1 hb |>.1

theorem incomparable_of_mem_cutHostPart
    {cut : List Address} {a b : Address}
    (hb : b ∈ cutHostPart cut a) :
    ¬ PTree.comparable a b := by
  exact (mem_cutHostPart_iff).1 hb |>.2

theorem boundaryFreeAt_mono
    {cut cut' : List Address} {a : Address}
    (hsub : List.Sublist cut cut')
    (hfree : BoundaryFreeAt cut' a) :
    BoundaryFreeAt cut a := by
  intro b hb
  exact hfree b (hsub.subset hb)

/--
Any address in a boundary-free cut is either on/below the graft site or
incomparable with it.

This is the corrected form of the naive statement "extends or incomparable":
without `BoundaryFreeAt`, admissible cuts may still contain ancestor addresses
such as the root cut.
-/
theorem cut_address_extends_or_incomparable_of_boundaryFree
    {cut : List Address} {a b : Address}
    (hfree : BoundaryFreeAt cut a)
    (hb : b ∈ cut) :
    PTree.isAncestorOf a b ∨ ¬ PTree.comparable a b := by
  by_cases hcomp : PTree.comparable a b
  · cases hcomp with
    | inl hab =>
        exact Or.inl hab
    | inr hba =>
        exact False.elim (hfree b hb hba)
  · exact Or.inr hcomp

theorem cut_address_extends_or_mem_cutHostPart_of_boundaryFree
    {cut : List Address} {a b : Address}
    (hfree : BoundaryFreeAt cut a)
    (hb : b ∈ cut) :
    (∃ c, b = a ++ c) ∨ b ∈ cutHostPart cut a := by
  rcases cut_address_extends_or_incomparable_of_boundaryFree hfree hb with hab | hinc
  · rcases hab with ⟨c, hc⟩
    exact Or.inl ⟨c, hc⟩
  · exact Or.inr ((mem_cutHostPart_iff).2 ⟨hb, hinc⟩)

theorem cutInsertPart_complete_of_boundaryFree
    {cut : List Address} {a b : Address}
    (hfree : BoundaryFreeAt cut a)
    (hb : b ∈ cut)
    (hcomp : PTree.comparable a b) :
    ∃ c, c ∈ cutInsertPart cut a ∧ b = a ++ c := by
  rcases cut_address_extends_or_incomparable_of_boundaryFree hfree hb with hab | hinc
  · rcases hab with ⟨c, hc⟩
    refine ⟨c, ?_, hc⟩
    subst b
    exact (mem_cutInsertPart_iff).2 hb
  · exact False.elim (hinc hcomp)

theorem cutHostPart_complete_of_boundaryFree
    {cut : List Address} {a b : Address}
    (_hfree : BoundaryFreeAt cut a)
    (hb : b ∈ cut)
    (hinc : ¬ PTree.comparable a b) :
    b ∈ cutHostPart cut a := by
  exact (mem_cutHostPart_iff).2 ⟨hb, hinc⟩

/--
Admissible cuts restrict along an arbitrary valid subtree address.

This is the recursive version of `PTree.isAdmissibleCut_restrictCut`, built by
walking down the address prefix one child at a time.
-/
def admissibleCut_restrictCutAt
    {t u : PTree}
    (cut : PTree.IsAdmissibleCut t)
    (a : Address)
    (hsub : PTree.subtreeAt t a = some u) :
    PTree.IsAdmissibleCut u := by
  induction a generalizing t u with
  | nil =>
      simp [PTree.subtreeAt] at hsub
      subst u
      exact cut
  | cons i rest ih =>
      cases t with
      | leaf s =>
          simp [PTree.subtreeAt] at hsub
      | node r s cs =>
          by_cases hi : i < cs.length
          · have hchild : PTree.subtreeAt cs[i] rest = some u := by
              simp [PTree.subtreeAt, hi] at hsub
              exact hsub
            exact ih (PTree.isAdmissibleCut_restrictCut cut i hi) hchild
          · simp [PTree.subtreeAt, hi] at hsub

@[simp] theorem admissibleCut_restrictCutAt_nodes
    {t u : PTree}
    (cut : PTree.IsAdmissibleCut t)
    (a : Address)
    (hsub : PTree.subtreeAt t a = some u) :
    (admissibleCut_restrictCutAt cut a hsub).nodes = cutInsertPart cut.nodes a := by
  induction a generalizing t u cut with
  | nil =>
      simp [admissibleCut_restrictCutAt, cutInsertPart, PTree.restrictCutAt] at hsub ⊢
      cases hsub
      rfl
  | cons i rest ih =>
      cases t with
      | leaf s =>
          simp [PTree.subtreeAt] at hsub
      | node r s cs =>
          by_cases hi : i < cs.length
          · have hchild : PTree.subtreeAt cs[i] rest = some u := by
              simp [PTree.subtreeAt, hi] at hsub
              exact hsub
            simpa [admissibleCut_restrictCutAt, cutInsertPart, PTree.restrictCutAt, hi] using
              ih (cut := PTree.isAdmissibleCut_restrictCut cut i hi) (hsub := hchild)
          · simp [PTree.subtreeAt, hi] at hsub

/--
If a cut address lies inside the graft branch, its stripped address belongs to
the insert-side part.
-/
theorem mem_cutInsertPart_of_mem_of_eq_append
    {cut : List Address} {a b c : Address}
    (hb : b ∈ cut)
    (hba : b = a ++ c) :
    c ∈ cutInsertPart cut a := by
  exact (mem_cutInsertPart_iff).2 (by simpa [hba] using hb)

/--
Every insert-side address corresponds to an original cut address obtained by
re-attaching the graft prefix.
-/
theorem mem_cut_of_mem_cutInsertPart
    {cut : List Address} {a c : Address}
    (hc : c ∈ cutInsertPart cut a) :
    a ++ c ∈ cut := by
  exact (mem_cutInsertPart_iff).1 hc

/--
The root of the insert-side cut appears exactly when the original cut contains
the graft address itself.
-/
theorem cutInsertPart_contains_root_iff
    {cut : List Address} {a : Address} :
    [] ∈ cutInsertPart cut a ↔ a ∈ cut := by
  simpa using (nil_mem_cutInsertPart_iff (cut := cut) (a := a))

/--
Reassemble a cut from its host-side and insert-side pieces at prefix `a`.

This is the list-level inverse shape suggested by the boundary-free partition
theorem: keep the addresses incomparable with `a`, and reattach `a` to the
restricted insert-side addresses.
-/
def reassembleCutAt (cut : List Address) (a : Address) : List Address :=
  cutHostPart cut a ++ (cutInsertPart cut a).map (fun c => a ++ c)

theorem mem_reassembleCutAt_iff_of_boundaryFree
    {cut : List Address} {a b : Address}
    (hfree : BoundaryFreeAt cut a) :
    b ∈ reassembleCutAt cut a ↔ b ∈ cut := by
  unfold reassembleCutAt
  constructor
  · intro hb
    rw [List.mem_append] at hb
    rcases hb with hhost | hins
    · exact mem_cut_of_mem_cutHostPart hhost
    · rcases List.mem_map.1 hins with ⟨c, hc, hbc⟩
      rw [← hbc]
      exact mem_cut_of_mem_cutInsertPart hc
  · intro hb
    rcases cut_address_extends_or_mem_cutHostPart_of_boundaryFree hfree hb with
      ⟨c, rfl⟩ | hhost
    · exact List.mem_append.2 <| Or.inr <|
        List.mem_map.2 ⟨c, (mem_cutInsertPart_iff).2 hb, rfl⟩
    · exact List.mem_append.2 <| Or.inl hhost

/-!
## Host-side and insert-side admissible cuts of a grafted tree

Given `v = graftMatchingLeafAt u t a` and a `BoundaryFreeAt` admissible cut `C`
of `v`, we construct admissible cuts of `t` (host side) and `u` (insert side)
separately, and transfer subtree data across the graft.
-/

/--
The host-side addresses of a boundary-free cut of `v = graft(u, t, a)` form an
admissible cut of the host tree `t`.

Validity transfers because incomparable addresses have identical subtrees in `v`
and `t` (`subtreeAt_graftMatchingLeafAt_of_not_comparable`).  The antichain
property is inherited from the original cut since `cutHostPart` is a sublist.
-/
def hostSideCut
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) :
    PTree.IsAdmissibleCut t where
  nodes := cutHostPart cut.nodes a
  valid := fun b hb => by
    have hbv  := mem_cut_of_mem_cutHostPart hb
    have hinc := incomparable_of_mem_cutHostPart hb
    rw [PTree.valid_iff_exists_subtree]
    obtain ⟨w, hw⟩ := (PTree.valid_iff_exists_subtree _ _).mp (cut.valid b hbv)
    exact ⟨w, by rwa [← subtreeAt_graftMatchingLeafAt_of_not_comparable u t a b v hg hinc]⟩
  antichain := fun b hb c hc hbc =>
    cut.antichain b (mem_cut_of_mem_cutHostPart hb)
                  c (mem_cut_of_mem_cutHostPart hc) hbc

/--
For any host-side cut address `b` (incomparable to `a`), the subtree of the
grafted tree `v` at `b` equals the subtree of `t` at `b`.
-/
theorem subtreeAt_v_eq_subtreeAt_t_of_hostSide
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    {b : Address}
    (hb : b ∈ cutHostPart cut.nodes a) :
    PTree.subtreeAt v b = PTree.subtreeAt t b :=
  subtreeAt_graftMatchingLeafAt_of_not_comparable u t a b v hg
    (incomparable_of_mem_cutHostPart hb)

/--
For any insert-side cut address `c`, the subtree of the grafted tree `v` at
`a ++ c` equals the subtree of the inserted tree `u` at `c`.
-/
theorem subtreeAt_v_eq_subtreeAt_u_of_insertSide
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (_cut : PTree.IsAdmissibleCut v)
    {c : Address} :
    PTree.subtreeAt v (a ++ c) = PTree.subtreeAt u c :=
  subtreeAt_graftMatchingLeafAt_append u t a c v hg

/--
The nodes of the host-side admissible cut are exactly `cutHostPart cut.nodes a`.
-/
@[simp]
theorem hostSideCut_nodes
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) :
    (hostSideCut hg cut hfree).nodes = cutHostPart cut.nodes a :=
  rfl

/--
The insert-side admissible cut of `u`, obtained by restricting `cut` to
addresses that extend `a` and stripping the prefix.

This is `admissibleCut_restrictCutAt` applied at the graft address, using
`subtreeAt_graftMatchingLeafAt_self` to obtain `subtreeAt v a = some u`.
-/
def insertSideCut
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v) :
    PTree.IsAdmissibleCut u :=
  admissibleCut_restrictCutAt cut a (subtreeAt_graftMatchingLeafAt_self u t a v hg)

/--
The nodes of the insert-side cut equal `cutInsertPart cut.nodes a`.
-/
theorem insertSideCut_nodes
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v) :
    (insertSideCut hg cut).nodes = cutInsertPart cut.nodes a := by
  simpa [insertSideCut] using
    admissibleCut_restrictCutAt_nodes cut a
      (subtreeAt_graftMatchingLeafAt_self u t a v hg)

/--
Every boundary-free cut address is accounted for by either the host or insert
side.

The statement uses explicit `Or`/`Exists`/`And` to avoid the object-language
connective notation imported from `Syntax`.
-/
theorem cut_nodes_partition_of_boundaryFree
    {cut : List Address} {a b : Address}
    (hfree : BoundaryFreeAt cut a)
    (hb : List.Mem b cut) :
    Or (List.Mem b (cutHostPart cut a))
      (Exists fun c => And (List.Mem c (cutInsertPart cut a)) (b = a ++ c)) := by
  rcases cut_address_extends_or_mem_cutHostPart_of_boundaryFree hfree hb with h | hhost
  · rcases h with ⟨c, hc⟩
    exact Or.inr ⟨c, And.intro ((mem_cutInsertPart_iff).2 (by simpa [hc] using hb)) hc⟩
  · exact Or.inl hhost

theorem cut_nodes_insertPart_of_boundaryFree_of_comparable
    {cut : List Address} {a b : Address}
    (hfree : BoundaryFreeAt cut a)
    (hb : List.Mem b cut)
    (hcomp : PTree.comparable a b) :
    Exists fun c => And (List.Mem c (cutInsertPart cut a)) (b = a ++ c) := by
  rcases cut_nodes_partition_of_boundaryFree hfree hb with hhost | hins
  · have hinc := incomparable_of_mem_cutHostPart hhost
    exact False.elim (hinc hcomp)
  · exact hins

theorem cut_nodes_hostPart_of_boundaryFree_of_not_comparable
    {cut : List Address} {a b : Address}
    (hfree : BoundaryFreeAt cut a)
    (hb : List.Mem b cut)
    (hinc : Not (PTree.comparable a b)) :
    List.Mem b (cutHostPart cut a) := by
  rcases cut_nodes_partition_of_boundaryFree hfree hb with hhost | hins
  · exact hhost
  · rcases hins with ⟨c, _hc, hb_eq⟩
    apply False.elim
    apply hinc
    exact Or.inl ⟨c, hb_eq⟩

theorem cut_nodes_partition_for_admissibleCut
    {u t v : PTree} {a b : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a)
    (hb : List.Mem b cut.nodes) :
    Or (List.Mem b (hostSideCut hg cut hfree).nodes)
      (Exists fun c => And (List.Mem c (insertSideCut hg cut).nodes) (b = a ++ c)) := by
  rw [hostSideCut_nodes, insertSideCut_nodes]
  exact cut_nodes_partition_of_boundaryFree hfree hb

theorem mem_original_cut_of_mem_hostSideCut
    {u t v : PTree} {a b : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a)
    (hb : List.Mem b (hostSideCut hg cut hfree).nodes) :
    List.Mem b cut.nodes := by
  rw [hostSideCut_nodes] at hb
  exact mem_cut_of_mem_cutHostPart hb

theorem incomparable_of_mem_hostSideCut
    {u t v : PTree} {a b : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a)
    (hb : List.Mem b (hostSideCut hg cut hfree).nodes) :
    Not (PTree.comparable a b) := by
  rw [hostSideCut_nodes] at hb
  exact incomparable_of_mem_cutHostPart hb

theorem mem_original_cut_of_mem_insertSideCut
    {u t v : PTree} {a c : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hc : List.Mem c (insertSideCut hg cut).nodes) :
    List.Mem (a ++ c) cut.nodes := by
  rw [insertSideCut_nodes] at hc
  exact mem_cut_of_mem_cutInsertPart hc

theorem mem_reassembleCutAt_iff_for_admissibleCut
    {u t v : PTree} {a b : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) :
    b ∈
        (hostSideCut hg cut hfree).nodes ++
          (insertSideCut hg cut).nodes.map (fun c => a ++ c) ↔
      b ∈ cut.nodes := by
  rw [hostSideCut_nodes, insertSideCut_nodes]
  exact mem_reassembleCutAt_iff_of_boundaryFree hfree

theorem subtreeAt_v_eq_subtreeAt_t_of_hostSideCut
    {u t v : PTree} {a b : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a)
    (hb : List.Mem b (hostSideCut hg cut hfree).nodes) :
    PTree.subtreeAt v b = PTree.subtreeAt t b := by
  exact subtreeAt_graftMatchingLeafAt_of_not_comparable u t a b v hg
    (incomparable_of_mem_hostSideCut hg cut hfree hb)

theorem subtreeAt_v_eq_subtreeAt_u_of_insertSideCut
    {u t v : PTree} {a c : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hc : List.Mem c (insertSideCut hg cut).nodes) :
    PTree.subtreeAt v (a ++ c) = PTree.subtreeAt u c := by
  exact subtreeAt_graftMatchingLeafAt_append u t a c v hg

theorem hostSideCut_filterMap_subtreeAt_v_eq_t
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) :
    (hostSideCut hg cut hfree).nodes.filterMap (PTree.subtreeAt v) =
      (hostSideCut hg cut hfree).nodes.filterMap (PTree.subtreeAt t) := by
  apply List.filterMap_congr
  intro b hb
  exact subtreeAt_v_eq_subtreeAt_t_of_hostSideCut hg cut hfree hb

theorem hostSideCut_pruned_hypersequent_v_eq_t
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) :
    HQ.ofForest ((hostSideCut hg cut hfree).nodes.filterMap (PTree.subtreeAt v)) =
      HQ.ofForest ((hostSideCut hg cut hfree).nodes.filterMap (PTree.subtreeAt t)) := by
  rw [hostSideCut_filterMap_subtreeAt_v_eq_t hg cut hfree]

/--
The insert-side nodes reattached to the graft prefix.

These are the original cut addresses of `v` corresponding to the insert-side
cut of `u`.
-/
def prefixedInsertSideNodes
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v) :
    List Address :=
  (insertSideCut hg cut).nodes.map (fun c => a ++ c)

theorem mem_prefixedInsertSideNodes_iff
    {u t v : PTree} {a b : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v) :
    List.Mem b (prefixedInsertSideNodes hg cut) ↔
      Exists fun c => And (List.Mem c (insertSideCut hg cut).nodes) (b = a ++ c) := by
  unfold prefixedInsertSideNodes
  constructor
  · intro hb
    rcases List.mem_map.1 hb with ⟨c, hc, hbc⟩
    exact ⟨c, And.intro hc hbc.symm⟩
  · intro hb
    rcases hb with ⟨c, hc, hbc⟩
    exact List.mem_map.2 ⟨c, hc, hbc.symm⟩

theorem mem_original_cut_of_mem_prefixedInsertSideNodes
    {u t v : PTree} {a b : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hb : List.Mem b (prefixedInsertSideNodes hg cut)) :
    List.Mem b cut.nodes := by
  rcases (mem_prefixedInsertSideNodes_iff hg cut).1 hb with ⟨c, hc, hbc⟩
  rw [hbc]
  exact mem_original_cut_of_mem_insertSideCut hg cut hc

theorem insertSideCut_filterMap_subtreeAt_v_eq_u
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v) :
    (prefixedInsertSideNodes hg cut).filterMap (PTree.subtreeAt v) =
      (insertSideCut hg cut).nodes.filterMap (PTree.subtreeAt u) := by
  unfold prefixedInsertSideNodes
  rw [List.filterMap_map]
  apply List.filterMap_congr
  intro c hc
  exact subtreeAt_v_eq_subtreeAt_u_of_insertSideCut hg cut hc

theorem insertSideCut_pruned_hypersequent_v_eq_u
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v) :
    HQ.ofForest ((prefixedInsertSideNodes hg cut).filterMap (PTree.subtreeAt v)) =
      HQ.ofForest ((insertSideCut hg cut).nodes.filterMap (PTree.subtreeAt u)) := by
  rw [insertSideCut_filterMap_subtreeAt_v_eq_u hg cut]

/--
Support-level data extracted from a boundary-free split of a grafted tree.

This is not yet the full bialgebra law.  It is the proof-theoretic skeleton:
one side records the host contribution, the other the inserted-tree
contribution, and the partition theorem says every boundary-free cut address
of the grafted tree is accounted for by one of those two pieces.
-/
structure BoundaryFreeGraftSplitData
    (u t v : PTree) (a : Address)
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) where
  hostCut : PTree.IsAdmissibleCut t := hostSideCut hg cut hfree
  insertCut : PTree.IsAdmissibleCut u := insertSideCut hg cut
  host_pruned_transport :
    HQ.ofForest (hostCut.nodes.filterMap (PTree.subtreeAt v)) =
      HQ.ofForest (hostCut.nodes.filterMap (PTree.subtreeAt t)) := by
        simpa using hostSideCut_pruned_hypersequent_v_eq_t hg cut hfree
  insert_pruned_transport :
    HQ.ofForest ((prefixedInsertSideNodes hg cut).filterMap (PTree.subtreeAt v)) =
      HQ.ofForest (insertCut.nodes.filterMap (PTree.subtreeAt u)) := by
        simpa using insertSideCut_pruned_hypersequent_v_eq_u hg cut
  covers :
    ∀ b, List.Mem b cut.nodes →
      Or (List.Mem b hostCut.nodes)
        (Exists fun c => And (List.Mem c insertCut.nodes) (b = a ++ c)) := by
          intro b hb
          simpa using cut_nodes_partition_for_admissibleCut hg cut hfree hb

def boundaryFreeGraftSplitData
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) :
    BoundaryFreeGraftSplitData u t v a hg cut hfree :=
  {}

/-!
## Split terms as support-level coalgebra atoms

The linear bialgebra instance should ultimately sum over terms of the form
`(detached hypersequent, remainder)`.  The next definitions package those terms
directly from admissible cuts, without introducing any module or tensor
machinery yet.
-/

abbrev SplitTerm := Hypersequent × PTree

def splitTermOfAdmissibleCut (t : PTree) (cut : PTree.IsAdmissibleCut t) :
    SplitTerm :=
  (HQ.ofForest (cut.nodes.filterMap (PTree.subtreeAt t)), PTree.remainder t cut)

theorem splitTermOfAdmissibleCut_fst
    (t : PTree) (cut : PTree.IsAdmissibleCut t) :
    (splitTermOfAdmissibleCut t cut).1 =
      HQ.ofForest (cut.nodes.filterMap (PTree.subtreeAt t)) := rfl

theorem splitTermOfAdmissibleCut_snd
    (t : PTree) (cut : PTree.IsAdmissibleCut t) :
    (splitTermOfAdmissibleCut t cut).2 = PTree.remainder t cut := rfl

theorem splitsTo_splitTermOfAdmissibleCut
    (t : PTree) (cut : PTree.IsAdmissibleCut t) :
    SplitsTo t (splitTermOfAdmissibleCut t cut).1
      (splitTermOfAdmissibleCut t cut).2 := by
  refine ⟨cut, ?_, ?_⟩
  · simp [splitTermOfAdmissibleCut, PTree.pruned]
  · simp [splitTermOfAdmissibleCut, PTree.remainder]

@[simp]
theorem splitTermOfAdmissibleCut_emptyCut (t : PTree) :
    splitTermOfAdmissibleCut t (emptyCut t) = (0, t) := by
  simp [splitTermOfAdmissibleCut, PTree.remainder, HQ.ofForest,
    PTree.remainderGo_nil]

@[simp]
theorem splitTermOfAdmissibleCut_rootCut (t : PTree) :
    splitTermOfAdmissibleCut t (rootCut t) =
      (HQ.singleton t, PTree.leaf t.conclusion) := by
  cases t with
  | leaf s =>
      simp [splitTermOfAdmissibleCut, PTree.remainder,
        HQ.ofForest, HQ.singleton, PTree.subtreeAt_root, PTree.remainderGo,
        PTree.conclusion]
  | node r s cs =>
      simp [splitTermOfAdmissibleCut, PTree.remainder,
        HQ.ofForest, HQ.singleton, PTree.subtreeAt_root, PTree.remainderGo,
        PTree.conclusion]

def hostSplitTerm
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) :
    SplitTerm :=
  splitTermOfAdmissibleCut t (hostSideCut hg cut hfree)

def insertSplitTerm
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v) :
    SplitTerm :=
  splitTermOfAdmissibleCut u (insertSideCut hg cut)

def originalSplitTerm
    {u t v : PTree} {a : Address}
    (_hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v) :
    SplitTerm :=
  splitTermOfAdmissibleCut v cut

theorem hostSplitTerm_splitsTo
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) :
    SplitsTo t (hostSplitTerm hg cut hfree).1 (hostSplitTerm hg cut hfree).2 := by
  exact splitsTo_splitTermOfAdmissibleCut t (hostSideCut hg cut hfree)

theorem insertSplitTerm_splitsTo
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v) :
    SplitsTo u (insertSplitTerm hg cut).1 (insertSplitTerm hg cut).2 := by
  exact splitsTo_splitTermOfAdmissibleCut u (insertSideCut hg cut)

theorem originalSplitTerm_splitsTo
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v) :
    SplitsTo v (originalSplitTerm hg cut).1 (originalSplitTerm hg cut).2 := by
  exact splitsTo_splitTermOfAdmissibleCut v cut

theorem hostSplitTerm_fst_v_transport
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) :
    (hostSplitTerm hg cut hfree).1 =
      HQ.ofForest ((hostSideCut hg cut hfree).nodes.filterMap (PTree.subtreeAt v)) := by
  unfold hostSplitTerm splitTermOfAdmissibleCut
  exact (hostSideCut_pruned_hypersequent_v_eq_t hg cut hfree).symm

theorem insertSplitTerm_fst_v_transport
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v) :
    (insertSplitTerm hg cut).1 =
      HQ.ofForest ((prefixedInsertSideNodes hg cut).filterMap (PTree.subtreeAt v)) := by
  unfold insertSplitTerm splitTermOfAdmissibleCut
  exact (insertSideCut_pruned_hypersequent_v_eq_u hg cut).symm

/--
The support-level shape of bialgebra compatibility for one boundary-free split
of one grafted tree.

This structure deliberately stops before tensor linearization.  It says that a
split of a grafted tree has canonical host and insert split terms, both
certified by the external splitting relation, and that their detached
hypersequents are transported from the grafted tree by the address geometry.
-/
structure BoundaryFreeGraftSupportCoherence
    (u t v : PTree) (a : Address)
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) where
  original : SplitTerm := originalSplitTerm hg cut
  host : SplitTerm := hostSplitTerm hg cut hfree
  insert : SplitTerm := insertSplitTerm hg cut
  original_splits : SplitsTo v original.1 original.2 := by
    simpa using originalSplitTerm_splitsTo hg cut
  host_splits : SplitsTo t host.1 host.2 := by
    simpa using hostSplitTerm_splitsTo hg cut hfree
  insert_splits : SplitsTo u insert.1 insert.2 := by
    simpa using insertSplitTerm_splitsTo hg cut
  host_detached_from_graft :
    host.1 = HQ.ofForest ((hostSideCut hg cut hfree).nodes.filterMap (PTree.subtreeAt v)) := by
      simpa using hostSplitTerm_fst_v_transport hg cut hfree
  insert_detached_from_graft :
    insert.1 = HQ.ofForest ((prefixedInsertSideNodes hg cut).filterMap (PTree.subtreeAt v)) := by
      simpa using insertSplitTerm_fst_v_transport hg cut

def boundaryFreeGraftSupportCoherence
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) :
    BoundaryFreeGraftSupportCoherence u t v a hg cut hfree :=
  {}

/-
The next layer reconnects the support-level split terms to the hypersequent
inference relation.  These are the proof-theoretic atoms that will later feed
the algebra-side `Bialgebra`/`HopfAlgebra` packaging already developed in the
coalgebra file: the grafted tree splits externally, and its host and insert
pieces split externally in their own components.
-/

namespace BoundaryFreeGraftSupportCoherence

theorem original_externalStep
    {u t v : PTree} {a : Address}
    {hg : PTree.graftMatchingLeafAt u t a = some v}
    {cut : PTree.IsAdmissibleCut v}
    {hfree : BoundaryFreeAt cut.nodes a}
    (W : ExternalWeakeningPolicy)
    (G : Hypersequent)
    (C : BoundaryFreeGraftSupportCoherence u t v a hg cut hfree) :
    ExternalStep W
      (G + HQ.singleton v)
      (G + C.original.1 + HQ.singleton C.original.2) := by
  exact
    ExternalStep.split (W := W) G v C.original.1 C.original.2
      C.original_splits

theorem host_externalStep
    {u t v : PTree} {a : Address}
    {hg : PTree.graftMatchingLeafAt u t a = some v}
    {cut : PTree.IsAdmissibleCut v}
    {hfree : BoundaryFreeAt cut.nodes a}
    (W : ExternalWeakeningPolicy)
    (G : Hypersequent)
    (C : BoundaryFreeGraftSupportCoherence u t v a hg cut hfree) :
    ExternalStep W
      (G + HQ.singleton t)
      (G + C.host.1 + HQ.singleton C.host.2) := by
  exact
    ExternalStep.split (W := W) G t C.host.1 C.host.2
      C.host_splits

theorem insert_externalStep
    {u t v : PTree} {a : Address}
    {hg : PTree.graftMatchingLeafAt u t a = some v}
    {cut : PTree.IsAdmissibleCut v}
    {hfree : BoundaryFreeAt cut.nodes a}
    (W : ExternalWeakeningPolicy)
    (G : Hypersequent)
    (C : BoundaryFreeGraftSupportCoherence u t v a hg cut hfree) :
    ExternalStep W
      (G + HQ.singleton u)
      (G + C.insert.1 + HQ.singleton C.insert.2) := by
  exact
    ExternalStep.split (W := W) G u C.insert.1 C.insert.2
      C.insert_splits

/--
The three external split steps associated to one boundary-free split of a
grafted tree.

This is deliberately still support-level data.  The linear/tensor
interpretation should be supplied by the existing Oudom-Guin target structures
in `GrossmanLarssonOudomGuinCoalgebra.lean`, rather than rebuilt here.
-/
structure ExternalBialgebraAtom
    (W : ExternalWeakeningPolicy)
    (G : Hypersequent)
    (u t v : PTree) (a : Address)
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) where
  support : BoundaryFreeGraftSupportCoherence u t v a hg cut hfree
  originalStep :
    ExternalStep W
      (G + HQ.singleton v)
      (G + support.original.1 + HQ.singleton support.original.2)
  hostStep :
    ExternalStep W
      (G + HQ.singleton t)
      (G + support.host.1 + HQ.singleton support.host.2)
  insertStep :
    ExternalStep W
      (G + HQ.singleton u)
      (G + support.insert.1 + HQ.singleton support.insert.2)

def externalBialgebraAtom
    {u t v : PTree} {a : Address}
    (W : ExternalWeakeningPolicy)
    (G : Hypersequent)
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) :
    ExternalBialgebraAtom W G u t v a hg cut hfree where
  support := boundaryFreeGraftSupportCoherence hg cut hfree
  originalStep := original_externalStep W G (boundaryFreeGraftSupportCoherence hg cut hfree)
  hostStep := host_externalStep W G (boundaryFreeGraftSupportCoherence hg cut hfree)
  insertStep := insert_externalStep W G (boundaryFreeGraftSupportCoherence hg cut hfree)

@[simp]
theorem externalBialgebraAtom_support
    {u t v : PTree} {a : Address}
    (W : ExternalWeakeningPolicy)
    (G : Hypersequent)
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) :
    (externalBialgebraAtom W G hg cut hfree).support =
      boundaryFreeGraftSupportCoherence hg cut hfree := rfl

theorem externalBialgebraAtom_originalStep
    {u t v : PTree} {a : Address}
    (W : ExternalWeakeningPolicy)
    (G : Hypersequent)
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) :
    ExternalStep W
      (G + HQ.singleton v)
      (G + (boundaryFreeGraftSupportCoherence hg cut hfree).original.1 +
        HQ.singleton (boundaryFreeGraftSupportCoherence hg cut hfree).original.2) := by
  exact (externalBialgebraAtom W G hg cut hfree).originalStep

theorem externalBialgebraAtom_hostStep
    {u t v : PTree} {a : Address}
    (W : ExternalWeakeningPolicy)
    (G : Hypersequent)
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) :
    ExternalStep W
      (G + HQ.singleton t)
      (G + (boundaryFreeGraftSupportCoherence hg cut hfree).host.1 +
        HQ.singleton (boundaryFreeGraftSupportCoherence hg cut hfree).host.2) := by
  exact (externalBialgebraAtom W G hg cut hfree).hostStep

theorem externalBialgebraAtom_insertStep
    {u t v : PTree} {a : Address}
    (W : ExternalWeakeningPolicy)
    (G : Hypersequent)
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) :
    ExternalStep W
      (G + HQ.singleton u)
      (G + (boundaryFreeGraftSupportCoherence hg cut hfree).insert.1 +
        HQ.singleton (boundaryFreeGraftSupportCoherence hg cut hfree).insert.2) := by
  exact (externalBialgebraAtom W G hg cut hfree).insertStep

end BoundaryFreeGraftSupportCoherence

/-!
## Algebraic carrier for split forests

The commutative algebra below is the **split-forest** algebra: multiplication
is induced by external juxtaposition of components, i.e. multiset union.  This
is the Grossman--Larson / Connes--Kreimer style symmetric envelope in which the
cut-splitting coproduct is multiplicative.

It is deliberately not the proof-composition product.  Proof composition is
still the internal grafting operation on tree components, named in the next
section as a separate pre-Lie operation.  Keeping both operations visible avoids
the conceptual trap of treating mere external juxtaposition as derivational
composition.
-/

noncomputable section HypersequentAlgebra

variable (R : Type) [Semiring R]

/-- The semiring of finite `R`-linear combinations of hypersequents. -/
abbrev HypersequentAlgebra := AddMonoidAlgebra R Hypersequent

/-- Basis element corresponding to a hypersequent. -/
def hseqMonomial (G : Hypersequent) : HypersequentAlgebra R :=
  AddMonoidAlgebra.single G 1

/-- Basis element corresponding to a single proof-tree component. -/
def treeMonomial (t : PTree) : HypersequentAlgebra R :=
  hseqMonomial R (HQ.singleton t)

@[simp]
theorem hseqMonomial_zero :
    hseqMonomial R 0 = (1 : HypersequentAlgebra R) := by
  rw [AddMonoidAlgebra.one_def]
  rfl

@[simp]
theorem hseqMonomial_mul (G H : Hypersequent) :
    hseqMonomial R G * hseqMonomial R H =
      hseqMonomial R (G + H) := by
  simp [hseqMonomial, AddMonoidAlgebra.single_mul_single]

@[simp]
theorem treeMonomial_mul_treeMonomial (s t : PTree) :
    treeMonomial R s * treeMonomial R t =
      hseqMonomial R (HQ.singleton s + HQ.singleton t) := by
  simp [treeMonomial]

@[simp]
theorem hseqMonomial_singleton_eq_treeMonomial (t : PTree) :
    hseqMonomial R (HQ.singleton t) = treeMonomial R t := rfl

end HypersequentAlgebra

/-!
## Internal grafting as proof composition

The forest product above is useful algebraically, but it is proof-theoretically
passive: it only places components side by side.  The active internal
composition is matching-leaf grafting.  On one-tree generators it gives a
formal sum of one-tree hypersequents, not the two-component product
`treeMonomial u * treeMonomial t`.

This is the operation whose pre-Lie identity was developed in
`GrossmanLarsson.lean` / `GrossmanLarssonQuotient.lean`; the hypersequent route
keeps it as a second operation and studies how the splitting coproduct sees it.
-/

noncomputable section HypersequentInternalGrafting

variable (R : Type) [Semiring R]

/-- The support of the internal proof-composition product `u ▷ t`. -/
def treeGraftSupport (u t : PTree) : List PTree :=
  PTree.matchingLeafGraftings u t

/--
The internal grafting product on one-tree hypersequent generators.

This is the proof-composition operation: sum over all trees obtained by
grafting `u` into a matching leaf of `t`.
-/
def treeGraftCompositionElement (u t : PTree) : HypersequentAlgebra R :=
  (treeGraftSupport u t).foldr (fun v acc => treeMonomial R v + acc) 0

/-- The same internal grafting support, viewed as one-component hypersequents. -/
def internalGraftHypersequentSupport (u t : PTree) : List Hypersequent :=
  (treeGraftSupport u t).map HQ.singleton

/--
The internal grafting product, viewed directly as a formal sum of
one-component hypersequents.
-/
def internalGraftHypersequentElement (u t : PTree) : HypersequentAlgebra R :=
  (internalGraftHypersequentSupport u t).foldr
    (fun G acc => hseqMonomial R G + acc) 0

@[simp]
theorem treeGraftSupport_eq_matchingLeafGraftings (u t : PTree) :
    treeGraftSupport u t = PTree.matchingLeafGraftings u t := rfl

theorem mem_treeGraftSupport_iff {u t v : PTree} :
    v ∈ treeGraftSupport u t ↔ v ∈ PTree.matchingLeafGraftings u t := by
  rfl

/--
Every concrete successful matching-leaf graft contributes to the internal
grafting support.
-/
theorem mem_treeGraftSupport_of_graftMatchingLeafAt_eq_some
    {u t v : PTree} {a : Address}
    (h : PTree.graftMatchingLeafAt u t a = some v) :
    v ∈ treeGraftSupport u t := by
  unfold treeGraftSupport PTree.matchingLeafGraftings
  apply List.mem_filterMap.2
  have hgraft : PTree.IsGraftableLeafAt u t a :=
    PTree.isGraftableLeafAt_of_graftMatchingLeafAt_eq_some u t a v h
  have hsub : PTree.subtreeAt t a = some (PTree.leaf u.conclusion) :=
    (PTree.IsGraftableLeafAt_iff u t a).mp hgraft
  have ha : a ∈ PTree.allAddresses t :=
    PTree.subtreeAt_some_implies_mem_allAddresses
      t (PTree.leaf u.conclusion) a hsub
  exact ⟨a, ha, h⟩

/--
Internal grafting preserves the outer/root conclusion of the host tree.

This is the formal version of the proof-theoretic point: grafting composes a
subproof into a matching open leaf, but the whole derivation still concludes
the same sequent as the host.
-/
theorem conclusion_eq_of_mem_treeGraftSupport
    {u t v : PTree}
    (hv : v ∈ treeGraftSupport u t) :
    v.conclusion = t.conclusion := by
  unfold treeGraftSupport PTree.matchingLeafGraftings at hv
  rcases List.mem_filterMap.1 hv with ⟨a, _ha, hg⟩
  exact graftMatchingLeafAt_preserves_conclusion u t v a hg

/--
The relational internal step used earlier is exactly support membership for the
formal internal grafting operation.
-/
theorem mem_treeGraftSupport_of_internalGraft
    {u t v : PTree}
    (h : InternalGraft u t v) :
    v ∈ treeGraftSupport u t := by
  rcases h with ⟨a, ha⟩
  exact mem_treeGraftSupport_of_graftMatchingLeafAt_eq_some ha

theorem mem_internalGraftHypersequentSupport_iff {u t : PTree} {G : Hypersequent} :
    G ∈ internalGraftHypersequentSupport u t ↔
      ∃ v ∈ treeGraftSupport u t, HQ.singleton v = G := by
  unfold internalGraftHypersequentSupport
  constructor
  · intro h
    rcases List.mem_map.1 h with ⟨v, hv, hG⟩
    exact ⟨v, hv, hG⟩
  · intro h
    rcases h with ⟨v, hv, hG⟩
    exact List.mem_map.2 ⟨v, hv, hG⟩

theorem singleton_mem_internalGraftHypersequentSupport_of_internalGraft
    {u t v : PTree}
    (h : InternalGraft u t v) :
    HQ.singleton v ∈ internalGraftHypersequentSupport u t := by
  exact (mem_internalGraftHypersequentSupport_iff).2
    ⟨v, mem_treeGraftSupport_of_internalGraft h, rfl⟩

/--
Internal grafting preserves the sequent-level projection of the active
component.
-/
theorem conclusions_singleton_eq_of_mem_treeGraftSupport
    {u t v : PTree}
    (hv : v ∈ treeGraftSupport u t) :
    HQ.conclusions (HQ.singleton v) = HQ.conclusions (HQ.singleton t) := by
  rw [HQ.conclusions_singleton, HQ.conclusions_singleton]
  rw [conclusion_eq_of_mem_treeGraftSupport hv]

theorem conclusions_singleton_eq_of_internalGraft
    {u t v : PTree}
    (h : InternalGraft u t v) :
    HQ.conclusions (HQ.singleton v) = HQ.conclusions (HQ.singleton t) := by
  exact conclusions_singleton_eq_of_mem_treeGraftSupport
    (mem_treeGraftSupport_of_internalGraft h)

@[simp]
theorem internalGraftHypersequentElement_eq_treeGraftCompositionElement
    (u t : PTree) :
    internalGraftHypersequentElement R u t =
      treeGraftCompositionElement R u t := by
  unfold internalGraftHypersequentElement internalGraftHypersequentSupport
    treeGraftCompositionElement
  induction treeGraftSupport u t with
  | nil =>
      rfl
  | cons v vs ih =>
      dsimp
      rw [ih]

@[simp]
theorem internalGraftHypersequentSupport_nil_of_no_grafts
    {u t : PTree}
    (h : PTree.matchingLeafGraftings u t = []) :
    internalGraftHypersequentSupport u t = [] := by
  simp [internalGraftHypersequentSupport, treeGraftSupport, h]

@[simp]
theorem treeGraftCompositionElement_nil_of_no_grafts
    {u t : PTree}
    (h : PTree.matchingLeafGraftings u t = []) :
    treeGraftCompositionElement R u t = 0 := by
  simp [treeGraftCompositionElement, treeGraftSupport, h]

@[simp]
theorem internalGraftHypersequentElement_nil_of_no_grafts
    {u t : PTree}
    (h : PTree.matchingLeafGraftings u t = []) :
    internalGraftHypersequentElement R u t = 0 := by
  simp [internalGraftHypersequentElement, h]

/--
For singleton inputs, forest multiplication and internal grafting have different
shapes: multiplication gives a two-component hypersequent, while grafting is a
sum of one-component hypersequents.  This theorem records the forest-product
side explicitly so later statements can contrast it with
`treeGraftCompositionElement`.
-/
theorem forestProduct_of_tree_generators (u t : PTree) :
    treeMonomial R u * treeMonomial R t =
      hseqMonomial R (HQ.singleton u + HQ.singleton t) := by
  simp

end HypersequentInternalGrafting

/-!
## Bridge from primitive grafting carrier to labelled hypersequents

The older GL/OG development works with the primitive linear span
`PreLieCarrier = PTree →₀ ℤ`.  The hypersequent route works with the symmetric
split-forest algebra generated by labelled hypersequents.

The map below is the clean bridge: a primitive tree generator is sent to the
one-component proof-labelled hypersequent generated by that tree.  Under this
map, the existing tree-level grafting product becomes exactly the
one-component internal grafting element defined above.
-/

noncomputable section PrimitiveToHypersequentBridge

/-- Embed primitive proof-tree generators as singleton labelled hypersequents. -/
def primitiveToHypersequentAlgebra :
    PreLieCarrier →ₗ[ℤ] HypersequentAlgebra ℤ :=
  Finsupp.linearCombination ℤ (treeMonomial ℤ)

@[simp]
theorem primitiveToHypersequentAlgebra_treeGen (t : PTree) :
    primitiveToHypersequentAlgebra (treeGen t) = treeMonomial ℤ t := by
  unfold primitiveToHypersequentAlgebra treeGen
  rw [Finsupp.linearCombination_single]
  change (1 : ℤ) • treeMonomial ℤ t = treeMonomial ℤ t
  exact one_smul ℤ (treeMonomial ℤ t)

/--
The singleton-hypersequent image of the existing tree-level pre-Lie product is
the internal grafting element on labelled hypersequents.
-/
theorem primitiveToHypersequentAlgebra_graftPreLieTree
    (u t : PTree) :
    primitiveToHypersequentAlgebra (PTree.graftPreLieTree u t) =
      treeGraftCompositionElement ℤ u t := by
  unfold PTree.graftPreLieTree treeGraftCompositionElement treeGraftSupport
  induction PTree.matchingLeafGraftings u t with
  | nil =>
      simp [primitiveToHypersequentAlgebra]
  | cons v vs ih =>
      simp only [List.foldr_cons]
      rw [map_add, primitiveToHypersequentAlgebra_treeGen, ih]

theorem primitiveToHypersequentAlgebra_graftPreLie_on_generators
    (u t : PTree) :
    primitiveToHypersequentAlgebra (graftPreLie (treeGen u) (treeGen t)) =
      treeGraftCompositionElement ℤ u t := by
  rw [graftPreLie_on_generators]
  exact primitiveToHypersequentAlgebra_graftPreLieTree u t

end PrimitiveToHypersequentBridge

/-!
## Contextual internal grafting inside a hypersequent

This is the key interface between the Avron-style external structure and the
proof-tree internal structure.

A singleton proof tree is the ordinary/sequent case embedded as one component.
External juxtaposition adds possible components, and therefore possible graft
targets, but the grafting step itself still inspects the labelled proof tree:
it is available only at matching leaves.  This is exactly where external
weakening/permutation becomes proof-theoretically nontrivial rather than mere
multiset bookkeeping.
-/

namespace HQ

/-- The ordinary sequent `s`, seen as the one-component leaf hypersequent. -/
def sequentSingleton (s : MultiSequent) : Hypersequent :=
  singleton (PTree.leaf s)

@[simp]
theorem conclusions_sequentSingleton (s : MultiSequent) :
    conclusions (sequentSingleton s) = ({s} : SequentHypersequent) := by
  exact conclusions_leaf_singleton s

/-- A proof tree as a one-component proof-labelled hypersequent. -/
def treeSingleton (t : PTree) : Hypersequent :=
  singleton t

@[simp]
theorem conclusions_treeSingleton (t : PTree) :
    conclusions (treeSingleton t) = ({t.conclusion} : SequentHypersequent) := by
  simp [treeSingleton]

end HQ

/--
Internal grafting in an external hypersequent context.

`ContextualInternalGraft u G H` says that one component `t` of `G` can be
replaced by a matching-leaf graft result `v`, leaving the surrounding external
context `C` untouched.
-/
def ContextualInternalGraft (u : PTree) (G H : Hypersequent) : Prop :=
  ∃ C : Hypersequent, ∃ t v : PTree,
    G = C + HQ.singleton t ∧
    H = C + HQ.singleton v ∧
    InternalGraft u t v

/--
Readable constructor for contextual grafting.
-/
theorem contextualInternalGraft_mk
    {u t v : PTree} {C : Hypersequent}
    (h : InternalGraft u t v) :
    ContextualInternalGraft u
      (C + HQ.singleton t)
      (C + HQ.singleton v) := by
  exact ⟨C, t, v, rfl, rfl, h⟩

/-- The ordinary one-component case embeds into contextual hypersequents. -/
theorem contextualInternalGraft_singleton
    {u t v : PTree}
    (h : InternalGraft u t v) :
    ContextualInternalGraft u (HQ.singleton t) (HQ.singleton v) := by
  simpa using contextualInternalGraft_mk (C := 0) h

/--
External juxtaposition preserves an already-available internal grafting step.

This is the harmless direction of external weakening: adding unrelated
components does not invalidate an existing matching-leaf graft.
-/
theorem contextualInternalGraft_add_context
    {u : PTree} {G H : Hypersequent}
    (K : Hypersequent)
    (h : ContextualInternalGraft u G H) :
    ContextualInternalGraft u (K + G) (K + H) := by
  rcases h with ⟨C, t, v, hG, hH, hg⟩
  refine ⟨K + C, t, v, ?_, ?_, hg⟩
  · rw [hG]
    ac_rfl
  · rw [hH]
    ac_rfl

/--
Adding a component may create a new internal grafting step, but only because
the new labelled proof tree has a matching leaf.
-/
theorem contextualInternalGraft_of_added_component
    {u t v : PTree} (G : Hypersequent)
    (h : InternalGraft u t v) :
    ContextualInternalGraft u
      (G + HQ.singleton t)
      (G + HQ.singleton v) := by
  exact contextualInternalGraft_mk h

/--
Contextual grafting preserves the ordinary sequent-level hypersequent shadow:
the proof-tree label changes, but the active component's root conclusion does
not.
-/
theorem contextualInternalGraft_preserves_conclusions
    {u : PTree} {G H : Hypersequent}
    (h : ContextualInternalGraft u G H) :
    HQ.conclusions H = HQ.conclusions G := by
  rcases h with ⟨C, t, v, hG, hH, hg⟩
  rw [hG, hH, HQ.conclusions_add, HQ.conclusions_add]
  rw [conclusions_singleton_eq_of_internalGraft hg]

/--
Internal proof composition stays inside the same ordinary hypersequent shadow.

This is the labelled-hypersequent version of the slogan: grafting changes proof
labels and internal derivation structure, but it does not change the displayed
root sequents of the external components.
-/
def contextualInternalGraft_over
    {S : SequentHypersequent}
    {u : PTree}
    (G : ProofRelevantHypersequentOver S)
    {H : Hypersequent}
    (h : ContextualInternalGraft u G.carrier H) :
    ProofRelevantHypersequentOver S where
  carrier := H
  shadow := by
    calc
      HQ.conclusions H = HQ.conclusions G.carrier :=
        contextualInternalGraft_preserves_conclusions h
      _ = S := G.shadow

@[simp]
theorem contextualInternalGraft_over_carrier
    {S : SequentHypersequent}
    {u : PTree}
    (G : ProofRelevantHypersequentOver S)
    {H : Hypersequent}
    (h : ContextualInternalGraft u G.carrier H) :
    (contextualInternalGraft_over G h).carrier = H := rfl

/--
One-component grafting is an internal move in the fiber over the singleton
conclusion hypersequent.
-/
def singletonInternalGraft_over
    {u t v : PTree}
    (h : InternalGraft u t v) :
    ProofRelevantHypersequentOver ({t.conclusion} : SequentHypersequent) :=
  contextualInternalGraft_over
    (ProofRelevantHypersequentOver.ofTree t)
    (by
      simpa using contextualInternalGraft_singleton h)

@[simp]
theorem singletonInternalGraft_over_carrier
    {u t v : PTree}
    (h : InternalGraft u t v) :
    (singletonInternalGraft_over h).carrier = HQ.singleton v := rfl

theorem singletonInternalGraft_over_shadow
    {u t v : PTree}
    (h : InternalGraft u t v) :
    HQ.conclusions (HQ.singleton v) =
      ({t.conclusion} : SequentHypersequent) := by
  simpa using (singletonInternalGraft_over h).shadow

/--
Permutation/exchange is already built into `Hypersequent = Multiset PTree`.
This theorem records that contextual grafting is invariant under replacing
source and target hypersequents by equal multisets.
-/
theorem contextualInternalGraft_of_eq
    {u : PTree} {G G' H H' : Hypersequent}
    (hG : G = G') (hH : H = H')
    (h : ContextualInternalGraft u G H) :
    ContextualInternalGraft u G' H' := by
  subst G'
  subst H'
  exact h

/-- `u` has at least one available internal grafting target in `G`. -/
def ContextualGraftable (u : PTree) (G : Hypersequent) : Prop :=
  ∃ H : Hypersequent, ContextualInternalGraft u G H

theorem contextualGraftable_of_contextualInternalGraft
    {u : PTree} {G H : Hypersequent}
    (h : ContextualInternalGraft u G H) :
    ContextualGraftable u G :=
  ⟨H, h⟩

/--
External juxtaposition is monotone for availability of internal grafting: if a
graft was available before adding an external component/context, it remains
available afterward.
-/
theorem contextualGraftable_add_context
    {u : PTree} {G : Hypersequent}
    (K : Hypersequent)
    (h : ContextualGraftable u G) :
    ContextualGraftable u (K + G) := by
  rcases h with ⟨H, hGH⟩
  exact ⟨K + H, contextualInternalGraft_add_context K hGH⟩

/--
External weakening can create a new available graft only through the labelled
component that it adds.
-/
theorem contextualGraftable_of_added_component
    {u t v : PTree} (G : Hypersequent)
    (h : InternalGraft u t v) :
    ContextualGraftable u (G + HQ.singleton t) := by
  exact ⟨G + HQ.singleton v, contextualInternalGraft_of_added_component G h⟩

/--
In the one-component case, contextual graftability is exactly ordinary
tree-level internal graftability into that component, up to the contextual
packaging.
-/
theorem contextualGraftable_singleton_of_internalGraft
    {u t v : PTree}
    (h : InternalGraft u t v) :
    ContextualGraftable u (HQ.treeSingleton t) := by
  exact ⟨HQ.treeSingleton v, by
    simpa [HQ.treeSingleton] using contextualInternalGraft_singleton h⟩

/-!
## Graft-controlled external weakening

Avron-style external weakening is dangerous for nonmonotonic proof systems if
it is read as freely adding proof components.  The labelled-tree perspective
lets us state a controlled replacement: adding a component is admissible for a
chosen internal proof-composition probe `u` exactly when that labelled
component can participate in a matching-leaf graft with `u`.

This is deliberately proof-relevant.  The conclusion sequent alone is not
enough: the proof-tree label determines whether and where matching leaves are
available.
-/

/--
External weakening policy controlled by a fixed grafting probe `u`.

A component may be externally added when it supplies at least one possible
internal graft target for `u`.
-/
def graftControlledWeakeningPolicy (u : PTree) : ExternalWeakeningPolicy where
  admissible t := ∃ v : PTree, InternalGraft u t v

theorem graftControlledWeakeningPolicy_admissible_iff
    (u t : PTree) :
    (graftControlledWeakeningPolicy u).admissible t ↔
      ∃ v : PTree, InternalGraft u t v := by
  rfl

/--
If a component is admissible for graft-controlled weakening, adding it to any
external context creates an available contextual grafting step.
-/
theorem contextualGraftable_add_of_graftControlledWeakening
    {u t : PTree} (G : Hypersequent)
    (h : (graftControlledWeakeningPolicy u).admissible t) :
    ContextualGraftable u (G + HQ.treeSingleton t) := by
  rcases (graftControlledWeakeningPolicy_admissible_iff u t).1 h with ⟨v, hv⟩
  exact contextualGraftable_of_added_component G hv

/--
Conversely, any explicit internal graft witness makes the added component
admissible for the graft-controlled weakening policy.
-/
theorem graftControlledWeakening_admissible_of_internalGraft
    {u t v : PTree}
    (h : InternalGraft u t v) :
    (graftControlledWeakeningPolicy u).admissible t := by
  exact (graftControlledWeakeningPolicy_admissible_iff u t).2 ⟨v, h⟩

/-!
## External product versus internal proof composition

The algebra product on `HypersequentAlgebra` is external juxtaposition:
multiset union of proof-labelled components.  This is the Grossman--Larsson
forest product side.  It is intentionally not grafting.

Grafting remains present as internal proof composition through
`ContextualInternalGraft` and `treeGraftCompositionElement`.  The point of this
section is to keep that distinction theorem-level, so later bialgebra/Hopf
statements can say exactly which product is being used.
-/

/-- External juxtaposition of proof-labelled hypersequents. -/
def ExternalJuxtaposition (G H : Hypersequent) : Hypersequent :=
  G + H

@[simp]
theorem externalJuxtaposition_zero_left (G : Hypersequent) :
    ExternalJuxtaposition 0 G = G := by
  simp [ExternalJuxtaposition]

@[simp]
theorem externalJuxtaposition_zero_right (G : Hypersequent) :
    ExternalJuxtaposition G 0 = G := by
  simp [ExternalJuxtaposition]

@[simp]
theorem externalJuxtaposition_conclusions (G H : Hypersequent) :
    HQ.conclusions (ExternalJuxtaposition G H) =
      HQ.conclusions G + HQ.conclusions H := by
  simp [ExternalJuxtaposition]

@[simp]
theorem externalJuxtaposition_assoc (G H K : Hypersequent) :
    ExternalJuxtaposition (ExternalJuxtaposition G H) K =
      ExternalJuxtaposition G (ExternalJuxtaposition H K) := by
  simp [ExternalJuxtaposition, add_assoc]

@[simp]
theorem externalJuxtaposition_comm (G H : Hypersequent) :
    ExternalJuxtaposition G H = ExternalJuxtaposition H G := by
  simp [ExternalJuxtaposition, add_comm]

theorem externalProduct_treeSingletons (u t : PTree) :
    ExternalJuxtaposition (HQ.treeSingleton u) (HQ.treeSingleton t) =
      HQ.singleton u + HQ.singleton t := by
  rfl

/--
External product of tree generators is two-component juxtaposition, not
internal proof composition.
-/
theorem hypersequentAlgebra_mul_is_external_product
    (R : Type) [Semiring R] (u t : PTree) :
    treeMonomial R u * treeMonomial R t =
      hseqMonomial R (ExternalJuxtaposition (HQ.treeSingleton u) (HQ.treeSingleton t)) := by
  simp [ExternalJuxtaposition, HQ.treeSingleton]

/-!
## Size grading scaffold

The connected graded Hopf-algebra route needs a degree.  The natural degree of
a proof-labelled hypersequent is the total size of its proof-tree labels.  This
is deliberately proof-relevant: two labelled hypersequents with the same
ordinary sequent shadow may have different proof-theoretic degree.
-/

/-- Total proof-tree size of a proof-labelled hypersequent. -/
def hypersequentSize (G : Hypersequent) : Nat :=
  (G.map PTree.size).sum

@[simp]
theorem hypersequentSize_zero :
    hypersequentSize (0 : Hypersequent) = 0 := by
  simp [hypersequentSize]

@[simp]
theorem hypersequentSize_singleton (t : PTree) :
    hypersequentSize (HQ.singleton t) = t.size := by
  simp [hypersequentSize, HQ.singleton]

@[simp]
theorem hypersequentSize_treeSingleton (t : PTree) :
    hypersequentSize (HQ.treeSingleton t) = t.size := by
  simp [HQ.treeSingleton]

@[simp]
theorem hypersequentSize_ofTree (t : PTree) :
    hypersequentSize (ProofRelevantHypersequentOver.ofTree t).carrier =
      t.size := by
  simp

theorem hypersequentSize_add (G H : Hypersequent) :
    hypersequentSize (G + H) =
      hypersequentSize G + hypersequentSize H := by
  simp [hypersequentSize, Multiset.map_add, Multiset.sum_add]

theorem hypersequentSize_externalJuxtaposition (G H : Hypersequent) :
    hypersequentSize (ExternalJuxtaposition G H) =
      hypersequentSize G + hypersequentSize H := by
  simp [ExternalJuxtaposition, hypersequentSize_add]

theorem hypersequentSize_ofForest_append (f g : Forest) :
    hypersequentSize (HQ.ofForest (f ++ g)) =
      hypersequentSize (HQ.ofForest f) +
        hypersequentSize (HQ.ofForest g) := by
  simp [HQ.ofForest_append, hypersequentSize_add]

/-- Basis hypersequents of fixed proof-theoretic degree. -/
def HypersequentDegreeBasis (n : Nat) :=
  { G : Hypersequent // hypersequentSize G = n }

/--
The degree-zero connectedness target.

This is intentionally kept as a named proposition rather than prematurely
forcing a Mathlib graded-algebra instance.  The proof should use
`PTree.size_ne_zero` for each component.
-/
def HypersequentDegreeConnected : Prop :=
  ∀ G : Hypersequent, hypersequentSize G = 0 → G = 0

/-- The empty hypersequent is the canonical degree-zero basis element. -/
def degreeZeroEmpty : HypersequentDegreeBasis 0 where
  val := 0
  property := by simp

@[simp]
theorem degreeZeroEmpty_val :
    (degreeZeroEmpty : HypersequentDegreeBasis 0).val = 0 := rfl

/-!
## Linear extensionality on hypersequent monomials

The Hopf algebra axioms are linear-map equations.  Since
`HypersequentAlgebra R` is the free `R`-module on proof-labelled
hypersequents, it is enough to prove those equations on basis monomials.
-/

theorem hypersequentAlgebra_linearMap_ext
    (R : Type) [Semiring R]
    {M : Type} [AddCommMonoid M] [Module R M]
    (f g : HypersequentAlgebra R →ₗ[R] M)
    (h : ∀ G : Hypersequent, f (hseqMonomial R G) = g (hseqMonomial R G)) :
    f = g := by
  apply LinearMap.ext
  intro x
  induction x using Finsupp.induction with
  | zero =>
      exact (map_zero f).trans (map_zero g).symm
  | single_add G r x hG hr ih =>
      have hsingle :
          (Finsupp.single G r : Hypersequent →₀ R) =
            r • (hseqMonomial R G : Hypersequent →₀ R) := by
        simp [hseqMonomial]
      have hf_single :
          f (Finsupp.single G r : Hypersequent →₀ R) =
            r • f (hseqMonomial R G) := by
        rw [hsingle]
        exact map_smul f r (hseqMonomial R G)
      have hg_single :
          g (Finsupp.single G r : Hypersequent →₀ R) =
            r • g (hseqMonomial R G) := by
        rw [hsingle]
        exact map_smul g r (hseqMonomial R G)
      calc
        f ((Finsupp.single G r : Hypersequent →₀ R) + x)
            = f (Finsupp.single G r : Hypersequent →₀ R) + f x := by
                exact map_add f (Finsupp.single G r : Hypersequent →₀ R) x
        _ = g (Finsupp.single G r : Hypersequent →₀ R) + g x := by
                rw [hf_single, hg_single, h G, ih]
        _ = g ((Finsupp.single G r : Hypersequent →₀ R) + x) := by
                exact (map_add g (Finsupp.single G r : Hypersequent →₀ R) x).symm

theorem hypersequentAlgebra_linearMap_ext_iff
    (R : Type) [Semiring R]
    {M : Type} [AddCommMonoid M] [Module R M]
    (f g : HypersequentAlgebra R →ₗ[R] M) :
    f = g ↔
      ∀ G : Hypersequent, f (hseqMonomial R G) = g (hseqMonomial R G) := by
  constructor
  · intro h G
    rw [h]
  · intro h
    exact hypersequentAlgebra_linearMap_ext R f g h

/--
Graft-controlled external weakening is exactly the external rule whose
admissibility is witnessed by an internal graft.
-/
theorem externalStep_graftControlledWeakening_of_internalGraft
    {u t v : PTree}
    (G : Hypersequent)
    (h : InternalGraft u t v) :
    ExternalStep (graftControlledWeakeningPolicy u)
      G (G + HQ.singleton t) := by
  exact ExternalStep.weakening G t
    (graftControlledWeakening_admissible_of_internalGraft h)

/--
Under the graft-controlled policy, a weakening step adding `t` supplies exactly
the resource needed to make `u` contextually graftable.
-/
theorem contextualGraftable_of_graftControlledExternalStep
    {u t : PTree}
    (G : Hypersequent)
    (h : (graftControlledWeakeningPolicy u).admissible t) :
    ContextualGraftable u (ExternalJuxtaposition G (HQ.treeSingleton t)) := by
  simpa [ExternalJuxtaposition, HQ.treeSingleton] using
    contextualGraftable_add_of_graftControlledWeakening (u := u) (t := t) G h

theorem contextualInternalGraft_add_externalJuxtaposition_left
    {u : PTree} {G H : Hypersequent}
    (K : Hypersequent)
    (h : ContextualInternalGraft u G H) :
    ContextualInternalGraft u
      (ExternalJuxtaposition K G)
      (ExternalJuxtaposition K H) := by
  simpa [ExternalJuxtaposition] using contextualInternalGraft_add_context K h

theorem contextualInternalGraft_preserves_external_shadow
    {u : PTree} {G H : Hypersequent}
    (K : Hypersequent)
    (h : ContextualInternalGraft u G H) :
    HQ.conclusions (ExternalJuxtaposition K H) =
      HQ.conclusions (ExternalJuxtaposition K G) := by
  simp [ExternalJuxtaposition, contextualInternalGraft_preserves_conclusions h]

/-!
## Support-level coproduct atoms

Before building a linear map into a tensor product, it is useful to name the
basis indices that the splitting rule contributes.  A tensor basis index is a
pair of hypersequents: the detached forest on the left and the remaining
component, as a singleton hypersequent, on the right.
-/

/-- Basis index for a pure tensor of hypersequent monomials. -/
abbrev HypersequentTensorBasis := Hypersequent × Hypersequent

namespace HypersequentTensorBasis

/-- Componentwise multiplication of tensor-basis indices. -/
def mul (p q : HypersequentTensorBasis) : HypersequentTensorBasis :=
  (p.1 + q.1, p.2 + q.2)

@[simp]
theorem add_eq_mul (p q : HypersequentTensorBasis) :
    p + q = mul p q := by
  cases p
  cases q
  rfl

@[simp]
theorem mul_fst (p q : HypersequentTensorBasis) :
    (mul p q).1 = p.1 + q.1 := rfl

@[simp]
theorem mul_snd (p q : HypersequentTensorBasis) :
    (mul p q).2 = p.2 + q.2 := rfl

/-- The tensor unit basis index. -/
def one : HypersequentTensorBasis := (0, 0)

@[simp]
theorem one_fst : (one : HypersequentTensorBasis).1 = 0 := rfl

@[simp]
theorem one_snd : (one : HypersequentTensorBasis).2 = 0 := rfl

@[simp]
theorem one_mul (p : HypersequentTensorBasis) :
    mul one p = p := by
  cases p
  simp [mul, one]

@[simp]
theorem mul_one (p : HypersequentTensorBasis) :
    mul p one = p := by
  cases p
  simp [mul, one]

theorem mul_assoc (p q r : HypersequentTensorBasis) :
    mul (mul p q) r = mul p (mul q r) := by
  cases p
  cases q
  cases r
  simp [mul, add_assoc]

theorem mul_comm (p q : HypersequentTensorBasis) :
    mul p q = mul q p := by
  cases p
  cases q
  simp [mul, add_comm]

end HypersequentTensorBasis

noncomputable section HypersequentTensorAlgebra

variable (R : Type) [Semiring R]

/--
The monoid algebra on tensor-basis indices.  This is the support-level model of
`HypersequentAlgebra R ⊗ HypersequentAlgebra R`: a basis index is a pair of
hypersequents.
-/
abbrev HypersequentTensorAlgebra := AddMonoidAlgebra R HypersequentTensorBasis

/-- Basis element of the tensor-support algebra. -/
def tensorBasisMonomial (p : HypersequentTensorBasis) :
    HypersequentTensorAlgebra R :=
  AddMonoidAlgebra.single p 1

@[simp]
theorem tensorBasisMonomial_of
    (p : HypersequentTensorBasis) :
    AddMonoidAlgebra.of R HypersequentTensorBasis (Multiplicative.ofAdd p) =
      tensorBasisMonomial R p := rfl

@[simp]
theorem tensorBasisMonomial_one :
    tensorBasisMonomial R HypersequentTensorBasis.one =
      (1 : HypersequentTensorAlgebra R) := by
  rw [AddMonoidAlgebra.one_def]
  rfl

@[simp]
theorem tensorBasisMonomial_mul
    (p q : HypersequentTensorBasis) :
    tensorBasisMonomial R p * tensorBasisMonomial R q =
      tensorBasisMonomial R (HypersequentTensorBasis.mul p q) := by
  simp [tensorBasisMonomial, AddMonoidAlgebra.single_mul_single]

/-- Sum of tensor-basis monomials over a finite support list. -/
def tensorSupportElement (xs : List HypersequentTensorBasis) :
    HypersequentTensorAlgebra R :=
  (xs.map (tensorBasisMonomial R)).sum

@[simp]
theorem tensorSupportElement_nil :
    tensorSupportElement R [] = 0 := rfl

@[simp]
theorem tensorSupportElement_cons
    (p : HypersequentTensorBasis) (xs : List HypersequentTensorBasis) :
    tensorSupportElement R (p :: xs) =
      tensorBasisMonomial R p + tensorSupportElement R xs := rfl

end HypersequentTensorAlgebra

/--
The tensor-basis support of the splitting coproduct on a single tree.

Each admissible split contributes the detached hypersequent on the left and
the remainder as a singleton component on the right.
-/
def treeSplittingTensorSupport (t : PTree) : List HypersequentTensorBasis :=
  (splittingSupport t).map (fun p => (p.1, HQ.singleton p.2))

theorem mem_treeSplittingTensorSupport_iff
    {t : PTree} {q : HypersequentTensorBasis} :
    List.Mem q (treeSplittingTensorSupport t) ↔
      Exists fun p => And (List.Mem p (splittingSupport t))
        (q = (p.1, HQ.singleton p.2)) := by
  unfold treeSplittingTensorSupport
  constructor
  · intro hq
    rcases List.mem_map.1 hq with ⟨p, hp, hpq⟩
    exact ⟨p, And.intro hp hpq.symm⟩
  · intro hq
    rcases hq with ⟨p, hp, hpq⟩
    exact List.mem_map.2 ⟨p, hp, hpq.symm⟩

@[simp]
theorem treeSplittingTensorSupport_contains_identity (t : PTree) :
    List.Mem (0, HQ.singleton t) (treeSplittingTensorSupport t) := by
  exact (mem_treeSplittingTensorSupport_iff).2
    ⟨(0, t), And.intro (splittingSupport_contains_identity t) rfl⟩

@[simp]
theorem treeSplittingTensorSupport_contains_root (t : PTree) :
    List.Mem (HQ.singleton t, HQ.singleton (PTree.leaf t.conclusion))
      (treeSplittingTensorSupport t) := by
  exact (mem_treeSplittingTensorSupport_iff).2
    ⟨(HQ.singleton t, PTree.leaf t.conclusion),
      And.intro (splittingSupport_contains_root t) rfl⟩

/--
The reduced tensor-basis support of the splitting coproduct on a single tree.

This removes the identity split while retaining the root/interface split.
-/
noncomputable def reducedTreeSplittingTensorSupport (t : PTree) :
    List HypersequentTensorBasis :=
  (reducedSplittingSupport t).map (fun p => (p.1, HQ.singleton p.2))

theorem mem_reducedTreeSplittingTensorSupport_iff
    {t : PTree} {q : HypersequentTensorBasis} :
    List.Mem q (reducedTreeSplittingTensorSupport t) ↔
      Exists fun p => And (List.Mem p (reducedSplittingSupport t))
        (q = (p.1, HQ.singleton p.2)) := by
  unfold reducedTreeSplittingTensorSupport
  constructor
  · intro hq
    rcases List.mem_map.1 hq with ⟨p, hp, hpq⟩
    exact ⟨p, And.intro hp hpq.symm⟩
  · intro hq
    rcases hq with ⟨p, hp, hpq⟩
    exact List.mem_map.2 ⟨p, hp, hpq.symm⟩

theorem identity_not_mem_reducedTreeSplittingTensorSupport (t : PTree) :
    Not (List.Mem (0, HQ.singleton t) (reducedTreeSplittingTensorSupport t)) := by
  intro h
  rcases (mem_reducedTreeSplittingTensorSupport_iff).1 h with ⟨p, hp, hpq⟩
  have hp_left : p.1 ≠ 0 := left_ne_zero_of_mem_reducedSplittingSupport hp
  have hleft : p.1 = 0 := by
    have hfst := congrArg Prod.fst hpq
    simpa using hfst.symm
  exact hp_left hleft

@[simp]
theorem reducedTreeSplittingTensorSupport_contains_root (t : PTree) :
    List.Mem (HQ.singleton t, HQ.singleton (PTree.leaf t.conclusion))
      (reducedTreeSplittingTensorSupport t) := by
  exact (mem_reducedTreeSplittingTensorSupport_iff).2
    ⟨(HQ.singleton t, PTree.leaf t.conclusion),
      And.intro (reducedSplittingSupport_contains_root t) rfl⟩

/--
Tensor-support multiplication: all componentwise products of a term from `xs`
and a term from `ys`.
-/
def tensorSupportMul
    (xs ys : List HypersequentTensorBasis) : List HypersequentTensorBasis :=
  xs.flatMap (fun x => ys.map (fun y => HypersequentTensorBasis.mul x y))

theorem mem_tensorSupportMul_iff
    {xs ys : List HypersequentTensorBasis} {z : HypersequentTensorBasis} :
    List.Mem z (tensorSupportMul xs ys) ↔
      Exists fun x => Exists fun y =>
        And (List.Mem x xs)
          (And (List.Mem y ys) (z = HypersequentTensorBasis.mul x y)) := by
  unfold tensorSupportMul
  constructor
  · intro hz
    rcases (List.mem_flatMap.1 hz) with ⟨x, hx, hzmap⟩
    rcases List.mem_map.1 hzmap with ⟨y, hy, hyz⟩
    exact ⟨x, y, And.intro hx (And.intro hy hyz.symm)⟩
  · intro hz
    rcases hz with ⟨x, y, hx, hy, hzy⟩
    exact List.mem_flatMap.2
      ⟨x, hx, List.mem_map.2 ⟨y, hy, hzy.symm⟩⟩

theorem mem_tensorSupportMul_of_mem
    {xs ys : List HypersequentTensorBasis}
    {x y : HypersequentTensorBasis}
    (hx : List.Mem x xs)
    (hy : List.Mem y ys) :
    List.Mem (HypersequentTensorBasis.mul x y) (tensorSupportMul xs ys) := by
  exact (mem_tensorSupportMul_iff).2
    ⟨x, y, And.intro hx (And.intro hy rfl)⟩

theorem tensorSupportMul_perm_left
    {xs ys zs : List HypersequentTensorBasis}
    (h : List.Perm xs ys) :
    List.Perm (tensorSupportMul xs zs) (tensorSupportMul ys zs) := by
  unfold tensorSupportMul
  exact List.Perm.flatMap h (by
    intro x _hx
    rfl)

theorem tensorSupportMul_perm_right
    {xs ys zs : List HypersequentTensorBasis}
    (h : List.Perm ys zs) :
    List.Perm (tensorSupportMul xs ys) (tensorSupportMul xs zs) := by
  unfold tensorSupportMul
  exact List.Perm.flatMap (List.Perm.refl xs) (by
    intro x _hx
    exact List.Perm.map (fun y => HypersequentTensorBasis.mul x y) h)

theorem tensorSupportMul_assoc
    (xs ys zs : List HypersequentTensorBasis) :
    tensorSupportMul (tensorSupportMul xs ys) zs =
      tensorSupportMul xs (tensorSupportMul ys zs) := by
  unfold tensorSupportMul
  rw [List.flatMap_assoc]
  apply List.flatMap_congr
  intro x _hx
  rw [List.flatMap_map, List.map_flatMap]
  apply List.flatMap_congr
  intro y _hy
  rw [List.map_map]
  apply List.map_congr_left
  intro z _hz
  exact HypersequentTensorBasis.mul_assoc x y z

theorem tensorSupportMul_comm
    (xs ys : List HypersequentTensorBasis) :
    List.Perm (tensorSupportMul xs ys) (tensorSupportMul ys xs) := by
  induction xs with
  | nil =>
      simp [tensorSupportMul]
  | cons x xs ih =>
      unfold tensorSupportMul
      simp only [List.flatMap_cons, List.map_cons]
      have hhead :
          List.Perm
            (ys.map (fun y => HypersequentTensorBasis.mul x y))
            (ys.map (fun y => HypersequentTensorBasis.mul y x)) := by
        have hmap :
            ys.map (fun y => HypersequentTensorBasis.mul x y) =
              ys.map (fun y => HypersequentTensorBasis.mul y x) := by
          apply List.map_congr_left
          intro y _hy
          exact HypersequentTensorBasis.mul_comm x y
        rw [hmap]
      refine (List.Perm.append hhead ih).trans ?_
      simpa [List.map_cons] using
        List.map_append_flatMap_perm ys
          (fun y => HypersequentTensorBasis.mul y x)
          (fun y => xs.map (fun x' => HypersequentTensorBasis.mul y x'))

@[simp]
theorem tensorSupportMul_nil_left (xs : List HypersequentTensorBasis) :
    tensorSupportMul [] xs = [] := rfl

@[simp]
theorem tensorSupportMul_nil_right (xs : List HypersequentTensorBasis) :
    tensorSupportMul xs [] = [] := by
  simp [tensorSupportMul]

@[simp]
theorem tensorSupportMul_singleton_one_left (xs : List HypersequentTensorBasis) :
    tensorSupportMul [HypersequentTensorBasis.one] xs = xs := by
  simp [tensorSupportMul]

@[simp]
theorem tensorSupportMul_singleton_one_right (xs : List HypersequentTensorBasis) :
    tensorSupportMul xs [HypersequentTensorBasis.one] = xs := by
  simp [tensorSupportMul]

/--
Multiplicative splitting tensor support for an ordered forest.

This is the support-level version of extending the tree splitting coproduct
multiplicatively from components to forests.  Since the basis indices are
hypersequents, the resulting support is insensitive to the intended order once
we later quotient/list-permutation at the coefficient layer.
-/
def forestSplittingTensorSupport : Forest → List HypersequentTensorBasis
  | [] => [HypersequentTensorBasis.one]
  | t :: ts =>
      tensorSupportMul (treeSplittingTensorSupport t)
        (forestSplittingTensorSupport ts)

@[simp]
theorem forestSplittingTensorSupport_nil :
    forestSplittingTensorSupport [] = [HypersequentTensorBasis.one] := rfl

@[simp]
theorem forestSplittingTensorSupport_cons (t : PTree) (ts : Forest) :
    forestSplittingTensorSupport (t :: ts) =
      tensorSupportMul (treeSplittingTensorSupport t)
        (forestSplittingTensorSupport ts) := rfl

@[simp]
theorem forestSplittingTensorSupport_singleton (t : PTree) :
    forestSplittingTensorSupport [t] = treeSplittingTensorSupport t := by
  simp [forestSplittingTensorSupport]

/--
Every forest has the identity tensor split in its multiplicative splitting
support.
-/
theorem forestSplittingTensorSupport_contains_identity :
    ∀ f : Forest,
      List.Mem (0, HQ.ofForest f) (forestSplittingTensorSupport f)
  | [] => by
      exact List.Mem.head []
  | t :: ts => by
      have ht : List.Mem (0, HQ.singleton t) (treeSplittingTensorSupport t) :=
        treeSplittingTensorSupport_contains_identity t
      have hts : List.Mem (0, HQ.ofForest ts) (forestSplittingTensorSupport ts) :=
        forestSplittingTensorSupport_contains_identity ts
      simpa [HypersequentTensorBasis.mul, HQ.ofForest_cons] using
        mem_tensorSupportMul_of_mem ht hts

/--
The forest-level root split obtained by taking the root split of the first
component and identity splits of all later components.
-/
theorem forestSplittingTensorSupport_contains_head_root
    (t : PTree) (ts : Forest) :
    List.Mem
      (HQ.singleton t, HQ.singleton (PTree.leaf t.conclusion) + HQ.ofForest ts)
      (forestSplittingTensorSupport (t :: ts)) := by
  have ht :
      List.Mem (HQ.singleton t, HQ.singleton (PTree.leaf t.conclusion))
        (treeSplittingTensorSupport t) :=
    treeSplittingTensorSupport_contains_root t
  have hts :
      List.Mem (0, HQ.ofForest ts) (forestSplittingTensorSupport ts) :=
    forestSplittingTensorSupport_contains_identity ts
  simpa [HypersequentTensorBasis.mul] using
    mem_tensorSupportMul_of_mem ht hts

/--
Multiplicativity of forest splitting support, in the membership form needed for
linearization: multiplying a support atom of `f` with a support atom of `g`
gives a support atom of `f ++ g`.
-/
theorem mem_forestSplittingTensorSupport_append_of_mem
    {f g : Forest} {p q : HypersequentTensorBasis}
    (hp : List.Mem p (forestSplittingTensorSupport f))
    (hq : List.Mem q (forestSplittingTensorSupport g)) :
    List.Mem (HypersequentTensorBasis.mul p q)
      (forestSplittingTensorSupport (f ++ g)) := by
  induction f generalizing p with
  | nil =>
      have hp_eq : p = HypersequentTensorBasis.one := by
        cases hp with
        | head => rfl
        | tail _ htail => cases htail
      subst p
      simpa using hq
  | cons t ts ih =>
      rcases (mem_tensorSupportMul_iff).1 hp with ⟨pt, pts, hpt, hpts, hp_eq⟩
      have htail :
          List.Mem (HypersequentTensorBasis.mul pts q)
            (forestSplittingTensorSupport (ts ++ g)) :=
        ih hpts
      have hhead :
          List.Mem
            (HypersequentTensorBasis.mul pt (HypersequentTensorBasis.mul pts q))
            (forestSplittingTensorSupport (t :: (ts ++ g))) :=
        mem_tensorSupportMul_of_mem hpt htail
      have hassoc :
          HypersequentTensorBasis.mul pt (HypersequentTensorBasis.mul pts q) =
            HypersequentTensorBasis.mul (HypersequentTensorBasis.mul pt pts) q := by
        exact (HypersequentTensorBasis.mul_assoc pt pts q).symm
      have hpq :
          HypersequentTensorBasis.mul p q =
            HypersequentTensorBasis.mul (HypersequentTensorBasis.mul pt pts) q := by
        subst p
        rfl
      simpa [hassoc, hpq]
        using hhead

theorem mem_forestSplittingTensorSupport_cons_of_mem
    {t : PTree} {ts : Forest} {p q : HypersequentTensorBasis}
    (hp : List.Mem p (treeSplittingTensorSupport t))
    (hq : List.Mem q (forestSplittingTensorSupport ts)) :
    List.Mem (HypersequentTensorBasis.mul p q)
      (forestSplittingTensorSupport (t :: ts)) := by
  exact mem_tensorSupportMul_of_mem hp hq

/-!
## Counit support

At support level, the counit is the augmentation of the forest algebra: only
the empty hypersequent survives.
-/

/-- Support predicate for the hypersequent counit/augmentation. -/
def hypersequentCounitSupport (G : Hypersequent) : Prop :=
  G = 0

@[simp]
theorem hypersequentCounitSupport_zero :
    hypersequentCounitSupport 0 := rfl

@[simp]
theorem hypersequentCounitSupport_singleton_false (t : PTree) :
    Not (hypersequentCounitSupport (HQ.singleton t)) := by
  intro h
  exact singleton_ne_zero t h

theorem hypersequentCounitSupport_add_iff
    (G H : Hypersequent) :
    hypersequentCounitSupport (G + H) ↔
      And (hypersequentCounitSupport G) (hypersequentCounitSupport H) := by
  constructor
  · intro h
    have hcard : Multiset.card G + Multiset.card H = 0 := by
      have hc := congrArg Multiset.card h
      simpa [hypersequentCounitSupport, Multiset.card_add] using hc
    rcases Nat.add_eq_zero_iff.mp hcard with ⟨hG, hH⟩
    exact And.intro
      (Multiset.card_eq_zero.mp hG)
      (Multiset.card_eq_zero.mp hH)
  · intro h
    rcases h with ⟨hG, hH⟩
    change G + H = 0
    rw [hG, hH]
    simp

theorem hypersequentCounitSupport_ofForest_append_iff
    (f g : Forest) :
    hypersequentCounitSupport (HQ.ofForest (f ++ g)) ↔
      And (hypersequentCounitSupport (HQ.ofForest f))
        (hypersequentCounitSupport (HQ.ofForest g)) := by
  simpa [HQ.ofForest_append] using
    hypersequentCounitSupport_add_iff (HQ.ofForest f) (HQ.ofForest g)

theorem not_hypersequentCounitSupport_ofForest_cons
    (t : PTree) (f : Forest) :
    Not (hypersequentCounitSupport (HQ.ofForest (t :: f))) := by
  intro h
  have hsplit :=
    (hypersequentCounitSupport_add_iff (HQ.singleton t) (HQ.ofForest f)).1
      (by simpa [HQ.ofForest_cons] using h)
  exact hypersequentCounitSupport_singleton_false t hsplit.left

noncomputable section HypersequentCounitCoefficient

variable (R : Type) [Semiring R]

/--
The basis-level counit coefficient.  It is the augmentation of the forest
algebra: the empty hypersequent has counit `1`, all nonempty hypersequents have
counit `0`.
-/
def hypersequentCounitCoeff (G : Hypersequent) : R :=
  by
    classical
    exact if hypersequentCounitSupport G then 1 else 0

@[simp]
theorem hypersequentCounitCoeff_zero :
    hypersequentCounitCoeff R 0 = 1 := by
  classical
  simp [hypersequentCounitCoeff]

@[simp]
theorem hypersequentCounitCoeff_singleton (t : PTree) :
    hypersequentCounitCoeff R (HQ.singleton t) = 0 := by
  classical
  simp [hypersequentCounitCoeff]

theorem hypersequentCounitCoeff_eq_one_of_support
    {G : Hypersequent}
    (hG : hypersequentCounitSupport G) :
    hypersequentCounitCoeff R G = 1 := by
  classical
  simp [hypersequentCounitCoeff, hG]

theorem hypersequentCounitCoeff_eq_zero_of_not_support
    {G : Hypersequent}
    (hG : Not (hypersequentCounitSupport G)) :
    hypersequentCounitCoeff R G = 0 := by
  classical
  simp [hypersequentCounitCoeff, hG]

/--
The basis-level counit is multiplicative.  This is the support-level shadow of
the `Bialgebra.counit_mul` obligation.
-/
theorem hypersequentCounitCoeff_add
    (G H : Hypersequent) :
    hypersequentCounitCoeff R (G + H) =
      hypersequentCounitCoeff R G * hypersequentCounitCoeff R H := by
  classical
  by_cases hG : hypersequentCounitSupport G
  · by_cases hH : hypersequentCounitSupport H
    · have hGH : hypersequentCounitSupport (G + H) :=
        (hypersequentCounitSupport_add_iff G H).2 (And.intro hG hH)
      simp [hypersequentCounitCoeff, hG, hH, hGH]
    · have hGH : Not (hypersequentCounitSupport (G + H)) := by
        intro h
        exact hH ((hypersequentCounitSupport_add_iff G H).1 h).right
      simp [hypersequentCounitCoeff, hG, hH, hGH]
  · have hGH : Not (hypersequentCounitSupport (G + H)) := by
      intro h
      exact hG ((hypersequentCounitSupport_add_iff G H).1 h).left
    simp [hypersequentCounitCoeff, hG, hGH]

@[simp]
theorem hypersequentCounitCoeff_ofForest_nil :
    hypersequentCounitCoeff R (HQ.ofForest []) = 1 := by
  simp

@[simp]
theorem hypersequentCounitCoeff_ofForest_cons
    (t : PTree) (f : Forest) :
    hypersequentCounitCoeff R (HQ.ofForest (t :: f)) = 0 := by
  exact hypersequentCounitCoeff_eq_zero_of_not_support R
    (not_hypersequentCounitSupport_ofForest_cons t f)

theorem hypersequentCounitCoeff_ofForest_append
    (f g : Forest) :
    hypersequentCounitCoeff R (HQ.ofForest (f ++ g)) =
      hypersequentCounitCoeff R (HQ.ofForest f) *
        hypersequentCounitCoeff R (HQ.ofForest g) := by
  simpa [HQ.ofForest_append] using
    hypersequentCounitCoeff_add R (HQ.ofForest f) (HQ.ofForest g)

end HypersequentCounitCoefficient

/-!
## Splitting counit

The plain augmentation above is useful for the forest algebra, but the
admissible-cut coproduct has a root cut whose remainder is
`PTree.leaf t.conclusion`.  For the coalgebra counit laws, that leaf remainder
must be counit-unit.  The splitting counit therefore evaluates to `1` on leaf
components and `0` on proper rule-node components, extended multiplicatively
over hypersequents.
-/

noncomputable section SplittingCounitCoefficient

variable (R : Type) [CommSemiring R]

/-- Tree-level counit for the splitting coalgebra: leaves are units. -/
def treeSplittingCounitCoeff (t : PTree) : R :=
  by
    classical
    exact if PTree.IsLeaf t then 1 else 0

@[simp]
theorem treeSplittingCounitCoeff_leaf (s : MultiSequent) :
    treeSplittingCounitCoeff R (PTree.leaf s) = 1 := by
  classical
  simp [treeSplittingCounitCoeff]

@[simp]
theorem treeSplittingCounitCoeff_node
    (r : RuleTag) (s : MultiSequent) (cs : List PTree) :
    treeSplittingCounitCoeff R (PTree.node r s cs) = 0 := by
  classical
  simp [treeSplittingCounitCoeff]

@[simp]
theorem treeSplittingCounitCoeff_root_remainder (t : PTree) :
    treeSplittingCounitCoeff R (PTree.leaf t.conclusion) = 1 := by
  cases t <;> simp

/--
Basis-level splitting counit on hypersequents, multiplicatively extended over
components.
-/
def hypersequentSplittingCounitCoeff (G : Hypersequent) : R :=
  (G.map (treeSplittingCounitCoeff R)).prod

@[simp]
theorem hypersequentSplittingCounitCoeff_zero :
    hypersequentSplittingCounitCoeff R 0 = 1 := by
  simp [hypersequentSplittingCounitCoeff]

@[simp]
theorem hypersequentSplittingCounitCoeff_singleton (t : PTree) :
    hypersequentSplittingCounitCoeff R (HQ.singleton t) =
      treeSplittingCounitCoeff R t := by
  simp [hypersequentSplittingCounitCoeff, HQ.singleton]

@[simp]
theorem hypersequentSplittingCounitCoeff_leaf_singleton
    (s : MultiSequent) :
    hypersequentSplittingCounitCoeff R (HQ.singleton (PTree.leaf s)) = 1 := by
  rw [hypersequentSplittingCounitCoeff_singleton]
  simp

@[simp]
theorem hypersequentSplittingCounitCoeff_node_singleton
    (r : RuleTag) (s : MultiSequent) (cs : List PTree) :
    hypersequentSplittingCounitCoeff R (HQ.singleton (PTree.node r s cs)) = 0 := by
  rw [hypersequentSplittingCounitCoeff_singleton]
  simp

@[simp]
theorem hypersequentSplittingCounitCoeff_root_remainder_singleton
    (t : PTree) :
    hypersequentSplittingCounitCoeff R (HQ.singleton (PTree.leaf t.conclusion)) = 1 := by
  rw [hypersequentSplittingCounitCoeff_singleton]
  simp

theorem hypersequentSplittingCounitCoeff_add
    (G H : Hypersequent) :
    hypersequentSplittingCounitCoeff R (G + H) =
      hypersequentSplittingCounitCoeff R G *
        hypersequentSplittingCounitCoeff R H := by
  simp [hypersequentSplittingCounitCoeff, Multiset.map_add, Multiset.prod_add]

theorem hypersequentSplittingCounitCoeff_ofForest_append
    (f g : Forest) :
    hypersequentSplittingCounitCoeff R (HQ.ofForest (f ++ g)) =
      hypersequentSplittingCounitCoeff R (HQ.ofForest f) *
        hypersequentSplittingCounitCoeff R (HQ.ofForest g) := by
  simpa [HQ.ofForest_append] using
    hypersequentSplittingCounitCoeff_add R (HQ.ofForest f) (HQ.ofForest g)

end SplittingCounitCoefficient

noncomputable section SplittingTensorElements

variable (R : Type) [Semiring R]

@[simp]
theorem tensorSupportElement_append
    (xs ys : List HypersequentTensorBasis) :
    tensorSupportElement R (xs ++ ys) =
      tensorSupportElement R xs + tensorSupportElement R ys := by
  simp [tensorSupportElement, List.map_append]

theorem tensorSupportElement_map_mul_left
    (p : HypersequentTensorBasis)
    (xs : List HypersequentTensorBasis) :
    tensorSupportElement R
        (xs.map (fun q => HypersequentTensorBasis.mul p q)) =
      tensorBasisMonomial R p * tensorSupportElement R xs := by
  induction xs with
  | nil =>
      simp
  | cons x xs ih =>
      rw [tensorSupportElement_cons]
      change
        tensorBasisMonomial R (HypersequentTensorBasis.mul p x) +
            tensorSupportElement R
              (xs.map (fun q => HypersequentTensorBasis.mul p q)) =
          tensorBasisMonomial R p *
            (tensorBasisMonomial R x + tensorSupportElement R xs)
      rw [left_distrib, tensorBasisMonomial_mul, ih]

/--
The support-polynomial version of multiplicativity: multiplying two support
elements is the same as summing over all pairwise products of their support
atoms.
-/
theorem tensorSupportElement_tensorSupportMul
    (xs ys : List HypersequentTensorBasis) :
    tensorSupportElement R (tensorSupportMul xs ys) =
      tensorSupportElement R xs * tensorSupportElement R ys := by
  induction xs with
  | nil =>
      simp [tensorSupportMul]
  | cons x xs ih =>
      unfold tensorSupportMul
      change
        tensorSupportElement R
            ((ys.map (fun y => HypersequentTensorBasis.mul x y)) ++
              (xs.flatMap
                fun x => ys.map (fun y => HypersequentTensorBasis.mul x y))) =
          (tensorBasisMonomial R x + tensorSupportElement R xs) *
            tensorSupportElement R ys
      rw [tensorSupportElement_append, tensorSupportElement_map_mul_left]
      change
        tensorBasisMonomial R x * tensorSupportElement R ys +
            tensorSupportElement R (tensorSupportMul xs ys) =
          (tensorBasisMonomial R x + tensorSupportElement R xs) *
            tensorSupportElement R ys
      rw [ih, right_distrib]

/-- Support element for the splitting coproduct of one tree. -/
def treeSplittingTensorElement (t : PTree) :
    HypersequentTensorAlgebra R :=
  tensorSupportElement R (treeSplittingTensorSupport t)

/-- Reduced support element for the splitting coproduct of one tree. -/
def reducedTreeSplittingTensorElement (t : PTree) :
    HypersequentTensorAlgebra R :=
  tensorSupportElement R (reducedTreeSplittingTensorSupport t)

/-- Multiplicative support element for an ordered forest. -/
def forestSplittingTensorElement (f : Forest) :
    HypersequentTensorAlgebra R :=
  tensorSupportElement R (forestSplittingTensorSupport f)

@[simp]
theorem forestSplittingTensorElement_nil :
    forestSplittingTensorElement R [] =
      (1 : HypersequentTensorAlgebra R) := by
  simp [forestSplittingTensorElement, forestSplittingTensorSupport,
    tensorSupportElement]

@[simp]
theorem forestSplittingTensorElement_singleton (t : PTree) :
    forestSplittingTensorElement R [t] =
      treeSplittingTensorElement R t := by
  simp [forestSplittingTensorElement, treeSplittingTensorElement]

@[simp]
theorem forestSplittingTensorElement_cons_mul (t : PTree) (ts : Forest) :
    forestSplittingTensorElement R (t :: ts) =
      treeSplittingTensorElement R t * forestSplittingTensorElement R ts := by
  simp [forestSplittingTensorElement, treeSplittingTensorElement,
    tensorSupportElement_tensorSupportMul]

/--
The support-polynomial coproduct on forests is multiplicative with respect to
forest concatenation.
-/
theorem forestSplittingTensorElement_append_mul :
    ∀ f g : Forest,
      forestSplittingTensorElement R (f ++ g) =
        forestSplittingTensorElement R f * forestSplittingTensorElement R g
  | [], g => by
      simp
  | t :: ts, g => by
      simp [forestSplittingTensorElement_append_mul ts g, mul_assoc]

end SplittingTensorElements

/-!
## Linearized algebra maps

The support-polynomial coproduct now extends from single trees to
hypersequents by multiplying over components.  Because hypersequents are
multisets, this uses `Multiset.prod`; hence this layer works over a
commutative base semiring, exactly as Mathlib's bialgebra API does.
-/

noncomputable section HypersequentAlgebraMaps

variable (R : Type) [CommSemiring R]

/--
Comultiplication on a basis hypersequent, valued in the tensor-support
algebra.  It multiplies the tree splitting tensors over all components.
-/
def comulHypersequent (G : Hypersequent) : HypersequentTensorAlgebra R :=
  (G.map (treeSplittingTensorElement R)).prod

@[simp]
theorem comulHypersequent_zero :
    comulHypersequent R 0 = 1 := by
  simp [comulHypersequent]

@[simp]
theorem comulHypersequent_singleton (t : PTree) :
    comulHypersequent R (HQ.singleton t) =
      treeSplittingTensorElement R t := by
  simp [comulHypersequent, HQ.singleton]

theorem comulHypersequent_add (G H : Hypersequent) :
    comulHypersequent R (G + H) =
      comulHypersequent R G * comulHypersequent R H := by
  simp [comulHypersequent, Multiset.map_add, Multiset.prod_add]

/-- The multiplicative monoid hom on basis hypersequents underlying `comul`. -/
def comulHypersequentMonoidHom :
    Multiplicative Hypersequent →* HypersequentTensorAlgebra R where
  toFun G := comulHypersequent R G.toAdd
  map_one' := by
    simp
  map_mul' G H := by
    exact comulHypersequent_add R G.toAdd H.toAdd

/--
The actual algebra-map version of the hypersequent splitting coproduct.

This is the support-level replacement for the previously missing linearized
map: multiplicativity is now supplied by `AddMonoidAlgebra.lift`.
-/
def hypersequentComulAlgHom :
    HypersequentAlgebra R →ₐ[R] HypersequentTensorAlgebra R :=
  AddMonoidAlgebra.lift R (HypersequentTensorAlgebra R) Hypersequent
    (comulHypersequentMonoidHom R)

@[simp]
theorem hypersequentComulAlgHom_single (G : Hypersequent) :
    hypersequentComulAlgHom R (AddMonoidAlgebra.single G 1) =
      comulHypersequent R G := by
  rw [hypersequentComulAlgHom]
  simp [comulHypersequentMonoidHom]

@[simp]
theorem hypersequentComulAlgHom_tree (t : PTree) :
    hypersequentComulAlgHom R (treeMonomial R t) =
      treeSplittingTensorElement R t := by
  simp [treeMonomial, hseqMonomial]

theorem hypersequentComulAlgHom_mul
    (x y : HypersequentAlgebra R) :
    hypersequentComulAlgHom R (x * y) =
      hypersequentComulAlgHom R x * hypersequentComulAlgHom R y := by
  exact map_mul (hypersequentComulAlgHom R) x y

/-- The multiplicative monoid hom on basis hypersequents underlying `counit`. -/
def hypersequentCounitMonoidHom :
    Multiplicative Hypersequent →* R where
  toFun G := hypersequentCounitCoeff R G.toAdd
  map_one' := by
    simp
  map_mul' G H := by
    exact hypersequentCounitCoeff_add R G.toAdd H.toAdd

/-- The actual algebra-map version of the hypersequent counit. -/
def hypersequentCounitAlgHom :
    HypersequentAlgebra R →ₐ[R] R :=
  AddMonoidAlgebra.lift R R Hypersequent
    (hypersequentCounitMonoidHom R)

@[simp]
theorem hypersequentCounitAlgHom_single (G : Hypersequent) :
    hypersequentCounitAlgHom R (AddMonoidAlgebra.single G 1) =
      hypersequentCounitCoeff R G := by
  rw [hypersequentCounitAlgHom]
  simp [hypersequentCounitMonoidHom]

@[simp]
theorem hypersequentCounitAlgHom_one :
    hypersequentCounitAlgHom R (1 : HypersequentAlgebra R) = 1 := by
  exact map_one (hypersequentCounitAlgHom R)

@[simp]
theorem hypersequentCounitAlgHom_tree (t : PTree) :
    hypersequentCounitAlgHom R (treeMonomial R t) = 0 := by
  simp [treeMonomial, hseqMonomial]

theorem hypersequentCounitAlgHom_mul
    (x y : HypersequentAlgebra R) :
    hypersequentCounitAlgHom R (x * y) =
      hypersequentCounitAlgHom R x * hypersequentCounitAlgHom R y := by
  exact map_mul (hypersequentCounitAlgHom R) x y

/--
The multiplicative monoid hom on basis hypersequents underlying the splitting
counit.
-/
def hypersequentSplittingCounitMonoidHom :
    Multiplicative Hypersequent →* R where
  toFun G := hypersequentSplittingCounitCoeff R G.toAdd
  map_one' := by
    simp
  map_mul' G H := by
    exact hypersequentSplittingCounitCoeff_add R G.toAdd H.toAdd

/--
The algebra-map version of the splitting counit.

Unlike the plain augmentation, this sends singleton leaf components to `1`;
that is what the root admissible cut needs for the coalgebra counit law.
-/
def hypersequentSplittingCounitAlgHom :
    HypersequentAlgebra R →ₐ[R] R :=
  AddMonoidAlgebra.lift R R Hypersequent
    (hypersequentSplittingCounitMonoidHom R)

@[simp]
theorem hypersequentSplittingCounitAlgHom_single (G : Hypersequent) :
    hypersequentSplittingCounitAlgHom R (AddMonoidAlgebra.single G 1) =
      hypersequentSplittingCounitCoeff R G := by
  rw [hypersequentSplittingCounitAlgHom]
  simp [hypersequentSplittingCounitMonoidHom]

@[simp]
theorem hypersequentSplittingCounitAlgHom_hseqMonomial (G : Hypersequent) :
    hypersequentSplittingCounitAlgHom R (hseqMonomial R G) =
      hypersequentSplittingCounitCoeff R G := by
  simp [hseqMonomial]

@[simp]
theorem hypersequentSplittingCounitAlgHom_one :
    hypersequentSplittingCounitAlgHom R (1 : HypersequentAlgebra R) = 1 := by
  exact map_one (hypersequentSplittingCounitAlgHom R)

@[simp]
theorem hypersequentSplittingCounitAlgHom_leaf (s : MultiSequent) :
    hypersequentSplittingCounitAlgHom R (treeMonomial R (PTree.leaf s)) = 1 := by
  rw [treeMonomial, hseqMonomial, hypersequentSplittingCounitAlgHom_single]
  exact hypersequentSplittingCounitCoeff_leaf_singleton R s

@[simp]
theorem hypersequentSplittingCounitAlgHom_node
    (r : RuleTag) (s : MultiSequent) (cs : List PTree) :
    hypersequentSplittingCounitAlgHom R
        (treeMonomial R (PTree.node r s cs)) = 0 := by
  rw [treeMonomial, hseqMonomial, hypersequentSplittingCounitAlgHom_single]
  exact hypersequentSplittingCounitCoeff_node_singleton R r s cs

@[simp]
theorem hypersequentSplittingCounitAlgHom_root_remainder (t : PTree) :
    hypersequentSplittingCounitAlgHom R
        (treeMonomial R (PTree.leaf t.conclusion)) = 1 := by
  rw [treeMonomial, hseqMonomial, hypersequentSplittingCounitAlgHom_single]
  exact hypersequentSplittingCounitCoeff_root_remainder_singleton R t

theorem hypersequentSplittingCounitAlgHom_mul
    (x y : HypersequentAlgebra R) :
    hypersequentSplittingCounitAlgHom R (x * y) =
      hypersequentSplittingCounitAlgHom R x *
        hypersequentSplittingCounitAlgHom R y := by
  exact map_mul (hypersequentSplittingCounitAlgHom R) x y

end HypersequentAlgebraMaps

/-!
## Tensor atoms from admissible cuts

The definitions below are the exact support-level shadow of a coalgebra map:
an admissible cut contributes a pure tensor basis index.  This is the place
where the proof-theoretic splitting rule becomes ready for later
linearization.
-/

/-- Tensor-basis term contributed by one admissible cut of one tree. -/
def tensorTermOfAdmissibleCut (t : PTree) (cut : PTree.IsAdmissibleCut t) :
    HypersequentTensorBasis :=
  ((splitTermOfAdmissibleCut t cut).1,
    HQ.singleton (splitTermOfAdmissibleCut t cut).2)

@[simp]
theorem tensorTermOfAdmissibleCut_fst
    (t : PTree) (cut : PTree.IsAdmissibleCut t) :
    (tensorTermOfAdmissibleCut t cut).1 =
      HQ.ofForest (cut.nodes.filterMap (PTree.subtreeAt t)) := rfl

@[simp]
theorem tensorTermOfAdmissibleCut_snd
    (t : PTree) (cut : PTree.IsAdmissibleCut t) :
    (tensorTermOfAdmissibleCut t cut).2 =
      HQ.singleton (PTree.remainder t cut) := rfl

@[simp]
theorem tensorTermOfAdmissibleCut_emptyCut (t : PTree) :
    tensorTermOfAdmissibleCut t (emptyCut t) =
      (0, HQ.singleton t) := by
  simp [tensorTermOfAdmissibleCut]

@[simp]
theorem tensorTermOfAdmissibleCut_rootCut (t : PTree) :
    tensorTermOfAdmissibleCut t (rootCut t) =
      (HQ.singleton t, HQ.singleton (PTree.leaf t.conclusion)) := by
  simp [tensorTermOfAdmissibleCut]

/-!
## Coalgebra-normalized split tensor terms

The proof-theoretic split relation records the root/interface remainder as the
leaf `PTree.leaf t.conclusion`.  That is right for external proof theory, but
it is not the right unit convention for the GL/CK coalgebra laws.  For the
coalgebra, the empty cut must contribute `1 ⊗ t` and the root cut must
contribute `t ⊗ 1`.

The normalized tensor term below keeps ordinary cuts unchanged, but rewrites
the two counit-critical boundary cuts into tensor units.
-/

/--
Coalgebra-normalized tensor-basis term for a raw cut list.

* `[]` contributes the right-counit term `(0, {t})`;
* a cut containing the root contributes the left-counit term `({t}, 0)`;
* all other cuts use the proof-theoretic pruned/remainder data.
-/
noncomputable def coalgebraTensorTermOfCutList
    (t : PTree) (cut : List Address) : HypersequentTensorBasis := by
  classical
  exact
    if cut = [] then
      (0, HQ.singleton t)
    else if ([] : Address) ∈ cut then
      (HQ.singleton t, 0)
    else
      (HQ.ofForest (cut.filterMap (PTree.subtreeAt t)),
        HQ.singleton (PTree.remainderGo cut [] t))

@[simp]
theorem coalgebraTensorTermOfCutList_nil (t : PTree) :
    coalgebraTensorTermOfCutList t [] = (0, HQ.singleton t) := by
  simp [coalgebraTensorTermOfCutList]

@[simp]
theorem coalgebraTensorTermOfCutList_root (t : PTree) :
    coalgebraTensorTermOfCutList t [([] : Address)] =
      (HQ.singleton t, 0) := by
  simp [coalgebraTensorTermOfCutList]

theorem coalgebraTensorTermOfCutList_of_ne_nil_of_root_not_mem
    {t : PTree} {cut : List Address}
    (hcut : cut ≠ [])
    (hroot : ([] : Address) ∉ cut) :
    coalgebraTensorTermOfCutList t cut =
      (HQ.ofForest (cut.filterMap (PTree.subtreeAt t)),
        HQ.singleton (PTree.remainderGo cut [] t)) := by
  simp [coalgebraTensorTermOfCutList, hcut, hroot]

/--
An address is coalgebraically splittable when it points to a genuine rule node.

Leaves are primitive proof-theoretic interfaces/base steps.  They may appear as
the whole component via the root cut, but they should not contribute proper
internal cut noise: cutting a leaf below a larger tree leaves the remainder
unchanged and creates precisely the bogus terms that obstruct
coassociativity.
-/
def IsNodeAddress (t : PTree) (a : Address) : Prop :=
  ∃ r s cs, PTree.subtreeAt t a = some (PTree.node r s cs)

/--
Coalgebraically admissible cuts.

The normalized coalgebra keeps the two boundary cuts:

* the empty cut, giving `1 ⊗ t`;
* any root-containing cut, normalized to `t ⊗ 1`.

Every other proper cut must select only genuine node addresses.  This removes
proper cuts of primitive/base leaves while preserving the proof-theoretic
root-boundary convention for a leaf considered as a whole component.
-/
def IsCoalgebraCut (t : PTree) (cut : List Address) : Prop :=
  Or (cut = [])
    (Or (([] : Address) ∈ cut)
      (∀ a : Address, a ∈ cut → IsNodeAddress t a))

/--
The genuinely nontrivial cuts for normalized coassociativity.

The empty cut and the root cut are boundary terms; the cut-extension bijection
only has to control the remaining internal cuts.
-/
def InternalCut (cut : List Address) : Prop :=
  cut ≠ [] ∧ ([] : Address) ∉ cut

/--
Leaf-cut noise is the coalgebra-side analogue of the bureaucratic overlap
noise isolated on the pre-Lie side: it is a proper internal cut whose support
contains a primitive leaf address.
-/
def LeafCutNoise (t : PTree) (cut : List Address) : Prop :=
  InternalCut cut ∧
    ∃ a : Address, a ∈ cut ∧ ∃ s : MultiSequent,
      PTree.subtreeAt t a = some (PTree.leaf s)

/-- The finite list of admissible cuts used by the normalized coalgebra. -/
noncomputable def coalgebraAdmissibleCuts (t : PTree) : List (List Address) := by
  classical
  exact (PTree.allAdmissibleCuts t).filter
    (fun cut => decide (IsCoalgebraCut t cut))

/-- Internal coalgebra cuts: non-boundary cuts after leaf-cut noise is removed. -/
noncomputable def internalCoalgebraAdmissibleCuts
    (t : PTree) : List (List Address) := by
  classical
  exact ((coalgebraAdmissibleCuts t).filter (fun cut => !(decide (cut = [])))).filter
    (fun cut => !(decide (([] : Address) ∈ cut)))

theorem mem_coalgebraAdmissibleCuts_iff
    {t : PTree} {cut : List Address} :
    cut ∈ coalgebraAdmissibleCuts t ↔
      cut ∈ PTree.allAdmissibleCuts t ∧ IsCoalgebraCut t cut := by
  classical
  unfold coalgebraAdmissibleCuts
  simp [IsCoalgebraCut]

theorem coalgebraTensorTermOfCutList_fst_eq_zero_iff_cut_nil
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts t) :
    (coalgebraTensorTermOfCutList t cut).1 = 0 ↔ cut = [] := by
  classical
  rcases (mem_coalgebraAdmissibleCuts_iff).1 hcut with ⟨hraw, _hcoal⟩
  by_cases hnil : cut = []
  · simp [hnil]
  · by_cases hroot : ([] : Address) ∈ cut
    · simp [coalgebraTensorTermOfCutList, hnil, hroot, singleton_ne_zero]
    · rw [coalgebraTensorTermOfCutList_of_ne_nil_of_root_not_mem
        (t := t) (cut := cut) hnil hroot]
      have hne :
          HQ.ofForest (cut.filterMap (PTree.subtreeAt t)) ≠ 0 :=
        pruned_hypersequent_ne_zero_of_cut_ne_nil
          (t := t) (cut := cut) hraw hnil
      simp [hnil, hne]

theorem coalgebraTensorTermOfCutList_snd_eq_zero_iff_root_mem
    {t : PTree} {cut : List Address}
    (_hcut : cut ∈ coalgebraAdmissibleCuts t) :
    (coalgebraTensorTermOfCutList t cut).2 = 0 ↔
      ([] : Address) ∈ cut := by
  classical
  by_cases hnil : cut = []
  · simp [hnil, singleton_ne_zero]
  · by_cases hroot : ([] : Address) ∈ cut
    · simp [coalgebraTensorTermOfCutList, hnil, hroot]
    · rw [coalgebraTensorTermOfCutList_of_ne_nil_of_root_not_mem
        (t := t) (cut := cut) hnil hroot]
      simp [hroot, singleton_ne_zero]

theorem mem_internalCoalgebraAdmissibleCuts_iff
    {t : PTree} {cut : List Address} :
    cut ∈ internalCoalgebraAdmissibleCuts t ↔
      cut ∈ coalgebraAdmissibleCuts t ∧ InternalCut cut := by
  classical
  unfold internalCoalgebraAdmissibleCuts InternalCut
  simpa [and_assoc, and_left_comm, and_comm]

@[simp]
theorem empty_mem_coalgebraAdmissibleCuts
    (t : PTree) :
    ([] : List Address) ∈ coalgebraAdmissibleCuts t := by
  exact (mem_coalgebraAdmissibleCuts_iff).2
    ⟨PTree.empty_cut_mem_allAdmissibleCuts t, Or.inl rfl⟩

@[simp]
theorem root_mem_coalgebraAdmissibleCuts
    (t : PTree) :
    ([([] : Address)] : List Address) ∈ coalgebraAdmissibleCuts t := by
  exact (mem_coalgebraAdmissibleCuts_iff).2
    ⟨singleton_root_cut_mem_allAdmissibleCuts t,
      Or.inr (Or.inl (List.mem_singleton_self ([] : Address)))⟩

theorem node_addresses_of_mem_coalgebraAdmissibleCuts_of_internal
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts t)
    (hinternal : InternalCut cut) :
    ∀ a : Address, a ∈ cut → IsNodeAddress t a := by
  rcases (mem_coalgebraAdmissibleCuts_iff).1 hcut with ⟨_hadm, hcoal⟩
  rcases hcoal with hempty | hroot | hnodes
  · exact False.elim (hinternal.1 hempty)
  · exact False.elim (hinternal.2 hroot)
  · exact hnodes

theorem antichain_of_mem_coalgebraAdmissibleCuts
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts t) :
    ∀ a, a ∈ cut →
      ∀ b, b ∈ cut →
        a ≠ b → ¬ PTree.comparable a b := by
  let C : PTree.IsAdmissibleCut t :=
    PTree.isAdmissibleCut_of_mem_allAdmissibleCuts
      ((mem_coalgebraAdmissibleCuts_iff).1 hcut).1
  exact C.antichain

theorem PTree.sublists_nodup_of_nodup
    {α : Type} [DecidableEq α] {xs : List α}
    (hxs : xs.Nodup) :
    (PTree.sublists xs).Nodup := by
  rw [PTree.sublists_eq_list_sublists']
  exact List.nodup_sublists'.2 hxs

theorem nodup_of_mem_allAdmissibleCuts
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ PTree.allAdmissibleCuts t) :
    cut.Nodup := by
  unfold PTree.allAdmissibleCuts at hcut
  rcases List.mem_filter.mp hcut with ⟨_hsub, hbool⟩
  have hanti : PTree.isAntichainBool cut = true := by
    cases hv : cut.all (fun a => PTree.validAddress t a) <;>
      cases ha : PTree.isAntichainBool cut <;>
        simp [hv, ha] at hbool
    rfl
  exact PTree.isAntichainBool_eq_true_implies_nodup hanti

theorem nodup_of_mem_coalgebraAdmissibleCuts
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts t) :
    cut.Nodup :=
  nodup_of_mem_allAdmissibleCuts
    ((mem_coalgebraAdmissibleCuts_iff).1 hcut).1

theorem nodup_of_mem_internalCoalgebraAdmissibleCuts
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ internalCoalgebraAdmissibleCuts t) :
    cut.Nodup :=
  nodup_of_mem_coalgebraAdmissibleCuts
    ((mem_internalCoalgebraAdmissibleCuts_iff).1 hcut).1

/--
Proper internal coalgebra cuts cannot cut primitive leaves.

This is the local obstruction-removal lemma for coassociativity: if an internal
coalgebra cut contains an address, that address cannot point to a leaf.
-/
theorem not_leaf_subtreeAt_of_mem_coalgebraAdmissibleCuts_of_internal
    {t : PTree} {cut : List Address} {a : Address} {s : MultiSequent}
    (hcut : cut ∈ coalgebraAdmissibleCuts t)
    (hinternal : InternalCut cut)
    (ha : a ∈ cut) :
    PTree.subtreeAt t a ≠ some (PTree.leaf s) := by
  intro hleaf
  rcases node_addresses_of_mem_coalgebraAdmissibleCuts_of_internal
      hcut hinternal a ha with ⟨r, s', cs, hnode⟩
  rw [hleaf] at hnode
  cases hnode

theorem not_leafCutNoise_of_mem_coalgebraAdmissibleCuts
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts t) :
    ¬ LeafCutNoise t cut := by
  intro hnoise
  rcases hnoise with ⟨hinternal, a, ha, s, hleaf⟩
  exact not_leaf_subtreeAt_of_mem_coalgebraAdmissibleCuts_of_internal
    hcut hinternal ha hleaf

@[simp]
theorem isNodeAddress_node_root
    (r : RuleTag) (s : MultiSequent) (cs : List PTree) :
    IsNodeAddress (PTree.node r s cs) ([] : Address) := by
  exact ⟨r, s, cs, by simp [IsNodeAddress, PTree.subtreeAt_root]⟩

theorem isNodeAddress_node_cons_iff
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {i : Nat} {addr : Address} (hi : i < cs.length) :
    IsNodeAddress (PTree.node r s cs) (i :: addr) ↔
      IsNodeAddress cs[i] addr := by
  constructor
  · rintro ⟨r', s', cs', hsub⟩
    exact ⟨r', s', cs', by
      simpa [PTree.subtreeAt_node_cons_eq r s cs i addr hi] using hsub⟩
  · rintro ⟨r', s', cs', hsub⟩
    exact ⟨r', s', cs', by
      simpa [PTree.subtreeAt_node_cons_eq r s cs i addr hi] using hsub⟩

/-- Node addresses descend and ascend along a known subtree prefix. -/
theorem isNodeAddress_subtreeAt_append_iff
    {t u : PTree} {a b : Address}
    (hsub : PTree.subtreeAt t a = some u) :
    IsNodeAddress t (a ++ b) ↔ IsNodeAddress u b := by
  induction a generalizing t u with
  | nil =>
      simp [PTree.subtreeAt] at hsub
      subst u
      simp
  | cons i rest ih =>
      cases t with
      | leaf s =>
          simp [PTree.subtreeAt] at hsub
      | node r s cs =>
          by_cases hi : i < cs.length
          · simp [PTree.subtreeAt, hi] at hsub
            have hih := ih (t := cs[i]) (u := u) hsub
            simpa [List.cons_append, isNodeAddress_node_cons_iff
              (r := r) (s := s) (cs := cs) (i := i)
              (addr := rest ++ b) hi] using hih
          · simp [PTree.subtreeAt, hi] at hsub

/--
Node-ness in a remainder reflects back to node-ness in the original tree.

Cutting replaces subtrees by primitive leaves; it never creates new rule
nodes.  Thus every rule-node address visible after a cut was already a
rule-node address in the original rooted proof tree.
-/
theorem isNodeAddress_of_remainderGo
    {t : PTree} {cut : List Address} {addr a : Address}
    (hnode : IsNodeAddress (PTree.remainderGo cut addr t) a) :
    IsNodeAddress t a := by
  induction a generalizing t addr with
  | nil =>
      cases t with
      | leaf seq =>
          rcases hnode with ⟨r, s, cs, hsub⟩
          simp [PTree.remainderGo, PTree.subtreeAt] at hsub
      | node r s cs =>
          by_cases haddr : addr ∈ cut
          · rcases hnode with ⟨r', s', cs', hsub⟩
            simp [PTree.remainderGo, haddr, PTree.subtreeAt] at hsub
          · exact isNodeAddress_node_root r s cs
  | cons i rest ih =>
      cases t with
      | leaf seq =>
          rcases hnode with ⟨r, s, cs, hsub⟩
          simp [PTree.remainderGo, PTree.subtreeAt] at hsub
      | node r s cs =>
          by_cases haddr : addr ∈ cut
          · rcases hnode with ⟨r', s', cs', hsub⟩
            simp [PTree.remainderGo, haddr, PTree.subtreeAt] at hsub
          · let remChildren :=
              cs.attach.mapIdx (fun j child =>
                PTree.remainderGo cut (addr ++ [j]) child.1)
            have hrem :
                PTree.remainderGo cut addr (PTree.node r s cs) =
                  PTree.node r s remChildren := by
              simp [PTree.remainderGo, haddr, remChildren]
            have hiRem : i < remChildren.length := by
              by_contra hnot
              rcases hnode with ⟨r', s', cs', hsub⟩
              simp [hrem, PTree.subtreeAt, remChildren] at hsub
              rcases hsub with ⟨hi, _hsub⟩
              exact hnot (by
                simpa [remChildren, List.length_mapIdx] using hi)
            have hi : i < cs.length := by
              simpa [remChildren, List.length_mapIdx] using hiRem
            have hchild :
                IsNodeAddress remChildren[i] rest := by
              exact (isNodeAddress_node_cons_iff
                (r := r) (s := s) (cs := remChildren)
                (i := i) (addr := rest) hiRem).1
                (by simpa [hrem] using hnode)
            have hchild' :
                IsNodeAddress
                  (PTree.remainderGo cut (addr ++ [i]) cs[i]) rest := by
              simpa [remChildren, List.getElem_mapIdx, List.getElem_attach] using hchild
            exact (isNodeAddress_node_cons_iff
              (r := r) (s := s) (cs := cs)
              (i := i) (addr := rest) hi).2
              (ih hchild')

theorem validAddress_of_isNodeAddress
    {t : PTree} {a : Address}
    (hnode : IsNodeAddress t a) :
    PTree.ValidAddress t a := by
  rcases hnode with ⟨r, s, cs, hsub⟩
  exact (PTree.valid_iff_exists_subtree t a).2
    ⟨PTree.node r s cs, hsub⟩

theorem mem_allAddresses_of_validAddress
    {t : PTree} {a : Address}
    (hvalid : PTree.ValidAddress t a) :
    a ∈ PTree.allAddresses t := by
  rcases (PTree.valid_iff_exists_subtree t a).1 hvalid with
    ⟨u, hsub⟩
  exact PTree.subtreeAt_some_implies_mem_allAddresses
    (t := t) (u := u) (a := a) hsub

theorem list_mapIdx_congr_mem
    {α β : Type _} (xs : List α) (f g : Nat → α → β)
    (h : ∀ i x, x ∈ xs → f i x = g i x) :
    xs.mapIdx f = xs.mapIdx g := by
  induction xs generalizing f g with
  | nil =>
      rfl
  | cons x xs ih =>
      simp only [List.mapIdx_cons]
      congr 1
      · exact h 0 x (by simp)
      · apply ih
        intro i y hy
        exact h (i + 1) y (by simp [hy])

theorem list_filter_nodup
    {α : Type _} (p : α → Bool) :
    ∀ {xs : List α}, xs.Nodup → (xs.filter p).Nodup
  | [], _ => by simp
  | x :: xs, hnodup => by
      have hnot : x ∉ xs := (List.nodup_cons.mp hnodup).1
      have htail : xs.Nodup := (List.nodup_cons.mp hnodup).2
      by_cases hp : p x = true
      · simp [List.filter, hp]
        constructor
        · intro hx
          exact hnot hx
        · exact list_filter_nodup p htail
      · have hpFalse : p x = false := by
          cases hpx : p x
          · rfl
          · exact False.elim (hp hpx)
        simp [List.filter, hpFalse]
        exact list_filter_nodup p htail

theorem list_filterMap_length_eq_of_all_some
    {α β : Type _} {f : α → Option β} :
    ∀ {xs : List α},
      (∀ x ∈ xs, ∃ y, f x = some y) →
        (xs.filterMap f).length = xs.length
  | [], _ => by
      simp
  | x :: xs, hsome => by
      rcases hsome x (by simp) with ⟨y, hy⟩
      have htail :
          ∀ z ∈ xs, ∃ y, f z = some y := by
        intro z hz
        exact hsome z (by simp [hz])
      simp [hy, list_filterMap_length_eq_of_all_some htail]

theorem list_map_cons_address_nodup
    (i : Nat) :
    ∀ {xs : List Address}, xs.Nodup →
      (xs.map (fun a => i :: a)).Nodup
  | [], _ => by simp
  | a :: rest, hnodup => by
      have hnot : a ∉ rest := (List.nodup_cons.mp hnodup).1
      have htail : rest.Nodup := (List.nodup_cons.mp hnodup).2
      simp
      constructor
      · intro hmem
        exact hnot hmem
      · exact list_map_cons_address_nodup i htail

theorem nil_not_mem_mapIdx_prefixed_address_blocks
    {α : Type _} (xs : List α) (blocks : α → List Address) :
    ([] : Address) ∉
      (xs.mapIdx
        (fun i x => (blocks x).map (fun a => i :: a))).flatten := by
  intro hnil
  rcases List.mem_flatten.1 hnil with ⟨block, hblock, hnilBlock⟩
  rw [List.mem_mapIdx] at hblock
  rcases hblock with ⟨i, hi, hblockEq⟩
  subst block
  rcases List.mem_map.1 hnilBlock with ⟨a, _ha, hEq⟩
  cases hEq

theorem list_append_nodup_of_disjoint
    {α : Type _} :
    ∀ {xs ys : List α}, xs.Nodup → ys.Nodup →
      (∀ x, x ∈ xs → x ∉ ys) → (xs ++ ys).Nodup
  | [], ys, _hxs, hys, _hdisj => by
      simpa using hys
  | x :: xs, ys, hxs, hys, hdisj => by
      have hnot : x ∉ xs := (List.nodup_cons.mp hxs).1
      have htail : xs.Nodup := (List.nodup_cons.mp hxs).2
      have htailAppend :
          (xs ++ ys).Nodup :=
        list_append_nodup_of_disjoint htail hys
          (by
            intro y hy
            exact hdisj y (by simp [hy]))
      have hxNot : x ∉ xs ++ ys := by
        intro hx
        rcases List.mem_append.1 hx with hxTail | hxYs
        · exact hnot hxTail
        · exact hdisj x (by simp) hxYs
      simpa [List.cons_append] using List.Nodup.cons hxNot htailAppend

theorem mapIdx_prefixed_address_blocks_nodup_from
    {α : Type _} (xs : List α) (blocks : α → List Address) (k : Nat)
    (hblocks : ∀ x, x ∈ xs → (blocks x).Nodup) :
    ((xs.mapIdx
        (fun i x => (blocks x).map (fun a => (k + i) :: a))).flatten).Nodup := by
  induction xs generalizing blocks k with
  | nil =>
      simp
  | cons x xs ih =>
      simp only [List.mapIdx_cons, List.flatten_cons]
      apply list_append_nodup_of_disjoint
      · exact list_map_cons_address_nodup (k + 0)
          (hblocks x (by simp))
      · simpa [Nat.add_assoc, Nat.add_left_comm, Nat.add_comm] using
          ih (blocks := blocks) (k := k + 1)
            (by
              intro y hy
              exact hblocks y (by simp [hy]))
      · intro addr hleft hright
        rcases List.mem_map.1 hleft with ⟨a, _ha, haddr⟩
        subst addr
        rcases List.mem_flatten.1 hright with ⟨block, hblock, hmemBlock⟩
        rw [List.mem_mapIdx] at hblock
        rcases hblock with ⟨i, hi, hblockEq⟩
        subst block
        rcases List.mem_map.1 hmemBlock with ⟨b, _hb, hEq⟩
        have hfirst : k + 0 = k + (i + 1) := (List.cons.inj hEq).1.symm
        omega

theorem mapIdx_prefixed_address_blocks_nodup
    {α : Type _} (xs : List α) (blocks : α → List Address)
    (hblocks : ∀ x, x ∈ xs → (blocks x).Nodup) :
    ((xs.mapIdx
        (fun i x => (blocks x).map (fun a => i :: a))).flatten).Nodup := by
  simpa using
    mapIdx_prefixed_address_blocks_nodup_from
      (xs := xs) (blocks := blocks) 0 hblocks

theorem PTree.allAddresses_nodup (t : PTree) :
    (PTree.allAddresses t).Nodup := by
  let P : Nat → Prop :=
    fun n => ∀ t : PTree, t.size = n → (PTree.allAddresses t).Nodup
  have hP : ∀ n, (∀ m < n, P m) → P n := by
    intro n ih t hsize
    cases t with
    | leaf s =>
        simp [PTree.allAddresses, PTree.allAddressesGo, PTree.size]
    | node r s cs =>
        rw [PTree.allAddresses_node]
        apply List.Nodup.cons
        · exact nil_not_mem_mapIdx_prefixed_address_blocks cs PTree.allAddresses
        · apply mapIdx_prefixed_address_blocks_nodup
          intro child hchild
          have hlt : child.size < (PTree.node r s cs).size :=
            child_size_lt_parent (PTree.node r s cs) child (by
              unfold IsImmediateSubtree PTree.children
              exact hchild)
          have hltN : child.size < n := by
            simpa [hsize] using hlt
          exact ih child.size hltN child rfl
  have hstrong : ∀ n, P n := by
    intro n
    exact Nat.strong_induction_on n hP
  exact hstrong t.size t rfl

theorem PTree.allAdmissibleCuts_nodup (t : PTree) :
    (PTree.allAdmissibleCuts t).Nodup := by
  unfold PTree.allAdmissibleCuts
  exact List.Nodup.filter _
    (PTree.sublists_nodup_of_nodup (PTree.allAddresses_nodup t))

theorem coalgebraAdmissibleCuts_nodup (t : PTree) :
    (coalgebraAdmissibleCuts t).Nodup := by
  unfold coalgebraAdmissibleCuts
  exact List.Nodup.filter _ (PTree.allAdmissibleCuts_nodup t)

theorem internalCoalgebraAdmissibleCuts_nodup (t : PTree) :
    (internalCoalgebraAdmissibleCuts t).Nodup := by
  unfold internalCoalgebraAdmissibleCuts
  exact List.Nodup.filter _
    (List.Nodup.filter _ (coalgebraAdmissibleCuts_nodup t))

/--
`remainderGo` depends on a cut list only through address membership.

This is the membership-extensionality principle needed for the staged
ambient-cut route: once two cut lists prune the same addresses, their
remainders are the same rooted proof tree.
-/
theorem PTree.remainderGo_eq_of_forall_mem_iff
    (cut₁ cut₂ : List Address) (addr : Address) (t : PTree)
    (hmem : ∀ a : Address, a ∈ cut₁ ↔ a ∈ cut₂) :
    PTree.remainderGo cut₁ addr t =
      PTree.remainderGo cut₂ addr t := by
  cases t with
  | leaf s =>
      simp [PTree.remainderGo]
  | node r s cs =>
      by_cases h₁ : addr ∈ cut₁
      · have h₂ : addr ∈ cut₂ := (hmem addr).1 h₁
        simp [PTree.remainderGo, h₁, h₂]
      · have h₂ : addr ∉ cut₂ := by
          intro h₂
          exact h₁ ((hmem addr).2 h₂)
        simp [PTree.remainderGo, h₁, h₂]
        apply list_mapIdx_congr_mem
        intro i child hchild
        exact PTree.remainderGo_eq_of_forall_mem_iff
          cut₁ cut₂ (addr ++ [i]) child.1 hmem
termination_by t.size
decreasing_by
  have hlt : child.1.size < (PTree.node r s cs).size := by
    exact child_size_lt_parent (PTree.node r s cs) child.1 (by
      unfold IsImmediateSubtree PTree.children
      exact child.2)
  simpa [PTree.size] using hlt

theorem PTree.remainderGo_eq_of_perm
    {cut₁ cut₂ : List Address}
    (hperm : List.Perm cut₁ cut₂)
    (addr : Address) (t : PTree) :
    PTree.remainderGo cut₁ addr t =
      PTree.remainderGo cut₂ addr t := by
  exact PTree.remainderGo_eq_of_forall_mem_iff
    cut₁ cut₂ addr t
    (fun _a => hperm.mem_iff)

theorem coalgebraTensorTermOfCutList_eq_of_perm
    {t : PTree} {cut₁ cut₂ : List Address}
    (hperm : List.Perm cut₁ cut₂) :
    coalgebraTensorTermOfCutList t cut₁ =
      coalgebraTensorTermOfCutList t cut₂ := by
  classical
  by_cases hnil₁ : cut₁ = []
  · have hnil₂ : cut₂ = [] := by
      have hlen : cut₂.length = 0 := by
        simpa [hnil₁] using hperm.length_eq.symm
      cases cut₂ with
      | nil => rfl
      | cons a rest =>
          simp at hlen
    simp [coalgebraTensorTermOfCutList, hnil₁, hnil₂]
  · have hnil₂ : cut₂ ≠ [] := by
      intro hnil₂
      have hlen : cut₁.length = 0 := by
        simpa [hnil₂] using hperm.length_eq
      apply hnil₁
      cases cut₁ with
      | nil => rfl
      | cons a rest =>
          simp at hlen
    by_cases hroot₁ : ([] : Address) ∈ cut₁
    · have hroot₂ : ([] : Address) ∈ cut₂ :=
        (hperm.mem_iff).1 hroot₁
      simp [coalgebraTensorTermOfCutList, hnil₁, hnil₂, hroot₁, hroot₂]
    · have hroot₂ : ([] : Address) ∉ cut₂ := by
        intro hroot₂
        exact hroot₁ ((hperm.mem_iff).2 hroot₂)
      have hforest :
          HQ.ofForest (cut₁.filterMap (PTree.subtreeAt t)) =
            HQ.ofForest (cut₂.filterMap (PTree.subtreeAt t)) :=
        HQ.ofForest_eq_of_perm (hperm.filterMap (PTree.subtreeAt t))
      have hrem :
          PTree.remainderGo cut₁ [] t =
            PTree.remainderGo cut₂ [] t :=
        PTree.remainderGo_eq_of_perm hperm [] t
      simp [coalgebraTensorTermOfCutList, hnil₁, hnil₂,
        hroot₁, hroot₂, hforest, hrem]

/--
Canonical representative of an extensionally described cut.

`allAdmissibleCuts` enumerates ordered sublists of `allAddresses`, while the
staged ambient operation is naturally set-like.  This filters the tree's own
address order by the staged membership predicate, giving the canonical list
representative needed by the finite cut enumerator.
-/
def PTree.canonicalCut (t : PTree) (cut : List Address) : List Address :=
  (PTree.allAddresses t).filter (fun a => decide (a ∈ cut))

theorem PTree.mem_canonicalCut_iff
    {t : PTree} {cut : List Address} {a : Address} :
    a ∈ PTree.canonicalCut t cut ↔
      a ∈ PTree.allAddresses t ∧ a ∈ cut := by
  classical
  simp [PTree.canonicalCut]

theorem PTree.mem_canonicalCut_iff_of_forall_mem_allAddresses
    {t : PTree} {cut : List Address}
    (hvalid : ∀ a : Address, a ∈ cut → a ∈ PTree.allAddresses t)
    {a : Address} :
    a ∈ PTree.canonicalCut t cut ↔ a ∈ cut := by
  constructor
  · intro ha
    exact (PTree.mem_canonicalCut_iff.1 ha).2
  · intro ha
    exact PTree.mem_canonicalCut_iff.2 ⟨hvalid a ha, ha⟩

theorem PTree.canonicalCut_sublist_allAddresses
    (t : PTree) (cut : List Address) :
    List.Sublist (PTree.canonicalCut t cut) (PTree.allAddresses t) := by
  classical
  unfold PTree.canonicalCut
  exact List.filter_sublist

theorem PTree.canonicalCut_nodup_of_allAddresses_nodup
    {t : PTree} {cut : List Address}
    (hnodup : (PTree.allAddresses t).Nodup) :
    (PTree.canonicalCut t cut).Nodup := by
  classical
  unfold PTree.canonicalCut
  exact list_filter_nodup
    (fun a => decide (a ∈ cut)) hnodup

theorem PTree.remainderGo_canonicalCut_eq
    (t : PTree) (cut : List Address)
    (hvalid : ∀ a : Address, a ∈ cut → a ∈ PTree.allAddresses t) :
    PTree.remainderGo (PTree.canonicalCut t cut) [] t =
      PTree.remainderGo cut [] t := by
  exact PTree.remainderGo_eq_of_forall_mem_iff
    (PTree.canonicalCut t cut) cut [] t
    (fun a =>
      PTree.mem_canonicalCut_iff_of_forall_mem_allAddresses
        (t := t) (cut := cut) hvalid (a := a))

theorem PTree.canonicalCut_perm_of_nodup_of_forall_mem_allAddresses
    {t : PTree} {cut : List Address}
    (hnodup : cut.Nodup)
    (hvalid : ∀ a : Address, a ∈ cut → a ∈ PTree.allAddresses t) :
    cut.Perm (PTree.canonicalCut t cut) := by
  have hcanonNodup :
      (PTree.canonicalCut t cut).Nodup :=
    PTree.canonicalCut_nodup_of_allAddresses_nodup
      (PTree.allAddresses_nodup t)
  have hsubCutCanon : List.Subperm cut (PTree.canonicalCut t cut) :=
    hnodup.subperm (by
      intro a ha
      exact PTree.mem_canonicalCut_iff.2 ⟨hvalid a ha, ha⟩)
  have hsubCanonCut : List.Subperm (PTree.canonicalCut t cut) cut :=
    hcanonNodup.subperm (by
      intro a ha
      exact (PTree.mem_canonicalCut_iff.1 ha).2)
  exact hsubCutCanon.antisymm hsubCanonCut

theorem node_addresses_of_mem_remainder_coalgebraAdmissibleCuts_of_internal
    {t : PTree} {cut₁ cut₂ : List Address}
    (hcut₂ : cut₂ ∈ coalgebraAdmissibleCuts (PTree.remainderGo cut₁ [] t))
    (hinternal₂ : InternalCut cut₂) :
    ∀ a : Address, a ∈ cut₂ → IsNodeAddress t a := by
  intro a ha
  exact isNodeAddress_of_remainderGo
    (t := t) (cut := cut₁) (addr := []) (a := a)
    (node_addresses_of_mem_coalgebraAdmissibleCuts_of_internal
      hcut₂ hinternal₂ a ha)

theorem isCoalgebraCut_restrictCut_of_node
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut : List Address}
    (hcoal : IsCoalgebraCut (PTree.node r s cs) cut)
    (hroot : ([] : Address) ∉ cut)
    (i : Nat) (hi : i < cs.length) :
    IsCoalgebraCut cs[i] (PTree.restrictCut cut i) := by
  classical
  by_cases hnil : PTree.restrictCut cut i = []
  · exact Or.inl hnil
  · by_cases hchildRoot : ([] : Address) ∈ PTree.restrictCut cut i
    · exact Or.inr (Or.inl hchildRoot)
    · rcases hcoal with hparentEmpty | hparentRoot | hnodes
      · subst cut
        simp [PTree.restrictCut] at hnil
      · exact False.elim (hroot hparentRoot)
      · refine Or.inr (Or.inr ?_)
        intro addr haddr
        have hparentAddr : i :: addr ∈ cut := by
          exact (PTree.mem_restrictCut_iff
            (cut := cut) (i := i) (addr := addr)).1 haddr
        exact (isNodeAddress_node_cons_iff
          (r := r) (s := s) (cs := cs) (i := i) (addr := addr) hi).1
          (hnodes (i :: addr) hparentAddr)

theorem restrictCut_mem_coalgebraAdmissibleCuts_of_mem_node
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts (PTree.node r s cs))
    (hroot : ([] : Address) ∉ cut)
    (i : Nat) (hi : i < cs.length) :
    PTree.restrictCut cut i ∈ coalgebraAdmissibleCuts cs[i] := by
  rcases (mem_coalgebraAdmissibleCuts_iff).1 hcut with ⟨hraw, hcoal⟩
  exact (mem_coalgebraAdmissibleCuts_iff).2
    ⟨PTree.restrictCut_mem_allAdmissibleCuts_of_mem_node
        hraw i hi,
      isCoalgebraCut_restrictCut_of_node
        (r := r) (s := s) (cs := cs) hcoal hroot i hi⟩

theorem restrictCut_mem_internalCoalgebraAdmissibleCuts_of_mem_node
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut : List Address} {i : Nat} (hi : i < cs.length)
    (hcut : cut ∈ coalgebraAdmissibleCuts (PTree.node r s cs))
    (hroot : ([] : Address) ∉ cut)
    (hne : PTree.restrictCut cut i ≠ [])
    (hchildRoot : ([] : Address) ∉ PTree.restrictCut cut i) :
    PTree.restrictCut cut i ∈ internalCoalgebraAdmissibleCuts cs[i] := by
  exact (mem_internalCoalgebraAdmissibleCuts_iff).2
    ⟨restrictCut_mem_coalgebraAdmissibleCuts_of_mem_node
        (r := r) (s := s) (cs := cs) hcut hroot i hi,
      ⟨hne, hchildRoot⟩⟩

/--
Raw admissible cuts restrict along an arbitrary known subtree prefix.

This iterates the already-proved immediate-child restriction theorem along the
rooted address `a`.
-/
theorem restrictCutAt_mem_allAdmissibleCuts_of_mem_subtreeAt
    {t u : PTree} {cut : List Address} {a : Address}
    (hcut : cut ∈ PTree.allAdmissibleCuts t)
    (hsub : PTree.subtreeAt t a = some u) :
    PTree.restrictCutAt cut a ∈ PTree.allAdmissibleCuts u := by
  induction a generalizing t u cut with
  | nil =>
      simp [PTree.subtreeAt] at hsub
      subst u
      simpa [PTree.restrictCutAt] using hcut
  | cons i rest ih =>
      cases t with
      | leaf s =>
          simp [PTree.subtreeAt] at hsub
      | node r s cs =>
          by_cases hi : i < cs.length
          · simp [PTree.subtreeAt, hi] at hsub
            have hchild :
                PTree.restrictCut cut i ∈
                  PTree.allAdmissibleCuts cs[i] :=
              PTree.restrictCut_mem_allAdmissibleCuts_of_mem_node
                hcut i hi
            exact ih
              (t := cs[i])
              (u := u)
              (cut := PTree.restrictCut cut i)
              hchild hsub
          · simp [PTree.subtreeAt, hi] at hsub

theorem restrictCut_node_addresses_of_mem_coalgebraAdmissibleCuts
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts (PTree.node r s cs))
    (hroot : ([] : Address) ∉ cut)
    (i : Nat) (hi : i < cs.length) :
    ∀ addr : Address, addr ∈ PTree.restrictCut cut i →
      IsNodeAddress cs[i] addr := by
  intro addr haddr
  have hparentAddr : i :: addr ∈ cut := by
    exact (PTree.mem_restrictCut_iff
      (cut := cut) (i := i) (addr := addr)).1 haddr
  have hinternal : InternalCut cut := by
    refine ⟨?_, hroot⟩
    intro hnil
    subst cut
    simpa using hparentAddr
  exact (isNodeAddress_node_cons_iff
    (r := r) (s := s) (cs := cs) (i := i) (addr := addr) hi).1
    (node_addresses_of_mem_coalgebraAdmissibleCuts_of_internal
      hcut hinternal (i :: addr) hparentAddr)

theorem not_leaf_subtreeAt_restrictCut_of_mem_coalgebraAdmissibleCuts
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut : List Address} {i : Nat} {addr : Address} {leafSeq : MultiSequent}
    (hi : i < cs.length)
    (hcut : cut ∈ coalgebraAdmissibleCuts (PTree.node r s cs))
    (hroot : ([] : Address) ∉ cut)
    (haddr : addr ∈ PTree.restrictCut cut i) :
    PTree.subtreeAt cs[i] addr ≠ some (PTree.leaf leafSeq) := by
  intro hleaf
  rcases restrictCut_node_addresses_of_mem_coalgebraAdmissibleCuts
      (r := r) (s := s) (cs := cs) hcut hroot i hi addr haddr with
    ⟨r', s', cs', hnode⟩
  rw [hleaf] at hnode
  cases hnode

/--
A nonempty admissible cut prunes at least one subtree.

This is the small support fact used by the normalized counit proof: if a cut
is not the empty cut, then its detached forest is nonempty, hence killed by the
ordinary augmentation counit.
-/
theorem filterMap_subtreeAt_ne_nil_of_mem_allAdmissibleCuts_of_ne_nil
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ PTree.allAdmissibleCuts t)
    (hne : cut ≠ []) :
    cut.filterMap (PTree.subtreeAt t) ≠ [] := by
  cases cut with
  | nil =>
      exact False.elim (hne rfl)
  | cons a rest =>
      let C : PTree.IsAdmissibleCut t :=
        PTree.isAdmissibleCut_of_mem_allAdmissibleCuts hcut
      have ha : a ∈ a :: rest := by simp
      have hvalid : PTree.ValidAddress t a := C.valid a ha
      rcases (PTree.valid_iff_exists_subtree t a).1 hvalid with ⟨u, hu⟩
      simp [List.filterMap_cons, hu]

/--
The augmentation kills the detached forest of every nonempty admissible cut.
-/
theorem hypersequentCounitCoeff_ofForest_filterMap_subtreeAt_eq_zero_of_ne_nil
    (R : Type) [Semiring R]
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ PTree.allAdmissibleCuts t)
    (hne : cut ≠ []) :
    hypersequentCounitCoeff R
        (HQ.ofForest (cut.filterMap (PTree.subtreeAt t))) = 0 := by
  have hforest :=
    filterMap_subtreeAt_ne_nil_of_mem_allAdmissibleCuts_of_ne_nil
      (t := t) (cut := cut) hcut hne
  cases hfm : cut.filterMap (PTree.subtreeAt t) with
  | nil =>
      exact False.elim (hforest hfm)
  | cons u us =>
      exact hypersequentCounitCoeff_ofForest_cons R u us

/--
For a normalized coalgebra atom, the left tensor factor has nonzero
augmentation exactly for the empty cut.
-/
theorem hypersequentCounitCoeff_fst_coalgebraTensorTermOfCutList
    (R : Type) [Semiring R]
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ PTree.allAdmissibleCuts t) :
    hypersequentCounitCoeff R (coalgebraTensorTermOfCutList t cut).1 =
      if cut = [] then 1 else 0 := by
  classical
  by_cases hnil : cut = []
  · simp [hnil]
  · by_cases hroot : ([] : Address) ∈ cut
    · simp [coalgebraTensorTermOfCutList, hnil, hroot]
    · rw [coalgebraTensorTermOfCutList_of_ne_nil_of_root_not_mem hnil hroot]
      simp [
        hnil,
        hypersequentCounitCoeff_ofForest_filterMap_subtreeAt_eq_zero_of_ne_nil
          R hcut hnil]

/--
For a normalized coalgebra atom, the right tensor factor has nonzero
augmentation exactly for the root cut.  Admissibility makes "contains the root"
the same as being the singleton root cut.
-/
theorem hypersequentCounitCoeff_snd_coalgebraTensorTermOfCutList
    (R : Type) [Semiring R]
    {t : PTree} {cut : List Address}
    (_hcut : cut ∈ PTree.allAdmissibleCuts t) :
    hypersequentCounitCoeff R (coalgebraTensorTermOfCutList t cut).2 =
      if ([] : Address) ∈ cut then 1 else 0 := by
  classical
  by_cases hnil : cut = []
  · simp [hnil]
  · by_cases hroot : ([] : Address) ∈ cut
    · simp [coalgebraTensorTermOfCutList, hnil, hroot]
    · simp [coalgebraTensorTermOfCutList, hnil, hroot]

/--
Applying a linear map to a support sum is the sum of the images of the support
atoms.
-/
theorem linearMap_apply_tensorSupportElement
    (R : Type) [Semiring R]
    {M : Type} [AddCommMonoid M] [Module R M]
    (L : HypersequentTensorAlgebra R →ₗ[R] M)
    (xs : List HypersequentTensorBasis) :
    L (tensorSupportElement R xs) =
      (xs.map (fun p => L (tensorBasisMonomial R p))).sum := by
  induction xs with
  | nil =>
      simp [tensorSupportElement]
  | cons x xs ih =>
      simp [tensorSupportElement_cons, map_add, ih]

/--
If every element of a list maps to zero, then the sum of the mapped list is
zero.
-/
theorem List.sum_map_eq_zero_of_forall
    {α M : Type} [AddCommMonoid M]
    (xs : List α) (f : α → M)
    (h : ∀ x ∈ xs, f x = 0) :
    (xs.map f).sum = 0 := by
  induction xs with
  | nil =>
      simp
  | cons x xs ih =>
      simp [h x (by simp), ih (by
        intro y hy
        exact h y (by simp [hy]))]

/--
Split a list sum into the part satisfying a decidable predicate and the
complementary part.
-/
theorem List.sum_map_eq_filter_add_filter_not
    {α M : Type} [AddCommMonoid M]
    (xs : List α) (p : α → Bool) (f : α → M) :
    (xs.map f).sum =
      ((xs.filter p).map f).sum + ((xs.filter fun x => ! p x).map f).sum := by
  induction xs with
  | nil =>
      simp
  | cons x xs ih =>
      by_cases hp : p x = true
      · simp [hp, ih, add_assoc]
      · simp [hp, ih, add_left_comm, add_assoc]

/-- Move the head of a list past a fixed prefix, preserving permutation. -/
theorem List.perm_cons_append
    {α : Type} (a : α) :
    ∀ xs ys : List α, List.Perm (a :: xs ++ ys) (xs ++ a :: ys)
  | xs, ys => by
      simpa using
        (List.perm_middle (l₁ := xs) (a := a) (l₂ := ys)).symm

/--
A list is a permutation of its `p`-part followed by its non-`p` part.

The staged coproduct support is list-valued, but coassociativity only needs the
finite family up to order.  This lemma is the reusable filter partition used
to expose empty/root/internal cut sectors as permutations.
-/
theorem List.perm_filter_append_filter_not
    {α : Type} (xs : List α) (p : α → Bool) :
    List.Perm xs (xs.filter p ++ xs.filter (fun x => ! p x)) := by
  induction xs with
  | nil =>
      simp
  | cons x xs ih =>
      by_cases hp : p x = true
      · simpa [hp] using ih.cons x
      ·
        have hmove :
            List.Perm (x :: xs.filter p ++ xs.filter (fun x => ! p x))
              (xs.filter p ++ x :: xs.filter (fun x => ! p x)) :=
          List.perm_cons_append x (xs.filter p) (xs.filter (fun x => ! p x))
        exact (ih.cons x).trans (by simpa [hp] using hmove)

/--
Three-way filter partition: first the `p` sector, then the `¬p ∧ q` sector,
then the `¬p ∧ ¬q` sector, up to permutation.
-/
theorem List.perm_filter_append_filter_filter_append_filter_filter_not
    {α : Type} (xs : List α) (p q : α → Bool) :
    List.Perm xs
      (xs.filter p ++
        ((xs.filter (fun x => ! p x)).filter q ++
          (xs.filter (fun x => ! p x)).filter (fun x => ! q x))) := by
  have h₁ := List.perm_filter_append_filter_not xs p
  have h₂ :=
    List.perm_filter_append_filter_not (xs.filter (fun x => ! p x)) q
  exact h₁.trans (List.Perm.append_left (xs.filter p) h₂)

/-- Pointwise permutations induce a permutation after `flatMap`. -/
theorem List.Perm.flatMap_congr_left
    {α β : Type} {xs : List α} {f g : α → List β}
    (h : ∀ x ∈ xs, List.Perm (f x) (g x)) :
    List.Perm (xs.flatMap f) (xs.flatMap g) := by
  induction xs with
  | nil =>
      simp
  | cons x xs ih =>
      simp [List.flatMap_cons]
      exact (h x (by simp)).append
        (ih (by
          intro y hy
          exact h y (by simp [hy])))

/--
Flattening two boundary atoms plus a residual list over an index list is
permutation-equivalent to grouping all first boundary atoms, then all second
boundary atoms, then the residuals.
-/
theorem List.flatMap_append_perm
    {α β : Type} (xs : List α) (f g : α → List β) :
    List.Perm
      (xs.flatMap (fun x => f x ++ g x))
      (xs.flatMap f ++ xs.flatMap g) := by
  induction xs with
  | nil =>
      simp
  | cons x xs ih =>
      simp [List.flatMap_cons]
      apply List.Perm.append_left (f x)
      have h₁ :
          List.Perm
            (g x ++ xs.flatMap (fun x => f x ++ g x))
            (g x ++ (xs.flatMap f ++ xs.flatMap g)) :=
        List.Perm.append_left (g x) ih
      have h₂ :
          List.Perm
            (g x ++ (xs.flatMap f ++ xs.flatMap g))
            (xs.flatMap f ++ (g x ++ xs.flatMap g)) := by
        simpa [List.append_assoc] using
          (List.perm_append_comm (l₁ := g x) (l₂ := xs.flatMap f)).append_right
            (xs.flatMap g)
      exact h₁.trans h₂

theorem List.flatMap_singleton_eq_map
    {α β : Type} (xs : List α) (f : α → β) :
    xs.flatMap (fun x => [f x]) = xs.map f := by
  induction xs with
  | nil =>
      rfl
  | cons x xs ih =>
      simp [ih]

theorem List.flatMap_two_boundary_perm
    {α β : Type} (xs : List α)
    (a b : α → β) (c : α → List β) :
    List.Perm
      (xs.flatMap (fun x => [a x] ++ ([b x] ++ c x)))
      (xs.map a ++ (xs.map b ++ xs.flatMap c)) := by
  have h₁ :
      List.Perm
        (xs.flatMap (fun x => [a x] ++ ([b x] ++ c x)))
        (xs.flatMap (fun x => [a x]) ++
          xs.flatMap (fun x => [b x] ++ c x)) :=
    List.flatMap_append_perm xs (fun x => [a x])
      (fun x => [b x] ++ c x)
  have h₂ :
      List.Perm
        (xs.flatMap (fun x => [a x]) ++
          xs.flatMap (fun x => [b x] ++ c x))
        (xs.flatMap (fun x => [a x]) ++
          (xs.flatMap (fun x => [b x]) ++ xs.flatMap c)) :=
    List.Perm.append_left (xs.flatMap (fun x => [a x]))
      (List.flatMap_append_perm xs (fun x => [b x]) c)
  exact h₁.trans (h₂.trans (by
    rw [List.flatMap_singleton_eq_map xs a,
      List.flatMap_singleton_eq_map xs b]))

theorem List.Perm.four_block_rotate_left
    {α : Type} (a b c d : List α) :
    List.Perm
      (a ++ (b ++ (c ++ d)))
      (b ++ (c ++ (a ++ d))) := by
  simpa [List.append_assoc] using
    (List.perm_append_comm (l₁ := a) (l₂ := b ++ c)).append_right d

theorem List.Perm.five_block_internal_stage
    {α : Type} (d g c e f : List α) :
    List.Perm
      (d ++ (g ++ (c ++ (e ++ f))))
      (c ++ (d ++ (e ++ (g ++ f)))) := by
  have h₁ :
      List.Perm
        (d ++ (g ++ (c ++ (e ++ f))))
        (c ++ (d ++ (g ++ (e ++ f)))) := by
    simpa [List.append_assoc] using
      (List.perm_append_comm (l₁ := d ++ g) (l₂ := c)).append_right
        (e ++ f)
  have h₂ :
      List.Perm
        (c ++ (d ++ (g ++ (e ++ f))))
        (c ++ (d ++ (e ++ (g ++ f)))) := by
    apply List.Perm.append_left c
    apply List.Perm.append_left d
    simpa [List.append_assoc] using
      (List.perm_append_comm (l₁ := g) (l₂ := e)).append_right f
  exact h₁.trans h₂

/--
Filtering a root-prefixed mapped list by the singleton root cut is the same as
first filtering the source list by the empty cut and then prefixing the root.
-/
theorem filter_map_rootCons_eq_rootCut
    (xs : List (List Address)) :
    (xs.map (fun cut => [] :: cut)).filter (fun cut => decide (cut = [[]])) =
      (xs.filter (fun cut => decide (cut = []))).map (fun cut => [] :: cut) := by
  induction xs with
  | nil =>
      simp
  | cons x xs ih =>
      cases x with
      | nil =>
          simp [ih]
      | cons a rest =>
          simp [ih]

/--
Among all sublists of a list, the empty list occurs exactly once.
-/
theorem filter_eq_nil_sublists
    {α : Type} [DecidableEq α]
    (xs : List α) :
    (PTree.sublists xs).filter (fun ys => decide (ys = [])) = [[]] := by
  induction xs with
  | nil =>
      simp [PTree.sublists]
  | cons x xs ih =>
      simp [PTree.sublists, ih]

/--
The address list of any proof tree is the root address followed by a tail that
contains no further root address.
-/
theorem allAddresses_root_cons_no_root_tail
    (t : PTree) :
    ∃ xs : List Address, PTree.allAddresses t = [] :: xs ∧ ([] : Address) ∉ xs := by
  cases t with
  | leaf s =>
      refine ⟨[], ?_, by simp⟩
      simp [PTree.allAddresses, PTree.size, PTree.allAddressesGo]
  | node r s cs =>
      refine ⟨(cs.mapIdx (fun i child => (PTree.allAddresses child).map (fun a => i :: a))).flatten, ?_, ?_⟩
      · simpa [PTree.allAddresses_node]
      · intro h
        simp at h

/--
If the tail contains no root address, then among the sublists of `[] :: xs`
the singleton root cut `[[]]` appears exactly once.
-/
theorem filter_eq_rootCut_sublists_root_cons
    (xs : List Address)
    (hxs : ([] : Address) ∉ xs) :
    (PTree.sublists ([] :: xs)).filter (fun cut => decide (cut = [[]])) = [[[]]] := by
  have hfirst :
      (PTree.sublists xs).filter (fun cut => decide (cut = [[]])) = [] := by
    apply List.eq_nil_iff_forall_not_mem.mpr
    intro cut hcut
    rcases List.mem_filter.1 hcut with ⟨hsub, heq⟩
    have hEq : cut = [[]] := by simpa using heq
    subst cut
    have hsub' : List.Sublist ([[]] : List Address) xs :=
      (PTree.mem_sublists_iff_sublist).1 hsub
    exact hxs (hsub'.subset (by simp))
  simp [PTree.sublists, hfirst, filter_map_rootCons_eq_rootCut, filter_eq_nil_sublists]

/--
Among the raw sublists of the address list of a tree, the singleton root cut
`[[]]` occurs exactly once.
-/
theorem filter_eq_rootCut_sublists_allAddresses
    (t : PTree) :
    (PTree.sublists (PTree.allAddresses t)).filter (fun cut => decide (cut = [[]])) = [[[]]] := by
  rcases allAddresses_root_cons_no_root_tail t with ⟨xs, haddr, hxs⟩
  rw [haddr]
  exact filter_eq_rootCut_sublists_root_cons xs hxs

/--
Among all admissible cuts, the empty cut occurs exactly once.
-/
theorem filter_eq_emptyCut_allAdmissibleCuts
    (t : PTree) :
    (PTree.allAdmissibleCuts t).filter (fun cut => decide (cut = [])) = [[]] := by
  classical
  unfold PTree.allAdmissibleCuts
  have hcongr :
      List.filter
          (fun a =>
            decide (a = []) &&
              ((a.all fun b => PTree.validAddress t b) && PTree.isAntichainBool a))
          (PTree.sublists (PTree.allAddresses t)) =
        List.filter
          (fun a => decide (a = []))
          (PTree.sublists (PTree.allAddresses t)) := by
    apply List.filter_congr
    intro a _ha
    by_cases h : a = []
    · subst a
      simp [PTree.isAntichainBool]
    · simp [h]
  rw [List.filter_filter]
  rw [hcongr]
  exact filter_eq_nil_sublists (xs := PTree.allAddresses t)

/--
Among all admissible cuts, the singleton root cut `[[]]` occurs exactly once.
-/
theorem filter_eq_rootCut_allAdmissibleCuts
    (t : PTree) :
    (PTree.allAdmissibleCuts t).filter (fun cut => decide (cut = [[]])) = [[[]]] := by
  classical
  unfold PTree.allAdmissibleCuts
  rw [List.filter_filter]
  have hcongr :
      List.filter
          (fun cut =>
            decide (cut = [[]]) &&
              ((cut.all fun a => PTree.validAddress t a) && PTree.isAntichainBool cut))
          (PTree.sublists (PTree.allAddresses t)) =
        List.filter
          (fun cut => decide (cut = [[]]))
          (PTree.sublists (PTree.allAddresses t)) := by
    apply List.filter_congr
    intro cut _hcut
    by_cases h : cut = [[]]
    · subst cut
      simp [PTree.isAntichainBool, PTree.validAddress_root]
    · simp [h]
  rw [hcongr]
  exact filter_eq_rootCut_sublists_allAddresses t

/--
Among all admissible cuts, the cuts containing the root are exactly the
singleton root cut `[[]]`.
-/
theorem filter_eq_rootContainingCut_allAdmissibleCuts
    (t : PTree) :
    (PTree.allAdmissibleCuts t).filter (fun cut => decide (([] : Address) ∈ cut)) = [[[]]] := by
  classical
  have hcongr :
      (PTree.allAdmissibleCuts t).filter (fun cut => decide (([] : Address) ∈ cut)) =
        (PTree.allAdmissibleCuts t).filter (fun cut => decide (cut = [[]])) := by
    apply List.filter_congr
    intro cut hcut
    by_cases hroot : ([] : Address) ∈ cut
    · have hEq := PTree.eq_singleton_root_of_mem_allAdmissibleCuts_of_root_mem hcut hroot
      simp [hroot, hEq]
    · have hne : cut ≠ [[]] := by
          intro hEq
          subst cut
          exact hroot (by simp)
      simp [hroot, hne]
  rw [hcongr]
  exact filter_eq_rootCut_allAdmissibleCuts t

theorem filter_eq_emptyCut_coalgebraAdmissibleCuts
    (t : PTree) :
    (coalgebraAdmissibleCuts t).filter (fun cut => decide (cut = [])) =
      [[]] := by
  classical
  unfold coalgebraAdmissibleCuts
  calc
    ((PTree.allAdmissibleCuts t).filter
        (fun cut => decide (IsCoalgebraCut t cut))).filter
          (fun cut => decide (cut = [])) =
      ((PTree.allAdmissibleCuts t).filter
          (fun cut => decide (cut = []))).filter
        (fun cut => decide (IsCoalgebraCut t cut)) := by
          rw [List.filter_filter, List.filter_filter]
          apply List.filter_congr
          intro cut _hcut
          by_cases hnil : cut = []
          · simp [hnil, IsCoalgebraCut]
          · simp [hnil]
    _ = ([[]] : List (List Address)).filter
        (fun cut => decide (IsCoalgebraCut t cut)) := by
          rw [filter_eq_emptyCut_allAdmissibleCuts]
    _ = ([[]] : List (List Address)) := by
          have hcoal : IsCoalgebraCut t ([] : List Address) := Or.inl rfl
          simp [hcoal]

theorem filter_eq_rootContainingCut_coalgebraAdmissibleCuts
    (t : PTree) :
    (coalgebraAdmissibleCuts t).filter
        (fun cut => decide (([] : Address) ∈ cut)) =
      [[([] : Address)]] := by
  classical
  unfold coalgebraAdmissibleCuts
  calc
    ((PTree.allAdmissibleCuts t).filter
        (fun cut => decide (IsCoalgebraCut t cut))).filter
          (fun cut => decide (([] : Address) ∈ cut)) =
      ((PTree.allAdmissibleCuts t).filter
          (fun cut => decide (([] : Address) ∈ cut))).filter
        (fun cut => decide (IsCoalgebraCut t cut)) := by
          rw [List.filter_filter, List.filter_filter]
          apply List.filter_congr
          intro cut _hcut
          by_cases hroot : ([] : Address) ∈ cut
          · simp [hroot, IsCoalgebraCut]
          · simp [hroot]
    _ = ([[([] : Address)]] : List (List Address)).filter
        (fun cut => decide (IsCoalgebraCut t cut)) := by
          rw [filter_eq_rootContainingCut_allAdmissibleCuts]
    _ = ([[([] : Address)]] : List (List Address)) := by
          have hcoal : IsCoalgebraCut t ([([] : Address)] : List Address) :=
            Or.inr (Or.inl (List.mem_singleton_self ([] : Address)))
          simp [hcoal]

/--
After removing the empty cut, the root-containing coalgebra cut sector is still
exactly the singleton root cut.
-/
theorem filter_ne_empty_eq_rootContainingCut_coalgebraAdmissibleCuts
    (t : PTree) :
    ((coalgebraAdmissibleCuts t).filter
        (fun cut => !(decide (cut = [])))).filter
        (fun cut => decide (([] : Address) ∈ cut)) =
      [[([] : Address)]] := by
  classical
  calc
    ((coalgebraAdmissibleCuts t).filter
        (fun cut => !(decide (cut = [])))).filter
        (fun cut => decide (([] : Address) ∈ cut)) =
      (coalgebraAdmissibleCuts t).filter
        (fun cut => !(decide (cut = [])) &&
          decide (([] : Address) ∈ cut)) := by
            rw [List.filter_filter]
            simp [Bool.and_comm]
    _ =
      (coalgebraAdmissibleCuts t).filter
        (fun cut => decide (([] : Address) ∈ cut)) := by
            apply List.filter_congr
            intro cut _hcut
            by_cases hroot : ([] : Address) ∈ cut
            · have hneq : cut ≠ [] := by
                intro hnil
                subst cut
                simpa using hroot
              simp [hroot, hneq]
            · simp [hroot]
    _ = [[([] : Address)]] := by
            rw [filter_eq_rootContainingCut_coalgebraAdmissibleCuts]

/--
Coalgebra-normalized tensor-basis support for one proof tree.

This is the support that should feed the Mathlib `Coalgebra` instance.  It is
separate from `treeSplittingTensorSupport`, which remains the proof-theoretic
external-split support.
-/
noncomputable def coalgebraTreeSplittingTensorSupport
    (t : PTree) : List HypersequentTensorBasis :=
  (coalgebraAdmissibleCuts t).map (coalgebraTensorTermOfCutList t)

theorem mem_coalgebraTreeSplittingTensorSupport_iff
    {t : PTree} {p : HypersequentTensorBasis} :
    List.Mem p (coalgebraTreeSplittingTensorSupport t) ↔
      ∃ cut ∈ coalgebraAdmissibleCuts t,
        p = coalgebraTensorTermOfCutList t cut := by
  unfold coalgebraTreeSplittingTensorSupport
  constructor
  · intro hp
    rcases List.mem_map.1 hp with ⟨cut, hcut, hpcut⟩
    exact ⟨cut, hcut, hpcut.symm⟩
  · intro hp
    rcases hp with ⟨cut, hcut, hp⟩
    exact List.mem_map.2 ⟨cut, hcut, hp.symm⟩

@[simp]
theorem coalgebraTreeSplittingTensorSupport_contains_empty (t : PTree) :
    List.Mem (0, HQ.singleton t) (coalgebraTreeSplittingTensorSupport t) := by
  exact (mem_coalgebraTreeSplittingTensorSupport_iff).2
    ⟨[], empty_mem_coalgebraAdmissibleCuts t, by simp⟩

@[simp]
theorem coalgebraTreeSplittingTensorSupport_contains_root (t : PTree) :
    List.Mem (HQ.singleton t, 0) (coalgebraTreeSplittingTensorSupport t) := by
  exact (mem_coalgebraTreeSplittingTensorSupport_iff).2
    ⟨[([] : Address)], root_mem_coalgebraAdmissibleCuts t, by simp⟩

/--
The tensor-basis index associated to a split term.

This is the small bridge between the proof-theoretic external split relation
and the algebraic support of the splitting coproduct: a split term
`(detached, remainder)` contributes the pure tensor basis index
`detached ⊗ {remainder}`.
-/
def tensorBasisOfSplitTerm (p : SplitTerm) : HypersequentTensorBasis :=
  (p.1, HQ.singleton p.2)

@[simp]
theorem tensorBasisOfSplitTerm_fst (p : SplitTerm) :
    (tensorBasisOfSplitTerm p).1 = p.1 := rfl

@[simp]
theorem tensorBasisOfSplitTerm_snd (p : SplitTerm) :
    (tensorBasisOfSplitTerm p).2 = HQ.singleton p.2 := rfl

@[simp]
theorem tensorTermOfAdmissibleCut_eq_tensorBasisOfSplitTerm
    (t : PTree) (cut : PTree.IsAdmissibleCut t) :
    tensorTermOfAdmissibleCut t cut =
      tensorBasisOfSplitTerm (splitTermOfAdmissibleCut t cut) := rfl

/-- Tensor atom attached to the original split of a grafted tree. -/
def originalTensorTerm
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v) :
    HypersequentTensorBasis :=
  tensorBasisOfSplitTerm (originalSplitTerm hg cut)

/-- Tensor atom attached to the host-side part of a boundary-free split. -/
def hostTensorTerm
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) :
    HypersequentTensorBasis :=
  tensorBasisOfSplitTerm (hostSplitTerm hg cut hfree)

/-- Tensor atom attached to the insert-side part of a boundary-free split. -/
def insertTensorTerm
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v) :
    HypersequentTensorBasis :=
  tensorBasisOfSplitTerm (insertSplitTerm hg cut)

@[simp]
theorem originalTensorTerm_fst
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v) :
    (originalTensorTerm hg cut).1 = (originalSplitTerm hg cut).1 := rfl

@[simp]
theorem originalTensorTerm_snd
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v) :
    (originalTensorTerm hg cut).2 =
      HQ.singleton (originalSplitTerm hg cut).2 := rfl

@[simp]
theorem hostTensorTerm_fst
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) :
    (hostTensorTerm hg cut hfree).1 = (hostSplitTerm hg cut hfree).1 := rfl

@[simp]
theorem hostTensorTerm_snd
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) :
    (hostTensorTerm hg cut hfree).2 =
      HQ.singleton (hostSplitTerm hg cut hfree).2 := rfl

@[simp]
theorem insertTensorTerm_fst
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v) :
    (insertTensorTerm hg cut).1 = (insertSplitTerm hg cut).1 := rfl

@[simp]
theorem insertTensorTerm_snd
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v) :
    (insertTensorTerm hg cut).2 =
      HQ.singleton (insertSplitTerm hg cut).2 := rfl

/--
A tensor-basis index is a splitting atom for `t` when it is the detached
hypersequent paired with the singleton remainder of some external split.
-/
def SplittingTensorAtom (t : PTree) (q : HypersequentTensorBasis) : Prop :=
  Exists fun H => Exists fun r =>
    And (SplitsTo t H r) (q = (H, HQ.singleton r))

theorem splittingTensorAtom_of_splitsTo
    {t r : PTree} {H : Hypersequent}
    (hs : SplitsTo t H r) :
    SplittingTensorAtom t (H, HQ.singleton r) :=
  ⟨H, r, And.intro hs rfl⟩

theorem splittingTensorAtom_tensorBasisOfSplitTerm
    {t : PTree} {p : SplitTerm}
    (hs : SplitsTo t p.1 p.2) :
    SplittingTensorAtom t (tensorBasisOfSplitTerm p) := by
  exact splittingTensorAtom_of_splitsTo hs

theorem originalTensorTerm_atom
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v) :
    SplittingTensorAtom v (originalTensorTerm hg cut) := by
  exact splittingTensorAtom_tensorBasisOfSplitTerm
    (originalSplitTerm_splitsTo hg cut)

theorem hostTensorTerm_atom
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) :
    SplittingTensorAtom t (hostTensorTerm hg cut hfree) := by
  exact splittingTensorAtom_tensorBasisOfSplitTerm
    (hostSplitTerm_splitsTo hg cut hfree)

theorem insertTensorTerm_atom
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v) :
    SplittingTensorAtom u (insertTensorTerm hg cut) := by
  exact splittingTensorAtom_tensorBasisOfSplitTerm
    (insertSplitTerm_splitsTo hg cut)

/--
The tensor atom produced by multiplying the host-side and insert-side split
atoms.  This is the exact support-level shape expected on the right side of
the graft/split coherence theorem.
-/
def hostInsertTensorProductTerm
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) :
    HypersequentTensorBasis :=
  HypersequentTensorBasis.mul
    (hostTensorTerm hg cut hfree)
    (insertTensorTerm hg cut)

@[simp]
theorem hostInsertTensorProductTerm_fst
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) :
    (hostInsertTensorProductTerm hg cut hfree).1 =
      (hostSplitTerm hg cut hfree).1 + (insertSplitTerm hg cut).1 := rfl

@[simp]
theorem hostInsertTensorProductTerm_snd
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) :
    (hostInsertTensorProductTerm hg cut hfree).2 =
      HQ.singleton (hostSplitTerm hg cut hfree).2 +
        HQ.singleton (insertSplitTerm hg cut).2 := rfl

theorem hostInsertTensorProductTerm_mem_tensorSupportMul
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a)
    (hhost : List.Mem (hostTensorTerm hg cut hfree)
      (treeSplittingTensorSupport t))
    (hinsert : List.Mem (insertTensorTerm hg cut)
      (treeSplittingTensorSupport u)) :
    List.Mem (hostInsertTensorProductTerm hg cut hfree)
      (tensorSupportMul (treeSplittingTensorSupport t)
        (treeSplittingTensorSupport u)) := by
  exact mem_tensorSupportMul_of_mem hhost hinsert

noncomputable section BoundaryFreeGraftTensorMonomials

variable (R : Type) [Semiring R]

/--
At the polynomial level, the host-insert tensor product term is represented by
the product of the host tensor monomial and the insert tensor monomial.

This is the algebraic shadow of the proof-theoretic statement that external
splitting distributes over the two independent components of a boundary-free
graft split.
-/
theorem tensorBasisMonomial_hostInsertTensorProductTerm
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) :
    tensorBasisMonomial R (hostInsertTensorProductTerm hg cut hfree) =
      tensorBasisMonomial R (hostTensorTerm hg cut hfree) *
        tensorBasisMonomial R (insertTensorTerm hg cut) := by
  simpa [hostInsertTensorProductTerm] using
    (tensorBasisMonomial_mul R
      (hostTensorTerm hg cut hfree)
      (insertTensorTerm hg cut)).symm

/--
Equivalently, multiplying the host and insert tensor monomials lands at the
named host-insert tensor product atom.
-/
theorem tensorBasisMonomial_host_mul_insert
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) :
    tensorBasisMonomial R (hostTensorTerm hg cut hfree) *
        tensorBasisMonomial R (insertTensorTerm hg cut) =
      tensorBasisMonomial R (hostInsertTensorProductTerm hg cut hfree) := by
  simpa using
    (tensorBasisMonomial_hostInsertTensorProductTerm R hg cut hfree).symm

/--
If host and insert atoms occur in their respective tree supports, the product
of the corresponding one-term tensor polynomials is a summand indexed by the
pairwise support product.
-/
theorem tensorSupportElement_host_insert_product_supports_named_atom
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a)
    (hhost : List.Mem (hostTensorTerm hg cut hfree)
      (treeSplittingTensorSupport t))
    (hinsert : List.Mem (insertTensorTerm hg cut)
      (treeSplittingTensorSupport u)) :
    List.Mem (hostInsertTensorProductTerm hg cut hfree)
      (tensorSupportMul (treeSplittingTensorSupport t)
        (treeSplittingTensorSupport u)) := by
  exact hostInsertTensorProductTerm_mem_tensorSupportMul
    hg cut hfree hhost hinsert

end BoundaryFreeGraftTensorMonomials

theorem splittingTensorAtom_of_mem_treeSplittingTensorSupport
    {t : PTree} {q : HypersequentTensorBasis}
    (hq : List.Mem q (treeSplittingTensorSupport t)) :
    SplittingTensorAtom t q := by
  rcases (mem_treeSplittingTensorSupport_iff).1 hq with ⟨p, hp, hpq⟩
  exact ⟨p.1, p.2, And.intro (splitsTo_of_mem_splittingSupport hp) hpq⟩

theorem mem_treeSplittingTensorSupport_of_mem_allAdmissibleCuts
    {t : PTree} {cut : List Address}
    (hcut : List.Mem cut (PTree.allAdmissibleCuts t)) :
    List.Mem
      (HQ.ofForest (cut.filterMap (PTree.subtreeAt t)),
        HQ.singleton (PTree.remainderGo cut [] t))
      (treeSplittingTensorSupport t) := by
  exact (mem_treeSplittingTensorSupport_iff).2
    ⟨(HQ.ofForest (cut.filterMap (PTree.subtreeAt t)),
        PTree.remainderGo cut [] t),
      And.intro (mem_splittingSupport_of_mem_allAdmissibleCuts hcut) rfl⟩

theorem tensorTermOfAdmissibleCut_mem_treeSplittingTensorSupport
    (t : PTree) (cut : PTree.IsAdmissibleCut t)
    (hcut : List.Mem cut.nodes (PTree.allAdmissibleCuts t)) :
    List.Mem (tensorTermOfAdmissibleCut t cut)
      (treeSplittingTensorSupport t) := by
  simpa [tensorTermOfAdmissibleCut, splitTermOfAdmissibleCut, PTree.remainder]
    using mem_treeSplittingTensorSupport_of_mem_allAdmissibleCuts hcut

theorem treeSplittingTensorSupport_terms_are_external_splits
    (W : ExternalWeakeningPolicy)
    (G : Hypersequent)
    {t : PTree} {q : HypersequentTensorBasis}
    (hq : List.Mem q (treeSplittingTensorSupport t)) :
    Exists fun r =>
      And (q.2 = HQ.singleton r)
        (ExternalStep W (G + HQ.singleton t) (G + q.1 + HQ.singleton r)) := by
  rcases (mem_treeSplittingTensorSupport_iff).1 hq with ⟨p, hp, hpq⟩
  refine ⟨p.2, ?_⟩
  constructor
  · have hq2 := congrArg Prod.snd hpq
    simpa using hq2
  · have hstep := externalStep_of_mem_splittingSupport W G hp
    have hq1 : q.1 = p.1 := by
      have hq1' := congrArg Prod.fst hpq
      simpa using hq1'
    subst q
    simpa using hstep

/-!
## Tensor-support form of boundary-free graft coherence

The earlier `BoundaryFreeGraftSupportCoherence` object lives at the
proof-theoretic split-term level.  The lemmas here translate it into the tensor
basis used by `hypersequentComulAlgHom`.
-/

namespace BoundaryFreeGraftSupportCoherence

/-- The original split tensor atom of a boundary-free graft split. -/
def originalTensor
    {u t v : PTree} {a : Address}
    {hg : PTree.graftMatchingLeafAt u t a = some v}
    {cut : PTree.IsAdmissibleCut v}
    {hfree : BoundaryFreeAt cut.nodes a}
    (C : BoundaryFreeGraftSupportCoherence u t v a hg cut hfree) :
    HypersequentTensorBasis :=
  tensorBasisOfSplitTerm C.original

/-- The host-side split tensor atom of a boundary-free graft split. -/
def hostTensor
    {u t v : PTree} {a : Address}
    {hg : PTree.graftMatchingLeafAt u t a = some v}
    {cut : PTree.IsAdmissibleCut v}
    {hfree : BoundaryFreeAt cut.nodes a}
    (C : BoundaryFreeGraftSupportCoherence u t v a hg cut hfree) :
    HypersequentTensorBasis :=
  tensorBasisOfSplitTerm C.host

/-- The insert-side split tensor atom of a boundary-free graft split. -/
def insertTensor
    {u t v : PTree} {a : Address}
    {hg : PTree.graftMatchingLeafAt u t a = some v}
    {cut : PTree.IsAdmissibleCut v}
    {hfree : BoundaryFreeAt cut.nodes a}
    (C : BoundaryFreeGraftSupportCoherence u t v a hg cut hfree) :
    HypersequentTensorBasis :=
  tensorBasisOfSplitTerm C.insert

/--
The tensor-basis product of the host-side and insert-side split atoms.

This is the right-hand support atom in the boundary-free part of the future
identity `Delta_split (u graft t) = F (Delta_split u, Delta_split t)`.
-/
def hostInsertTensorProduct
    {u t v : PTree} {a : Address}
    {hg : PTree.graftMatchingLeafAt u t a = some v}
    {cut : PTree.IsAdmissibleCut v}
    {hfree : BoundaryFreeAt cut.nodes a}
    (C : BoundaryFreeGraftSupportCoherence u t v a hg cut hfree) :
    HypersequentTensorBasis :=
  HypersequentTensorBasis.mul C.hostTensor C.insertTensor

@[simp]
theorem originalTensor_fst
    {u t v : PTree} {a : Address}
    {hg : PTree.graftMatchingLeafAt u t a = some v}
    {cut : PTree.IsAdmissibleCut v}
    {hfree : BoundaryFreeAt cut.nodes a}
    (C : BoundaryFreeGraftSupportCoherence u t v a hg cut hfree) :
    C.originalTensor.1 = C.original.1 := rfl

@[simp]
theorem originalTensor_snd
    {u t v : PTree} {a : Address}
    {hg : PTree.graftMatchingLeafAt u t a = some v}
    {cut : PTree.IsAdmissibleCut v}
    {hfree : BoundaryFreeAt cut.nodes a}
    (C : BoundaryFreeGraftSupportCoherence u t v a hg cut hfree) :
    C.originalTensor.2 = HQ.singleton C.original.2 := rfl

@[simp]
theorem hostTensor_fst
    {u t v : PTree} {a : Address}
    {hg : PTree.graftMatchingLeafAt u t a = some v}
    {cut : PTree.IsAdmissibleCut v}
    {hfree : BoundaryFreeAt cut.nodes a}
    (C : BoundaryFreeGraftSupportCoherence u t v a hg cut hfree) :
    C.hostTensor.1 = C.host.1 := rfl

@[simp]
theorem hostTensor_snd
    {u t v : PTree} {a : Address}
    {hg : PTree.graftMatchingLeafAt u t a = some v}
    {cut : PTree.IsAdmissibleCut v}
    {hfree : BoundaryFreeAt cut.nodes a}
    (C : BoundaryFreeGraftSupportCoherence u t v a hg cut hfree) :
    C.hostTensor.2 = HQ.singleton C.host.2 := rfl

@[simp]
theorem insertTensor_fst
    {u t v : PTree} {a : Address}
    {hg : PTree.graftMatchingLeafAt u t a = some v}
    {cut : PTree.IsAdmissibleCut v}
    {hfree : BoundaryFreeAt cut.nodes a}
    (C : BoundaryFreeGraftSupportCoherence u t v a hg cut hfree) :
    C.insertTensor.1 = C.insert.1 := rfl

@[simp]
theorem insertTensor_snd
    {u t v : PTree} {a : Address}
    {hg : PTree.graftMatchingLeafAt u t a = some v}
    {cut : PTree.IsAdmissibleCut v}
    {hfree : BoundaryFreeAt cut.nodes a}
    (C : BoundaryFreeGraftSupportCoherence u t v a hg cut hfree) :
    C.insertTensor.2 = HQ.singleton C.insert.2 := rfl

@[simp]
theorem hostInsertTensorProduct_fst
    {u t v : PTree} {a : Address}
    {hg : PTree.graftMatchingLeafAt u t a = some v}
    {cut : PTree.IsAdmissibleCut v}
    {hfree : BoundaryFreeAt cut.nodes a}
    (C : BoundaryFreeGraftSupportCoherence u t v a hg cut hfree) :
    C.hostInsertTensorProduct.1 = C.host.1 + C.insert.1 := rfl

@[simp]
theorem hostInsertTensorProduct_snd
    {u t v : PTree} {a : Address}
    {hg : PTree.graftMatchingLeafAt u t a = some v}
    {cut : PTree.IsAdmissibleCut v}
    {hfree : BoundaryFreeAt cut.nodes a}
    (C : BoundaryFreeGraftSupportCoherence u t v a hg cut hfree) :
    C.hostInsertTensorProduct.2 =
      HQ.singleton C.host.2 + HQ.singleton C.insert.2 := rfl

theorem originalTensor_atom
    {u t v : PTree} {a : Address}
    {hg : PTree.graftMatchingLeafAt u t a = some v}
    {cut : PTree.IsAdmissibleCut v}
    {hfree : BoundaryFreeAt cut.nodes a}
    (C : BoundaryFreeGraftSupportCoherence u t v a hg cut hfree) :
    SplittingTensorAtom v C.originalTensor := by
  exact splittingTensorAtom_tensorBasisOfSplitTerm C.original_splits

theorem hostTensor_atom
    {u t v : PTree} {a : Address}
    {hg : PTree.graftMatchingLeafAt u t a = some v}
    {cut : PTree.IsAdmissibleCut v}
    {hfree : BoundaryFreeAt cut.nodes a}
    (C : BoundaryFreeGraftSupportCoherence u t v a hg cut hfree) :
    SplittingTensorAtom t C.hostTensor := by
  exact splittingTensorAtom_tensorBasisOfSplitTerm C.host_splits

theorem insertTensor_atom
    {u t v : PTree} {a : Address}
    {hg : PTree.graftMatchingLeafAt u t a = some v}
    {cut : PTree.IsAdmissibleCut v}
    {hfree : BoundaryFreeAt cut.nodes a}
    (C : BoundaryFreeGraftSupportCoherence u t v a hg cut hfree) :
    SplittingTensorAtom u C.insertTensor := by
  exact splittingTensorAtom_tensorBasisOfSplitTerm C.insert_splits

theorem hostInsertTensorProduct_mem_tensorSupportMul
    {u t v : PTree} {a : Address}
    {hg : PTree.graftMatchingLeafAt u t a = some v}
    {cut : PTree.IsAdmissibleCut v}
    {hfree : BoundaryFreeAt cut.nodes a}
    (C : BoundaryFreeGraftSupportCoherence u t v a hg cut hfree)
    (hhost : List.Mem C.hostTensor (treeSplittingTensorSupport t))
    (hinsert : List.Mem C.insertTensor (treeSplittingTensorSupport u)) :
    List.Mem C.hostInsertTensorProduct
      (tensorSupportMul (treeSplittingTensorSupport t)
        (treeSplittingTensorSupport u)) := by
  exact mem_tensorSupportMul_of_mem hhost hinsert

noncomputable section TensorMonomials

variable (R : Type) [Semiring R]

/--
The tensor product atom carried by a coherence object is represented by the
product of its host and insert tensor monomials.
-/
theorem tensorBasisMonomial_hostInsertTensorProduct
    {u t v : PTree} {a : Address}
    {hg : PTree.graftMatchingLeafAt u t a = some v}
    {cut : PTree.IsAdmissibleCut v}
    {hfree : BoundaryFreeAt cut.nodes a}
    (C : BoundaryFreeGraftSupportCoherence u t v a hg cut hfree) :
    tensorBasisMonomial R C.hostInsertTensorProduct =
      tensorBasisMonomial R C.hostTensor *
        tensorBasisMonomial R C.insertTensor := by
  simpa [hostInsertTensorProduct] using
    (tensorBasisMonomial_mul R C.hostTensor C.insertTensor).symm

/--
The same identity, oriented as an ordinary multiplication rule.
-/
theorem tensorBasisMonomial_hostTensor_mul_insertTensor
    {u t v : PTree} {a : Address}
    {hg : PTree.graftMatchingLeafAt u t a = some v}
    {cut : PTree.IsAdmissibleCut v}
    {hfree : BoundaryFreeAt cut.nodes a}
    (C : BoundaryFreeGraftSupportCoherence u t v a hg cut hfree) :
    tensorBasisMonomial R C.hostTensor *
        tensorBasisMonomial R C.insertTensor =
      tensorBasisMonomial R C.hostInsertTensorProduct := by
  simpa using
    (tensorBasisMonomial_hostInsertTensorProduct R C).symm

end TensorMonomials

theorem canonical_originalTensor
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) :
    (boundaryFreeGraftSupportCoherence hg cut hfree).originalTensor =
      originalTensorTerm hg cut := rfl

theorem canonical_hostTensor
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) :
    (boundaryFreeGraftSupportCoherence hg cut hfree).hostTensor =
      hostTensorTerm hg cut hfree := rfl

theorem canonical_insertTensor
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) :
    (boundaryFreeGraftSupportCoherence hg cut hfree).insertTensor =
      insertTensorTerm hg cut := rfl

theorem canonical_hostInsertTensorProduct
    {u t v : PTree} {a : Address}
    (hg : PTree.graftMatchingLeafAt u t a = some v)
    (cut : PTree.IsAdmissibleCut v)
    (hfree : BoundaryFreeAt cut.nodes a) :
    (boundaryFreeGraftSupportCoherence hg cut hfree).hostInsertTensorProduct =
      hostInsertTensorProductTerm hg cut hfree := rfl

end BoundaryFreeGraftSupportCoherence

/--
Support-level data for the splitting bialgebra candidate.

This is intentionally not a Mathlib `Bialgebra` yet.  It names the algebra
carrier and the generator/forest tensor supports that should be linearized into
`CoalgebraStruct.comul`; the algebra-side target structures already present in
the coalgebra file are the intended final consumer.
-/
structure HypersequentSplittingBialgebraSupport (R : Type) [Semiring R] where
  carrier : Type := HypersequentAlgebra R
  treeComulSupport : PTree → List HypersequentTensorBasis :=
    treeSplittingTensorSupport
  forestComulSupport : Forest → List HypersequentTensorBasis :=
    forestSplittingTensorSupport
  tensorMul : HypersequentTensorBasis → HypersequentTensorBasis →
      HypersequentTensorBasis := HypersequentTensorBasis.mul
  tensorOne : HypersequentTensorBasis := HypersequentTensorBasis.one

noncomputable def hypersequentSplittingBialgebraSupport
    (R : Type) [Semiring R] :
    HypersequentSplittingBialgebraSupport R :=
  {}

@[simp]
theorem hypersequentSplittingBialgebraSupport_treeComulSupport
    (R : Type) [Semiring R] (t : PTree) :
    (hypersequentSplittingBialgebraSupport R).treeComulSupport t =
      treeSplittingTensorSupport t := rfl

@[simp]
theorem hypersequentSplittingBialgebraSupport_forestComulSupport
    (R : Type) [Semiring R] (f : Forest) :
    (hypersequentSplittingBialgebraSupport R).forestComulSupport f =
      forestSplittingTensorSupport f := rfl

@[simp]
theorem hypersequentSplittingBialgebraSupport_tensorMul
    (R : Type) [Semiring R] (p q : HypersequentTensorBasis) :
    (hypersequentSplittingBialgebraSupport R).tensorMul p q =
      HypersequentTensorBasis.mul p q := rfl

@[simp]
theorem hypersequentSplittingBialgebraSupport_tensorOne
    (R : Type) [Semiring R] :
    (hypersequentSplittingBialgebraSupport R).tensorOne =
      HypersequentTensorBasis.one := rfl

/-!
## Algebra-map data for the splitting bialgebra

At this point the multiplication and unit laws for the splitting coproduct and
counit are already handled by construction: both are algebra homomorphisms out
of `AddMonoidAlgebra R Hypersequent`.  The remaining non-formal bialgebra
axioms are the coalgebra laws, especially coassociativity of two-stage
admissible splitting.
-/

/--
The algebra-map layer of the hypersequent splitting bialgebra candidate.

This packages the actual multiplicative maps:

* `comulAlgHom` is the GL/admissible-cut splitting coproduct, extended
  multiplicatively from one proof-tree component to hypersequents.
* `counitAlgHom` is the splitting counit, extended multiplicatively from the
  rule `ε(leaf) = 1`, `ε(node) = 0`.

Turning this into a Mathlib `Bialgebra` is now exactly the task of proving the
coalgebra axioms for these maps.
-/
structure HypersequentSplittingBialgebraMaps (R : Type) [CommSemiring R] where
  carrier : Type := HypersequentAlgebra R
  tensorCarrier : Type := HypersequentTensorAlgebra R
  comulAlgHom : HypersequentAlgebra R →ₐ[R] HypersequentTensorAlgebra R :=
    hypersequentComulAlgHom R
  counitAlgHom : HypersequentAlgebra R →ₐ[R] R :=
    hypersequentSplittingCounitAlgHom R

noncomputable def hypersequentSplittingBialgebraMaps
    (R : Type) [CommSemiring R] :
    HypersequentSplittingBialgebraMaps R := {}

@[simp]
theorem hypersequentSplittingBialgebraMaps_comulAlgHom
    (R : Type) [CommSemiring R] :
    (hypersequentSplittingBialgebraMaps R).comulAlgHom =
      hypersequentComulAlgHom R := rfl

@[simp]
theorem hypersequentSplittingBialgebraMaps_counitAlgHom
    (R : Type) [CommSemiring R] :
    (hypersequentSplittingBialgebraMaps R).counitAlgHom =
      hypersequentSplittingCounitAlgHom R := rfl

theorem hypersequentSplitting_comul_preserves_mul
    (R : Type) [CommSemiring R]
    (x y : HypersequentAlgebra R) :
    hypersequentComulAlgHom R (x * y) =
      hypersequentComulAlgHom R x * hypersequentComulAlgHom R y := by
  exact map_mul (hypersequentComulAlgHom R) x y

theorem hypersequentSplitting_comul_preserves_one
    (R : Type) [CommSemiring R] :
    hypersequentComulAlgHom R (1 : HypersequentAlgebra R) =
      (1 : HypersequentTensorAlgebra R) := by
  exact map_one (hypersequentComulAlgHom R)

theorem hypersequentSplitting_counit_preserves_mul
    (R : Type) [CommSemiring R]
    (x y : HypersequentAlgebra R) :
    hypersequentSplittingCounitAlgHom R (x * y) =
      hypersequentSplittingCounitAlgHom R x *
        hypersequentSplittingCounitAlgHom R y := by
  exact map_mul (hypersequentSplittingCounitAlgHom R) x y

theorem hypersequentSplitting_counit_preserves_one
    (R : Type) [CommSemiring R] :
    hypersequentSplittingCounitAlgHom R (1 : HypersequentAlgebra R) = 1 := by
  exact map_one (hypersequentSplittingCounitAlgHom R)

/-!
## Bridge to Mathlib's tensor product

`HypersequentTensorAlgebra R` is the convenient support algebra
`R[Hypersequent × Hypersequent]`.  Mathlib's `Coalgebra` and `Bialgebra`
classes, however, use the actual tensor product
`HypersequentAlgebra R ⊗[R] HypersequentAlgebra R`.

The following algebra hom is the canonical comparison map: it sends a basis
pair `(G, H)` to the pure tensor `G ⊗ H`.  This lets the support-level
splitting coproduct become a genuine Mathlib-shaped comultiplication.
-/

noncomputable section MathlibTensorProductBridge

variable (R : Type) [CommSemiring R]

/-- The pure tensor represented by one tensor-basis index. -/
def tensorBasisTmul (p : HypersequentTensorBasis) :
    TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R) :=
  hseqMonomial R p.1 ⊗ₜ[R] hseqMonomial R p.2

theorem tensorBasisTmul_mul
    (p q : HypersequentTensorBasis) :
    tensorBasisTmul R (HypersequentTensorBasis.mul p q) =
      tensorBasisTmul R p * tensorBasisTmul R q := by
  simp [tensorBasisTmul, HypersequentTensorBasis.mul,
    hseqMonomial_mul, Algebra.TensorProduct.tmul_mul_tmul]

@[simp]
theorem tensorBasisTmul_zero :
    tensorBasisTmul R (0 : HypersequentTensorBasis) =
      (1 : TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R)) := by
  simp [tensorBasisTmul, hseqMonomial_zero]
  exact (Algebra.TensorProduct.one_def (R := R)
    (A := HypersequentAlgebra R) (B := HypersequentAlgebra R)).symm

/--
Applying the splitting counit to the left tensor factor of one basis atom.
-/
theorem rTensor_splittingCounit_tensorBasisTmul
    (p : HypersequentTensorBasis) :
    (LinearMap.rTensor (HypersequentAlgebra R)
        (hypersequentSplittingCounitAlgHom R).toLinearMap)
        (tensorBasisTmul R p) =
      hypersequentSplittingCounitCoeff R p.1 ⊗ₜ[R] hseqMonomial R p.2 := by
  rw [tensorBasisTmul]
  change TensorProduct.map
      (hypersequentSplittingCounitAlgHom R).toLinearMap
      (LinearMap.id : HypersequentAlgebra R →ₗ[R] HypersequentAlgebra R)
      (hseqMonomial R p.1 ⊗ₜ[R] hseqMonomial R p.2) =
    hypersequentSplittingCounitCoeff R p.1 ⊗ₜ[R] hseqMonomial R p.2
  rw [TensorProduct.map_tmul]
  simp [hseqMonomial]

/--
Applying the splitting counit to the right tensor factor of one basis atom.
-/
theorem lTensor_splittingCounit_tensorBasisTmul
    (p : HypersequentTensorBasis) :
    (LinearMap.lTensor (HypersequentAlgebra R)
        (hypersequentSplittingCounitAlgHom R).toLinearMap)
        (tensorBasisTmul R p) =
      hseqMonomial R p.1 ⊗ₜ[R] hypersequentSplittingCounitCoeff R p.2 := by
  rw [tensorBasisTmul]
  change TensorProduct.map
      (LinearMap.id : HypersequentAlgebra R →ₗ[R] HypersequentAlgebra R)
      (hypersequentSplittingCounitAlgHom R).toLinearMap
      (hseqMonomial R p.1 ⊗ₜ[R] hseqMonomial R p.2) =
    hseqMonomial R p.1 ⊗ₜ[R] hypersequentSplittingCounitCoeff R p.2
  rw [TensorProduct.map_tmul]
  simp [hseqMonomial]

/--
The identity split contributes the right-counit basis term.
-/
theorem rTensor_splittingCounit_identityTensor (t : PTree) :
    (LinearMap.rTensor (HypersequentAlgebra R)
        (hypersequentSplittingCounitAlgHom R).toLinearMap)
        (tensorBasisTmul R (0, HQ.singleton t)) =
      1 ⊗ₜ[R] treeMonomial R t := by
  rw [rTensor_splittingCounit_tensorBasisTmul]
  simp [treeMonomial, hseqMonomial]

theorem rTensor_splittingCounit_emptyCutTensor (t : PTree) :
    (LinearMap.rTensor (HypersequentAlgebra R)
        (hypersequentSplittingCounitAlgHom R).toLinearMap)
        (tensorBasisTmul R (tensorTermOfAdmissibleCut t (emptyCut t))) =
      1 ⊗ₜ[R] treeMonomial R t := by
  rw [tensorTermOfAdmissibleCut_emptyCut]
  exact rTensor_splittingCounit_identityTensor R t

/--
The root split contributes the left-counit basis term.
-/
theorem lTensor_splittingCounit_rootTensor (t : PTree) :
    (LinearMap.lTensor (HypersequentAlgebra R)
        (hypersequentSplittingCounitAlgHom R).toLinearMap)
        (tensorBasisTmul R
          (HQ.singleton t, HQ.singleton (PTree.leaf t.conclusion))) =
      treeMonomial R t ⊗ₜ[R] 1 := by
  rw [lTensor_splittingCounit_tensorBasisTmul]
  rw [hypersequentSplittingCounitCoeff_root_remainder_singleton]
  simp [treeMonomial, hseqMonomial]

theorem lTensor_splittingCounit_rootCutTensor (t : PTree) :
    (LinearMap.lTensor (HypersequentAlgebra R)
        (hypersequentSplittingCounitAlgHom R).toLinearMap)
        (tensorBasisTmul R (tensorTermOfAdmissibleCut t (rootCut t))) =
      treeMonomial R t ⊗ₜ[R] 1 := by
  rw [tensorTermOfAdmissibleCut_rootCut]
  exact lTensor_splittingCounit_rootTensor R t

/-!
## Augmentation counit for the coalgebra-normalized support

For the normalized CK/GL support, the correct counit is the ordinary
augmentation on the external forest algebra: empty hypersequent has counit `1`,
all nonempty hypersequents have counit `0`.
-/

/-- Applying the augmentation counit to the left tensor factor of one basis atom. -/
theorem rTensor_augmentationCounit_tensorBasisTmul
    (p : HypersequentTensorBasis) :
    (LinearMap.rTensor (HypersequentAlgebra R)
        (hypersequentCounitAlgHom R).toLinearMap)
        (tensorBasisTmul R p) =
      hypersequentCounitCoeff R p.1 ⊗ₜ[R] hseqMonomial R p.2 := by
  rw [tensorBasisTmul]
  change TensorProduct.map
      (hypersequentCounitAlgHom R).toLinearMap
      (LinearMap.id : HypersequentAlgebra R →ₗ[R] HypersequentAlgebra R)
      (hseqMonomial R p.1 ⊗ₜ[R] hseqMonomial R p.2) =
    hypersequentCounitCoeff R p.1 ⊗ₜ[R] hseqMonomial R p.2
  rw [TensorProduct.map_tmul]
  simp [hseqMonomial]

/-- Applying the augmentation counit to the right tensor factor of one basis atom. -/
theorem lTensor_augmentationCounit_tensorBasisTmul
    (p : HypersequentTensorBasis) :
    (LinearMap.lTensor (HypersequentAlgebra R)
        (hypersequentCounitAlgHom R).toLinearMap)
        (tensorBasisTmul R p) =
      hseqMonomial R p.1 ⊗ₜ[R] hypersequentCounitCoeff R p.2 := by
  rw [tensorBasisTmul]
  change TensorProduct.map
      (LinearMap.id : HypersequentAlgebra R →ₗ[R] HypersequentAlgebra R)
      (hypersequentCounitAlgHom R).toLinearMap
      (hseqMonomial R p.1 ⊗ₜ[R] hseqMonomial R p.2) =
    hseqMonomial R p.1 ⊗ₜ[R] hypersequentCounitCoeff R p.2
  rw [TensorProduct.map_tmul]
  simp [hseqMonomial]

theorem rTensor_augmentationCounit_coalgebraEmptyTensor (t : PTree) :
    (LinearMap.rTensor (HypersequentAlgebra R)
        (hypersequentCounitAlgHom R).toLinearMap)
        (tensorBasisTmul R (coalgebraTensorTermOfCutList t [])) =
      1 ⊗ₜ[R] treeMonomial R t := by
  rw [coalgebraTensorTermOfCutList_nil, rTensor_augmentationCounit_tensorBasisTmul]
  simp [treeMonomial, hseqMonomial]

theorem lTensor_augmentationCounit_coalgebraRootTensor (t : PTree) :
    (LinearMap.lTensor (HypersequentAlgebra R)
        (hypersequentCounitAlgHom R).toLinearMap)
        (tensorBasisTmul R (coalgebraTensorTermOfCutList t [([] : Address)])) =
      treeMonomial R t ⊗ₜ[R] 1 := by
  rw [coalgebraTensorTermOfCutList_root, lTensor_augmentationCounit_tensorBasisTmul]
  simp [treeMonomial, hseqMonomial]

/--
For nonempty cuts, the first factor of the normalized coalgebra atom is killed
by the augmentation counit.
-/
theorem rTensor_augmentationCounit_tensorBasisTmul_coalgebra_of_ne_nil
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ PTree.allAdmissibleCuts t)
    (hne : cut ≠ []) :
    (LinearMap.rTensor (HypersequentAlgebra R)
        (hypersequentCounitAlgHom R).toLinearMap)
        (tensorBasisTmul R (coalgebraTensorTermOfCutList t cut)) = 0 := by
  rw [rTensor_augmentationCounit_tensorBasisTmul]
  rw [hypersequentCounitCoeff_fst_coalgebraTensorTermOfCutList R hcut]
  simp [hne]

/--
For cuts not containing the root, the second factor of the normalized
coalgebra atom is killed by the augmentation counit.
-/
theorem lTensor_augmentationCounit_tensorBasisTmul_coalgebra_of_root_not_mem
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ PTree.allAdmissibleCuts t)
    (hroot : ([] : Address) ∉ cut) :
    (LinearMap.lTensor (HypersequentAlgebra R)
        (hypersequentCounitAlgHom R).toLinearMap)
        (tensorBasisTmul R (coalgebraTensorTermOfCutList t cut)) = 0 := by
  rw [lTensor_augmentationCounit_tensorBasisTmul]
  rw [hypersequentCounitCoeff_snd_coalgebraTensorTermOfCutList R hcut]
  simp [hroot]

/--
Applying the augmentation counit to the detached-forest factor of one support
atom.
-/
def rightCounitTensorBasisTmul (p : HypersequentTensorBasis) :
    TensorProduct R R (HypersequentAlgebra R) :=
  hypersequentCounitCoeff R p.1 ⊗ₜ[R] hseqMonomial R p.2

theorem rightCounitTensorBasisTmul_mul
    (p q : HypersequentTensorBasis) :
    rightCounitTensorBasisTmul R (HypersequentTensorBasis.mul p q) =
      rightCounitTensorBasisTmul R p *
        rightCounitTensorBasisTmul R q := by
  simp [rightCounitTensorBasisTmul, HypersequentTensorBasis.mul,
    hypersequentCounitCoeff_add, hseqMonomial_mul,
    Algebra.TensorProduct.tmul_mul_tmul]

@[simp]
theorem rightCounitTensorBasisTmul_zero :
    rightCounitTensorBasisTmul R (0 : HypersequentTensorBasis) =
      (1 : TensorProduct R R (HypersequentAlgebra R)) := by
  simp [rightCounitTensorBasisTmul, hseqMonomial_zero]
  exact (Algebra.TensorProduct.one_def (R := R)
    (A := R) (B := HypersequentAlgebra R)).symm

/--
Applying the augmentation counit to the remainder factor of one support atom.
-/
def leftCounitTensorBasisTmul (p : HypersequentTensorBasis) :
    TensorProduct R (HypersequentAlgebra R) R :=
  hseqMonomial R p.1 ⊗ₜ[R] hypersequentCounitCoeff R p.2

theorem leftCounitTensorBasisTmul_mul
    (p q : HypersequentTensorBasis) :
    leftCounitTensorBasisTmul R (HypersequentTensorBasis.mul p q) =
      leftCounitTensorBasisTmul R p *
        leftCounitTensorBasisTmul R q := by
  simp [leftCounitTensorBasisTmul, HypersequentTensorBasis.mul,
    hypersequentCounitCoeff_add, hseqMonomial_mul,
    Algebra.TensorProduct.tmul_mul_tmul]

theorem rightCounitTensorBasisTmul_eq_rTensor
    (p : HypersequentTensorBasis) :
    rightCounitTensorBasisTmul R p =
      (LinearMap.rTensor (HypersequentAlgebra R)
          (hypersequentCounitAlgHom R).toLinearMap)
        (tensorBasisTmul R p) := by
  simp [rightCounitTensorBasisTmul, rTensor_augmentationCounit_tensorBasisTmul]

theorem leftCounitTensorBasisTmul_eq_lTensor
    (p : HypersequentTensorBasis) :
    leftCounitTensorBasisTmul R p =
      (LinearMap.lTensor (HypersequentAlgebra R)
          (hypersequentCounitAlgHom R).toLinearMap)
        (tensorBasisTmul R p) := by
  simp [leftCounitTensorBasisTmul, lTensor_augmentationCounit_tensorBasisTmul]

/--
Support-to-tensor comparison after applying the augmentation counit on the
right factor, collapsed back into the hypersequent algebra.
-/
def leftCounitTensorBasisSmul (p : HypersequentTensorBasis) :
    HypersequentAlgebra R :=
  hypersequentCounitCoeff R p.2 • hseqMonomial R p.1

@[simp]
theorem leftCounitTensorBasisSmul_zero :
    leftCounitTensorBasisSmul R (0 : HypersequentTensorBasis) =
      (1 : HypersequentAlgebra R) := by
  simp [leftCounitTensorBasisSmul, hseqMonomial_zero]

theorem leftCounitTensorBasisSmul_mul
    (p q : HypersequentTensorBasis) :
    leftCounitTensorBasisSmul R (HypersequentTensorBasis.mul p q) =
      leftCounitTensorBasisSmul R p *
        leftCounitTensorBasisSmul R q := by
  simp [leftCounitTensorBasisSmul, HypersequentTensorBasis.mul,
    hypersequentCounitCoeff_add, hseqMonomial_mul, smul_smul,
    mul_comm, mul_left_comm, mul_assoc]

private def leftCounitBasisMonoidHom :
    Multiplicative HypersequentTensorBasis →* HypersequentAlgebra R where
  toFun b := leftCounitTensorBasisSmul R b.toAdd
  map_one' := leftCounitTensorBasisSmul_zero (R := R)
  map_mul' b₁ b₂ := leftCounitTensorBasisSmul_mul (R := R) b₁.toAdd b₂.toAdd

noncomputable def hypersequentTensorAlgToLeftCounitAlgHom :
    HypersequentTensorAlgebra R →ₐ[R] HypersequentAlgebra R :=
  AddMonoidAlgebra.lift R (HypersequentAlgebra R) HypersequentTensorBasis
    (leftCounitBasisMonoidHom (R := R))

@[simp]
theorem hypersequentTensorAlgToLeftCounitAlgHom_monomial
    (p : HypersequentTensorBasis) :
    hypersequentTensorAlgToLeftCounitAlgHom R (tensorBasisMonomial R p) =
      leftCounitTensorBasisSmul R p := by
  simp [hypersequentTensorAlgToLeftCounitAlgHom, tensorBasisMonomial,
    leftCounitBasisMonoidHom, leftCounitTensorBasisSmul]

/--
Support-to-tensor comparison after applying the augmentation counit on the left
factor.
-/
def rightCounitTensorBasisSmul (p : HypersequentTensorBasis) :
    HypersequentAlgebra R :=
  hypersequentCounitCoeff R p.1 • hseqMonomial R p.2

@[simp]
theorem rightCounitTensorBasisSmul_zero :
    rightCounitTensorBasisSmul R (0 : HypersequentTensorBasis) =
      (1 : HypersequentAlgebra R) := by
  simp [rightCounitTensorBasisSmul, hseqMonomial_zero]

theorem rightCounitTensorBasisSmul_mul
    (p q : HypersequentTensorBasis) :
    rightCounitTensorBasisSmul R (HypersequentTensorBasis.mul p q) =
      rightCounitTensorBasisSmul R p *
        rightCounitTensorBasisSmul R q := by
  simp [rightCounitTensorBasisSmul, HypersequentTensorBasis.mul,
    hypersequentCounitCoeff_add, hseqMonomial_mul, smul_smul,
    mul_comm, mul_left_comm, mul_assoc]

private def rightCounitBasisMonoidHom :
    Multiplicative HypersequentTensorBasis →* HypersequentAlgebra R where
  toFun b := rightCounitTensorBasisSmul R b.toAdd
  map_one' := rightCounitTensorBasisSmul_zero (R := R)
  map_mul' b₁ b₂ := rightCounitTensorBasisSmul_mul (R := R) b₁.toAdd b₂.toAdd

noncomputable def hypersequentTensorAlgToRightCounitAlgHom :
    HypersequentTensorAlgebra R →ₐ[R] HypersequentAlgebra R :=
  AddMonoidAlgebra.lift R (HypersequentAlgebra R) HypersequentTensorBasis
    (rightCounitBasisMonoidHom (R := R))

@[simp]
theorem hypersequentTensorAlgToRightCounitAlgHom_monomial
    (p : HypersequentTensorBasis) :
    hypersequentTensorAlgToRightCounitAlgHom R (tensorBasisMonomial R p) =
      rightCounitTensorBasisSmul R p := by
  simp [hypersequentTensorAlgToRightCounitAlgHom, tensorBasisMonomial,
    rightCounitBasisMonoidHom, rightCounitTensorBasisSmul]

noncomputable def hypersequentTensorAlgToRightCounitTensorLinearMap :
    HypersequentTensorAlgebra R →ₗ[R]
      TensorProduct R R (HypersequentAlgebra R) :=
  (((Algebra.TensorProduct.lid R (HypersequentAlgebra R)).symm.toAlgHom).comp
    (hypersequentTensorAlgToRightCounitAlgHom R)).toLinearMap

theorem hypersequentTensorAlgToRightCounitTensorLinearMap_eq_lid_symm_apply
    (x : HypersequentTensorAlgebra R) :
    hypersequentTensorAlgToRightCounitTensorLinearMap R x =
      (Algebra.TensorProduct.lid R (HypersequentAlgebra R)).symm
        (hypersequentTensorAlgToRightCounitAlgHom R x) := rfl

@[simp]
theorem hypersequentTensorAlgToRightCounitTensorLinearMap_monomial
    (p : HypersequentTensorBasis) :
    hypersequentTensorAlgToRightCounitTensorLinearMap R
        (tensorBasisMonomial R p) =
      rightCounitTensorBasisTmul R p := by
  rw [hypersequentTensorAlgToRightCounitTensorLinearMap_eq_lid_symm_apply,
    hypersequentTensorAlgToRightCounitAlgHom_monomial]
  simpa [rightCounitTensorBasisTmul, rightCounitTensorBasisSmul,
    Algebra.TensorProduct.lid_symm_apply] using
    (TensorProduct.smul_tmul' (R := R) (hypersequentCounitCoeff R p.1)
      (1 : R) (hseqMonomial R p.2))

/--
Support-to-tensor comparison after applying the augmentation counit on the
right factor.
-/
def hypersequentTensorAlgToLeftCounitTensorLinearMap :
    HypersequentTensorAlgebra R →ₗ[R]
      TensorProduct R (HypersequentAlgebra R) R :=
  ((TensorProduct.rid R (HypersequentAlgebra R)).symm.toLinearMap).comp
    (hypersequentTensorAlgToLeftCounitAlgHom R).toLinearMap

theorem hypersequentTensorAlgToLeftCounitTensorLinearMap_eq_rid_symm_apply
    (x : HypersequentTensorAlgebra R) :
    hypersequentTensorAlgToLeftCounitTensorLinearMap R x =
      (TensorProduct.rid R (HypersequentAlgebra R)).symm
        (hypersequentTensorAlgToLeftCounitAlgHom R x) := rfl

@[simp]
theorem hypersequentTensorAlgToLeftCounitTensorLinearMap_monomial
    (p : HypersequentTensorBasis) :
    hypersequentTensorAlgToLeftCounitTensorLinearMap R
        (tensorBasisMonomial R p) =
      leftCounitTensorBasisTmul R p := by
  rw [hypersequentTensorAlgToLeftCounitTensorLinearMap_eq_rid_symm_apply,
    hypersequentTensorAlgToLeftCounitAlgHom_monomial]
  simpa [leftCounitTensorBasisTmul, leftCounitTensorBasisSmul,
    TensorProduct.rid_symm_apply] using
    (TensorProduct.tmul_smul (R := R) (hypersequentCounitCoeff R p.2)
      (hseqMonomial R p.1) (1 : R)).symm

theorem hypersequentTensorAlgToRightCounitTensorLinearMap_tensorSupportElement_map_mul_left
    [LeftDistribClass (TensorProduct R R (HypersequentAlgebra R))]
    (p : HypersequentTensorBasis) (xs : List HypersequentTensorBasis) :
    hypersequentTensorAlgToRightCounitTensorLinearMap R
        (tensorSupportElement R
          (xs.map (fun q => HypersequentTensorBasis.mul p q))) =
      rightCounitTensorBasisTmul R p *
        hypersequentTensorAlgToRightCounitTensorLinearMap R
          (tensorSupportElement R xs) := by
  induction xs with
  | nil =>
      simp [tensorSupportElement]
      exact (mul_zero (rightCounitTensorBasisTmul R p)).symm
  | cons x xs ih =>
      rw [List.map_cons, tensorSupportElement_cons, map_add,
        hypersequentTensorAlgToRightCounitTensorLinearMap_monomial]
      rw [ih]
      rw [rightCounitTensorBasisTmul_mul]
      rw [tensorSupportElement_cons, map_add,
        hypersequentTensorAlgToRightCounitTensorLinearMap_monomial]
      exact (left_distrib
        (rightCounitTensorBasisTmul R p)
        (rightCounitTensorBasisTmul R x)
        ((hypersequentTensorAlgToRightCounitTensorLinearMap R)
          (tensorSupportElement R xs))).symm

theorem hypersequentTensorAlgToLeftCounitTensorLinearMap_tensorSupportElement_map_mul_left
    [LeftDistribClass (TensorProduct R (HypersequentAlgebra R) R)]
    (p : HypersequentTensorBasis) (xs : List HypersequentTensorBasis) :
    hypersequentTensorAlgToLeftCounitTensorLinearMap R
        (tensorSupportElement R
          (xs.map (fun q => HypersequentTensorBasis.mul p q))) =
      leftCounitTensorBasisTmul R p *
        hypersequentTensorAlgToLeftCounitTensorLinearMap R
          (tensorSupportElement R xs) := by
  induction xs with
  | nil =>
      simp [tensorSupportElement]
      exact (mul_zero (leftCounitTensorBasisTmul R p)).symm
  | cons x xs ih =>
      rw [List.map_cons, tensorSupportElement_cons, map_add,
        hypersequentTensorAlgToLeftCounitTensorLinearMap_monomial]
      rw [ih]
      rw [leftCounitTensorBasisTmul_mul]
      rw [tensorSupportElement_cons, map_add,
        hypersequentTensorAlgToLeftCounitTensorLinearMap_monomial]
      exact (left_distrib
        (leftCounitTensorBasisTmul R p)
        (leftCounitTensorBasisTmul R x)
        ((hypersequentTensorAlgToLeftCounitTensorLinearMap R)
          (tensorSupportElement R xs))).symm

theorem hypersequentTensorAlgToRightCounitTensorLinearMap_tensorSupportMul
    [LeftDistribClass (TensorProduct R R (HypersequentAlgebra R))]
    [RightDistribClass (TensorProduct R R (HypersequentAlgebra R))]
    (xs ys : List HypersequentTensorBasis) :
    hypersequentTensorAlgToRightCounitTensorLinearMap R
        (tensorSupportElement R (tensorSupportMul xs ys)) =
      hypersequentTensorAlgToRightCounitTensorLinearMap R
          (tensorSupportElement R xs) *
        hypersequentTensorAlgToRightCounitTensorLinearMap R
          (tensorSupportElement R ys) := by
  induction xs with
  | nil =>
      simp [tensorSupportMul, tensorSupportElement]
      exact (zero_mul
        ((hypersequentTensorAlgToRightCounitTensorLinearMap R)
          (tensorSupportElement R ys))).symm
  | cons x xs ih =>
      change
        hypersequentTensorAlgToRightCounitTensorLinearMap R
            (tensorSupportElement R
              ((ys.map (fun y => HypersequentTensorBasis.mul x y)) ++
                tensorSupportMul xs ys)) =
          hypersequentTensorAlgToRightCounitTensorLinearMap R
              (tensorSupportElement R (x :: xs)) *
            hypersequentTensorAlgToRightCounitTensorLinearMap R
              (tensorSupportElement R ys)
      rw [tensorSupportElement_append, map_add]
      rw [hypersequentTensorAlgToRightCounitTensorLinearMap_tensorSupportElement_map_mul_left]
      rw [ih]
      rw [tensorSupportElement_cons, map_add,
        hypersequentTensorAlgToRightCounitTensorLinearMap_monomial]
      exact (right_distrib
        (rightCounitTensorBasisTmul R x)
        ((hypersequentTensorAlgToRightCounitTensorLinearMap R)
          (tensorSupportElement R xs))
        ((hypersequentTensorAlgToRightCounitTensorLinearMap R)
          (tensorSupportElement R ys))).symm

theorem hypersequentTensorAlgToLeftCounitTensorLinearMap_tensorSupportMul
    [LeftDistribClass (TensorProduct R (HypersequentAlgebra R) R)]
    [RightDistribClass (TensorProduct R (HypersequentAlgebra R) R)]
    (xs ys : List HypersequentTensorBasis) :
    hypersequentTensorAlgToLeftCounitTensorLinearMap R
        (tensorSupportElement R (tensorSupportMul xs ys)) =
      hypersequentTensorAlgToLeftCounitTensorLinearMap R
          (tensorSupportElement R xs) *
        hypersequentTensorAlgToLeftCounitTensorLinearMap R
          (tensorSupportElement R ys) := by
  induction xs with
  | nil =>
      simp [tensorSupportMul, tensorSupportElement]
      exact (zero_mul
        ((hypersequentTensorAlgToLeftCounitTensorLinearMap R)
          (tensorSupportElement R ys))).symm
  | cons x xs ih =>
      change
        hypersequentTensorAlgToLeftCounitTensorLinearMap R
            (tensorSupportElement R
              ((ys.map (fun y => HypersequentTensorBasis.mul x y)) ++
                tensorSupportMul xs ys)) =
          hypersequentTensorAlgToLeftCounitTensorLinearMap R
              (tensorSupportElement R (x :: xs)) *
            hypersequentTensorAlgToLeftCounitTensorLinearMap R
              (tensorSupportElement R ys)
      rw [tensorSupportElement_append, map_add]
      rw [hypersequentTensorAlgToLeftCounitTensorLinearMap_tensorSupportElement_map_mul_left]
      rw [ih]
      rw [tensorSupportElement_cons, map_add,
        hypersequentTensorAlgToLeftCounitTensorLinearMap_monomial]
      exact (right_distrib
        (leftCounitTensorBasisTmul R x)
        ((hypersequentTensorAlgToLeftCounitTensorLinearMap R)
          (tensorSupportElement R xs))
        ((hypersequentTensorAlgToLeftCounitTensorLinearMap R)
          (tensorSupportElement R ys))).symm

/--
Canonical linear map from the support tensor algebra to Mathlib's tensor
product module.

Mathlib provides the tensor product multiplication needed by
`tensorBasisTmul_mul`, but not a full `Semiring` target here suitable for
`AddMonoidAlgebra.lift`.  So the comparison map is kept linear, with
multiplicativity isolated at the basis/support level.
-/
def hypersequentTensorAlgToTensorProductLinearMap :
    HypersequentTensorAlgebra R →ₗ[R]
      TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R) :=
  Finsupp.linearCombination R (tensorBasisTmul R)

@[simp]
theorem hypersequentTensorAlgToTensorProductLinearMap_single
    (p : HypersequentTensorBasis) :
    hypersequentTensorAlgToTensorProductLinearMap R
        (AddMonoidAlgebra.single p 1) =
      tensorBasisTmul R p := by
  change (Finsupp.linearCombination R (tensorBasisTmul R))
      (Finsupp.single p (1 : R)) = tensorBasisTmul R p
  rw [Finsupp.linearCombination_single]
  simp

@[simp]
theorem hypersequentTensorAlgToTensorProductLinearMap_monomial
    (p : HypersequentTensorBasis) :
    hypersequentTensorAlgToTensorProductLinearMap R
        (tensorBasisMonomial R p) =
      tensorBasisTmul R p := by
  simp [tensorBasisMonomial]

theorem hypersequentTensorAlgToTensorProductLinearMap_monomial_mul
    (p q : HypersequentTensorBasis) :
    hypersequentTensorAlgToTensorProductLinearMap R
        (tensorBasisMonomial R p * tensorBasisMonomial R q) =
      hypersequentTensorAlgToTensorProductLinearMap R
          (tensorBasisMonomial R p) *
        hypersequentTensorAlgToTensorProductLinearMap R
          (tensorBasisMonomial R q) := by
  rw [tensorBasisMonomial_mul]
  simp [tensorBasisTmul_mul]

theorem hypersequentTensorAlgToRightCounitTensorLinearMap_eq_comp
    (x : HypersequentTensorAlgebra R) :
    hypersequentTensorAlgToRightCounitTensorLinearMap R x =
      (((LinearMap.rTensor (HypersequentAlgebra R)
          (hypersequentCounitAlgHom R).toLinearMap).comp
        (hypersequentTensorAlgToTensorProductLinearMap R)) x) := by
  induction x using Finsupp.induction_linear with
  | zero =>
      calc
        (hypersequentTensorAlgToRightCounitTensorLinearMap R) 0 = 0 := by
          exact (hypersequentTensorAlgToRightCounitTensorLinearMap R).map_zero
        _ = (LinearMap.rTensor (HypersequentAlgebra R)
              (hypersequentCounitAlgHom R).toLinearMap)
              ((hypersequentTensorAlgToTensorProductLinearMap R) 0) := by
          exact Eq.symm (LinearMap.map_zero
            (LinearMap.rTensor (HypersequentAlgebra R)
              (hypersequentCounitAlgHom R).toLinearMap))
  | add x y hx hy =>
      calc
        (hypersequentTensorAlgToRightCounitTensorLinearMap R) (x + y)
          = (hypersequentTensorAlgToRightCounitTensorLinearMap R) x +
              (hypersequentTensorAlgToRightCounitTensorLinearMap R) y := by
              exact (hypersequentTensorAlgToRightCounitTensorLinearMap R).map_add x y
        _ =
            (LinearMap.rTensor (HypersequentAlgebra R)
              (hypersequentCounitAlgHom R).toLinearMap)
              ((hypersequentTensorAlgToTensorProductLinearMap R) x) +
            (LinearMap.rTensor (HypersequentAlgebra R)
              (hypersequentCounitAlgHom R).toLinearMap)
              ((hypersequentTensorAlgToTensorProductLinearMap R) y) := by
              simpa [LinearMap.comp_apply] using congrArg₂ HAdd.hAdd hx hy
        _ =
            (LinearMap.rTensor (HypersequentAlgebra R)
              (hypersequentCounitAlgHom R).toLinearMap)
              ((hypersequentTensorAlgToTensorProductLinearMap R) (x + y)) := by
              rw [← LinearMap.map_add]
              exact congrArg
                (LinearMap.rTensor (HypersequentAlgebra R)
                  (hypersequentCounitAlgHom R).toLinearMap)
                ((hypersequentTensorAlgToTensorProductLinearMap R).map_add x y).symm
  | single p r =>
      rw [show (Finsupp.single p r : HypersequentTensorAlgebra R) = r • tensorBasisMonomial R p by
        simp [tensorBasisMonomial]]
      calc
        hypersequentTensorAlgToRightCounitTensorLinearMap R
            (r • tensorBasisMonomial R p)
            = r • hypersequentTensorAlgToRightCounitTensorLinearMap R
                (tensorBasisMonomial R p) := by
                  rw [LinearMap.map_smul]
        _ = r • rightCounitTensorBasisTmul R p := by
              rw [hypersequentTensorAlgToRightCounitTensorLinearMap_monomial]
        _ = r •
              (LinearMap.rTensor (HypersequentAlgebra R)
                (hypersequentCounitAlgHom R).toLinearMap)
                (tensorBasisTmul R p) := by
              simp [rightCounitTensorBasisTmul_eq_rTensor]
        _ =
            (LinearMap.rTensor (HypersequentAlgebra R)
              (hypersequentCounitAlgHom R).toLinearMap)
              (r • tensorBasisTmul R p) := by
              exact
                (LinearMap.map_smul
                  (LinearMap.rTensor (HypersequentAlgebra R)
                    (hypersequentCounitAlgHom R).toLinearMap)
                  r (tensorBasisTmul R p)).symm
        _ =
            (LinearMap.rTensor (HypersequentAlgebra R)
              (hypersequentCounitAlgHom R).toLinearMap)
              ((hypersequentTensorAlgToTensorProductLinearMap R)
                (r • tensorBasisMonomial R p)) := by
              congr 1
              rw [LinearMap.map_smul,
                hypersequentTensorAlgToTensorProductLinearMap_monomial]

theorem hypersequentTensorAlgToLeftCounitTensorLinearMap_eq_comp
    (x : HypersequentTensorAlgebra R) :
    hypersequentTensorAlgToLeftCounitTensorLinearMap R x =
      (((LinearMap.lTensor (HypersequentAlgebra R)
          (hypersequentCounitAlgHom R).toLinearMap).comp
        (hypersequentTensorAlgToTensorProductLinearMap R)) x) := by
  induction x using Finsupp.induction_linear with
  | zero =>
      calc
        (hypersequentTensorAlgToLeftCounitTensorLinearMap R) 0 = 0 := by
          exact (hypersequentTensorAlgToLeftCounitTensorLinearMap R).map_zero
        _ = (LinearMap.lTensor (HypersequentAlgebra R)
              (hypersequentCounitAlgHom R).toLinearMap)
              ((hypersequentTensorAlgToTensorProductLinearMap R) 0) := by
          exact Eq.symm (LinearMap.map_zero
            (LinearMap.lTensor (HypersequentAlgebra R)
              (hypersequentCounitAlgHom R).toLinearMap))
  | add x y hx hy =>
      calc
        (hypersequentTensorAlgToLeftCounitTensorLinearMap R) (x + y)
          = (hypersequentTensorAlgToLeftCounitTensorLinearMap R) x +
              (hypersequentTensorAlgToLeftCounitTensorLinearMap R) y := by
              exact (hypersequentTensorAlgToLeftCounitTensorLinearMap R).map_add x y
        _ =
            (LinearMap.lTensor (HypersequentAlgebra R)
              (hypersequentCounitAlgHom R).toLinearMap)
              ((hypersequentTensorAlgToTensorProductLinearMap R) x) +
            (LinearMap.lTensor (HypersequentAlgebra R)
              (hypersequentCounitAlgHom R).toLinearMap)
              ((hypersequentTensorAlgToTensorProductLinearMap R) y) := by
              simpa [LinearMap.comp_apply] using congrArg₂ HAdd.hAdd hx hy
        _ =
            (LinearMap.lTensor (HypersequentAlgebra R)
              (hypersequentCounitAlgHom R).toLinearMap)
              ((hypersequentTensorAlgToTensorProductLinearMap R) (x + y)) := by
              rw [← LinearMap.map_add]
              exact congrArg
                (LinearMap.lTensor (HypersequentAlgebra R)
                  (hypersequentCounitAlgHom R).toLinearMap)
                ((hypersequentTensorAlgToTensorProductLinearMap R).map_add x y).symm
  | single p r =>
      rw [show (Finsupp.single p r : HypersequentTensorAlgebra R) = r • tensorBasisMonomial R p by
        simp [tensorBasisMonomial]]
      calc
        hypersequentTensorAlgToLeftCounitTensorLinearMap R
            (r • tensorBasisMonomial R p)
            = r • hypersequentTensorAlgToLeftCounitTensorLinearMap R
                (tensorBasisMonomial R p) := by
                  rw [LinearMap.map_smul]
        _ = r • leftCounitTensorBasisTmul R p := by
              rw [hypersequentTensorAlgToLeftCounitTensorLinearMap_monomial]
        _ = r •
              (LinearMap.lTensor (HypersequentAlgebra R)
                (hypersequentCounitAlgHom R).toLinearMap)
                (tensorBasisTmul R p) := by
              simp [leftCounitTensorBasisTmul_eq_lTensor]
        _ =
            (LinearMap.lTensor (HypersequentAlgebra R)
              (hypersequentCounitAlgHom R).toLinearMap)
              (r • tensorBasisTmul R p) := by
              exact
                (LinearMap.map_smul
                  (LinearMap.lTensor (HypersequentAlgebra R)
                    (hypersequentCounitAlgHom R).toLinearMap)
                  r (tensorBasisTmul R p)).symm
        _ =
            (LinearMap.lTensor (HypersequentAlgebra R)
              (hypersequentCounitAlgHom R).toLinearMap)
              ((hypersequentTensorAlgToTensorProductLinearMap R)
                (r • tensorBasisMonomial R p)) := by
              congr 1
              rw [LinearMap.map_smul,
                hypersequentTensorAlgToTensorProductLinearMap_monomial]

theorem hypersequentTensorAlgToLeftCounitTensorLinearMap_mul
    (x y : HypersequentTensorAlgebra R) :
    hypersequentTensorAlgToLeftCounitTensorLinearMap R (x * y) =
      hypersequentTensorAlgToLeftCounitTensorLinearMap R x *
        hypersequentTensorAlgToLeftCounitTensorLinearMap R y := by
  rw [hypersequentTensorAlgToLeftCounitTensorLinearMap_eq_rid_symm_apply,
    hypersequentTensorAlgToLeftCounitTensorLinearMap_eq_rid_symm_apply,
    hypersequentTensorAlgToLeftCounitTensorLinearMap_eq_rid_symm_apply]
  rw [show (hypersequentTensorAlgToLeftCounitAlgHom R) (x * y) =
      (hypersequentTensorAlgToLeftCounitAlgHom R x) *
        (hypersequentTensorAlgToLeftCounitAlgHom R y) by
        exact (hypersequentTensorAlgToLeftCounitAlgHom R).map_mul x y]
  simp [TensorProduct.rid_symm_apply, Algebra.TensorProduct.tmul_mul_tmul]

theorem hypersequentTensorAlgToRightCounitTensorLinearMap_mul
    (x y : HypersequentTensorAlgebra R) :
    hypersequentTensorAlgToRightCounitTensorLinearMap R (x * y) =
      hypersequentTensorAlgToRightCounitTensorLinearMap R x *
        hypersequentTensorAlgToRightCounitTensorLinearMap R y := by
  rw [hypersequentTensorAlgToRightCounitTensorLinearMap_eq_lid_symm_apply,
    hypersequentTensorAlgToRightCounitTensorLinearMap_eq_lid_symm_apply,
    hypersequentTensorAlgToRightCounitTensorLinearMap_eq_lid_symm_apply]
  rw [show (hypersequentTensorAlgToRightCounitAlgHom R) (x * y) =
      (hypersequentTensorAlgToRightCounitAlgHom R x) *
        (hypersequentTensorAlgToRightCounitAlgHom R y) by
        exact (hypersequentTensorAlgToRightCounitAlgHom R).map_mul x y]
  exact map_mul
    ((Algebra.TensorProduct.lid R (HypersequentAlgebra R)).symm.toAlgHom)
    (hypersequentTensorAlgToRightCounitAlgHom R x)
    (hypersequentTensorAlgToRightCounitAlgHom R y)

/--
The support-to-tensor map preserves multiplication by a single support atom on
finite support lists.
-/
theorem hypersequentTensorAlgToTensorProductLinearMap_tensorSupportElement_map_mul_left
    [LeftDistribClass
      (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))]
    (p : HypersequentTensorBasis) (xs : List HypersequentTensorBasis) :
    hypersequentTensorAlgToTensorProductLinearMap R
        (tensorSupportElement R
          (xs.map (fun q => HypersequentTensorBasis.mul p q))) =
      tensorBasisTmul R p *
        hypersequentTensorAlgToTensorProductLinearMap R
          (tensorSupportElement R xs) := by
  induction xs with
  | nil =>
      simp [tensorSupportElement]
      exact (mul_zero (tensorBasisTmul R p)).symm
  | cons x xs ih =>
      rw [List.map_cons, tensorSupportElement_cons, map_add,
        hypersequentTensorAlgToTensorProductLinearMap_monomial]
      rw [ih]
      rw [tensorBasisTmul_mul]
      rw [tensorSupportElement_cons, map_add,
        hypersequentTensorAlgToTensorProductLinearMap_monomial]
      exact (left_distrib
        (tensorBasisTmul R p)
        (tensorBasisTmul R x)
        ((hypersequentTensorAlgToTensorProductLinearMap R)
          (tensorSupportElement R xs))).symm

/--
The support-to-tensor map preserves support multiplication on finite support
lists.  This is the concrete list-level multiplicativity theorem needed by the
split coproduct.
-/
theorem hypersequentTensorAlgToTensorProductLinearMap_tensorSupportMul
    [LeftDistribClass
      (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))]
    [RightDistribClass
      (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))]
    (xs ys : List HypersequentTensorBasis) :
    hypersequentTensorAlgToTensorProductLinearMap R
        (tensorSupportElement R (tensorSupportMul xs ys)) =
      hypersequentTensorAlgToTensorProductLinearMap R
          (tensorSupportElement R xs) *
        hypersequentTensorAlgToTensorProductLinearMap R
          (tensorSupportElement R ys) := by
  induction xs with
  | nil =>
      simp [tensorSupportMul, tensorSupportElement]
      exact (zero_mul
        ((hypersequentTensorAlgToTensorProductLinearMap R)
          (tensorSupportElement R ys))).symm
  | cons x xs ih =>
      change
        hypersequentTensorAlgToTensorProductLinearMap R
            (tensorSupportElement R
              ((ys.map (fun y => HypersequentTensorBasis.mul x y)) ++
                tensorSupportMul xs ys)) =
          hypersequentTensorAlgToTensorProductLinearMap R
              (tensorSupportElement R (x :: xs)) *
            hypersequentTensorAlgToTensorProductLinearMap R
              (tensorSupportElement R ys)
      rw [tensorSupportElement_append, map_add]
      rw [hypersequentTensorAlgToTensorProductLinearMap_tensorSupportElement_map_mul_left]
      rw [ih]
      rw [tensorSupportElement_cons, map_add,
        hypersequentTensorAlgToTensorProductLinearMap_monomial]
      exact (right_distrib
        (tensorBasisTmul R x)
        ((hypersequentTensorAlgToTensorProductLinearMap R)
          (tensorSupportElement R xs))
        ((hypersequentTensorAlgToTensorProductLinearMap R)
          (tensorSupportElement R ys))).symm

theorem hypersequentTensorAlgToTensorProductLinearMap_forestSupportMul
    [LeftDistribClass
      (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))]
    [RightDistribClass
      (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))]
    (f g : Forest) :
    hypersequentTensorAlgToTensorProductLinearMap R
        (tensorSupportElement R
          (tensorSupportMul
            (forestSplittingTensorSupport f)
            (forestSplittingTensorSupport g))) =
      hypersequentTensorAlgToTensorProductLinearMap R
          (forestSplittingTensorElement R f) *
        hypersequentTensorAlgToTensorProductLinearMap R
          (forestSplittingTensorElement R g) := by
  unfold forestSplittingTensorElement
  exact hypersequentTensorAlgToTensorProductLinearMap_tensorSupportMul R
    (forestSplittingTensorSupport f) (forestSplittingTensorSupport g)

/-!
## Coalgebra-normalized comultiplication

The proof-theoretic splitting map keeps the interface leaf visible.  The
coalgebra-normalized map below uses the same admissible cuts, but turns the two
boundary cuts into tensor units so that the augmentation counit can satisfy the
coalgebra laws.
-/

/-- Support element for the coalgebra-normalized coproduct of one tree. -/
def coalgebraTreeSplittingTensorElement (t : PTree) :
    HypersequentTensorAlgebra R :=
  tensorSupportElement R (coalgebraTreeSplittingTensorSupport t)

/--
Multiplicative support element for an ordered forest, using the normalized
boundary conventions needed by the GL/CK coalgebra laws.
-/
def coalgebraForestSplittingTensorSupport : Forest → List HypersequentTensorBasis
  | [] => [HypersequentTensorBasis.one]
  | t :: ts =>
      tensorSupportMul (coalgebraTreeSplittingTensorSupport t)
        (coalgebraForestSplittingTensorSupport ts)

/-- Ordered-forest support element for the normalized coproduct. -/
def coalgebraForestSplittingTensorElement (f : Forest) :
    HypersequentTensorAlgebra R :=
  tensorSupportElement R (coalgebraForestSplittingTensorSupport f)

@[simp]
theorem coalgebraForestSplittingTensorSupport_nil :
    coalgebraForestSplittingTensorSupport [] = [HypersequentTensorBasis.one] := rfl

@[simp]
theorem coalgebraForestSplittingTensorSupport_cons (t : PTree) (ts : Forest) :
    coalgebraForestSplittingTensorSupport (t :: ts) =
      tensorSupportMul (coalgebraTreeSplittingTensorSupport t)
        (coalgebraForestSplittingTensorSupport ts) := rfl

theorem coalgebraForestSplittingTensorSupport_append_perm
    (f g : Forest) :
    List.Perm
      (coalgebraForestSplittingTensorSupport (f ++ g))
      (tensorSupportMul
        (coalgebraForestSplittingTensorSupport f)
        (coalgebraForestSplittingTensorSupport g)) := by
  induction f with
  | nil =>
      change List.Perm
        (coalgebraForestSplittingTensorSupport g)
        (tensorSupportMul [HypersequentTensorBasis.one]
          (coalgebraForestSplittingTensorSupport g))
      unfold tensorSupportMul
      have hmap :
          (coalgebraForestSplittingTensorSupport g).map
              (fun y => HypersequentTensorBasis.mul HypersequentTensorBasis.one y) =
            coalgebraForestSplittingTensorSupport g := by
        trans (coalgebraForestSplittingTensorSupport g).map (fun y => y)
        · apply List.map_congr_left
          intro y _hy
          simp
        · simp
      simp [hmap]
  | cons t ts ih =>
      simp [coalgebraForestSplittingTensorSupport]
      refine (tensorSupportMul_perm_right
        (xs := coalgebraTreeSplittingTensorSupport t) ih).trans ?_
      rw [← tensorSupportMul_assoc]

theorem coalgebraForestSplittingTensorSupport_perm_of_perm
    {f g : Forest}
    (h : List.Perm f g) :
    List.Perm
      (coalgebraForestSplittingTensorSupport f)
      (coalgebraForestSplittingTensorSupport g) := by
  induction h with
  | nil =>
      simp
  | cons t h ih =>
      simp [coalgebraForestSplittingTensorSupport]
      exact tensorSupportMul_perm_right ih
  | swap t u ts =>
      simp [coalgebraForestSplittingTensorSupport]
      rw [← tensorSupportMul_assoc, ← tensorSupportMul_assoc]
      exact tensorSupportMul_perm_left
        (tensorSupportMul_comm
          (coalgebraTreeSplittingTensorSupport u)
          (coalgebraTreeSplittingTensorSupport t))
  | trans _ _ ih₁ ih₂ =>
      exact ih₁.trans ih₂

/-- Every normalized forest coproduct has the identity split. -/
theorem coalgebraForestSplittingTensorSupport_contains_identity :
    ∀ f : Forest,
      List.Mem (0, HQ.ofForest f) (coalgebraForestSplittingTensorSupport f)
  | [] => by
      exact List.Mem.head []
  | t :: ts => by
      have ht : List.Mem (0, HQ.singleton t)
          (coalgebraTreeSplittingTensorSupport t) :=
        coalgebraTreeSplittingTensorSupport_contains_empty t
      have hts : List.Mem (0, HQ.ofForest ts)
          (coalgebraForestSplittingTensorSupport ts) :=
        coalgebraForestSplittingTensorSupport_contains_identity ts
      simpa [HypersequentTensorBasis.mul, HQ.ofForest_cons] using
        mem_tensorSupportMul_of_mem ht hts

/--
The normalized forest coproduct has the head-root split: split the first tree
at its root and leave all later forest components untouched.
-/
theorem coalgebraForestSplittingTensorSupport_contains_head_root
    (t : PTree) (ts : Forest) :
    List.Mem
      (HQ.singleton t, HQ.ofForest ts)
      (coalgebraForestSplittingTensorSupport (t :: ts)) := by
  have ht :
      List.Mem (HQ.singleton t, 0)
        (coalgebraTreeSplittingTensorSupport t) :=
    coalgebraTreeSplittingTensorSupport_contains_root t
  have hts :
      List.Mem (0, HQ.ofForest ts)
        (coalgebraForestSplittingTensorSupport ts) :=
    coalgebraForestSplittingTensorSupport_contains_identity ts
  simpa [HypersequentTensorBasis.mul] using
    mem_tensorSupportMul_of_mem ht hts

/--
The normalized forest coproduct contains the total-root split: every external
component of the forest is cut at its own root, leaving the tensor unit in the
right component.
-/
theorem coalgebraForestSplittingTensorSupport_contains_total_root :
    ∀ f : Forest,
      List.Mem (HQ.ofForest f, 0) (coalgebraForestSplittingTensorSupport f)
  | [] => by
      exact List.Mem.head []
  | t :: ts => by
      have ht :
          List.Mem (HQ.singleton t, 0)
            (coalgebraTreeSplittingTensorSupport t) :=
        coalgebraTreeSplittingTensorSupport_contains_root t
      have hts :
          List.Mem (HQ.ofForest ts, 0)
            (coalgebraForestSplittingTensorSupport ts) :=
        coalgebraForestSplittingTensorSupport_contains_total_root ts
      simpa [HypersequentTensorBasis.mul] using
        mem_tensorSupportMul_of_mem ht hts

/--
Forest coproduct support contains the split that sends a prefix forest wholly
to the left tensor factor and leaves a suffix forest wholly on the right.

This is the forest-level external structural move used by the ambient node
witness: the first-stage detached forest becomes the left component, while the
second-stage detached forest becomes the middle component.
-/
theorem coalgebraForestSplittingTensorSupport_contains_prefix_suffix
    (f g : Forest) :
    List.Mem (HQ.ofForest f, HQ.ofForest g)
      (coalgebraForestSplittingTensorSupport (f ++ g)) := by
  have hf :
      List.Mem (HQ.ofForest f, 0)
        (coalgebraForestSplittingTensorSupport f) :=
    coalgebraForestSplittingTensorSupport_contains_total_root f
  have hg :
      List.Mem (0, HQ.ofForest g)
        (coalgebraForestSplittingTensorSupport g) :=
    coalgebraForestSplittingTensorSupport_contains_identity g
  have hmul :
      List.Mem (HQ.ofForest f, HQ.ofForest g)
        (tensorSupportMul
          (coalgebraForestSplittingTensorSupport f)
          (coalgebraForestSplittingTensorSupport g)) := by
    simpa [HypersequentTensorBasis.mul] using
      mem_tensorSupportMul_of_mem hf hg
  exact ((coalgebraForestSplittingTensorSupport_append_perm f g).symm.mem_iff).1 hmul

theorem mem_coalgebraForestSplittingTensorSupport_append_of_mem
    {f g : Forest} {p q : HypersequentTensorBasis}
    (hp : p ∈ coalgebraForestSplittingTensorSupport f)
    (hq : q ∈ coalgebraForestSplittingTensorSupport g) :
    HypersequentTensorBasis.mul p q ∈
      coalgebraForestSplittingTensorSupport (f ++ g) := by
  have hmul :
      HypersequentTensorBasis.mul p q ∈
        tensorSupportMul
          (coalgebraForestSplittingTensorSupport f)
          (coalgebraForestSplittingTensorSupport g) :=
    mem_tensorSupportMul_of_mem hp hq
  exact ((coalgebraForestSplittingTensorSupport_append_perm f g).symm.mem_iff).1 hmul

theorem mem_coalgebraForestSplittingTensorSupport_cons_of_mem
    {t : PTree} {ts : Forest}
    {p q : HypersequentTensorBasis}
    (hp : p ∈ coalgebraTreeSplittingTensorSupport t)
    (hq : q ∈ coalgebraForestSplittingTensorSupport ts) :
    HypersequentTensorBasis.mul p q ∈
      coalgebraForestSplittingTensorSupport (t :: ts) := by
  exact mem_tensorSupportMul_of_mem hp hq

/-!
### Witness form for normalized forest splitting support

The proper left internal/internal sector is indexed by forest support atoms.
To invert such an atom back into a two-stage tree cut, we need the proof
relevant data hidden by `coalgebraForestSplittingTensorSupport`: one
coalgebra cut for each tree in the detached forest.  The definitions below
make that data explicit without changing the support list.
-/

/-- A normalized forest split profile chooses one admissible cut in each tree. -/
noncomputable def coalgebraForestCutProfiles :
    Forest → List (List (List Address))
  | [] => [[]]
  | t :: ts =>
      (coalgebraAdmissibleCuts t).flatMap
        (fun cut =>
          (coalgebraForestCutProfiles ts).map
            (fun profile => cut :: profile))

/-- Tensor-support atom represented by a forest cut profile. -/
noncomputable def coalgebraForestTensorTermOfProfile :
    Forest → List (List Address) → HypersequentTensorBasis
  | [], _ => HypersequentTensorBasis.one
  | t :: ts, [] =>
      HypersequentTensorBasis.mul
        (coalgebraTensorTermOfCutList t [])
        (coalgebraForestTensorTermOfProfile ts [])
  | t :: ts, cut :: profile =>
      HypersequentTensorBasis.mul
        (coalgebraTensorTermOfCutList t cut)
        (coalgebraForestTensorTermOfProfile ts profile)

@[simp]
theorem coalgebraForestCutProfiles_nil :
    coalgebraForestCutProfiles [] = [[]] := rfl

@[simp]
theorem coalgebraForestCutProfiles_cons (t : PTree) (ts : Forest) :
    coalgebraForestCutProfiles (t :: ts) =
      (coalgebraAdmissibleCuts t).flatMap
        (fun cut =>
          (coalgebraForestCutProfiles ts).map
            (fun profile => cut :: profile)) := rfl

@[simp]
theorem coalgebraForestTensorTermOfProfile_nil
    (profile : List (List Address)) :
    coalgebraForestTensorTermOfProfile [] profile =
      HypersequentTensorBasis.one := by
  cases profile <;> rfl

@[simp]
theorem coalgebraForestTensorTermOfProfile_cons_nil
    (t : PTree) (ts : Forest) :
    coalgebraForestTensorTermOfProfile (t :: ts) [] =
      HypersequentTensorBasis.mul
        (coalgebraTensorTermOfCutList t [])
        (coalgebraForestTensorTermOfProfile ts []) := rfl

@[simp]
theorem coalgebraForestTensorTermOfProfile_cons_cons
    (t : PTree) (ts : Forest)
    (cut : List Address) (profile : List (List Address)) :
    coalgebraForestTensorTermOfProfile (t :: ts) (cut :: profile) =
      HypersequentTensorBasis.mul
        (coalgebraTensorTermOfCutList t cut)
        (coalgebraForestTensorTermOfProfile ts profile) := rfl

noncomputable def coalgebraForestTensorTermOfPairs :
    List (PTree × List Address) → HypersequentTensorBasis
  | [] => HypersequentTensorBasis.one
  | (t, cut) :: rest =>
      HypersequentTensorBasis.mul
        (coalgebraTensorTermOfCutList t cut)
        (coalgebraForestTensorTermOfPairs rest)

@[simp]
theorem coalgebraForestTensorTermOfPairs_nil :
    coalgebraForestTensorTermOfPairs [] =
      HypersequentTensorBasis.one := rfl

@[simp]
theorem coalgebraForestTensorTermOfPairs_cons
    (t : PTree) (cut : List Address)
    (rest : List (PTree × List Address)) :
    coalgebraForestTensorTermOfPairs ((t, cut) :: rest) =
      HypersequentTensorBasis.mul
        (coalgebraTensorTermOfCutList t cut)
        (coalgebraForestTensorTermOfPairs rest) := rfl

theorem coalgebraForestTensorTermOfPairs_perm
    {xs ys : List (PTree × List Address)}
    (hperm : xs.Perm ys) :
    coalgebraForestTensorTermOfPairs xs =
      coalgebraForestTensorTermOfPairs ys := by
  induction hperm with
  | nil =>
      rfl
  | cons x _hperm ih =>
      cases x
      simp [ih]
  | swap x y l =>
      cases x
      cases y
      simp [coalgebraForestTensorTermOfPairs,
        HypersequentTensorBasis.mul, add_assoc, add_comm, add_left_comm]
  | trans _ _ ih₁ ih₂ =>
      exact ih₁.trans ih₂

theorem coalgebraForestTensorTermOfPairs_append
    (xs ys : List (PTree × List Address)) :
    coalgebraForestTensorTermOfPairs (xs ++ ys) =
      HypersequentTensorBasis.mul
        (coalgebraForestTensorTermOfPairs xs)
        (coalgebraForestTensorTermOfPairs ys) := by
  induction xs with
  | nil =>
      simp
  | cons x xs ih =>
      cases x
      simp [coalgebraForestTensorTermOfPairs, ih,
        HypersequentTensorBasis.mul_assoc]

theorem coalgebraForestTensorTermOfProfile_eq_pairs :
    ∀ {f : Forest} {profile : List (List Address)},
      profile.length = f.length →
        coalgebraForestTensorTermOfProfile f profile =
          coalgebraForestTensorTermOfPairs (List.zip f profile)
  | [], profile, hlen => by
      cases profile with
      | nil =>
          simp
      | cons cut rest =>
          simp at hlen
  | t :: ts, profile, hlen => by
      cases profile with
      | nil =>
          simp at hlen
      | cons cut rest =>
          have htail : rest.length = ts.length := by
            simpa using hlen
          simp [coalgebraForestTensorTermOfProfile,
            coalgebraForestTensorTermOfPairs,
            coalgebraForestTensorTermOfProfile_eq_pairs htail]

theorem coalgebraForestTensorTermOfProfile_eq_of_zip_perm
    {f₁ f₂ : Forest}
    {profile₁ profile₂ : List (List Address)}
    (hlen₁ : profile₁.length = f₁.length)
    (hlen₂ : profile₂.length = f₂.length)
    (hperm :
      List.Perm (List.zip f₁ profile₁) (List.zip f₂ profile₂)) :
    coalgebraForestTensorTermOfProfile f₁ profile₁ =
      coalgebraForestTensorTermOfProfile f₂ profile₂ := by
  rw [coalgebraForestTensorTermOfProfile_eq_pairs hlen₁,
    coalgebraForestTensorTermOfProfile_eq_pairs hlen₂]
  exact coalgebraForestTensorTermOfPairs_perm hperm

theorem mem_coalgebraForestCutProfiles_cons_iff
    {t : PTree} {ts : Forest}
    {profile : List (List Address)} :
    profile ∈ coalgebraForestCutProfiles (t :: ts) ↔
      ∃ cut ∈ coalgebraAdmissibleCuts t,
        ∃ rest ∈ coalgebraForestCutProfiles ts,
          profile = cut :: rest := by
  change profile ∈
      (coalgebraAdmissibleCuts t).flatMap
        (fun cut =>
          (coalgebraForestCutProfiles ts).map
            (fun profile => cut :: profile)) ↔
      ∃ cut ∈ coalgebraAdmissibleCuts t,
        ∃ rest ∈ coalgebraForestCutProfiles ts,
          profile = cut :: rest
  constructor
  · intro hprofile
    rcases List.mem_flatMap.1 hprofile with ⟨cut, hcut, hmap⟩
    rcases List.mem_map.1 hmap with ⟨rest, hrest, hEq⟩
    exact ⟨cut, hcut, rest, hrest, hEq.symm⟩
  · rintro ⟨cut, hcut, rest, hrest, rfl⟩
    exact List.mem_flatMap.2
      ⟨cut, hcut, List.mem_map.2 ⟨rest, hrest, rfl⟩⟩

theorem coalgebraForestSplittingTensorSupport_eq_profile_map :
    ∀ f : Forest,
      coalgebraForestSplittingTensorSupport f =
        (coalgebraForestCutProfiles f).map
          (coalgebraForestTensorTermOfProfile f)
  | [] => by
      simp [coalgebraForestSplittingTensorSupport,
        coalgebraForestCutProfiles, coalgebraForestTensorTermOfProfile]
  | t :: ts => by
      rw [coalgebraForestSplittingTensorSupport_cons,
        coalgebraForestSplittingTensorSupport_eq_profile_map ts]
      unfold tensorSupportMul coalgebraTreeSplittingTensorSupport
      simp [coalgebraForestCutProfiles, coalgebraForestTensorTermOfProfile,
        List.flatMap_map, List.map_flatMap, List.map_map, Function.comp_def]

theorem mem_coalgebraForestSplittingTensorSupport_iff_profile
    {f : Forest} {q : HypersequentTensorBasis} :
    q ∈ coalgebraForestSplittingTensorSupport f ↔
      ∃ profile ∈ coalgebraForestCutProfiles f,
        q = coalgebraForestTensorTermOfProfile f profile := by
  rw [coalgebraForestSplittingTensorSupport_eq_profile_map f]
  constructor
  · intro hq
    rcases List.mem_map.1 hq with ⟨profile, hprofile, hEq⟩
    exact ⟨profile, hprofile, hEq.symm⟩
  · rintro ⟨profile, hprofile, rfl⟩
    exact List.mem_map.2 ⟨profile, hprofile, rfl⟩

theorem coalgebraForestCutProfiles_length_eq :
    ∀ {f : Forest} {profile : List (List Address)},
      profile ∈ coalgebraForestCutProfiles f →
        profile.length = f.length
  | [], profile, hprofile => by
      simp [coalgebraForestCutProfiles] at hprofile
      subst profile
      simp
  | t :: ts, profile, hprofile => by
      rcases (mem_coalgebraForestCutProfiles_cons_iff
        (t := t) (ts := ts) (profile := profile)).1 hprofile with
        ⟨cut, _hcut, rest, hrest, rfl⟩
      have hlen :
          rest.length = ts.length :=
        coalgebraForestCutProfiles_length_eq
          (f := ts) (profile := rest) hrest
      simp [hlen]

theorem coalgebraForestTensorTermOfProfile_fst_eq_zero_iff_all_empty
    {f : Forest} {profile : List (List Address)}
    (hprofile : profile ∈ coalgebraForestCutProfiles f) :
    (coalgebraForestTensorTermOfProfile f profile).1 = 0 ↔
      ∀ cut ∈ profile, cut = [] := by
  induction f generalizing profile with
  | nil =>
      simp [coalgebraForestCutProfiles] at hprofile
      subst profile
      simp [coalgebraForestTensorTermOfProfile]
  | cons t ts ih =>
      rcases (mem_coalgebraForestCutProfiles_cons_iff
        (t := t) (ts := ts) (profile := profile)).1 hprofile with
        ⟨cut, hcut, rest, hrest, rfl⟩
      have htree :
          (coalgebraTensorTermOfCutList t cut).1 = 0 ↔ cut = [] :=
        coalgebraTensorTermOfCutList_fst_eq_zero_iff_cut_nil
          (t := t) (cut := cut) hcut
      have hrestZero :
          (coalgebraForestTensorTermOfProfile ts rest).1 = 0 ↔
            ∀ cut ∈ rest, cut = [] :=
        ih hrest
      simp [coalgebraForestTensorTermOfProfile,
        HypersequentTensorBasis.mul, htree, hrestZero]

theorem coalgebraForestTensorTermOfProfile_snd_eq_zero_iff_all_root
    {f : Forest} {profile : List (List Address)}
    (hprofile : profile ∈ coalgebraForestCutProfiles f) :
    (coalgebraForestTensorTermOfProfile f profile).2 = 0 ↔
      ∀ cut ∈ profile, ([] : Address) ∈ cut := by
  induction f generalizing profile with
  | nil =>
      simp [coalgebraForestCutProfiles] at hprofile
      subst profile
      simp [coalgebraForestTensorTermOfProfile]
  | cons t ts ih =>
      rcases (mem_coalgebraForestCutProfiles_cons_iff
        (t := t) (ts := ts) (profile := profile)).1 hprofile with
        ⟨cut, hcut, rest, hrest, rfl⟩
      have htree :
          (coalgebraTensorTermOfCutList t cut).2 = 0 ↔
            ([] : Address) ∈ cut :=
        coalgebraTensorTermOfCutList_snd_eq_zero_iff_root_mem
          (t := t) (cut := cut) hcut
      have hrestZero :
          (coalgebraForestTensorTermOfProfile ts rest).2 = 0 ↔
            ∀ cut ∈ rest, ([] : Address) ∈ cut :=
        ih hrest
      simp [coalgebraForestTensorTermOfProfile,
        HypersequentTensorBasis.mul, htree, hrestZero]

theorem mem_coalgebraForestCutProfiles_filterMap_of_zip
    {t : PTree} :
    ∀ {addrs : List Address} {profile : List (List Address)},
      profile.length = addrs.length →
      (∀ a cut, (a, cut) ∈ List.zip addrs profile →
        ∃ u, t.subtreeAt a = some u ∧
          cut ∈ coalgebraAdmissibleCuts u) →
      profile ∈ coalgebraForestCutProfiles
        (addrs.filterMap (PTree.subtreeAt t))
  | [], profile, hlen, _hzip => by
      cases profile with
      | nil =>
          simp
      | cons cut rest =>
          simp at hlen
  | a :: addrs, profile, hlen, hzip => by
      cases profile with
      | nil =>
          simp at hlen
      | cons cut rest =>
          have hlenTail : rest.length = addrs.length := by
            simpa using hlen
          have hzipTail :
              ∀ b cut',
                (b, cut') ∈ List.zip addrs rest →
                  ∃ u, t.subtreeAt b = some u ∧
                    cut' ∈ coalgebraAdmissibleCuts u := by
            intro b cut' hmem
            exact hzip b cut' (by simp [hmem])
          rcases hzip a cut (by simp) with ⟨u, hsub, hcut⟩
          have hrest :
              rest ∈ coalgebraForestCutProfiles
                (addrs.filterMap (PTree.subtreeAt t)) :=
            mem_coalgebraForestCutProfiles_filterMap_of_zip
              (t := t) hlenTail hzipTail
          simpa [hsub] using
            (mem_coalgebraForestCutProfiles_cons_iff
              (t := u)
              (ts := addrs.filterMap (PTree.subtreeAt t))
              (profile := cut :: rest)).2
              ⟨cut, hcut, rest, hrest, rfl⟩

/--
Conversely, if every ambient address denotes a subtree and a profile belongs
to the forest cut-profile list over those subtrees, then each zipped
ambient/profile component is an admissible cut of the addressed subtree.

This is the local inverse of `mem_coalgebraForestCutProfiles_filterMap_of_zip`
and is the proof-theoretic content needed for the antichain-refinement
direction of coassociativity.
-/
theorem zip_admissibleCuts_of_mem_coalgebraForestCutProfiles_filterMap
    {t : PTree} :
    ∀ {addrs : List Address} {profile : List (List Address)},
      (∀ a, a ∈ addrs → ∃ u, t.subtreeAt a = some u) →
      profile.length = addrs.length →
      profile ∈ coalgebraForestCutProfiles
        (addrs.filterMap (PTree.subtreeAt t)) →
      ∀ a cut, (a, cut) ∈ List.zip addrs profile →
        ∃ u, t.subtreeAt a = some u ∧
          cut ∈ coalgebraAdmissibleCuts u
  | [], profile, _hall, hlen, _hprofile => by
      cases profile with
      | nil =>
          intro a cut hmem
          simp at hmem
      | cons cut rest =>
          simp at hlen
  | a :: addrs, profile, hall, hlen, hprofile => by
      cases profile with
      | nil =>
          simp at hlen
      | cons cut rest =>
          rcases hall a (by simp) with ⟨u, hsub⟩
          have hprofile' :
              cut :: rest ∈
                coalgebraForestCutProfiles
                  (u :: addrs.filterMap (PTree.subtreeAt t)) := by
            simpa [hsub] using hprofile
          rcases (mem_coalgebraForestCutProfiles_cons_iff
              (t := u)
              (ts := addrs.filterMap (PTree.subtreeAt t))
              (profile := cut :: rest)).1 hprofile' with
            ⟨cut', hcut', rest', hrest', hEq⟩
          injection hEq with hcutEq hrestEq
          subst cut'
          subst rest'
          have hlenTail : rest.length = addrs.length := by
            simpa using hlen
          have hallTail :
              ∀ b, b ∈ addrs → ∃ u, t.subtreeAt b = some u := by
            intro b hb
            exact hall b (by simp [hb])
          have ihTail :
              ∀ b cut', (b, cut') ∈ List.zip addrs rest →
                ∃ u, t.subtreeAt b = some u ∧
                  cut' ∈ coalgebraAdmissibleCuts u :=
            zip_admissibleCuts_of_mem_coalgebraForestCutProfiles_filterMap
              (t := t) hallTail hlenTail hrest'
          intro b cutB hmem
          have hmem' :
              (b = a ∧ cutB = cut) ∨
                (b, cutB) ∈ List.zip addrs rest := by
            simpa using hmem
          rcases hmem' with hhead | htail
          · rcases hhead with ⟨rfl, rfl⟩
            exact ⟨u, hsub, hcut'⟩
          · exact ihTail b cutB htail

theorem subtreeAt_some_of_mem_coalgebraAdmissibleCuts
    {t : PTree} {cut : List Address} {a : Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts t)
    (ha : a ∈ cut) :
    ∃ u, t.subtreeAt a = some u := by
  have hvalid : PTree.ValidAddress t a :=
    (PTree.isAdmissibleCut_of_mem_allAdmissibleCuts
      ((mem_coalgebraAdmissibleCuts_iff).1 hcut).1).valid a ha
  exact (PTree.valid_iff_exists_subtree t a).1 hvalid

theorem eq_root_of_mem_coalgebraAdmissibleCuts_of_root_mem
    {t : PTree} {cut : List Address} {a : Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts t)
    (hroot : ([] : Address) ∈ cut)
    (ha : a ∈ cut) :
    a = ([] : Address) := by
  by_contra hne
  exact antichain_of_mem_coalgebraAdmissibleCuts hcut
    a ha ([] : Address) hroot hne
    (Or.inr (PTree.root_isAncestorOf a))

theorem eq_singleton_root_of_mem_coalgebraAdmissibleCuts_of_root_mem
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts t)
    (hroot : ([] : Address) ∈ cut) :
    cut = [([] : Address)] := by
  cases cut with
  | nil =>
      simp at hroot
  | cons a rest =>
      have ha : a = ([] : Address) :=
        eq_root_of_mem_coalgebraAdmissibleCuts_of_root_mem
          (t := t) (cut := a :: rest) (a := a) hcut hroot (by simp)
      subst a
      cases rest with
      | nil =>
          rfl
      | cons b rest =>
          have hb : b = ([] : Address) :=
            eq_root_of_mem_coalgebraAdmissibleCuts_of_root_mem
              (t := t) (cut := ([] : Address) :: b :: rest) (a := b)
              hcut hroot (by simp)
          subst b
          have hnodup :
              (([] : Address) :: ([] : Address) :: rest).Nodup :=
            nodup_of_mem_coalgebraAdmissibleCuts hcut
          simp at hnodup

theorem List.left_mem_of_mem_zip
    {α β : Type*} {xs : List α} {ys : List β}
    {a : α} {b : β} :
    (a, b) ∈ List.zip xs ys → a ∈ xs := by
  induction xs generalizing ys with
  | nil =>
      intro h
      cases ys <;> simp at h
  | cons x xs ih =>
      intro h
      cases ys with
      | nil =>
          simp at h
      | cons y ys =>
          simp at h ⊢
          rcases h with hhead | htail
          · exact Or.inl hhead.1
          · exact Or.inr (ih htail)

theorem List.exists_left_of_mem_right_zip_of_length
    {α β : Type*} {xs : List α} {ys : List β}
    (hlen : xs.length = ys.length) {b : β}
    (hb : b ∈ ys) :
    ∃ a : α, (a, b) ∈ List.zip xs ys := by
  induction xs generalizing ys with
  | nil =>
      cases ys with
      | nil => simp at hb
      | cons y ys => simp at hlen
  | cons x xs ih =>
      cases ys with
      | nil => simp at hb
      | cons y ys =>
          have hlenTail : xs.length = ys.length := by
            simpa using hlen
          rcases List.mem_cons.1 hb with hhead | htail
          · subst b
            exact ⟨x, by simp⟩
          · rcases ih hlenTail htail with ⟨a, ha⟩
            exact ⟨a, by simp [ha]⟩

theorem List.exists_right_of_mem_left_zip_of_length
    {α β : Type*} {xs : List α} {ys : List β}
    (hlen : xs.length = ys.length) {a : α}
    (ha : a ∈ xs) :
    ∃ b : β, (a, b) ∈ List.zip xs ys := by
  induction xs generalizing ys with
  | nil =>
      simp at ha
  | cons x xs ih =>
      cases ys with
      | nil => simp at hlen
      | cons y ys =>
          have hlenTail : xs.length = ys.length := by
            simpa using hlen
          rcases List.mem_cons.1 ha with hhead | htail
          · subst a
            exact ⟨y, by simp⟩
          · rcases ih hlenTail htail with ⟨b, hb⟩
            exact ⟨b, by simp [hb]⟩

theorem List.nodup_zip_of_left
    {α β : Type*} {xs : List α} {ys : List β}
    (hnodup : xs.Nodup) :
    (List.zip xs ys).Nodup := by
  induction xs generalizing ys with
  | nil =>
      cases ys <;> simp
  | cons x xs ih =>
      cases ys with
      | nil =>
          simp
      | cons y ys =>
          have hxnot : x ∉ xs := (List.nodup_cons.mp hnodup).1
          have htail : xs.Nodup := (List.nodup_cons.mp hnodup).2
          apply List.nodup_cons.mpr
          constructor
          · intro hmem
            have hxmem : x ∈ xs :=
              List.left_mem_of_mem_zip hmem
            exact hxnot hxmem
          · exact ih htail

theorem List.right_eq_of_mem_zip_same_left_of_nodup
    {α β : Type*} [DecidableEq α]
    {xs : List α} {ys : List β} {a : α} {b₁ b₂ : β}
    (hnodup : xs.Nodup)
    (h₁ : (a, b₁) ∈ List.zip xs ys)
    (h₂ : (a, b₂) ∈ List.zip xs ys) :
    b₁ = b₂ := by
  induction xs generalizing ys with
  | nil =>
      cases ys <;> simp at h₁
  | cons x xs ih =>
      cases ys with
      | nil =>
          simp at h₁
      | cons y ys =>
          have hxnot : x ∉ xs := (List.nodup_cons.mp hnodup).1
          have hnodupTail : xs.Nodup := (List.nodup_cons.mp hnodup).2
          rcases List.mem_cons.1 h₁ with h₁head | h₁tail
          · injection h₁head with hax hb₁
            subst a
            subst b₁
            rcases List.mem_cons.1 h₂ with h₂head | h₂tail
            · injection h₂head with _ha hb₂
              exact hb₂.symm
            · have hxmem : x ∈ xs :=
                List.left_mem_of_mem_zip h₂tail
              exact False.elim (hxnot hxmem)
          · rcases List.mem_cons.1 h₂ with h₂head | h₂tail
            · injection h₂head with hax hb₂
              subst a
              have hxmem : x ∈ xs :=
                List.left_mem_of_mem_zip h₁tail
              exact False.elim (hxnot hxmem)
            · exact ih hnodupTail h₁tail h₂tail

theorem List.mem_zip_map_self_iff
    {α β : Type*} {xs : List α} {f : α → β}
    {a : α} {b : β} :
    (a, b) ∈ List.zip xs (xs.map f) ↔
      a ∈ xs ∧ b = f a := by
  induction xs with
  | nil =>
      simp
  | cons x xs ih =>
      constructor
      · intro h
        rcases List.mem_cons.1 h with hhead | htail
        · injection hhead with ha hb
          subst a
          subst b
          simp
        · rcases ih.1 htail with ⟨ha, hb⟩
          exact ⟨by simp [ha], hb⟩
      · rintro ⟨ha, hb⟩
        rcases List.mem_cons.1 ha with hax | hax
        · subst a
          subst b
          simp
        · exact List.mem_cons.2 (Or.inr ((ih).2 ⟨hax, hb⟩))

theorem List.eq_map_of_forall_mem_zip_eq
    {α β : Type*} {xs : List α} {ys : List β} {f : α → β}
    (hlen : ys.length = xs.length)
    (hentry : ∀ a b, (a, b) ∈ List.zip xs ys → b = f a) :
    ys = xs.map f := by
  induction xs generalizing ys with
  | nil =>
      cases ys with
      | nil => simp
      | cons y ys => simp at hlen
  | cons x xs ih =>
      cases ys with
      | nil => simp at hlen
      | cons y ys =>
          have hy : y = f x := hentry x y (by simp)
          have hlenTail : ys.length = xs.length := by
            simpa using hlen
          have htail :
              ∀ a b, (a, b) ∈ List.zip xs ys → b = f a := by
            intro a b hb
            exact hentry a b (by simp [hb])
          simp [hy, ih hlenTail htail]

theorem List.zip_filterMap_map_eq_filterMap_pair
    {α β γ : Type*} :
    ∀ (xs : List α) (g : α → Option β) (f : α → γ),
      (∀ x, x ∈ xs → ∃ y, g x = some y) →
        List.zip (xs.filterMap g) (xs.map f) =
          xs.filterMap (fun x =>
            match g x with
            | some y => some (y, f x)
            | none => none)
  | [], _g, _f, _hall => by
      simp
  | x :: xs, g, f, hall => by
      rcases hall x (by simp) with ⟨y, hy⟩
      have htail :
          List.zip (xs.filterMap g) (xs.map f) =
            xs.filterMap (fun x =>
              match g x with
              | some y => some (y, f x)
              | none => none) :=
        List.zip_filterMap_map_eq_filterMap_pair
          xs g f (by
            intro z hz
            exact hall z (by simp [hz]))
      simp [hy, htail]

/-- First-stage contribution of one ambient detached tree/profile cut. -/
def forestProfileFirstCutPiece
    (a : Address) (cut : List Address) : List Address :=
  if cut = [([] : Address)] then
    [a]
  else
    cut.map (fun c => a ++ c)

/-- Second-stage contribution of one ambient detached tree/profile cut. -/
def forestProfileSecondCutPiece
    (a : Address) (cut : List Address) : List Address :=
  if cut = [([] : Address)] then
    []
  else
    [a]

/--
Recover the first staged cut from an ambient cut and a forest split profile.

For a component split at its root, the ambient address was already a first-stage
detached proof.  For every other component, the ambient address is a
second-stage address, and the chosen profile cut is re-prefixed below it.
-/
def forestProfileFirstCut
    (ambient : List Address) (profile : List (List Address)) : List Address :=
  (ambient.zip profile).flatMap
    (fun p => forestProfileFirstCutPiece p.1 p.2)

/--
Recover the second staged cut from an ambient cut and a forest split profile.

Exactly the non-root component profiles become the second-stage cut.
-/
def forestProfileSecondCut
    (ambient : List Address) (profile : List (List Address)) : List Address :=
  (ambient.zip profile).flatMap
    (fun p => forestProfileSecondCutPiece p.1 p.2)

@[simp]
theorem forestProfileFirstCutPiece_root (a : Address) :
    forestProfileFirstCutPiece a [([] : Address)] = [a] := by
  simp [forestProfileFirstCutPiece]

@[simp]
theorem forestProfileSecondCutPiece_root (a : Address) :
    forestProfileSecondCutPiece a [([] : Address)] = [] := by
  simp [forestProfileSecondCutPiece]

theorem forestProfileFirstCutPiece_nonroot
    {a : Address} {cut : List Address}
    (hroot : cut ≠ [([] : Address)]) :
    forestProfileFirstCutPiece a cut = cut.map (fun c => a ++ c) := by
  simp [forestProfileFirstCutPiece, hroot]

theorem forestProfileSecondCutPiece_nonroot
    {a : Address} {cut : List Address}
    (hroot : cut ≠ [([] : Address)]) :
    forestProfileSecondCutPiece a cut = [a] := by
  simp [forestProfileSecondCutPiece, hroot]

@[simp]
theorem forestProfileFirstCut_nil_left
    (profile : List (List Address)) :
    forestProfileFirstCut [] profile = [] := by
  cases profile <;> rfl

@[simp]
theorem forestProfileSecondCut_nil_left
    (profile : List (List Address)) :
    forestProfileSecondCut [] profile = [] := by
  cases profile <;> rfl

@[simp]
theorem forestProfileFirstCut_nil_right
    (ambient : List Address) :
    forestProfileFirstCut ambient [] = [] := by
  cases ambient <;> rfl

@[simp]
theorem forestProfileSecondCut_nil_right
    (ambient : List Address) :
    forestProfileSecondCut ambient [] = [] := by
  cases ambient <;> rfl

@[simp]
theorem forestProfileFirstCut_cons_cons
    (a : Address) (ambient : List Address)
    (cut : List Address) (profile : List (List Address)) :
    forestProfileFirstCut (a :: ambient) (cut :: profile) =
      forestProfileFirstCutPiece a cut ++
        forestProfileFirstCut ambient profile := by
  rfl

@[simp]
theorem forestProfileSecondCut_cons_cons
    (a : Address) (ambient : List Address)
    (cut : List Address) (profile : List (List Address)) :
    forestProfileSecondCut (a :: ambient) (cut :: profile) =
      forestProfileSecondCutPiece a cut ++
        forestProfileSecondCut ambient profile := by
  rfl

@[simp]
theorem forestProfileFirstCut_cons_root
    (a : Address) (ambient : List Address)
    (profile : List (List Address)) :
    forestProfileFirstCut (a :: ambient)
        ([([] : Address)] :: profile) =
      a :: forestProfileFirstCut ambient profile := by
  simp [forestProfileFirstCut]

@[simp]
theorem forestProfileSecondCut_cons_root
    (a : Address) (ambient : List Address)
    (profile : List (List Address)) :
    forestProfileSecondCut (a :: ambient)
        ([([] : Address)] :: profile) =
      forestProfileSecondCut ambient profile := by
  simp [forestProfileSecondCut]

theorem forestProfileFirstCut_cons_nonroot
    {a : Address} {ambient : List Address}
    {cut : List Address} {profile : List (List Address)}
    (hroot : cut ≠ [([] : Address)]) :
    forestProfileFirstCut (a :: ambient) (cut :: profile) =
      cut.map (fun c => a ++ c) ++
        forestProfileFirstCut ambient profile := by
  simp [forestProfileFirstCutPiece_nonroot hroot]

theorem forestProfileSecondCut_cons_nonroot
    {a : Address} {ambient : List Address}
    {cut : List Address} {profile : List (List Address)}
    (hroot : cut ≠ [([] : Address)]) :
    forestProfileSecondCut (a :: ambient) (cut :: profile) =
      a :: forestProfileSecondCut ambient profile := by
  simp [forestProfileSecondCutPiece_nonroot hroot]

theorem forestProfileFirstCutPiece_eq_map_append
    (a : Address) (cut : List Address) :
    forestProfileFirstCutPiece a cut =
      cut.map (fun c => a ++ c) := by
  classical
  by_cases hroot : cut = [([] : Address)]
  · subst cut
    simp [forestProfileFirstCutPiece]
  · simp [forestProfileFirstCutPiece, hroot]

theorem mem_forestProfileFirstCut_iff_exists_zip
    {ambient : List Address} {profile : List (List Address)}
    {x : Address} :
    x ∈ forestProfileFirstCut ambient profile ↔
      ∃ a cut c,
        (a, cut) ∈ List.zip ambient profile ∧
          c ∈ cut ∧ x = a ++ c := by
  constructor
  · intro hx
    rcases List.mem_flatMap.1 hx with ⟨p, hpzip, hp⟩
    rcases p with ⟨a, cut⟩
    rw [forestProfileFirstCutPiece_eq_map_append] at hp
    rcases List.mem_map.1 hp with ⟨c, hc, hxc⟩
    refine ⟨a, cut, c, hpzip, hc, ?_⟩
    simpa using hxc.symm
  · rintro ⟨a, cut, c, hpzip, hc, rfl⟩
    unfold forestProfileFirstCut
    exact List.mem_flatMap.2
      ⟨(a, cut), hpzip, by
        rw [forestProfileFirstCutPiece_eq_map_append]
        exact List.mem_map.2 ⟨c, hc, rfl⟩⟩

theorem mem_forestProfileFirstCut_of_mem_zip
    {ambient : List Address} {profile : List (List Address)}
    {a c : Address} {cut : List Address}
    (hzip : (a, cut) ∈ List.zip ambient profile)
    (hc : c ∈ cut) :
    a ++ c ∈ forestProfileFirstCut ambient profile := by
  exact (mem_forestProfileFirstCut_iff_exists_zip
    (ambient := ambient) (profile := profile)
    (x := a ++ c)).2 ⟨a, cut, c, hzip, hc, rfl⟩

theorem forestProfile_comparable_of_common_descendant
    {a b c : Address}
    (ha : PTree.isAncestorOf a c)
    (hb : PTree.isAncestorOf b c) :
    PTree.comparable a b := by
  rcases ha with ⟨ca, hca⟩
  rcases hb with ⟨cb, hcb⟩
  by_cases hlen : a.length ≤ b.length
  · have hp : a <+: b ++ cb := by
      refine ⟨ca, ?_⟩
      exact hca.symm.trans hcb
    have hpab : a <+: b :=
      (List.isPrefix_append_of_length
        (l₁ := a) (l₂ := b) (l₃ := cb) hlen).1 hp
    rcases hpab with ⟨d, hd⟩
    exact Or.inl ⟨d, hd.symm⟩
  · have hlen' : b.length ≤ a.length := Nat.le_of_not_ge hlen
    have hp : b <+: a ++ ca := by
      refine ⟨cb, ?_⟩
      exact hcb.symm.trans hca
    have hpba : b <+: a :=
      (List.isPrefix_append_of_length
        (l₁ := b) (l₂ := a) (l₃ := ca) hlen').1 hp
    rcases hpba with ⟨d, hd⟩
    exact Or.inr ⟨d, hd.symm⟩

theorem forestProfile_comparable_prefixes_of_comparable_appends
    {a b c d : Address}
    (hcomp : PTree.comparable (a ++ c) (b ++ d)) :
    PTree.comparable a b := by
  rcases hcomp with hleft | hright
  · have ha : PTree.isAncestorOf a (b ++ d) := by
      rcases hleft with ⟨e, he⟩
      exact ⟨c ++ e, by
        rw [he, List.append_assoc]⟩
    have hb : PTree.isAncestorOf b (b ++ d) := ⟨d, rfl⟩
    exact forestProfile_comparable_of_common_descendant ha hb
  · have ha : PTree.isAncestorOf a (a ++ c) := ⟨c, rfl⟩
    have hb : PTree.isAncestorOf b (a ++ c) := by
      rcases hright with ⟨e, he⟩
      exact ⟨d ++ e, by
        rw [he, List.append_assoc]⟩
    exact forestProfile_comparable_of_common_descendant ha hb

theorem forestProfileFirstCut_nodup_of_zip_admissible_antichain
    {t : PTree} {ambient : List Address} {profile : List (List Address)}
    (hambientNodup : ambient.Nodup)
    (hambientAnti :
      ∀ a, a ∈ ambient →
        ∀ b, b ∈ ambient →
          a ≠ b → ¬ PTree.comparable a b)
    (hzipAd :
      ∀ a cut, (a, cut) ∈ List.zip ambient profile →
        ∃ u, t.subtreeAt a = some u ∧
          cut ∈ coalgebraAdmissibleCuts u) :
    (forestProfileFirstCut ambient profile).Nodup := by
  classical
  unfold forestProfileFirstCut
  rw [List.nodup_flatMap]
  constructor
  · intro p hp
    rcases p with ⟨a, cut⟩
    rw [forestProfileFirstCutPiece_eq_map_append]
    rcases hzipAd a cut hp with ⟨u, _hsub, hcut⟩
    exact (nodup_of_mem_coalgebraAdmissibleCuts hcut).map
      (List.append_right_injective a)
  · refine (List.nodup_zip_of_left
        (xs := ambient) (ys := profile) hambientNodup).pairwise_of_forall_ne ?_
    intro p hp q hq hpq x hx hxq
    rcases p with ⟨a, cutA⟩
    rcases q with ⟨b, cutB⟩
    change x ∈ forestProfileFirstCutPiece a cutA at hx
    change x ∈ forestProfileFirstCutPiece b cutB at hxq
    rw [forestProfileFirstCutPiece_eq_map_append] at hx hxq
    rcases List.mem_map.1 hx with ⟨c, hc, hxc⟩
    rcases List.mem_map.1 hxq with ⟨d, hd, hxd⟩
    have hxEq : x = a ++ c := hxc.symm
    have hyEq : x = b ++ d := hxd.symm
    have haAmbient : a ∈ ambient :=
      List.left_mem_of_mem_zip hp
    have hbAmbient : b ∈ ambient :=
      List.left_mem_of_mem_zip hq
    by_cases hab : a = b
    · subst b
      have hcutEq : cutB = cutA :=
        List.right_eq_of_mem_zip_same_left_of_nodup
          (xs := ambient) (ys := profile) (a := a)
          (b₁ := cutB) (b₂ := cutA) hambientNodup hq hp
      subst cutB
      have hcd : c = d := by
        exact (List.append_right_injective a)
          (hxEq.symm.trans hyEq)
      subst d
      exact hpq rfl
    · have hcompAmbient : PTree.comparable a b := by
        apply forestProfile_comparable_prefixes_of_comparable_appends
          (c := c) (d := d)
        exact forestProfile_comparable_of_common_descendant
          (a := a ++ c) (b := b ++ d) (c := x)
          ⟨[], by simpa using hxEq⟩
          ⟨[], by simpa using hyEq⟩
      exact hambientAnti a haAmbient b hbAmbient hab hcompAmbient

theorem mem_forestProfileSecondCut_iff_exists_zip_nonroot
    {ambient : List Address} {profile : List (List Address)}
    {a : Address} :
    a ∈ forestProfileSecondCut ambient profile ↔
      ∃ cut,
        (a, cut) ∈ List.zip ambient profile ∧
          cut ≠ [([] : Address)] := by
  constructor
  · intro ha
    rcases List.mem_flatMap.1 ha with ⟨p, hpzip, hp⟩
    rcases p with ⟨b, cut⟩
    by_cases hroot : cut = [([] : Address)]
    · have hpiece : forestProfileSecondCutPiece b cut = [] := by
        simp [forestProfileSecondCutPiece, hroot]
      rw [hpiece] at hp
      cases hp
    · have hpiece : forestProfileSecondCutPiece b cut = [b] :=
        forestProfileSecondCutPiece_nonroot hroot
      rw [hpiece] at hp
      simp at hp
      subst a
      exact ⟨cut, hpzip, hroot⟩
  · rintro ⟨cut, hzip, hroot⟩
    unfold forestProfileSecondCut
    exact List.mem_flatMap.2
      ⟨(a, cut), hzip, by
        rw [forestProfileSecondCutPiece_nonroot hroot]
        simp⟩

theorem mem_forestProfileSecondCut_of_mem_zip_nonroot
    {ambient : List Address} {profile : List (List Address)}
    {a : Address} {cut : List Address}
    (hzip : (a, cut) ∈ List.zip ambient profile)
    (hroot : cut ≠ [([] : Address)]) :
    a ∈ forestProfileSecondCut ambient profile := by
  exact (mem_forestProfileSecondCut_iff_exists_zip_nonroot
    (ambient := ambient) (profile := profile) (a := a)).2
    ⟨cut, hzip, hroot⟩

theorem forestProfileSecondCut_sublist_left
    (ambient : List Address) (profile : List (List Address)) :
    List.Sublist (forestProfileSecondCut ambient profile) ambient := by
  induction ambient generalizing profile with
  | nil =>
      cases profile <;> simp
  | cons a ambient ih =>
      cases profile with
      | nil =>
          simp
      | cons cut profile =>
          by_cases hroot : cut = [([] : Address)]
          · subst cut
            simpa [forestProfileSecondCut] using
              List.Sublist.cons a (ih profile)
          · rw [forestProfileSecondCut_cons_nonroot
              (a := a) (ambient := ambient)
              (cut := cut) (profile := profile) hroot]
            simpa using
              List.Sublist.cons₂ a (ih profile)

theorem forestProfileFirstCut_map_rightProfileAt
    (ambient cut₁ cut₂ : List Address) :
    forestProfileFirstCut ambient
        (ambient.map (fun a =>
          if a ∈ cut₂ then
            PTree.restrictCutAt cut₁ a
          else
            [([] : Address)])) =
      ambient.flatMap (fun a =>
        if a ∈ cut₂ then
          (PTree.restrictCutAt cut₁ a).map (fun c => a ++ c)
        else
          [a]) := by
  classical
  induction ambient with
  | nil =>
      simp [forestProfileFirstCut]
  | cons a rest ih =>
      have ih' :
          List.flatMap
              (fun p => (p.2).map (fun c => p.1 ++ c))
              (rest.zip
                (rest.map (fun a =>
                  if a ∈ cut₂ then
                    PTree.restrictCutAt cut₁ a
                  else
                    [([] : Address)]))) =
            rest.flatMap (fun a =>
              if a ∈ cut₂ then
                (PTree.restrictCutAt cut₁ a).map (fun c => a ++ c)
              else
                [a]) := by
        simpa [forestProfileFirstCut, forestProfileFirstCutPiece_eq_map_append] using ih
      by_cases ha : a ∈ cut₂
      · simp [forestProfileFirstCut, forestProfileFirstCutPiece_eq_map_append,
          ha, ih']
      · simp [forestProfileFirstCut, forestProfileFirstCutPiece_eq_map_append,
          ha, ih']

theorem forestProfileSecondCut_map_rightProfileAt
    (ambient cut₁ cut₂ : List Address)
    (hnotRoot :
      ∀ a ∈ ambient, a ∈ cut₂ →
        PTree.restrictCutAt cut₁ a ≠ [([] : Address)]) :
    forestProfileSecondCut ambient
        (ambient.map (fun a =>
          if a ∈ cut₂ then
            PTree.restrictCutAt cut₁ a
          else
            [([] : Address)])) =
      ambient.filter (fun a => decide (a ∈ cut₂)) := by
  classical
  induction ambient with
  | nil =>
      simp [forestProfileSecondCut]
  | cons a rest ih =>
      have hrest :
          ∀ b ∈ rest, b ∈ cut₂ →
            PTree.restrictCutAt cut₁ b ≠ [([] : Address)] := by
        intro b hb hb₂
        exact hnotRoot b (by simp [hb]) hb₂
      have ih' :
          List.flatMap
              (fun p =>
                if p.2 = [([] : Address)] then [] else [p.1])
              (rest.zip
                (rest.map (fun a =>
                  if a ∈ cut₂ then
                    PTree.restrictCutAt cut₁ a
                  else
                    [([] : Address)]))) =
            rest.filter (fun a => decide (a ∈ cut₂)) := by
        simpa [forestProfileSecondCut] using ih hrest
      by_cases ha : a ∈ cut₂
      · have haRoot :
            PTree.restrictCutAt cut₁ a ≠ [([] : Address)] :=
          hnotRoot a (by simp) ha
        simp [forestProfileSecondCut, forestProfileSecondCutPiece,
          ha, haRoot, ih']
      · simp [forestProfileSecondCut, forestProfileSecondCutPiece,
          ha, ih']

theorem List.flatMap_eq_self_of_forall_singleton
    {α : Type _} {xs : List α} {f : α → List α}
    (h : ∀ x ∈ xs, f x = [x]) :
    xs.flatMap f = xs := by
  induction xs with
  | nil =>
      simp
  | cons x xs ih =>
      have hx : f x = [x] := h x (by simp)
      have htail : ∀ y ∈ xs, f y = [y] := by
        intro y hy
        exact h y (by simp [hy])
      simp [hx, ih htail]

@[simp]
theorem coalgebraForestSplittingTensorElement_nil :
    coalgebraForestSplittingTensorElement R [] =
      (1 : HypersequentTensorAlgebra R) := by
  simp [coalgebraForestSplittingTensorElement,
    coalgebraForestSplittingTensorSupport, tensorSupportElement]

@[simp]
theorem coalgebraForestSplittingTensorElement_singleton (t : PTree) :
    coalgebraForestSplittingTensorElement R [t] =
      coalgebraTreeSplittingTensorElement R t := by
  simp [coalgebraForestSplittingTensorElement, coalgebraTreeSplittingTensorElement]

@[simp]
theorem coalgebraForestSplittingTensorElement_cons_mul (t : PTree) (ts : Forest) :
    coalgebraForestSplittingTensorElement R (t :: ts) =
      coalgebraTreeSplittingTensorElement R t *
        coalgebraForestSplittingTensorElement R ts := by
  simp [coalgebraForestSplittingTensorElement,
    coalgebraTreeSplittingTensorElement, tensorSupportElement_tensorSupportMul]

/--
The normalized support-polynomial coproduct on forests is multiplicative with
respect to forest concatenation.
-/
theorem coalgebraForestSplittingTensorElement_append_mul :
    ∀ f g : Forest,
      coalgebraForestSplittingTensorElement R (f ++ g) =
        coalgebraForestSplittingTensorElement R f *
          coalgebraForestSplittingTensorElement R g
  | [], g => by
      simp
  | t :: ts, g => by
      simp [coalgebraForestSplittingTensorElement_append_mul ts g, mul_assoc]

@[simp]
theorem coalgebraTreeSplittingTensorElement_emptySupportTerm (t : PTree) :
    List.Mem (0, HQ.singleton t) (coalgebraTreeSplittingTensorSupport t) := by
  exact coalgebraTreeSplittingTensorSupport_contains_empty t

@[simp]
theorem coalgebraTreeSplittingTensorElement_rootSupportTerm (t : PTree) :
    List.Mem (HQ.singleton t, 0) (coalgebraTreeSplittingTensorSupport t) := by
  exact coalgebraTreeSplittingTensorSupport_contains_root t

/--
Coalgebra-normalized comultiplication on a basis hypersequent, valued in the
support tensor algebra.
-/
def coalgebraComulHypersequent (G : Hypersequent) :
    HypersequentTensorAlgebra R :=
  (G.map (coalgebraTreeSplittingTensorElement R)).prod

@[simp]
theorem coalgebraComulHypersequent_zero :
    coalgebraComulHypersequent R 0 = 1 := by
  simp [coalgebraComulHypersequent]

@[simp]
theorem coalgebraComulHypersequent_singleton (t : PTree) :
    coalgebraComulHypersequent R (HQ.singleton t) =
      coalgebraTreeSplittingTensorElement R t := by
  simp [coalgebraComulHypersequent, HQ.singleton]

theorem coalgebraComulHypersequent_add (G H : Hypersequent) :
    coalgebraComulHypersequent R (G + H) =
      coalgebraComulHypersequent R G *
        coalgebraComulHypersequent R H := by
  simp [coalgebraComulHypersequent, Multiset.map_add, Multiset.prod_add]

/--
On an ordered forest, the normalized hypersequent coproduct agrees with the
explicit normalized forest support element.
-/
theorem coalgebraComulHypersequent_ofForest
    (f : Forest) :
    coalgebraComulHypersequent R (HQ.ofForest f) =
      coalgebraForestSplittingTensorElement R f := by
  induction f with
  | nil =>
      simp [coalgebraComulHypersequent, coalgebraForestSplittingTensorElement]
  | cons t ts ih =>
      rw [HQ.ofForest_cons, coalgebraComulHypersequent_add, coalgebraComulHypersequent_singleton]
      simpa [coalgebraForestSplittingTensorElement_cons_mul] using congrArg
        (HMul.hMul (coalgebraTreeSplittingTensorElement R t)) ih

/-- Multiplicative monoid hom underlying the normalized coproduct. -/
def coalgebraComulHypersequentMonoidHom :
    Multiplicative Hypersequent →* HypersequentTensorAlgebra R where
  toFun G := coalgebraComulHypersequent R G.toAdd
  map_one' := by
    simp
  map_mul' G H := by
    exact coalgebraComulHypersequent_add R G.toAdd H.toAdd

/-- Algebra-map version of the normalized support coproduct. -/
def hypersequentCoalgebraComulAlgHom :
    HypersequentAlgebra R →ₐ[R] HypersequentTensorAlgebra R :=
  AddMonoidAlgebra.lift R (HypersequentTensorAlgebra R) Hypersequent
    (coalgebraComulHypersequentMonoidHom R)

@[simp]
theorem hypersequentCoalgebraComulAlgHom_single (G : Hypersequent) :
    hypersequentCoalgebraComulAlgHom R (AddMonoidAlgebra.single G 1) =
      coalgebraComulHypersequent R G := by
  rw [hypersequentCoalgebraComulAlgHom]
  simp [coalgebraComulHypersequentMonoidHom]

@[simp]
theorem hypersequentCoalgebraComulAlgHom_tree (t : PTree) :
    hypersequentCoalgebraComulAlgHom R (treeMonomial R t) =
      coalgebraTreeSplittingTensorElement R t := by
  simp [treeMonomial, hseqMonomial]

theorem hypersequentCoalgebraComulAlgHom_mul
    (x y : HypersequentAlgebra R) :
    hypersequentCoalgebraComulAlgHom R (x * y) =
      hypersequentCoalgebraComulAlgHom R x *
        hypersequentCoalgebraComulAlgHom R y := by
  exact map_mul (hypersequentCoalgebraComulAlgHom R) x y

/--
The Mathlib-shaped normalized splitting comultiplication as a linear map into
the actual tensor product.
-/
def hypersequentCoalgebraComulTensorLinearMap :
    HypersequentAlgebra R →ₗ[R]
      TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R) :=
  (hypersequentTensorAlgToTensorProductLinearMap R).comp
    (hypersequentCoalgebraComulAlgHom R).toLinearMap

@[simp]
theorem hypersequentCoalgebraComulTensorLinearMap_monomial
    (G : Hypersequent) :
    hypersequentCoalgebraComulTensorLinearMap R (hseqMonomial R G) =
      hypersequentTensorAlgToTensorProductLinearMap R
        (coalgebraComulHypersequent R G) := by
  unfold hypersequentCoalgebraComulTensorLinearMap
  exact congrArg (hypersequentTensorAlgToTensorProductLinearMap R)
    (hypersequentCoalgebraComulAlgHom_single R G)

@[simp]
theorem hypersequentCoalgebraComulTensorLinearMap_tree (t : PTree) :
    hypersequentCoalgebraComulTensorLinearMap R (treeMonomial R t) =
      (hypersequentTensorAlgToTensorProductLinearMap R)
        (coalgebraTreeSplittingTensorElement R t) := by
  exact congrArg (hypersequentTensorAlgToTensorProductLinearMap R)
    (hypersequentCoalgebraComulAlgHom_tree R t)

/--
On ordered forests, the normalized tensor coproduct is multiplicative with
respect to external concatenation.

This is the list/forest-level form of normalized comultiplicativity.  It is
the algebraic shadow of the structural-rule fact that external composition of
components is reflected by multiplication in the tensor-support algebra.
-/
theorem hypersequentCoalgebraComulTensorLinearMap_ofForest
    (f : Forest) :
    hypersequentCoalgebraComulTensorLinearMap R (hseqMonomial R (HQ.ofForest f)) =
      hypersequentTensorAlgToTensorProductLinearMap R
        (coalgebraForestSplittingTensorElement R f) := by
  rw [hypersequentCoalgebraComulTensorLinearMap_monomial]
  simpa [coalgebraComulHypersequent_ofForest]

@[simp]
theorem hypersequentTensorAlgToTensorProductLinearMap_one :
    hypersequentTensorAlgToTensorProductLinearMap R
        (1 : HypersequentTensorAlgebra R) =
      (1 : TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R)) := by
  change
    hypersequentTensorAlgToTensorProductLinearMap R
      (AddMonoidAlgebra.single (0 : HypersequentTensorBasis) 1) =
    (1 : TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))
  rw [hypersequentTensorAlgToTensorProductLinearMap_single]
  exact tensorBasisTmul_zero R

/--
The tensor bridge sends the normalized forest support element of a cons forest
to the product of the bridged tree factor and the bridged tail factor.
-/
theorem hypersequentTensorAlgToTensorProductLinearMap_coalgebraForest_cons_mul
    [LeftDistribClass
      (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))]
    [RightDistribClass
      (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))]
    (t : PTree) (ts : Forest) :
    hypersequentTensorAlgToTensorProductLinearMap R
        (coalgebraForestSplittingTensorElement R (t :: ts)) =
      hypersequentTensorAlgToTensorProductLinearMap R
          (coalgebraTreeSplittingTensorElement R t) *
        hypersequentTensorAlgToTensorProductLinearMap R
          (coalgebraForestSplittingTensorElement R ts) := by
  simpa [coalgebraForestSplittingTensorElement,
    coalgebraForestSplittingTensorSupport, coalgebraTreeSplittingTensorElement]
    using
      hypersequentTensorAlgToTensorProductLinearMap_tensorSupportMul R
        (coalgebraTreeSplittingTensorSupport t)
        (coalgebraForestSplittingTensorSupport ts)

/-- The tensor bridge sends the empty normalized forest support to the tensor unit. -/
theorem hypersequentTensorAlgToTensorProductLinearMap_coalgebraForest_nil :
    hypersequentTensorAlgToTensorProductLinearMap R
        (coalgebraForestSplittingTensorElement R []) =
      (1 : TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R)) := by
  simpa [coalgebraForestSplittingTensorElement, coalgebraForestSplittingTensorSupport,
    tensorSupportElement] using
    (hypersequentTensorAlgToTensorProductLinearMap_single (R := R)
      (p := (0 : HypersequentTensorBasis)))

/--
The normalized tensor coproduct respects forest concatenation.

This is not yet the full `HypersequentNormalizedComulMul`, but it isolates the
external-composition part of the theorem: ordered forests compose by the same
tensor multiplication that later underlies the bialgebra structure.
-/
theorem hypersequentCoalgebraComulTensorLinearMap_ofForest_append_mul
    [LeftDistribClass
      (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))]
    [RightDistribClass
      (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))]
    (f g : Forest) :
    hypersequentCoalgebraComulTensorLinearMap R
        (hseqMonomial R (HQ.ofForest (f ++ g))) =
      hypersequentCoalgebraComulTensorLinearMap R
          (hseqMonomial R (HQ.ofForest f)) *
        hypersequentCoalgebraComulTensorLinearMap R
          (hseqMonomial R (HQ.ofForest g)) := by
  calc
    hypersequentCoalgebraComulTensorLinearMap R
        (hseqMonomial R (HQ.ofForest (f ++ g))) =
      hypersequentTensorAlgToTensorProductLinearMap R
        (coalgebraForestSplittingTensorElement R (f ++ g)) := by
          simpa using hypersequentCoalgebraComulTensorLinearMap_ofForest (R := R) (f ++ g)
    _ =
      hypersequentTensorAlgToTensorProductLinearMap R
          (coalgebraForestSplittingTensorElement R f) *
        hypersequentTensorAlgToTensorProductLinearMap R
          (coalgebraForestSplittingTensorElement R g) := by
          induction f with
          | nil =>
              calc
                hypersequentTensorAlgToTensorProductLinearMap R
                    (coalgebraForestSplittingTensorElement R ([] ++ g)) =
                  hypersequentTensorAlgToTensorProductLinearMap R
                    (coalgebraForestSplittingTensorElement R g) := by
                      rfl
                _ =
                  (1 : TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R)) *
                    hypersequentTensorAlgToTensorProductLinearMap R
                      (coalgebraForestSplittingTensorElement R g) := by
                        exact (one_mul
                          (hypersequentTensorAlgToTensorProductLinearMap R
                            (coalgebraForestSplittingTensorElement R g))).symm
                _ =
                  hypersequentTensorAlgToTensorProductLinearMap R
                      (coalgebraForestSplittingTensorElement R []) *
                    hypersequentTensorAlgToTensorProductLinearMap R
                      (coalgebraForestSplittingTensorElement R g) := by
                        simp [hypersequentTensorAlgToTensorProductLinearMap_coalgebraForest_nil,
                          hypersequentTensorAlgToTensorProductLinearMap_one]
          | cons t ts ih =>
              calc
                hypersequentTensorAlgToTensorProductLinearMap R
                    (coalgebraForestSplittingTensorElement R ((t :: ts) ++ g)) =
                  hypersequentTensorAlgToTensorProductLinearMap R
                    (coalgebraForestSplittingTensorElement R (t :: (ts ++ g))) := by
                      rfl
                _ =
                  hypersequentTensorAlgToTensorProductLinearMap R
                      (coalgebraTreeSplittingTensorElement R t) *
                    hypersequentTensorAlgToTensorProductLinearMap R
                      (coalgebraForestSplittingTensorElement R (ts ++ g)) := by
                        simpa using
                          hypersequentTensorAlgToTensorProductLinearMap_coalgebraForest_cons_mul
                            (R := R) t (ts ++ g)
                _ =
                  hypersequentTensorAlgToTensorProductLinearMap R
                      (coalgebraTreeSplittingTensorElement R t) *
                    (hypersequentTensorAlgToTensorProductLinearMap R
                        (coalgebraForestSplittingTensorElement R ts) *
                      hypersequentTensorAlgToTensorProductLinearMap R
                        (coalgebraForestSplittingTensorElement R g)) := by
                        rw [ih]
                _ =
                  (hypersequentTensorAlgToTensorProductLinearMap R
                      (coalgebraTreeSplittingTensorElement R t) *
                    hypersequentTensorAlgToTensorProductLinearMap R
                      (coalgebraForestSplittingTensorElement R ts)) *
                  hypersequentTensorAlgToTensorProductLinearMap R
                    (coalgebraForestSplittingTensorElement R g) := by
                      exact (mul_assoc
                        (hypersequentTensorAlgToTensorProductLinearMap R
                          (coalgebraTreeSplittingTensorElement R t))
                        (hypersequentTensorAlgToTensorProductLinearMap R
                          (coalgebraForestSplittingTensorElement R ts))
                        (hypersequentTensorAlgToTensorProductLinearMap R
                          (coalgebraForestSplittingTensorElement R g))).symm
                _ =
                  hypersequentTensorAlgToTensorProductLinearMap R
                      (coalgebraForestSplittingTensorElement R (t :: ts)) *
                    hypersequentTensorAlgToTensorProductLinearMap R
                      (coalgebraForestSplittingTensorElement R g) := by
                        rw [hypersequentTensorAlgToTensorProductLinearMap_coalgebraForest_cons_mul]
    _ =
      hypersequentCoalgebraComulTensorLinearMap R
          (hseqMonomial R (HQ.ofForest f)) *
        hypersequentCoalgebraComulTensorLinearMap R
          (hseqMonomial R (HQ.ofForest g)) := by
          rw [hypersequentCoalgebraComulTensorLinearMap_ofForest,
            hypersequentCoalgebraComulTensorLinearMap_ofForest]

/--
Normalized comultiplicativity on hypersequent monomials.

This is the quotient-invariant form of the forest concatenation theorem above:
external composition of hypersequents is already respected by the normalized
tensor coproduct on the algebra generators.
-/
theorem hypersequentCoalgebraComulTensorLinearMap_monomial_mul
    [LeftDistribClass
      (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))]
    [RightDistribClass
      (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))]
    (G H : Hypersequent) :
    hypersequentCoalgebraComulTensorLinearMap R
        (hseqMonomial R (G + H)) =
      hypersequentCoalgebraComulTensorLinearMap R
          (hseqMonomial R G) *
        hypersequentCoalgebraComulTensorLinearMap R
          (hseqMonomial R H) := by
  refine Quotient.inductionOn₂ G H ?_
  intro f g
  simpa [HQ.ofForest_append] using
    hypersequentCoalgebraComulTensorLinearMap_ofForest_append_mul
      (R := R) f g

/-!
## Tree-level normalized coassociativity scaffolding

The full normalized coassociativity theorem compares two-stage splitting in two
orders.  The right-associated stage is the cleaner side combinatorially: one
first chooses an admissible cut of `t`, then a second admissible cut of the
remainder tree produced by the first cut.  The definitions below package that
data explicitly so the final theorem can be stated in terms of named nested-cut
objects rather than only in terms of composed linear maps.
-/

/-- Basis index for a triple tensor factor in tree-level coassociativity. -/
abbrev HypersequentTripleBasis := Hypersequent × Hypersequent × Hypersequent

namespace HypersequentTripleBasis

/-- Componentwise multiplication of triple tensor-basis indices. -/
def mul (p q : HypersequentTripleBasis) : HypersequentTripleBasis :=
  (p.1 + q.1, p.2.1 + q.2.1, p.2.2 + q.2.2)

@[simp]
theorem mul_fst (p q : HypersequentTripleBasis) :
    (mul p q).1 = p.1 + q.1 := rfl

@[simp]
theorem mul_snd_fst (p q : HypersequentTripleBasis) :
    (mul p q).2.1 = p.2.1 + q.2.1 := rfl

@[simp]
theorem mul_snd_snd (p q : HypersequentTripleBasis) :
    (mul p q).2.2 = p.2.2 + q.2.2 := rfl

end HypersequentTripleBasis

/--
The right-associated triple support term contributed by a first cut and a
second cut of its remainder.

Intuitively:
- the first component is the detached hypersequent from the first cut;
- the second and third components come from the normalized coproduct of the
  remainder produced by that first cut.

For the boundary cuts, this specializes to the expected unit behavior.
-/
noncomputable def coalgebraRightStageTripleOfCuts
    (t : PTree) (cut₁ cut₂ : List Address) : HypersequentTripleBasis := by
  classical
  if h₁ : cut₁ = [] then
    let p := coalgebraTensorTermOfCutList t cut₂
    exact (0, p.1, p.2)
  else if hroot : ([] : Address) ∈ cut₁ then
    exact (HQ.singleton t, 0, 0)
  else
    let r := PTree.remainderGo cut₁ [] t
    let p := coalgebraTensorTermOfCutList r cut₂
    exact (HQ.ofForest (cut₁.filterMap (PTree.subtreeAt t)), p.1, p.2)

@[simp]
theorem coalgebraRightStageTripleOfCuts_empty_first
    (t : PTree) (cut₂ : List Address) :
    coalgebraRightStageTripleOfCuts t [] cut₂ =
      let p := coalgebraTensorTermOfCutList t cut₂
      (0, p.1, p.2) := by
  simp [coalgebraRightStageTripleOfCuts]

@[simp]
theorem coalgebraRightStageTripleOfCuts_root_first
    (t : PTree) (cut₂ : List Address) :
    coalgebraRightStageTripleOfCuts t [([] : Address)] cut₂ =
      (HQ.singleton t, 0, 0) := by
  simp [coalgebraRightStageTripleOfCuts]

theorem coalgebraRightStageTripleOfCuts_of_ne_nil_of_root_not_mem
    {t : PTree} {cut₁ cut₂ : List Address}
    (h₁ : cut₁ ≠ [])
    (hroot : ([] : Address) ∉ cut₁) :
    coalgebraRightStageTripleOfCuts t cut₁ cut₂ =
      let r := PTree.remainderGo cut₁ [] t
      let p := coalgebraTensorTermOfCutList r cut₂
      (HQ.ofForest (cut₁.filterMap (PTree.subtreeAt t)), p.1, p.2) := by
  simp [coalgebraRightStageTripleOfCuts, h₁, hroot]

/--
The nested-cut branch contributed by one fixed first cut.

This separates the outer admissible-cut summation from the inner normalized
coproduct of the remainder.
-/
noncomputable def coalgebraRightStageTripleBranch
    (t : PTree) (cut₁ : List Address) :
    List HypersequentTripleBasis :=
  if h₁ : cut₁ = [] then
    (coalgebraAdmissibleCuts t).map
      (fun cut₂ => coalgebraRightStageTripleOfCuts t cut₁ cut₂)
  else if hroot : ([] : Address) ∈ cut₁ then
    [coalgebraRightStageTripleOfCuts t cut₁ []]
  else
    (coalgebraAdmissibleCuts (PTree.remainderGo cut₁ [] t)).map
      (fun cut₂ => coalgebraRightStageTripleOfCuts t cut₁ cut₂)

@[simp]
theorem coalgebraRightStageTripleBranch_empty
    (t : PTree) :
    coalgebraRightStageTripleBranch t [] =
      (coalgebraAdmissibleCuts t).map
        (fun cut₂ => coalgebraRightStageTripleOfCuts t [] cut₂) := by
  simp [coalgebraRightStageTripleBranch]

@[simp]
theorem coalgebraRightStageTripleBranch_root
    (t : PTree) :
    coalgebraRightStageTripleBranch t [([] : Address)] =
      [(HQ.singleton t, 0, 0)] := by
  have hne : ([([] : Address)] : List Address) ≠ [] := List.cons_ne_nil [] []
  have hroot : ([] : Address) ∈ ([([] : Address)] : List Address) := by simp
  simp [coalgebraRightStageTripleBranch, hne, hroot,
    coalgebraRightStageTripleOfCuts]

theorem coalgebraRightStageTripleBranch_of_ne_nil_of_root_not_mem
    {t : PTree} {cut₁ : List Address}
    (h₁ : cut₁ ≠ [])
    (hroot : ([] : Address) ∉ cut₁) :
    coalgebraRightStageTripleBranch t cut₁ =
      (coalgebraAdmissibleCuts (PTree.remainderGo cut₁ [] t)).map
        (fun cut₂ => coalgebraRightStageTripleOfCuts t cut₁ cut₂) := by
  simp [coalgebraRightStageTripleBranch, h₁, hroot]

/--
The full right-associated nested-cut support of a tree.

Each first cut contributes:
- all second cuts of `t` itself, if the first cut is empty;
- the unique tensor-unit triple, if the first cut is the root cut;
- all second cuts of the remainder tree otherwise.
-/
noncomputable def coalgebraRightStageTripleSupport (t : PTree) :
    List HypersequentTripleBasis :=
  (coalgebraAdmissibleCuts t).flatMap (coalgebraRightStageTripleBranch t)

@[simp]
theorem coalgebraRightStageTripleSupport_contains_empty_empty
    (t : PTree) :
    List.Mem (0, 0, HQ.singleton t) (coalgebraRightStageTripleSupport t) := by
  unfold coalgebraRightStageTripleSupport coalgebraRightStageTripleBranch
  refine List.mem_flatMap.2 ?_
  refine ⟨[], empty_mem_coalgebraAdmissibleCuts t, ?_⟩
  simp only [dif_pos rfl]
  refine List.mem_map.2 ?_
  refine ⟨[], empty_mem_coalgebraAdmissibleCuts t, ?_⟩
  simp [coalgebraRightStageTripleOfCuts, coalgebraTensorTermOfCutList_nil]

@[simp]
theorem coalgebraRightStageTripleSupport_contains_root_unit
    (t : PTree) :
    List.Mem (HQ.singleton t, 0, 0) (coalgebraRightStageTripleSupport t) := by
  unfold coalgebraRightStageTripleSupport coalgebraRightStageTripleBranch
  refine List.mem_flatMap.2 ?_
  refine ⟨[([] : Address)], root_mem_coalgebraAdmissibleCuts t, ?_⟩
  have hne : ([([] : Address)] : List Address) ≠ [] := List.cons_ne_nil [] []
  have hroot : ([] : Address) ∈ ([([] : Address)] : List Address) := by simp
  simp [hne, hroot, coalgebraRightStageTripleOfCuts, coalgebraTensorTermOfCutList_root]

/-- The common triple tensor target used by staged normalized coproducts. -/
abbrev HypersequentTripleTensor :=
  TensorProduct R (HypersequentAlgebra R)
    (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))

/--
The tensor monomial associated to one triple support atom.

This is the concrete basis tensor against which tree-level coassociativity is
most naturally compared.
-/
def hypersequentTripleBasisTmul
    (p : HypersequentTripleBasis) :
    HypersequentTripleTensor R :=
  hseqMonomial R p.1 ⊗ₜ[R]
    (hseqMonomial R p.2.1 ⊗ₜ[R] hseqMonomial R p.2.2)

@[simp]
theorem hypersequentTripleBasisTmul_empty_empty_tree
    (t : PTree) :
    hypersequentTripleBasisTmul R (0, 0, HQ.singleton t) =
      1 ⊗ₜ[R] (1 ⊗ₜ[R] treeMonomial R t) := by
  simp [hypersequentTripleBasisTmul, hseqMonomial_singleton_eq_treeMonomial]

@[simp]
theorem hypersequentTripleBasisTmul_root_unit
    (t : PTree) :
    hypersequentTripleBasisTmul R (HQ.singleton t, 0, 0) =
      treeMonomial R t ⊗ₜ[R] (1 ⊗ₜ[R] (1 : HypersequentAlgebra R)) := by
  simp [hypersequentTripleBasisTmul, hseqMonomial_singleton_eq_treeMonomial]

/--
The explicit right-associated triple tensor sum of all nested admissible cuts
of a tree.

This is the concrete support-level expansion expected from the staged map
`(assoc ∘ rTensor Δ ∘ Δ)` on tree generators.
-/
noncomputable def coalgebraRightStageTripleElement (t : PTree) :
    HypersequentTripleTensor R :=
  ((coalgebraRightStageTripleSupport t).map
      (hypersequentTripleBasisTmul (R := R))).sum

/--
The right-associated staged normalized coproduct, landing in the common triple
tensor target used for coassociativity.
-/
def hypersequentCoalgebraRightStageTensorLinearMap :
    HypersequentAlgebra R →ₗ[R] HypersequentTripleTensor R :=
  (TensorProduct.assoc R
      (HypersequentAlgebra R)
      (HypersequentAlgebra R)
      (HypersequentAlgebra R)).toLinearMap ∘ₗ
      LinearMap.rTensor (HypersequentAlgebra R)
        (hypersequentCoalgebraComulTensorLinearMap R) ∘ₗ
      hypersequentCoalgebraComulTensorLinearMap R

/--
The left-associated staged normalized coproduct, already landing in the common
triple tensor target.
-/
def hypersequentCoalgebraLeftStageTensorLinearMap :
    HypersequentAlgebra R →ₗ[R] HypersequentTripleTensor R :=
  LinearMap.lTensor (HypersequentAlgebra R)
      (hypersequentCoalgebraComulTensorLinearMap R) ∘ₗ
    hypersequentCoalgebraComulTensorLinearMap R

/--
Support-to-triple comparison map for the right-associated staged normalized
coproduct.

This is the threefold analogue of the earlier support-to-tensor bridge maps:
it applies the normalized coproduct to the second component of one support
atom and reassociates into the common triple tensor target.
-/
def hypersequentTensorAlgToRightStageTripleLinearMap :
    HypersequentTensorAlgebra R →ₗ[R] HypersequentTripleTensor R :=
  LinearMap.lTensor (HypersequentAlgebra R)
      (hypersequentCoalgebraComulTensorLinearMap R) ∘ₗ
    hypersequentTensorAlgToTensorProductLinearMap R

@[simp]
theorem hypersequentTensorAlgToRightStageTripleLinearMap_monomial
    (p : HypersequentTensorBasis) :
    hypersequentTensorAlgToRightStageTripleLinearMap R
        (tensorBasisMonomial R p) =
      hseqMonomial R p.1 ⊗ₜ[R]
        (hypersequentCoalgebraComulTensorLinearMap R
          (hseqMonomial R p.2)) := by
  unfold hypersequentTensorAlgToRightStageTripleLinearMap
  simp only [LinearMap.comp_apply]
  rw [hypersequentTensorAlgToTensorProductLinearMap_monomial]
  rw [tensorBasisTmul]
  simp [LinearMap.lTensor_tmul]

theorem hypersequentCoalgebraLeftStageTensorLinearMap_eq_comp
    (x : HypersequentAlgebra R) :
    hypersequentCoalgebraLeftStageTensorLinearMap R x =
      hypersequentTensorAlgToRightStageTripleLinearMap R
        (hypersequentCoalgebraComulAlgHom R x) := by
  rfl

@[simp]
theorem hypersequentTripleBasisTmul_of_tensorBasis
    (G : Hypersequent) (p : HypersequentTensorBasis) :
    hypersequentTripleBasisTmul R (G, p.1, p.2) =
      (LinearMap.lTensor (HypersequentAlgebra R)
          (hypersequentTensorAlgToTensorProductLinearMap R))
        ((((TensorProduct.mk R
            (HypersequentAlgebra R)
            (HypersequentTensorAlgebra R))
          (hseqMonomial R G)) (tensorBasisMonomial R p))) := by
  simp [hypersequentTripleBasisTmul, tensorBasisTmul, LinearMap.lTensor_tmul,
    hypersequentTensorAlgToTensorProductLinearMap_monomial]

theorem hypersequentTripleTensor_ofFirst_tensorSupportElement
    (G : Hypersequent) (xs : List HypersequentTensorBasis) :
    (LinearMap.lTensor (HypersequentAlgebra R)
        (hypersequentTensorAlgToTensorProductLinearMap R))
      ((((TensorProduct.mk R
          (HypersequentAlgebra R)
          (HypersequentTensorAlgebra R))
        (hseqMonomial R G)) (tensorSupportElement R xs))) =
    (xs.map (fun p => hypersequentTripleBasisTmul R (G, p.1, p.2))).sum := by
  let L : HypersequentTensorAlgebra R →ₗ[R] HypersequentTripleTensor R :=
    (LinearMap.lTensor (HypersequentAlgebra R)
        (hypersequentTensorAlgToTensorProductLinearMap R)).comp
      (((TensorProduct.mk R
          (HypersequentAlgebra R)
          (HypersequentTensorAlgebra R))
        (hseqMonomial R G)))
  simpa [L, hypersequentTripleBasisTmul_of_tensorBasis] using
    (linearMap_apply_tensorSupportElement R L xs)

theorem hypersequentTensorAlgToRightStageTripleLinearMap_coalgebraCut
    (t : PTree) (cut₁ : List Address) :
    hypersequentTensorAlgToRightStageTripleLinearMap R
        (tensorBasisMonomial R (coalgebraTensorTermOfCutList t cut₁)) =
      ((coalgebraRightStageTripleBranch t cut₁).map
        (hypersequentTripleBasisTmul (R := R))).sum := by
  classical
  by_cases h₁ : cut₁ = []
  · subst cut₁
    rw [hypersequentTensorAlgToRightStageTripleLinearMap_monomial,
      coalgebraTensorTermOfCutList_nil, hseqMonomial_zero,
      hseqMonomial_singleton_eq_treeMonomial,
      hypersequentCoalgebraComulTensorLinearMap_tree]
    unfold coalgebraTreeSplittingTensorElement coalgebraTreeSplittingTensorSupport
    unfold coalgebraRightStageTripleBranch
    simpa [hypersequentTripleBasisTmul] using
      (hypersequentTripleTensor_ofFirst_tensorSupportElement
        (R := R) (G := 0)
        ((coalgebraAdmissibleCuts t).map (coalgebraTensorTermOfCutList t)))
  · by_cases hroot : ([] : Address) ∈ cut₁
    · have hcut : coalgebraTensorTermOfCutList t cut₁ = (HQ.singleton t, 0) := by
        simp [coalgebraTensorTermOfCutList, h₁, hroot]
      rw [hypersequentTensorAlgToRightStageTripleLinearMap_monomial, hcut]
      simp [hseqMonomial_zero, hseqMonomial_singleton_eq_treeMonomial]
      rw [show hypersequentCoalgebraComulTensorLinearMap R (1 : HypersequentAlgebra R) =
          hypersequentCoalgebraComulTensorLinearMap R (hseqMonomial R (0 : Hypersequent)) by
            simp [hseqMonomial_zero]]
      rw [hypersequentCoalgebraComulTensorLinearMap_monomial (R := R) (G := 0)]
      unfold coalgebraRightStageTripleBranch
      have htriple : coalgebraRightStageTripleOfCuts t cut₁ [] = (HQ.singleton t, 0, 0) := by
        simp [coalgebraRightStageTripleOfCuts, h₁, hroot]
      simp [h₁, hroot, htriple, hypersequentTripleBasisTmul,
        hseqMonomial_zero, coalgebraComulHypersequent_zero,
        hypersequentTensorAlgToTensorProductLinearMap_one]
      have hone :
          (1 : TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R)) =
            (1 : HypersequentAlgebra R) ⊗ₜ[R] (1 : HypersequentAlgebra R) := by
        exact Algebra.TensorProduct.one_def (R := R)
          (A := HypersequentAlgebra R) (B := HypersequentAlgebra R)
      simpa using
        congrArg
          (((TensorProduct.mk R
              (HypersequentAlgebra R)
              (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R)))
            (treeMonomial R t)))
          hone
    · rw [hypersequentTensorAlgToRightStageTripleLinearMap_monomial]
      have hcut :
          coalgebraTensorTermOfCutList t cut₁ =
            (HQ.ofForest (cut₁.filterMap (PTree.subtreeAt t)),
              HQ.singleton (PTree.remainderGo cut₁ [] t)) := by
        exact coalgebraTensorTermOfCutList_of_ne_nil_of_root_not_mem h₁ hroot
      rw [hcut]
      rw [hseqMonomial_singleton_eq_treeMonomial,
        hypersequentCoalgebraComulTensorLinearMap_tree]
      unfold coalgebraTreeSplittingTensorElement coalgebraTreeSplittingTensorSupport
      unfold coalgebraRightStageTripleBranch
      simpa [h₁, hroot, hypersequentTripleBasisTmul,
        coalgebraRightStageTripleOfCuts, Function.comp_def] using
        (hypersequentTripleTensor_ofFirst_tensorSupportElement
          (R := R)
          (G := HQ.ofForest (cut₁.filterMap (PTree.subtreeAt t)))
          ((coalgebraAdmissibleCuts (PTree.remainderGo cut₁ [] t)).map
            (coalgebraTensorTermOfCutList (PTree.remainderGo cut₁ [] t))))

theorem List.sum_map_sum_eq_sum_flatMap
    {α β M : Type} [AddCommMonoid M]
    (xs : List α) (f : α → List β) (g : β → M) :
    (xs.map (fun x => ((f x).map g).sum)).sum =
      ((xs.flatMap f).map g).sum := by
  induction xs with
  | nil =>
      simp
  | cons x xs ih =>
      simp [List.flatMap_cons, ih, List.sum_append, add_assoc]

theorem List.sum_eq_of_perm
    {M : Type} [AddCommMonoid M] {xs ys : List M}
    (h : List.Perm xs ys) :
    xs.sum = ys.sum := by
  induction h with
  | nil =>
      simp
  | cons _ h ih =>
      simp [ih]
  | swap a b xs =>
      simp [add_assoc, add_comm, add_left_comm]
  | trans _ _ ih₁ ih₂ =>
      exact ih₁.trans ih₂

theorem List.sum_map_eq_of_perm
    {α M : Type} [AddCommMonoid M] {xs ys : List α}
    (h : List.Perm xs ys) (f : α → M) :
    (xs.map f).sum = (ys.map f).sum := by
  exact List.sum_eq_of_perm (h.map f)

/--
Pointwise equality of finite-list multiplicities gives a permutation.

This is the same count-balance adapter used on the grafting/pre-Lie side.  It
is repeated locally here so the hypersequent coassociativity proof can reduce
the final staged-cut comparison to a pure `Nat` count balance over triple
basis atoms.
-/
theorem list_perm_of_natCount_balance
    {α : Type*} [DecidableEq α]
    (l₁ l₂ : List α)
    (hcount : ∀ a : α, l₁.count a = l₂.count a) :
    l₁.Perm l₂ := by
  have hsub : List.Subperm l₁ l₂ := by
    rw [List.subperm_iff_count]
    intro a
    exact Nat.le_of_eq (hcount a)
  have hsub' : List.Subperm l₂ l₁ := by
    rw [List.subperm_iff_count]
    intro a
    exact Nat.le_of_eq (hcount a).symm
  exact hsub.antisymm hsub'

/--
Concrete right-stage expansion target for tree-level normalized
coassociativity.

Proving this identifies the nested-cut combinatorics on the right-associated
side with an explicit support sum.  The eventual coassociativity theorem can
then be obtained by showing the left-associated side yields the same sum.
-/
def HypersequentNormalizedCoalgebraRightTreeExpansion : Prop :=
  ∀ t : PTree,
    hypersequentCoalgebraLeftStageTensorLinearMap R
      (treeMonomial R t) =
    coalgebraRightStageTripleElement R t

theorem hypersequentNormalizedCoalgebraRightTreeExpansion :
    HypersequentNormalizedCoalgebraRightTreeExpansion R := by
  intro t
  rw [hypersequentCoalgebraLeftStageTensorLinearMap_eq_comp,
    hypersequentCoalgebraComulAlgHom_tree]
  unfold coalgebraTreeSplittingTensorElement coalgebraTreeSplittingTensorSupport
  rw [linearMap_apply_tensorSupportElement R
      (hypersequentTensorAlgToRightStageTripleLinearMap R)
      ((coalgebraAdmissibleCuts t).map (coalgebraTensorTermOfCutList t))]
  rw [List.map_map]
  change (List.map
      (fun cut =>
        hypersequentTensorAlgToRightStageTripleLinearMap R
          (tensorBasisMonomial R (coalgebraTensorTermOfCutList t cut)))
      (coalgebraAdmissibleCuts t)).sum =
    coalgebraRightStageTripleElement R t
  simp_rw [hypersequentTensorAlgToRightStageTripleLinearMap_coalgebraCut]
  unfold coalgebraRightStageTripleElement coalgebraRightStageTripleSupport
  simpa [Function.comp_def] using
    (List.sum_map_sum_eq_sum_flatMap
      (xs := coalgebraAdmissibleCuts t)
      (f := coalgebraRightStageTripleBranch t)
      (g := hypersequentTripleBasisTmul (R := R)))

/--
The detached ordered forest associated to one first-stage coalgebra cut.

This is the forest whose normalized coproduct governs the companion staged
expansion on the side that first splits off subtrees and then further splits
that detached forest.
-/
def coalgebraDetachedForestOfCut
    (t : PTree) (cut : List Address) : Forest :=
  if hcut : cut = [] then
    []
  else if hroot : ([] : Address) ∈ cut then
    [t]
  else
    cut.filterMap (PTree.subtreeAt t)

/-- The remainder hypersequent attached to one first-stage coalgebra cut. -/
def coalgebraRemainderOfCut
    (t : PTree) (cut : List Address) : Hypersequent :=
  (coalgebraTensorTermOfCutList t cut).2

/--
The companion triple-support branch for staged splitting of the detached forest.

For a fixed first cut of `t`, this records all normalized cuts of the detached
forest while keeping the original remainder in the third factor.
-/
noncomputable def coalgebraLeftStageTripleBranch
    (t : PTree) (cut : List Address) :
    List HypersequentTripleBasis :=
  (coalgebraForestSplittingTensorSupport (coalgebraDetachedForestOfCut t cut)).map
    (fun p => (p.1, p.2, coalgebraRemainderOfCut t cut))

/--
The explicit detached-forest-first staged expansion support of a tree.

This is the concrete list-level target for the side of coassociativity that
first splits the detached forest and only afterwards remembers the remainder.
-/
noncomputable def coalgebraLeftStageTripleSupport (t : PTree) :
    List HypersequentTripleBasis :=
  (coalgebraAdmissibleCuts t).flatMap (coalgebraLeftStageTripleBranch t)

/-- The corresponding explicit triple tensor sum. -/
noncomputable def coalgebraLeftStageTripleElement (t : PTree) :
    HypersequentTripleTensor R :=
  ((coalgebraLeftStageTripleSupport t).map
      (hypersequentTripleBasisTmul (R := R))).sum

@[simp]
theorem coalgebraDetachedForestOfCut_nil
    (t : PTree) :
    coalgebraDetachedForestOfCut t [] = [] := by
  simp [coalgebraDetachedForestOfCut]

@[simp]
theorem coalgebraDetachedForestOfCut_root
    (t : PTree) :
    coalgebraDetachedForestOfCut t [([] : Address)] = [t] := by
  simp [coalgebraDetachedForestOfCut]

@[simp]
theorem coalgebraRemainderOfCut_nil
    (t : PTree) :
    coalgebraRemainderOfCut t [] = HQ.singleton t := by
  simp [coalgebraRemainderOfCut, coalgebraTensorTermOfCutList_nil]

@[simp]
theorem coalgebraRemainderOfCut_root
    (t : PTree) :
    coalgebraRemainderOfCut t [([] : Address)] = 0 := by
  simp [coalgebraRemainderOfCut, coalgebraTensorTermOfCutList_root]

/-!
### Quotient-side shadows of normalized cuts

The normalized coproduct lives on proof-labelled hypersequents, while the
Oudom-Guin side lives on the linear proof-tree carrier and its stable pre-Lie
quotient.  The following maps interpret each detached/remainder term of a
normalized cut in that quotient.  This makes the coalgebra side visible in the
same algebraic world where the grafting pre-Lie identity has already been
proved.
-/

/-- Stable quotient profile of an ordered detached forest. -/
noncomputable def forestStableQuotientProfile
    (f : Forest) : PreLieDifferenceStableQuotient :=
  mkPreLieDifferenceStableQuotient (forestGLProfile f)

@[simp]
theorem forestStableQuotientProfile_nil :
    forestStableQuotientProfile ([] : Forest) = 0 := by
  simp [forestStableQuotientProfile]

@[simp]
theorem forestStableQuotientProfile_cons
    (t : PTree) (f : Forest) :
    forestStableQuotientProfile (t :: f) =
      mkPreLieDifferenceStableQuotient (treeGen t) +
        forestStableQuotientProfile f := by
  simp [forestStableQuotientProfile]

theorem forestStableQuotientProfile_append
    (f g : Forest) :
    forestStableQuotientProfile (f ++ g) =
      forestStableQuotientProfile f +
        forestStableQuotientProfile g := by
  simp [forestStableQuotientProfile, forestGLProfile_append]

theorem forestStableQuotientProfile_eq_of_perm
    {f g : Forest} (h : List.Perm f g) :
    forestStableQuotientProfile f =
      forestStableQuotientProfile g := by
  simp [forestStableQuotientProfile,
    forestGLProfile_eq_of_perm h]

/-- Stable quotient profile of the detached side of a cut. -/
noncomputable def coalgebraDetachedStableQuotientProfile
    (t : PTree) (cut : List Address) :
    PreLieDifferenceStableQuotient :=
  forestStableQuotientProfile (coalgebraDetachedForestOfCut t cut)

/-- Stable quotient profile of the remainder side of a cut. -/
noncomputable def coalgebraRemainderStableQuotientProfile
    (t : PTree) (cut : List Address) :
    PreLieDifferenceStableQuotient :=
  hypersequentStableQuotientProfile (coalgebraRemainderOfCut t cut)

@[simp]
theorem coalgebraDetachedStableQuotientProfile_nil
    (t : PTree) :
    coalgebraDetachedStableQuotientProfile t [] = 0 := by
  simp [coalgebraDetachedStableQuotientProfile]

@[simp]
theorem coalgebraDetachedStableQuotientProfile_root
    (t : PTree) :
    coalgebraDetachedStableQuotientProfile t [([] : Address)] =
      mkPreLieDifferenceStableQuotient (treeGen t) := by
  simp [coalgebraDetachedStableQuotientProfile,
    forestStableQuotientProfile]

@[simp]
theorem coalgebraRemainderStableQuotientProfile_nil
    (t : PTree) :
    coalgebraRemainderStableQuotientProfile t [] =
      mkPreLieDifferenceStableQuotient (treeGen t) := by
  simp [coalgebraRemainderStableQuotientProfile]

@[simp]
theorem coalgebraRemainderStableQuotientProfile_root
    (t : PTree) :
    coalgebraRemainderStableQuotientProfile t [([] : Address)] = 0 := by
  simp [coalgebraRemainderStableQuotientProfile]

/-- Tensor shadow of one normalized cut in the stable pre-Lie quotient. -/
noncomputable def coalgebraCutStableQuotientTensor
    (t : PTree) (cut : List Address) :
    TensorProduct ℤ
      PreLieDifferenceStableQuotient
      PreLieDifferenceStableQuotient :=
  coalgebraDetachedStableQuotientProfile t cut ⊗ₜ[ℤ]
    coalgebraRemainderStableQuotientProfile t cut

@[simp]
theorem coalgebraCutStableQuotientTensor_nil
    (t : PTree) :
    coalgebraCutStableQuotientTensor t [] =
      (0 : PreLieDifferenceStableQuotient) ⊗ₜ[ℤ]
        mkPreLieDifferenceStableQuotient (treeGen t) := by
  simp [coalgebraCutStableQuotientTensor]

@[simp]
theorem coalgebraCutStableQuotientTensor_root
    (t : PTree) :
    coalgebraCutStableQuotientTensor t [([] : Address)] =
      mkPreLieDifferenceStableQuotient (treeGen t) ⊗ₜ[ℤ]
        (0 : PreLieDifferenceStableQuotient) := by
  simp [coalgebraCutStableQuotientTensor]

/--
The stable-quotient shadow of the normalized tree coproduct, expressed as a
finite support sum over the same filtered admissible cuts.
-/
noncomputable def normalizedCoalgebraStableQuotientComulOnTree
    (t : PTree) :
    TensorProduct ℤ
      PreLieDifferenceStableQuotient
      PreLieDifferenceStableQuotient :=
  ((coalgebraAdmissibleCuts t).map
    (fun cut => coalgebraCutStableQuotientTensor t cut)).sum

/-- Internal-cut part of the stable-quotient coproduct shadow. -/
noncomputable def normalizedCoalgebraStableQuotientInternalComulOnTree
    (t : PTree) :
    TensorProduct ℤ
      PreLieDifferenceStableQuotient
      PreLieDifferenceStableQuotient :=
  ((internalCoalgebraAdmissibleCuts t).map
    (fun cut => coalgebraCutStableQuotientTensor t cut)).sum

theorem normalizedCoalgebraStableQuotientComulOnTree_eq_boundary_internal
    (t : PTree) :
    normalizedCoalgebraStableQuotientComulOnTree t =
      coalgebraCutStableQuotientTensor t [] +
        (coalgebraCutStableQuotientTensor t [([] : Address)] +
          normalizedCoalgebraStableQuotientInternalComulOnTree t) := by
  unfold normalizedCoalgebraStableQuotientComulOnTree
    normalizedCoalgebraStableQuotientInternalComulOnTree
  rw [List.sum_map_eq_filter_add_filter_not
      (xs := coalgebraAdmissibleCuts t)
      (p := fun cut => decide (cut = []))
      (f := fun cut => coalgebraCutStableQuotientTensor t cut)]
  rw [filter_eq_emptyCut_coalgebraAdmissibleCuts]
  simp only [List.map_singleton, List.sum_singleton]
  rw [List.sum_map_eq_filter_add_filter_not
      (xs := (coalgebraAdmissibleCuts t).filter (fun cut => !(decide (cut = []))))
      (p := fun cut => decide (([] : Address) ∈ cut))
      (f := fun cut => coalgebraCutStableQuotientTensor t cut)]
  have hrootFilter :
      ((coalgebraAdmissibleCuts t).filter (fun cut => !(decide (cut = [])))).filter
        (fun cut => decide (([] : Address) ∈ cut)) =
      [[([] : Address)]] := by
    calc
      ((coalgebraAdmissibleCuts t).filter (fun cut => !(decide (cut = [])))).filter
          (fun cut => decide (([] : Address) ∈ cut)) =
        (coalgebraAdmissibleCuts t).filter
          (fun cut => !(decide (cut = [])) && decide (([] : Address) ∈ cut)) := by
            rw [List.filter_filter]
            simp [Bool.and_comm]
      _ =
        (coalgebraAdmissibleCuts t).filter
          (fun cut => decide (([] : Address) ∈ cut)) := by
            apply List.filter_congr
            intro cut _hcut
            by_cases hroot : ([] : Address) ∈ cut
            · have hneq : cut ≠ [] := by
                intro hnil
                subst cut
                simpa using hroot
              simp [hroot, hneq]
            · simp [hroot]
      _ = [[([] : Address)]] := by
            rw [filter_eq_rootContainingCut_coalgebraAdmissibleCuts]
  rw [hrootFilter]
  simp only [List.map_singleton, List.sum_singleton]
  have hinternal :
      ((coalgebraAdmissibleCuts t).filter (fun cut => !(decide (cut = [])))).filter
        (fun cut => !decide (([] : Address) ∈ cut)) =
      internalCoalgebraAdmissibleCuts t := by
    rfl
  rw [hinternal]

theorem coalgebraDetachedStableQuotientProfile_eq_of_perm
    {t : PTree} {cut : List Address} {f : Forest}
    (h :
      List.Perm (coalgebraDetachedForestOfCut t cut) f) :
    coalgebraDetachedStableQuotientProfile t cut =
      forestStableQuotientProfile f := by
  simp [coalgebraDetachedStableQuotientProfile,
    forestStableQuotientProfile_eq_of_perm h]

theorem coalgebraRemainderStableQuotientProfile_of_hypersequent_eq
    {t : PTree} {cut : List Address} {G : Hypersequent}
    (h : coalgebraRemainderOfCut t cut = G) :
    coalgebraRemainderStableQuotientProfile t cut =
      hypersequentStableQuotientProfile G := by
  simp [coalgebraRemainderStableQuotientProfile, h]

@[simp]
theorem coalgebraLeftStageTripleBranch_empty
    (t : PTree) :
    coalgebraLeftStageTripleBranch t [] = [(0, 0, HQ.singleton t)] := by
  simp [coalgebraLeftStageTripleBranch, coalgebraDetachedForestOfCut_nil,
    coalgebraRemainderOfCut_nil, coalgebraForestSplittingTensorSupport_nil,
    HypersequentTensorBasis.one]

@[simp]
theorem coalgebraLeftStageTripleBranch_root
    (t : PTree) :
    coalgebraLeftStageTripleBranch t [([] : Address)] =
      (coalgebraTreeSplittingTensorSupport t).map
        (fun p => (p.1, p.2, (0 : Hypersequent))) := by
  simp [coalgebraLeftStageTripleBranch, coalgebraDetachedForestOfCut_root,
    coalgebraRemainderOfCut_root, coalgebraForestSplittingTensorSupport_cons,
    coalgebraForestSplittingTensorSupport_nil, tensorSupportMul]

theorem coalgebraLeftStageTripleBranch_of_ne_nil_of_root_not_mem
    {t : PTree} {cut : List Address}
    (hcut : cut ≠ [])
    (hroot : ([] : Address) ∉ cut) :
    coalgebraLeftStageTripleBranch t cut =
      (coalgebraForestSplittingTensorSupport (cut.filterMap (PTree.subtreeAt t))).map
        (fun p => (p.1, p.2, HQ.singleton (PTree.remainderGo cut [] t))) := by
  simp [coalgebraLeftStageTripleBranch, coalgebraDetachedForestOfCut, hcut, hroot,
    coalgebraRemainderOfCut, coalgebraTensorTermOfCutList_of_ne_nil_of_root_not_mem]

theorem coalgebraDetachedForestOfCut_mem_node_of_internal
    {t : PTree} {cut : List Address} {u : PTree}
    (hcut : cut ∈ coalgebraAdmissibleCuts t)
    (hinternal : InternalCut cut)
    (hu : u ∈ coalgebraDetachedForestOfCut t cut) :
    ∃ r : RuleTag, ∃ s : MultiSequent, ∃ cs : List PTree,
      u = PTree.node r s cs := by
  have hdetached :
      coalgebraDetachedForestOfCut t cut =
        cut.filterMap (PTree.subtreeAt t) := by
    simp [coalgebraDetachedForestOfCut, hinternal.1, hinternal.2]
  rw [hdetached] at hu
  rcases List.mem_filterMap.1 hu with ⟨addr, haddr, hsub⟩
  rcases node_addresses_of_mem_coalgebraAdmissibleCuts_of_internal
      hcut hinternal addr haddr with ⟨r, s, cs, hnode⟩
  rw [hsub] at hnode
  cases hnode
  exact ⟨r, s, cs, rfl⟩

theorem coalgebraDetachedForestOfCut_mem_node_of_mem_internal
    {t : PTree} {cut : List Address} {u : PTree}
    (hcut : cut ∈ internalCoalgebraAdmissibleCuts t)
    (hu : u ∈ coalgebraDetachedForestOfCut t cut) :
    ∃ r : RuleTag, ∃ s : MultiSequent, ∃ cs : List PTree,
      u = PTree.node r s cs := by
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut with
    ⟨hcoal, hinternal⟩
  exact coalgebraDetachedForestOfCut_mem_node_of_internal
    hcoal hinternal hu

theorem coalgebraDetachedForestOfCut_no_leaf_of_internal
    {t : PTree} {cut : List Address} {u : PTree}
    (hcut : cut ∈ coalgebraAdmissibleCuts t)
    (hinternal : InternalCut cut)
    (hu : u ∈ coalgebraDetachedForestOfCut t cut) :
    (∀ s : MultiSequent, u ≠ PTree.leaf s) := by
  intro s hleaf
  rcases coalgebraDetachedForestOfCut_mem_node_of_internal
      hcut hinternal hu with ⟨r, s', cs, hnode⟩
  rw [hleaf] at hnode
  cases hnode

/--
Any valid non-root address of a rule node begins with an in-bounds premise
index.  This is the basic rooted-tree descent fact behind the cut extension
proof.
-/
theorem validAddress_node_cons_index_lt
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {i : Nat} {addr : Address}
    (hvalid : PTree.ValidAddress (PTree.node r s cs) (i :: addr)) :
    i < cs.length := by
  rcases (PTree.valid_iff_exists_subtree
    (PTree.node r s cs) (i :: addr)).1 hvalid with
    ⟨u, hsub⟩
  by_contra hnot
  simp [PTree.subtreeAt, hnot] at hsub

theorem cons_mem_allAdmissibleCuts_node_index_lt
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut : List Address} {i : Nat} {addr : Address}
    (hcut : cut ∈ PTree.allAdmissibleCuts (PTree.node r s cs))
    (hmem : i :: addr ∈ cut) :
    i < cs.length := by
  let C : PTree.IsAdmissibleCut (PTree.node r s cs) :=
    PTree.isAdmissibleCut_of_mem_allAdmissibleCuts hcut
  exact validAddress_node_cons_index_lt
    (r := r) (s := s) (cs := cs) (i := i) (addr := addr)
    (C.valid (i :: addr) hmem)

theorem cons_mem_coalgebraAdmissibleCuts_node_index_lt
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut : List Address} {i : Nat} {addr : Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts (PTree.node r s cs))
    (hmem : i :: addr ∈ cut) :
    i < cs.length := by
  exact cons_mem_allAdmissibleCuts_node_index_lt
    (r := r) (s := s) (cs := cs) (cut := cut)
    ((mem_coalgebraAdmissibleCuts_iff).1 hcut).1 hmem

/--
Well-founded descent over rooted proof trees, using the explicit tree size.

This is the replacement for naive `induction t`, which Lean rejects because
`PTree` is nested through `List PTree`.  The step receives the theorem for all
strictly smaller proof trees, so node cases may descend into any premise
subtree or any smaller remainder subtree.
-/
theorem PTree_size_induction
    {motive : PTree → Prop}
    (hstep :
      ∀ t : PTree,
        (∀ u : PTree, u.size < t.size → motive u) →
          motive t) :
    ∀ t : PTree, motive t := by
  intro t
  let P : Nat → Prop := fun n => ∀ u : PTree, u.size = n → motive u
  have hP : ∀ n : Nat, P n := by
    intro n
    refine Nat.strong_induction_on n ?_
    intro n ih u hsize
    exact hstep u (fun v hv =>
      ih v.size (by simpa [hsize] using hv) v rfl)
  exact hP t.size t rfl

/--
Every immediate premise subtree is strictly smaller than its rule node.  This
is the concrete descent measure for logical-rule branches.
-/
theorem node_getElem_size_lt_parent
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {i : Nat} (hi : i < cs.length) :
    cs[i].size < (PTree.node r s cs).size := by
  exact child_size_lt_parent (PTree.node r s cs) cs[i] (by
    unfold IsImmediateSubtree PTree.children
    exact List.getElem_mem (l := cs) hi)

/--
Every proper subtree selected by a non-root address is strictly smaller than
the tree it sits inside.
-/
theorem PTree.subtreeAt_size_lt_of_ne_root
    {t u : PTree} {a : Address}
    (ha : a ≠ [])
    (hsub : PTree.subtreeAt t a = some u) :
    u.size < t.size := by
  induction a generalizing t u with
  | nil =>
      exact False.elim (ha rfl)
  | cons i rest ih =>
      cases t with
      | leaf s =>
          simp [PTree.subtreeAt] at hsub
      | node r s cs =>
          by_cases hi : i < cs.length
          · have hchild : PTree.subtreeAt cs[i] rest = some u := by
              simpa [PTree.subtreeAt, hi] using hsub
            by_cases hrest : rest = []
            · subst rest
              simp [PTree.subtreeAt] at hchild
              subst u
              exact node_getElem_size_lt_parent
                (r := r) (s := s) (cs := cs) hi
            · exact Nat.lt_trans (ih hrest hchild)
                (node_getElem_size_lt_parent
                  (r := r) (s := s) (cs := cs) hi)
          · simp [PTree.subtreeAt, hi] at hsub

/--
The childwise detached forests associated to a root-free cut of a rule node.

This is the normalized coalgebra version of the old GL node decomposition:
each child receives the restriction of the parent cut to that child, and the
detached forest is the concatenation of the child-detached forests.
-/
def nodeRootFreeCutChildForests
    (cs : List PTree) (cut : List Address) : List Forest :=
  cs.attach.mapIdx (fun i child =>
    (PTree.restrictCut cut i).filterMap (PTree.subtreeAt child.1))

@[simp]
theorem nodeRootFreeCutChildForests_length
    (cs : List PTree) (cut : List Address) :
    (nodeRootFreeCutChildForests cs cut).length = cs.length := by
  simp [nodeRootFreeCutChildForests]

/-- The flattened childwise detached forest of a root-free node cut. -/
def nodeRootFreeCutDetachedForest
    (cs : List PTree) (cut : List Address) : Forest :=
  (nodeRootFreeCutChildForests cs cut).flatten

/-- The childwise remainders associated to a root-free node cut. -/
def nodeRootFreeCutRemainderChildren
    (cs : List PTree) (cut : List Address) : List PTree :=
  cs.attach.mapIdx (fun i child =>
    PTree.remainderGo (PTree.restrictCut cut i) [] child.1)

@[simp]
theorem nodeRootFreeCutRemainderChildren_length
    (cs : List PTree) (cut : List Address) :
    (nodeRootFreeCutRemainderChildren cs cut).length = cs.length := by
  simp [nodeRootFreeCutRemainderChildren]

/--
Flatten a child-indexed family of cuts back into the address space of the
parent node.

This is the arity-sensitive normal form used by the GL permutation proof: the
`i`th child cut is reattached by prefixing every address with `i`.
-/
def prefixedChildCuts (cuts : List (List Address)) : List Address :=
  (cuts.mapIdx (fun i cut => cut.map (fun a => i :: a))).flatten

@[simp]
theorem prefixedChildCuts_nil :
    prefixedChildCuts [] = [] := by
  rfl

@[simp]
theorem prefixedChildCuts_cons
    (cut : List Address) (cuts : List (List Address)) :
    prefixedChildCuts (cut :: cuts) =
      cut.map (fun a => 0 :: a) ++
        (cuts.mapIdx (fun i childCut =>
          childCut.map (fun a => (i + 1) :: a))).flatten := by
  simp [prefixedChildCuts, List.mapIdx_cons]

/--
Selector theorem for child-indexed cuts: restricting the flattened parent cut
to an existing child index recovers exactly that child cut.
-/
theorem restrictCut_prefixedChildCuts
    (cuts : List (List Address)) (i : Nat) (hi : i < cuts.length) :
    PTree.restrictCut (prefixedChildCuts cuts) i = cuts[i] := by
  unfold prefixedChildCuts
  exact PTree.restrictCut_flatten_mapIdx_cons_lists cuts i hi

/--
Restricting a flattened child-indexed cut beyond the node arity gives the
empty cut.
-/
theorem restrictCut_prefixedChildCuts_ge
    (cuts : List (List Address)) (i : Nat) (hge : cuts.length ≤ i) :
    PTree.restrictCut (prefixedChildCuts cuts) i = [] := by
  unfold prefixedChildCuts
  exact PTree.restrictCut_flatten_mapIdx_cons_lists_ge cuts i hge

theorem root_not_mem_prefixedChildCuts
    (cuts : List (List Address)) :
    ([] : Address) ∉ prefixedChildCuts cuts := by
  unfold prefixedChildCuts
  intro hroot
  rcases List.mem_flatten.1 hroot with ⟨block, hblock, hrootBlock⟩
  rw [List.mem_mapIdx] at hblock
  rcases hblock with ⟨i, hi, hblockEq⟩
  subst block
  rcases List.mem_map.1 hrootBlock with ⟨a, _ha, hnil⟩
  cases hnil

theorem mem_prefixedChildCuts_iff
    {cuts : List (List Address)} {b : Address} :
    b ∈ prefixedChildCuts cuts ↔
      ∃ i : Nat, ∃ hi : i < cuts.length, ∃ a : Address,
        a ∈ cuts[i] ∧ b = i :: a := by
  constructor
  · intro hb
    unfold prefixedChildCuts at hb
    rcases List.mem_flatten.1 hb with ⟨block, hblock, hbBlock⟩
    rw [List.mem_mapIdx] at hblock
    rcases hblock with ⟨i, hi, hblockEq⟩
    subst block
    rcases List.mem_map.1 hbBlock with ⟨a, ha, rfl⟩
    exact ⟨i, hi, a, ha, rfl⟩
  · rintro ⟨i, hi, a, ha, rfl⟩
    unfold prefixedChildCuts
    apply List.mem_flatten.2
    refine ⟨cuts[i].map (fun a => i :: a), ?_, ?_⟩
    · rw [List.mem_mapIdx]
      exact ⟨i, hi, rfl⟩
    · exact List.mem_map.2 ⟨a, ha, rfl⟩

/--
The GL root-free address permutation, repackaged in the coalgebra node
language.  A root-free parent cut is permutation-equivalent to the flattened
list of its child restrictions, with each restriction reattached under its
child index.
-/
def nodeRootFreeCutPrefixedRestrictions
    (cs : List PTree) (cut : List Address) : List Address :=
  (cs.attach.mapIdx (fun i _child =>
    (PTree.restrictCut cut i).map (fun a => i :: a))).flatten

theorem nodeRootFreeCut_perm_prefixedRestrictions
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts (PTree.node r s cs))
    (hroot : ([] : Address) ∉ cut) :
    List.Perm cut (nodeRootFreeCutPrefixedRestrictions cs cut) := by
  rcases (mem_coalgebraAdmissibleCuts_iff).1 hcut with ⟨hraw, _hcoal⟩
  simpa [nodeRootFreeCutPrefixedRestrictions] using
    PTree.rootFree_sublist_node_cut_perm_flatten_restrictCut_map_cons
      (r := r) (s := s) (cs := cs) (cut := cut)
      (PTree.cut_sublist_allAddresses_of_mem_allAdmissibleCuts hraw)
      hroot

theorem nodeRootFreeCutPrefixedRestrictions_filterMap_subtreeAt
    (r : RuleTag) (s : MultiSequent) (cs : List PTree)
    (cut : List Address) :
    (nodeRootFreeCutPrefixedRestrictions cs cut).filterMap
        (PTree.subtreeAt (PTree.node r s cs)) =
      nodeRootFreeCutDetachedForest cs cut := by
  simpa [nodeRootFreeCutPrefixedRestrictions,
    nodeRootFreeCutDetachedForest, nodeRootFreeCutChildForests] using
    PTree.filterMap_subtreeAt_node_flatten_restrictCut_map_cons
      r s cs cut

theorem nodeRootFreeCutPrefixedRestrictions_length_eq_detachedForest
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts (PTree.node r s cs))
    (hroot : ([] : Address) ∉ cut) :
    (nodeRootFreeCutPrefixedRestrictions cs cut).length =
      (nodeRootFreeCutDetachedForest cs cut).length := by
  rcases (mem_coalgebraAdmissibleCuts_iff).1 hcut with ⟨hraw, _hcoal⟩
  let C : PTree.IsAdmissibleCut (PTree.node r s cs) :=
    PTree.isAdmissibleCut_of_mem_allAdmissibleCuts hraw
  have hperm :
      List.Perm cut (nodeRootFreeCutPrefixedRestrictions cs cut) :=
    nodeRootFreeCut_perm_prefixedRestrictions
      (r := r) (s := s) (cs := cs) (cut := cut) hcut hroot
  have hsome :
      ∀ a ∈ nodeRootFreeCutPrefixedRestrictions cs cut,
        ∃ u, PTree.subtreeAt (PTree.node r s cs) a = some u := by
    intro a ha
    have hacut : a ∈ cut := (hperm.mem_iff).2 ha
    exact (PTree.valid_iff_exists_subtree
      (PTree.node r s cs) a).1 (C.valid a hacut)
  have hlen :
      ((nodeRootFreeCutPrefixedRestrictions cs cut).filterMap
        (PTree.subtreeAt (PTree.node r s cs))).length =
        (nodeRootFreeCutPrefixedRestrictions cs cut).length :=
    list_filterMap_length_eq_of_all_some hsome
  rw [nodeRootFreeCutPrefixedRestrictions_filterMap_subtreeAt
    r s cs cut] at hlen
  exact hlen.symm

theorem subtreeAt_some_of_mem_nodeRootFreeCutPrefixedRestrictions
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut : List Address} {a : Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts (PTree.node r s cs))
    (hroot : ([] : Address) ∉ cut)
    (ha : a ∈ nodeRootFreeCutPrefixedRestrictions cs cut) :
    ∃ u, PTree.subtreeAt (PTree.node r s cs) a = some u := by
  rcases (mem_coalgebraAdmissibleCuts_iff).1 hcut with ⟨hraw, _hcoal⟩
  let C : PTree.IsAdmissibleCut (PTree.node r s cs) :=
    PTree.isAdmissibleCut_of_mem_allAdmissibleCuts hraw
  have hperm :
      List.Perm cut (nodeRootFreeCutPrefixedRestrictions cs cut) :=
    nodeRootFreeCut_perm_prefixedRestrictions
      (r := r) (s := s) (cs := cs) (cut := cut) hcut hroot
  have hacut : a ∈ cut := (hperm.mem_iff).2 ha
  exact (PTree.valid_iff_exists_subtree
    (PTree.node r s cs) a).1 (C.valid a hacut)

theorem root_not_mem_nodeRootFreeCutPrefixedRestrictions
    (cs : List PTree) (cut : List Address) :
    ([] : Address) ∉ nodeRootFreeCutPrefixedRestrictions cs cut := by
  unfold nodeRootFreeCutPrefixedRestrictions
  intro hroot
  rcases List.mem_flatten.1 hroot with ⟨block, hblock, hrootBlock⟩
  rw [List.mem_mapIdx] at hblock
  rcases hblock with ⟨i, hi, hblockEq⟩
  subst block
  rcases List.mem_map.1 hrootBlock with ⟨a, _ha, hnil⟩
  cases hnil

/--
Restricting the grouped root-free parent cut is permutation-equivalent to
restricting the original parent cut.  This is the coalgebra-facing selector
form that preserves the intentional child-grouped order.
-/
theorem restrictCut_nodeRootFreeCutPrefixedRestrictions_perm
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts (PTree.node r s cs))
    (hroot : ([] : Address) ∉ cut)
    (i : Nat) :
    List.Perm
      (PTree.restrictCut (nodeRootFreeCutPrefixedRestrictions cs cut) i)
      (PTree.restrictCut cut i) := by
  have hperm :=
    (nodeRootFreeCut_perm_prefixedRestrictions
      (r := r) (s := s) (cs := cs) (cut := cut) hcut hroot).symm
  simpa [PTree.restrictCut] using
    hperm.filterMap (fun a =>
      match a with
      | [] => none
      | j :: rest => if j = i then some rest else none)

theorem nodeRootFreeCutChild_mem_coalgebraAdmissibleCuts
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts (PTree.node r s cs))
    (hroot : ([] : Address) ∉ cut)
    (i : Nat) (hi : i < cs.length) :
    PTree.restrictCut cut i ∈ coalgebraAdmissibleCuts cs[i] :=
  restrictCut_mem_coalgebraAdmissibleCuts_of_mem_node
    (r := r) (s := s) (cs := cs) hcut hroot i hi

theorem nodeRootFreeCut_detachedForest_perm
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts (PTree.node r s cs))
    (hroot : ([] : Address) ∉ cut) :
    List.Perm
      (coalgebraDetachedForestOfCut (PTree.node r s cs) cut)
      (nodeRootFreeCutDetachedForest cs cut) := by
  rcases (mem_coalgebraAdmissibleCuts_iff).1 hcut with ⟨hraw, _hcoal⟩
  by_cases hnil : cut = []
  · subst cut
    simp [coalgebraDetachedForestOfCut, nodeRootFreeCutDetachedForest,
      nodeRootFreeCutChildForests, PTree.restrictCut]
  · have hperm :
        List.Perm
          (cut.filterMap (PTree.subtreeAt (PTree.node r s cs)))
          ((cs.attach.mapIdx (fun i child =>
            (PTree.restrictCut cut i).filterMap
              (PTree.subtreeAt child.1))).flatten) :=
      PTree.rootFree_sublist_node_cut_perm_filterMap_subtreeAt_flatten_restrictCut
        (r := r) (s := s) (cs := cs) (cut := cut)
        (PTree.cut_sublist_allAddresses_of_mem_allAdmissibleCuts hraw)
        hroot
    simpa [coalgebraDetachedForestOfCut, hnil, hroot,
      nodeRootFreeCutDetachedForest, nodeRootFreeCutChildForests] using hperm

theorem nodeRootFreeCut_detachedHypersequent_eq
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts (PTree.node r s cs))
    (hroot : ([] : Address) ∉ cut) :
    HQ.ofForest (coalgebraDetachedForestOfCut (PTree.node r s cs) cut) =
      HQ.ofForest (nodeRootFreeCutDetachedForest cs cut) := by
  exact HQ.ofForest_eq_of_perm
    (nodeRootFreeCut_detachedForest_perm
      (r := r) (s := s) (cs := cs) hcut hroot)

theorem nodeRootFreeCut_coalgebraForestSplittingTensorSupport_perm
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts (PTree.node r s cs))
    (hne : cut ≠ [])
    (hroot : ([] : Address) ∉ cut) :
    List.Perm
      (coalgebraForestSplittingTensorSupport
        (cut.filterMap (PTree.subtreeAt (PTree.node r s cs))))
      (coalgebraForestSplittingTensorSupport
        (nodeRootFreeCutDetachedForest cs cut)) := by
  apply coalgebraForestSplittingTensorSupport_perm_of_perm
  simpa [coalgebraDetachedForestOfCut, hne, hroot] using
    nodeRootFreeCut_detachedForest_perm
      (r := r) (s := s) (cs := cs) hcut hroot

theorem nodeRootFreeCut_remainder_eq
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut : List Address}
    (hne : cut ≠ [])
    (hroot : ([] : Address) ∉ cut) :
    coalgebraRemainderOfCut (PTree.node r s cs) cut =
      HQ.singleton
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut)) := by
  have hrem :
      PTree.remainderGo cut [] (PTree.node r s cs) =
        PTree.node r s (nodeRootFreeCutRemainderChildren cs cut) := by
    simpa [nodeRootFreeCutRemainderChildren] using
      PTree.remainderGo_node_root_not_mem
        (r := r) (s := s) (cs := cs) (cut := cut) hroot
  simp [coalgebraRemainderOfCut, coalgebraTensorTermOfCutList,
    hne, hroot, hrem]

theorem nodeRootFreeCut_filterMap_hypersequent_eq
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts (PTree.node r s cs))
    (hroot : ([] : Address) ∉ cut) :
    HQ.ofForest (cut.filterMap (PTree.subtreeAt (PTree.node r s cs))) =
      HQ.ofForest (nodeRootFreeCutDetachedForest cs cut) := by
  rcases (mem_coalgebraAdmissibleCuts_iff).1 hcut with ⟨hraw, _hcoal⟩
  exact HQ.ofForest_eq_of_perm
    (by
      simpa [nodeRootFreeCutDetachedForest, nodeRootFreeCutChildForests] using
        PTree.rootFree_sublist_node_cut_perm_filterMap_subtreeAt_flatten_restrictCut
          (r := r) (s := s) (cs := cs) (cut := cut)
          (PTree.cut_sublist_allAddresses_of_mem_allAdmissibleCuts hraw)
          hroot)

theorem coalgebraTensorTermOfCutList_node_rootFree
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts (PTree.node r s cs))
    (hne : cut ≠ [])
    (hroot : ([] : Address) ∉ cut) :
    coalgebraTensorTermOfCutList (PTree.node r s cs) cut =
      (HQ.ofForest (nodeRootFreeCutDetachedForest cs cut),
        HQ.singleton
          (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut))) := by
  have hforest :
      HQ.ofForest (cut.filterMap (PTree.subtreeAt (PTree.node r s cs))) =
        HQ.ofForest (nodeRootFreeCutDetachedForest cs cut) :=
    nodeRootFreeCut_filterMap_hypersequent_eq
      (r := r) (s := s) (cs := cs) hcut hroot
  have hrem :
      PTree.remainderGo cut [] (PTree.node r s cs) =
        PTree.node r s (nodeRootFreeCutRemainderChildren cs cut) := by
    simpa [nodeRootFreeCutRemainderChildren] using
      PTree.remainderGo_node_root_not_mem
        (r := r) (s := s) (cs := cs) (cut := cut) hroot
  simp [coalgebraTensorTermOfCutList, hne, hroot, hforest, hrem]

theorem coalgebraRightStageTripleOfCuts_node_rootFree_first
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ coalgebraAdmissibleCuts (PTree.node r s cs))
    (hne₁ : cut₁ ≠ [])
    (hroot₁ : ([] : Address) ∉ cut₁) :
    coalgebraRightStageTripleOfCuts
        (PTree.node r s cs) cut₁ cut₂ =
      let rem :=
        PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁)
      let p := coalgebraTensorTermOfCutList rem cut₂
      (HQ.ofForest (nodeRootFreeCutDetachedForest cs cut₁), p.1, p.2) := by
  have hforest :
      HQ.ofForest (cut₁.filterMap
          (PTree.subtreeAt (PTree.node r s cs))) =
        HQ.ofForest (nodeRootFreeCutDetachedForest cs cut₁) :=
    nodeRootFreeCut_filterMap_hypersequent_eq
      (r := r) (s := s) (cs := cs) hcut₁ hroot₁
  have hrem :
      PTree.remainderGo cut₁ [] (PTree.node r s cs) =
        PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁) := by
    simpa [nodeRootFreeCutRemainderChildren] using
      PTree.remainderGo_node_root_not_mem
        (r := r) (s := s) (cs := cs) (cut := cut₁) hroot₁
  rw [coalgebraRightStageTripleOfCuts_of_ne_nil_of_root_not_mem
      (t := PTree.node r s cs) (cut₁ := cut₁) (cut₂ := cut₂)
      hne₁ hroot₁]
  simp [hforest, hrem]

theorem coalgebraRightStageTripleBranch_node_rootFree_first
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts (PTree.node r s cs))
    (hne : cut ≠ [])
    (hroot : ([] : Address) ∉ cut) :
    coalgebraRightStageTripleBranch (PTree.node r s cs) cut =
      (coalgebraAdmissibleCuts
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut))).map
        (fun cut₂ =>
          let p :=
            coalgebraTensorTermOfCutList
              (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut)) cut₂
          (HQ.ofForest (nodeRootFreeCutDetachedForest cs cut), p.1, p.2)) := by
  have hrem :
      PTree.remainderGo cut [] (PTree.node r s cs) =
        PTree.node r s (nodeRootFreeCutRemainderChildren cs cut) := by
    simpa [nodeRootFreeCutRemainderChildren] using
      PTree.remainderGo_node_root_not_mem
        (r := r) (s := s) (cs := cs) (cut := cut) hroot
  rw [coalgebraRightStageTripleBranch_of_ne_nil_of_root_not_mem
      (t := PTree.node r s cs) (cut₁ := cut) hne hroot]
  rw [hrem]
  apply List.map_congr_left
  intro cut₂ _hcut₂
  exact coalgebraRightStageTripleOfCuts_node_rootFree_first
    (r := r) (s := s) (cs := cs)
    (cut₁ := cut) (cut₂ := cut₂) hcut hne hroot

theorem coalgebraLeftStageTripleBranch_node_rootFree_first_raw
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut : List Address}
    (hne : cut ≠ [])
    (hroot : ([] : Address) ∉ cut) :
    coalgebraLeftStageTripleBranch (PTree.node r s cs) cut =
      (coalgebraForestSplittingTensorSupport
        (cut.filterMap (PTree.subtreeAt (PTree.node r s cs)))).map
        (fun p =>
          (p.1, p.2,
            HQ.singleton
              (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut)))) := by
  have hrem :
      PTree.remainderGo cut [] (PTree.node r s cs) =
        PTree.node r s (nodeRootFreeCutRemainderChildren cs cut) := by
    simpa [nodeRootFreeCutRemainderChildren] using
      PTree.remainderGo_node_root_not_mem
        (r := r) (s := s) (cs := cs) (cut := cut) hroot
  rw [coalgebraLeftStageTripleBranch_of_ne_nil_of_root_not_mem
      (t := PTree.node r s cs) (cut := cut) hne hroot]
  simp [hrem]

/-!
### Named support sectors for normalized coassociativity

The full staged supports are finite lists, but the coassociativity bijection
is easiest to describe by sectors:

* empty first cut,
* root first cut,
* internal first cuts,
* and, inside an internal right-stage branch, empty/root/internal second cuts.

The definitions below expose exactly those sectors.  The pointwise formulas
turn boundary pieces into explicit triples; the only genuinely difficult
sector is the internal/internal one, where the extension bijection lives.
-/

/-- Right-stage sector where the first cut is empty. -/
noncomputable def coalgebraRightEmptyFirstTripleSupport
    (t : PTree) : List HypersequentTripleBasis :=
  coalgebraRightStageTripleBranch t []

/-- Right-stage sector where the first cut is the root cut. -/
noncomputable def coalgebraRightRootFirstTripleSupport
    (t : PTree) : List HypersequentTripleBasis :=
  coalgebraRightStageTripleBranch t [([] : Address)]

/-- Right-stage sector where the first cut is internal/proper. -/
noncomputable def coalgebraRightInternalFirstTripleSupport
    (t : PTree) : List HypersequentTripleBasis :=
  (internalCoalgebraAdmissibleCuts t).flatMap
    (coalgebraRightStageTripleBranch t)

/-- Left-stage sector where the first cut is empty. -/
noncomputable def coalgebraLeftEmptyFirstTripleSupport
    (t : PTree) : List HypersequentTripleBasis :=
  coalgebraLeftStageTripleBranch t []

/-- Left-stage sector where the first cut is the root cut. -/
noncomputable def coalgebraLeftRootFirstTripleSupport
    (t : PTree) : List HypersequentTripleBasis :=
  coalgebraLeftStageTripleBranch t [([] : Address)]

/-- Left-stage sector where the first cut is internal/proper. -/
noncomputable def coalgebraLeftInternalFirstTripleSupport
    (t : PTree) : List HypersequentTripleBasis :=
  (internalCoalgebraAdmissibleCuts t).flatMap
    (coalgebraLeftStageTripleBranch t)

/-- Boundary sector `(0,D,R)` indexed by internal cuts of `t`. -/
noncomputable def coalgebraInternalIdentityTripleSupport
    (t : PTree) : List HypersequentTripleBasis :=
  (internalCoalgebraAdmissibleCuts t).map
    (fun cut =>
      (0,
        HQ.ofForest (cut.filterMap (PTree.subtreeAt t)),
        HQ.singleton (PTree.remainderGo cut [] t)))

/-- Boundary sector `(D,0,R)` indexed by internal cuts of `t`. -/
noncomputable def coalgebraInternalSecondEmptyTripleSupport
    (t : PTree) : List HypersequentTripleBasis :=
  (internalCoalgebraAdmissibleCuts t).map
    (fun cut =>
      (HQ.ofForest (cut.filterMap (PTree.subtreeAt t)),
        0,
        HQ.singleton (PTree.remainderGo cut [] t)))

/-- Boundary sector `(D,R,0)` indexed by internal cuts of `t`. -/
noncomputable def coalgebraInternalSecondRootTripleSupport
    (t : PTree) : List HypersequentTripleBasis :=
  (internalCoalgebraAdmissibleCuts t).map
    (fun cut =>
      (HQ.ofForest (cut.filterMap (PTree.subtreeAt t)),
        HQ.singleton (PTree.remainderGo cut [] t),
        0))

@[simp]
theorem coalgebraRightEmptyFirstTripleSupport_eq
    (t : PTree) :
    coalgebraRightEmptyFirstTripleSupport t =
      (coalgebraAdmissibleCuts t).map
        (fun cut => coalgebraRightStageTripleOfCuts t [] cut) := by
  simp [coalgebraRightEmptyFirstTripleSupport]

@[simp]
theorem coalgebraRightRootFirstTripleSupport_eq
    (t : PTree) :
    coalgebraRightRootFirstTripleSupport t =
      [(HQ.singleton t, 0, 0)] := by
  simp [coalgebraRightRootFirstTripleSupport]

@[simp]
theorem coalgebraLeftEmptyFirstTripleSupport_eq
    (t : PTree) :
    coalgebraLeftEmptyFirstTripleSupport t =
      [(0, 0, HQ.singleton t)] := by
  simp [coalgebraLeftEmptyFirstTripleSupport]

@[simp]
theorem coalgebraLeftRootFirstTripleSupport_eq
    (t : PTree) :
    coalgebraLeftRootFirstTripleSupport t =
      (coalgebraTreeSplittingTensorSupport t).map
        (fun p => (p.1, p.2, (0 : Hypersequent))) := by
  simp [coalgebraLeftRootFirstTripleSupport]

/-- The empty-empty boundary atom in the right empty-first sector. -/
theorem coalgebraRightEmptyFirstTripleSupport_contains_empty_empty
    (t : PTree) :
    List.Mem (0, 0, HQ.singleton t)
      (coalgebraRightEmptyFirstTripleSupport t) := by
  unfold coalgebraRightEmptyFirstTripleSupport
  rw [coalgebraRightStageTripleBranch_empty]
  refine List.mem_map.2 ?_
  refine ⟨[], empty_mem_coalgebraAdmissibleCuts t, ?_⟩
  simp [coalgebraRightStageTripleOfCuts]

/-- The empty-root boundary atom in the right empty-first sector. -/
theorem coalgebraRightEmptyFirstTripleSupport_contains_empty_root
    (t : PTree) :
    List.Mem (0, HQ.singleton t, 0)
      (coalgebraRightEmptyFirstTripleSupport t) := by
  unfold coalgebraRightEmptyFirstTripleSupport
  rw [coalgebraRightStageTripleBranch_empty]
  refine List.mem_map.2 ?_
  refine ⟨[([] : Address)], root_mem_coalgebraAdmissibleCuts t, ?_⟩
  simp [coalgebraRightStageTripleOfCuts]

/-- The root-unit boundary atom in the right root-first sector. -/
theorem coalgebraRightRootFirstTripleSupport_contains_root_unit
    (t : PTree) :
    List.Mem (HQ.singleton t, 0, 0)
      (coalgebraRightRootFirstTripleSupport t) := by
  rw [coalgebraRightRootFirstTripleSupport_eq]
  exact List.Mem.head []

/-- The empty-empty boundary atom in the left empty-first sector. -/
theorem coalgebraLeftEmptyFirstTripleSupport_contains_empty_empty
    (t : PTree) :
    List.Mem (0, 0, HQ.singleton t)
      (coalgebraLeftEmptyFirstTripleSupport t) := by
  rw [coalgebraLeftEmptyFirstTripleSupport_eq]
  exact List.Mem.head []

/-- The empty-root boundary atom in the left root-first sector. -/
theorem coalgebraLeftRootFirstTripleSupport_contains_empty_root
    (t : PTree) :
    List.Mem (0, HQ.singleton t, 0)
      (coalgebraLeftRootFirstTripleSupport t) := by
  unfold coalgebraLeftRootFirstTripleSupport
  rw [coalgebraLeftStageTripleBranch_root]
  refine List.mem_map.2 ?_
  refine ⟨(0, HQ.singleton t), ?_, by simp⟩
  exact coalgebraTreeSplittingTensorSupport_contains_empty t

/-- The root-unit boundary atom in the left root-first sector. -/
theorem coalgebraLeftRootFirstTripleSupport_contains_root_unit
    (t : PTree) :
    List.Mem (HQ.singleton t, 0, 0)
      (coalgebraLeftRootFirstTripleSupport t) := by
  unfold coalgebraLeftRootFirstTripleSupport
  rw [coalgebraLeftStageTripleBranch_root]
  refine List.mem_map.2 ?_
  refine ⟨(HQ.singleton t, 0), ?_, by simp⟩
  exact coalgebraTreeSplittingTensorSupport_contains_root t

/--
For an internal first cut, the right-stage second empty cut contributes
`detached ⊗ 1 ⊗ remainder`.
-/
theorem coalgebraRightStageTripleOfCuts_internal_second_empty
    {t : PTree} {cut : List Address}
    (hinternal : InternalCut cut) :
    coalgebraRightStageTripleOfCuts t cut [] =
      (HQ.ofForest (cut.filterMap (PTree.subtreeAt t)),
        0,
        HQ.singleton (PTree.remainderGo cut [] t)) := by
  rw [coalgebraRightStageTripleOfCuts_of_ne_nil_of_root_not_mem
      (t := t) (cut₁ := cut) (cut₂ := []) hinternal.1 hinternal.2]
  simp [coalgebraTensorTermOfCutList_nil]

/--
For an internal first cut, the right-stage second root cut contributes
`detached ⊗ remainder ⊗ 1`.
-/
theorem coalgebraRightStageTripleOfCuts_internal_second_root
    {t : PTree} {cut : List Address}
    (hinternal : InternalCut cut) :
    coalgebraRightStageTripleOfCuts t cut [([] : Address)] =
      (HQ.ofForest (cut.filterMap (PTree.subtreeAt t)),
        HQ.singleton (PTree.remainderGo cut [] t),
        0) := by
  rw [coalgebraRightStageTripleOfCuts_of_ne_nil_of_root_not_mem
      (t := t) (cut₁ := cut) (cut₂ := [([] : Address)])
      hinternal.1 hinternal.2]
  simp [coalgebraTensorTermOfCutList_root]

/--
The right internal branch contains the second-empty boundary atom for every
internal first cut.
-/
theorem coalgebraRightStageTripleBranch_internal_contains_second_empty
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts t)
    (hinternal : InternalCut cut) :
    List.Mem
      (HQ.ofForest (cut.filterMap (PTree.subtreeAt t)),
        0,
        HQ.singleton (PTree.remainderGo cut [] t))
      (coalgebraRightStageTripleBranch t cut) := by
  rw [coalgebraRightStageTripleBranch_of_ne_nil_of_root_not_mem
      (t := t) (cut₁ := cut) hinternal.1 hinternal.2]
  refine List.mem_map.2 ?_
  refine ⟨[], empty_mem_coalgebraAdmissibleCuts
    (PTree.remainderGo cut [] t), ?_⟩
  exact (coalgebraRightStageTripleOfCuts_internal_second_empty
    (t := t) (cut := cut) hinternal)

/--
The right internal branch contains the second-root boundary atom for every
internal first cut.
-/
theorem coalgebraRightStageTripleBranch_internal_contains_second_root
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts t)
    (hinternal : InternalCut cut) :
    List.Mem
      (HQ.ofForest (cut.filterMap (PTree.subtreeAt t)),
        HQ.singleton (PTree.remainderGo cut [] t),
        0)
      (coalgebraRightStageTripleBranch t cut) := by
  rw [coalgebraRightStageTripleBranch_of_ne_nil_of_root_not_mem
      (t := t) (cut₁ := cut) hinternal.1 hinternal.2]
  refine List.mem_map.2 ?_
  refine ⟨[([] : Address)],
    root_mem_coalgebraAdmissibleCuts (PTree.remainderGo cut [] t), ?_⟩
  exact (coalgebraRightStageTripleOfCuts_internal_second_root
    (t := t) (cut := cut) hinternal)

/--
The left internal branch contains the forest-identity boundary atom for every
internal first cut: this is the term matching the right empty-first/proper-cut
sector.
-/
theorem coalgebraLeftStageTripleBranch_internal_contains_forest_identity
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts t)
    (hinternal : InternalCut cut) :
    List.Mem
      (0,
        HQ.ofForest (cut.filterMap (PTree.subtreeAt t)),
        HQ.singleton (PTree.remainderGo cut [] t))
      (coalgebraLeftStageTripleBranch t cut) := by
  rw [coalgebraLeftStageTripleBranch_of_ne_nil_of_root_not_mem
      (t := t) (cut := cut) hinternal.1 hinternal.2]
  refine List.mem_map.2 ?_
  refine ⟨(0, HQ.ofForest (cut.filterMap (PTree.subtreeAt t))), ?_, by simp⟩
  exact coalgebraForestSplittingTensorSupport_contains_identity
    (cut.filterMap (PTree.subtreeAt t))

/--
The left internal branch contains the detached-forest total-root boundary atom
for every internal first cut.  This is the term matching the right staged
branch where the second cut of the remainder is empty.
-/
theorem coalgebraLeftStageTripleBranch_internal_contains_total_root
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts t)
    (hinternal : InternalCut cut) :
    List.Mem
      (HQ.ofForest (cut.filterMap (PTree.subtreeAt t)),
        0,
        HQ.singleton (PTree.remainderGo cut [] t))
      (coalgebraLeftStageTripleBranch t cut) := by
  rw [coalgebraLeftStageTripleBranch_of_ne_nil_of_root_not_mem
      (t := t) (cut := cut) hinternal.1 hinternal.2]
  refine List.mem_map.2 ?_
  refine ⟨(HQ.ofForest (cut.filterMap (PTree.subtreeAt t)), 0), ?_, by simp⟩
  exact coalgebraForestSplittingTensorSupport_contains_total_root
    (cut.filterMap (PTree.subtreeAt t))

/--
The right empty-first branch contains the forest-identity atom associated with
every internal cut of the original tree.  This is the boundary mate of the left
internal branch's identity split.
-/
theorem coalgebraRightEmptyFirstTripleSupport_contains_internal_identity
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts t)
    (hinternal : InternalCut cut) :
    List.Mem
      (0,
        HQ.ofForest (cut.filterMap (PTree.subtreeAt t)),
        HQ.singleton (PTree.remainderGo cut [] t))
      (coalgebraRightEmptyFirstTripleSupport t) := by
  unfold coalgebraRightEmptyFirstTripleSupport
  rw [coalgebraRightStageTripleBranch_empty]
  refine List.mem_map.2 ?_
  refine ⟨cut, hcut, ?_⟩
  simp [coalgebraRightStageTripleOfCuts,
    coalgebraTensorTermOfCutList_of_ne_nil_of_root_not_mem
      (t := t) (cut := cut) hinternal.1 hinternal.2]

/--
The left root-first branch contains the atom obtained from an internal cut of
the original tree and then placing the original final tensor slot at the unit.
This is the boundary mate of the right internal branch's second-root term.
-/
theorem coalgebraLeftRootFirstTripleSupport_contains_internal_second_root
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts t)
    (hinternal : InternalCut cut) :
    List.Mem
      (HQ.ofForest (cut.filterMap (PTree.subtreeAt t)),
        HQ.singleton (PTree.remainderGo cut [] t),
        0)
      (coalgebraLeftRootFirstTripleSupport t) := by
  unfold coalgebraLeftRootFirstTripleSupport
  rw [coalgebraLeftStageTripleBranch_root]
  refine List.mem_map.2 ?_
  refine ⟨(HQ.ofForest (cut.filterMap (PTree.subtreeAt t)),
      HQ.singleton (PTree.remainderGo cut [] t)), ?_, by simp⟩
  exact (mem_coalgebraTreeSplittingTensorSupport_iff).2
    ⟨cut, hcut,
      (coalgebraTensorTermOfCutList_of_ne_nil_of_root_not_mem
        (t := t) (cut := cut) hinternal.1 hinternal.2).symm⟩

/-- Right-stage sector where both first and second cuts are internal. -/
noncomputable def coalgebraRightInternalInternalTripleSupport
    (t : PTree) : List HypersequentTripleBasis :=
  (internalCoalgebraAdmissibleCuts t).flatMap
    (fun cut =>
      (internalCoalgebraAdmissibleCuts
          (PTree.remainderGo cut [] t)).map
        (fun cut₂ => coalgebraRightStageTripleOfCuts t cut cut₂))

/--
Proper forest-splitting sector: remove the two boundary forest splits
`1 ⊗ F` and `F ⊗ 1`.

The normalized forest coproduct is multiplicative over external components, so
the true internal/internal coassociativity comparison must use this proper
sector after the identity and total-root atoms have been matched separately.
-/
noncomputable def coalgebraForestProperSplittingTensorSupport
    (f : Forest) : List HypersequentTensorBasis := by
  classical
  exact (coalgebraForestSplittingTensorSupport f).filter
    (fun p => decide (p.1 ≠ 0 ∧ p.2 ≠ 0))

theorem mem_coalgebraForestProperSplittingTensorSupport_iff
    {f : Forest} {p : HypersequentTensorBasis} :
    p ∈ coalgebraForestProperSplittingTensorSupport f ↔
      p ∈ coalgebraForestSplittingTensorSupport f ∧ p.1 ≠ 0 ∧ p.2 ≠ 0 := by
  classical
  unfold coalgebraForestProperSplittingTensorSupport
  simp

/-- Forest cut profiles whose represented tensor atom is proper. -/
noncomputable def coalgebraForestProperCutProfiles
    (f : Forest) : List (List (List Address)) := by
  classical
  exact (coalgebraForestCutProfiles f).filter
    (fun profile =>
      decide
        ((coalgebraForestTensorTermOfProfile f profile).1 ≠ 0 ∧
          (coalgebraForestTensorTermOfProfile f profile).2 ≠ 0))

theorem mem_coalgebraForestProperCutProfiles_iff
    {f : Forest} {profile : List (List Address)} :
    profile ∈ coalgebraForestProperCutProfiles f ↔
      profile ∈ coalgebraForestCutProfiles f ∧
        (coalgebraForestTensorTermOfProfile f profile).1 ≠ 0 ∧
        (coalgebraForestTensorTermOfProfile f profile).2 ≠ 0 := by
  classical
  unfold coalgebraForestProperCutProfiles
  simp

theorem coalgebraForestCutProfiles_nodup :
    ∀ f : Forest, (coalgebraForestCutProfiles f).Nodup
  | [] => by
      simp [coalgebraForestCutProfiles]
  | t :: ts => by
      rw [coalgebraForestCutProfiles_cons]
      rw [List.nodup_flatMap]
      constructor
      · intro cut _hcut
        exact (coalgebraForestCutProfiles_nodup ts).map
          (fun profile₁ profile₂ h => (List.cons.inj h).2)
      · refine (coalgebraAdmissibleCuts_nodup t).imp ?_
        intro cut₁ cut₂ hne z hz₁ hz₂
        rcases List.mem_map.1 hz₁ with ⟨profile₁, _hprofile₁, rfl⟩
        rcases List.mem_map.1 hz₂ with ⟨profile₂, _hprofile₂, hEq⟩
        exact hne (List.cons.inj hEq).1.symm

theorem coalgebraForestProperCutProfiles_nodup (f : Forest) :
    (coalgebraForestProperCutProfiles f).Nodup := by
  unfold coalgebraForestProperCutProfiles
  exact List.Nodup.filter _ (coalgebraForestCutProfiles_nodup f)

theorem mem_coalgebraForestProperCutProfiles_filterMap_of_zip
    {t : PTree} {addrs : List Address}
    {profile : List (List Address)}
    (hlen : profile.length = addrs.length)
    (hzip :
      ∀ a cut, (a, cut) ∈ List.zip addrs profile →
        ∃ u, t.subtreeAt a = some u ∧
          cut ∈ coalgebraAdmissibleCuts u)
    (hproper :
      (coalgebraForestTensorTermOfProfile
          (addrs.filterMap (PTree.subtreeAt t)) profile).1 ≠ 0 ∧
        (coalgebraForestTensorTermOfProfile
          (addrs.filterMap (PTree.subtreeAt t)) profile).2 ≠ 0) :
    profile ∈ coalgebraForestProperCutProfiles
      (addrs.filterMap (PTree.subtreeAt t)) := by
  exact (mem_coalgebraForestProperCutProfiles_iff
    (f := addrs.filterMap (PTree.subtreeAt t))
    (profile := profile)).2
    ⟨mem_coalgebraForestCutProfiles_filterMap_of_zip
        (t := t) hlen hzip,
      hproper⟩

theorem coalgebraForestProperCutProfiles_length_eq
    {f : Forest} {profile : List (List Address)}
    (hprofile : profile ∈ coalgebraForestProperCutProfiles f) :
    profile.length = f.length := by
  exact coalgebraForestCutProfiles_length_eq
    ((mem_coalgebraForestProperCutProfiles_iff).1 hprofile).1

theorem coalgebraForestProperSplittingTensorSupport_eq_profile_map
    (f : Forest) :
    coalgebraForestProperSplittingTensorSupport f =
      (coalgebraForestProperCutProfiles f).map
        (coalgebraForestTensorTermOfProfile f) := by
  classical
  unfold coalgebraForestProperSplittingTensorSupport
    coalgebraForestProperCutProfiles
  rw [coalgebraForestSplittingTensorSupport_eq_profile_map f]
  rw [List.filter_map]
  simpa [Function.comp_def]

theorem mem_coalgebraForestProperSplittingTensorSupport_iff_profile
    {f : Forest} {q : HypersequentTensorBasis} :
    q ∈ coalgebraForestProperSplittingTensorSupport f ↔
      ∃ profile ∈ coalgebraForestProperCutProfiles f,
        q = coalgebraForestTensorTermOfProfile f profile := by
  rw [coalgebraForestProperSplittingTensorSupport_eq_profile_map f]
  constructor
  · intro hq
    rcases List.mem_map.1 hq with ⟨profile, hprofile, hEq⟩
    exact ⟨profile, hprofile, hEq.symm⟩
  · rintro ⟨profile, hprofile, rfl⟩
    exact List.mem_map.2 ⟨profile, hprofile, rfl⟩

theorem coalgebraForestProperSplittingTensorSupport_contains_prefix_suffix
    {f g : Forest}
    (hf : f ≠ [])
    (hg : g ≠ []) :
    List.Mem (HQ.ofForest f, HQ.ofForest g)
      (coalgebraForestProperSplittingTensorSupport (f ++ g)) := by
  exact (mem_coalgebraForestProperSplittingTensorSupport_iff
    (f := f ++ g) (p := (HQ.ofForest f, HQ.ofForest g))).2
    ⟨coalgebraForestSplittingTensorSupport_contains_prefix_suffix f g,
      (by
        cases f with
        | nil => exact False.elim (hf rfl)
        | cons t ts =>
            exact ofForest_ne_zero_of_mem (f := t :: ts) (u := t) (by simp)),
      (by
        cases g with
        | nil => exact False.elim (hg rfl)
        | cons t ts =>
            exact ofForest_ne_zero_of_mem (f := t :: ts) (u := t) (by simp))⟩

theorem coalgebraForestProperSplittingTensorSupport_perm_of_splitting_perm
    {f g : Forest}
    (h :
      List.Perm
        (coalgebraForestSplittingTensorSupport f)
        (coalgebraForestSplittingTensorSupport g)) :
    List.Perm
      (coalgebraForestProperSplittingTensorSupport f)
      (coalgebraForestProperSplittingTensorSupport g) := by
  classical
  unfold coalgebraForestProperSplittingTensorSupport
  exact h.filter (fun p => decide (p.1 ≠ 0 ∧ p.2 ≠ 0))

theorem coalgebraForestProperSplittingTensorSupport_perm_of_forest_perm
    {f g : Forest}
    (h : List.Perm f g) :
    List.Perm
      (coalgebraForestProperSplittingTensorSupport f)
      (coalgebraForestProperSplittingTensorSupport g) :=
  coalgebraForestProperSplittingTensorSupport_perm_of_splitting_perm
    (coalgebraForestSplittingTensorSupport_perm_of_perm h)

theorem nodeRootFreeCut_coalgebraForestProperSplittingTensorSupport_perm
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut : List Address}
    (hcut : cut ∈ coalgebraAdmissibleCuts (PTree.node r s cs))
    (hne : cut ≠ [])
    (hroot : ([] : Address) ∉ cut) :
    List.Perm
      (coalgebraForestProperSplittingTensorSupport
        (cut.filterMap (PTree.subtreeAt (PTree.node r s cs))))
      (coalgebraForestProperSplittingTensorSupport
        (nodeRootFreeCutDetachedForest cs cut)) := by
  exact coalgebraForestProperSplittingTensorSupport_perm_of_forest_perm
    (by
      simpa [coalgebraDetachedForestOfCut, hne, hroot] using
        nodeRootFreeCut_detachedForest_perm
          (r := r) (s := s) (cs := cs) hcut hroot)

theorem not_mem_coalgebraForestProperSplittingTensorSupport_left_zero
    {f : Forest} {G : Hypersequent} :
    (0, G) ∉ coalgebraForestProperSplittingTensorSupport f := by
  intro hmem
  have h := (mem_coalgebraForestProperSplittingTensorSupport_iff
    (f := f) (p := (0, G))).1 hmem
  exact h.2.1 rfl

theorem not_mem_coalgebraForestProperSplittingTensorSupport_right_zero
    {f : Forest} {G : Hypersequent} :
    (G, 0) ∉ coalgebraForestProperSplittingTensorSupport f := by
  intro hmem
  have h := (mem_coalgebraForestProperSplittingTensorSupport_iff
    (f := f) (p := (G, 0))).1 hmem
  exact h.2.2 rfl

theorem coalgebraForestProperSplittingTensorSupport_no_identity
    (f : Forest) :
    (0, HQ.ofForest f) ∉ coalgebraForestProperSplittingTensorSupport f :=
  not_mem_coalgebraForestProperSplittingTensorSupport_left_zero

theorem coalgebraForestProperSplittingTensorSupport_no_total_root
    (f : Forest) :
    (HQ.ofForest f, 0) ∉ coalgebraForestProperSplittingTensorSupport f :=
  not_mem_coalgebraForestProperSplittingTensorSupport_right_zero

/-- Left-stage sector where the detached forest is split properly. -/
noncomputable def coalgebraLeftInternalInternalTripleSupport
    (t : PTree) : List HypersequentTripleBasis :=
  (internalCoalgebraAdmissibleCuts t).flatMap
    (fun cut =>
      (coalgebraForestProperSplittingTensorSupport
          (cut.filterMap (PTree.subtreeAt t))).map
        (fun p =>
          (p.1, p.2,
            HQ.singleton (PTree.remainderGo cut [] t))))

theorem coalgebraLeftInternalInternalTripleSupport_first_ne_zero_of_mem
    {t : PTree} {p : HypersequentTripleBasis}
    (hp : p ∈ coalgebraLeftInternalInternalTripleSupport t) :
    p.1 ≠ 0 := by
  unfold coalgebraLeftInternalInternalTripleSupport at hp
  rcases List.mem_flatMap.1 hp with ⟨cut, _hcut, hpmap⟩
  rcases List.mem_map.1 hpmap with ⟨q, hq, hpq⟩
  subst p
  exact ((mem_coalgebraForestProperSplittingTensorSupport_iff
    (f := cut.filterMap (PTree.subtreeAt t)) (p := q)).1 hq).2.1

theorem coalgebraLeftInternalInternalTripleSupport_second_ne_zero_of_mem
    {t : PTree} {p : HypersequentTripleBasis}
    (hp : p ∈ coalgebraLeftInternalInternalTripleSupport t) :
    p.2.1 ≠ 0 := by
  unfold coalgebraLeftInternalInternalTripleSupport at hp
  rcases List.mem_flatMap.1 hp with ⟨cut, _hcut, hpmap⟩
  rcases List.mem_map.1 hpmap with ⟨q, hq, hpq⟩
  subst p
  exact ((mem_coalgebraForestProperSplittingTensorSupport_iff
    (f := cut.filterMap (PTree.subtreeAt t)) (p := q)).1 hq).2.2

/--
Membership predicate for the right internal/internal sector.  This is the
nested-cut side of the final coassociativity comparison: choose an internal
first cut, then an internal cut of the normalized remainder.
-/
def RightInternalInternalTripleAtom
    (t : PTree) (p : HypersequentTripleBasis) : Prop :=
  ∃ cut₁ ∈ internalCoalgebraAdmissibleCuts t,
    ∃ cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.remainderGo cut₁ [] t),
      p = coalgebraRightStageTripleOfCuts t cut₁ cut₂

/--
Membership predicate for the left internal/internal sector.  This is the
detached-forest-first side: choose an internal ambient cut, then a proper
normalized split of the forest detached by that cut.
-/
def LeftInternalInternalTripleAtom
    (t : PTree) (p : HypersequentTripleBasis) : Prop :=
  ∃ cut ∈ internalCoalgebraAdmissibleCuts t,
    ∃ q ∈ coalgebraForestProperSplittingTensorSupport
        (cut.filterMap (PTree.subtreeAt t)),
      p = (q.1, q.2, HQ.singleton (PTree.remainderGo cut [] t))

theorem mem_coalgebraRightInternalInternalTripleSupport_iff
    {t : PTree} {p : HypersequentTripleBasis} :
    p ∈ coalgebraRightInternalInternalTripleSupport t ↔
      RightInternalInternalTripleAtom t p := by
  unfold coalgebraRightInternalInternalTripleSupport
    RightInternalInternalTripleAtom
  constructor
  · intro hp
    rcases List.mem_flatMap.1 hp with ⟨cut₁, hcut₁, hpmap⟩
    rcases List.mem_map.1 hpmap with ⟨cut₂, hcut₂, hpeq⟩
    exact ⟨cut₁, hcut₁, cut₂, hcut₂, hpeq.symm⟩
  · rintro ⟨cut₁, hcut₁, cut₂, hcut₂, rfl⟩
    exact List.mem_flatMap.2
      ⟨cut₁, hcut₁, List.mem_map.2 ⟨cut₂, hcut₂, rfl⟩⟩

theorem mem_coalgebraLeftInternalInternalTripleSupport_iff
    {t : PTree} {p : HypersequentTripleBasis} :
    p ∈ coalgebraLeftInternalInternalTripleSupport t ↔
      LeftInternalInternalTripleAtom t p := by
  unfold coalgebraLeftInternalInternalTripleSupport
    LeftInternalInternalTripleAtom
  constructor
  · intro hp
    rcases List.mem_flatMap.1 hp with ⟨cut, hcut, hpmap⟩
    rcases List.mem_map.1 hpmap with ⟨q, hq, hpeq⟩
    exact ⟨cut, hcut, q, hq, hpeq.symm⟩
  · rintro ⟨cut, hcut, q, hq, rfl⟩
    exact List.mem_flatMap.2
      ⟨cut, hcut, List.mem_map.2 ⟨q, hq, rfl⟩⟩

/-- Childwise normal form for the right node internal/internal support. -/
noncomputable def nodeRightInternalInternalNormalSupport
    (r : RuleTag) (s : MultiSequent) (cs : List PTree) :
    List HypersequentTripleBasis :=
  (internalCoalgebraAdmissibleCuts (PTree.node r s cs)).flatMap
    (fun cut =>
      (internalCoalgebraAdmissibleCuts
          (PTree.node r s
            (nodeRootFreeCutRemainderChildren cs cut))).map
        (fun cut₂ =>
          let p :=
            coalgebraTensorTermOfCutList
              (PTree.node r s
                (nodeRootFreeCutRemainderChildren cs cut)) cut₂
          (HQ.ofForest (nodeRootFreeCutDetachedForest cs cut),
            p.1, p.2)))

/-- Childwise normal form for the left node internal/internal support. -/
noncomputable def nodeLeftInternalInternalNormalSupport
    (r : RuleTag) (s : MultiSequent) (cs : List PTree) :
    List HypersequentTripleBasis :=
  (internalCoalgebraAdmissibleCuts (PTree.node r s cs)).flatMap
    (fun cut =>
      (coalgebraForestProperSplittingTensorSupport
          (nodeRootFreeCutDetachedForest cs cut)).map
        (fun p =>
          (p.1, p.2,
            HQ.singleton
              (PTree.node r s
                (nodeRootFreeCutRemainderChildren cs cut)))))

/-- Right normal branch over one fixed internal node cut. -/
noncomputable def nodeRightInternalInternalNormalBranch
    (r : RuleTag) (s : MultiSequent) (cs : List PTree)
    (cut : List Address) : List HypersequentTripleBasis :=
  (internalCoalgebraAdmissibleCuts
      (PTree.node r s
        (nodeRootFreeCutRemainderChildren cs cut))).map
    (fun cut₂ =>
      let p :=
        coalgebraTensorTermOfCutList
          (PTree.node r s
            (nodeRootFreeCutRemainderChildren cs cut)) cut₂
      (HQ.ofForest (nodeRootFreeCutDetachedForest cs cut), p.1, p.2))

/-- Left normal branch over one fixed internal node cut. -/
noncomputable def nodeLeftInternalInternalNormalBranch
    (r : RuleTag) (s : MultiSequent) (cs : List PTree)
    (cut : List Address) : List HypersequentTripleBasis :=
  (coalgebraForestProperSplittingTensorSupport
      (nodeRootFreeCutDetachedForest cs cut)).map
    (fun p =>
      (p.1, p.2,
        HQ.singleton
          (PTree.node r s
            (nodeRootFreeCutRemainderChildren cs cut))))

theorem nodeRightInternalInternalNormalSupport_eq_flatMap_branch
    (r : RuleTag) (s : MultiSequent) (cs : List PTree) :
    nodeRightInternalInternalNormalSupport r s cs =
      (internalCoalgebraAdmissibleCuts (PTree.node r s cs)).flatMap
        (nodeRightInternalInternalNormalBranch r s cs) := by
  rfl

theorem nodeLeftInternalInternalNormalSupport_eq_flatMap_branch
    (r : RuleTag) (s : MultiSequent) (cs : List PTree) :
    nodeLeftInternalInternalNormalSupport r s cs =
      (internalCoalgebraAdmissibleCuts (PTree.node r s cs)).flatMap
        (nodeLeftInternalInternalNormalBranch r s cs) := by
  rfl

theorem coalgebraInternalInternalExtensionPerm_node_normal_of_branches
    (r : RuleTag) (s : MultiSequent) (cs : List PTree)
    (hbranch :
      ∀ cut ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs),
        List.Perm
          (nodeRightInternalInternalNormalBranch r s cs cut)
          (nodeLeftInternalInternalNormalBranch r s cs cut)) :
    List.Perm
      (nodeRightInternalInternalNormalSupport r s cs)
      (nodeLeftInternalInternalNormalSupport r s cs) := by
  rw [nodeRightInternalInternalNormalSupport_eq_flatMap_branch,
    nodeLeftInternalInternalNormalSupport_eq_flatMap_branch]
  exact List.Perm.flatMap_congr_left hbranch

/-- Membership predicate for the right childwise normal support. -/
def NodeRightInternalInternalNormalAtom
    (r : RuleTag) (s : MultiSequent) (cs : List PTree)
    (p : HypersequentTripleBasis) : Prop :=
  ∃ cut ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs),
    ∃ cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut)),
      p =
        (let q :=
          coalgebraTensorTermOfCutList
            (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut)) cut₂
        (HQ.ofForest (nodeRootFreeCutDetachedForest cs cut), q.1, q.2))

/-- Membership predicate for the left childwise normal support. -/
def NodeLeftInternalInternalNormalAtom
    (r : RuleTag) (s : MultiSequent) (cs : List PTree)
    (p : HypersequentTripleBasis) : Prop :=
  ∃ cut ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs),
    ∃ q ∈ coalgebraForestProperSplittingTensorSupport
        (nodeRootFreeCutDetachedForest cs cut),
      p =
        (q.1, q.2,
          HQ.singleton
            (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut)))

theorem mem_nodeRightInternalInternalNormalBranch_iff
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut : List Address} {p : HypersequentTripleBasis} :
    p ∈ nodeRightInternalInternalNormalBranch r s cs cut ↔
      ∃ cut₂ ∈ internalCoalgebraAdmissibleCuts
          (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut)),
        p =
          (let q :=
            coalgebraTensorTermOfCutList
              (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut)) cut₂
          (HQ.ofForest (nodeRootFreeCutDetachedForest cs cut), q.1, q.2)) := by
  unfold nodeRightInternalInternalNormalBranch
  constructor
  · intro hp
    rcases List.mem_map.1 hp with ⟨cut₂, hcut₂, hpq⟩
    exact ⟨cut₂, hcut₂, hpq.symm⟩
  · rintro ⟨cut₂, hcut₂, rfl⟩
    exact List.mem_map.2 ⟨cut₂, hcut₂, rfl⟩

theorem mem_nodeLeftInternalInternalNormalBranch_iff
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut : List Address} {p : HypersequentTripleBasis} :
    p ∈ nodeLeftInternalInternalNormalBranch r s cs cut ↔
      ∃ q ∈ coalgebraForestProperSplittingTensorSupport
          (nodeRootFreeCutDetachedForest cs cut),
        p =
          (q.1, q.2,
            HQ.singleton
              (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut))) := by
  unfold nodeLeftInternalInternalNormalBranch
  constructor
  · intro hp
    rcases List.mem_map.1 hp with ⟨q, hq, hpq⟩
    exact ⟨q, hq, hpq.symm⟩
  · rintro ⟨q, hq, rfl⟩
    exact List.mem_map.2 ⟨q, hq, rfl⟩

theorem mem_nodeRightInternalInternalNormalSupport_iff
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {p : HypersequentTripleBasis} :
    p ∈ nodeRightInternalInternalNormalSupport r s cs ↔
      NodeRightInternalInternalNormalAtom r s cs p := by
  unfold nodeRightInternalInternalNormalSupport
    NodeRightInternalInternalNormalAtom
  constructor
  · intro hp
    rcases List.mem_flatMap.1 hp with ⟨cut, hcut, hpbranch⟩
    rcases (mem_nodeRightInternalInternalNormalBranch_iff
      (r := r) (s := s) (cs := cs) (cut := cut) (p := p)).1 hpbranch with
      ⟨cut₂, hcut₂, hp⟩
    exact ⟨cut, hcut, cut₂, hcut₂, hp⟩
  · rintro ⟨cut, hcut, cut₂, hcut₂, hp⟩
    exact List.mem_flatMap.2
      ⟨cut, hcut,
        (mem_nodeRightInternalInternalNormalBranch_iff
          (r := r) (s := s) (cs := cs) (cut := cut) (p := p)).2
          ⟨cut₂, hcut₂, hp⟩⟩

theorem mem_nodeLeftInternalInternalNormalSupport_iff
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {p : HypersequentTripleBasis} :
    p ∈ nodeLeftInternalInternalNormalSupport r s cs ↔
      NodeLeftInternalInternalNormalAtom r s cs p := by
  unfold nodeLeftInternalInternalNormalSupport
    NodeLeftInternalInternalNormalAtom
  constructor
  · intro hp
    rcases List.mem_flatMap.1 hp with ⟨cut, hcut, hpbranch⟩
    rcases (mem_nodeLeftInternalInternalNormalBranch_iff
      (r := r) (s := s) (cs := cs) (cut := cut) (p := p)).1 hpbranch with
      ⟨q, hq, hp⟩
    exact ⟨cut, hcut, q, hq, hp⟩
  · rintro ⟨cut, hcut, q, hq, hp⟩
    exact List.mem_flatMap.2
      ⟨cut, hcut,
        (mem_nodeLeftInternalInternalNormalBranch_iff
          (r := r) (s := s) (cs := cs) (cut := cut) (p := p)).2
          ⟨q, hq, hp⟩⟩

/--
Ambient cut obtained from two staged internal cuts in the node-normal
coordinate system.

The second-stage cut is read in the same address coordinates as the root-free
remainder.  If a second-stage address is an ancestor of a first-stage address,
the ambient cut must keep the ancestor rather than the lower first-stage
address.  This is the address-level replacement operation behind the remaining
internal/internal coassociativity bijection.
-/
noncomputable def stageAmbientCut
    (cut₁ cut₂ : List Address) : List Address := by
  classical
  exact
    cut₁.filter
      (fun a =>
        decide (∀ b : Address, b ∈ cut₂ → ¬ PTree.isAncestorOf b a)) ++
      cut₂

theorem mem_stageAmbientCut_iff
    {cut₁ cut₂ : List Address} {a : Address} :
    a ∈ stageAmbientCut cut₁ cut₂ ↔
      (a ∈ cut₁ ∧ ∀ b : Address, b ∈ cut₂ → ¬ PTree.isAncestorOf b a) ∨
        a ∈ cut₂ := by
  classical
  unfold stageAmbientCut
  simp

theorem mem_stageAmbientCut_left_of_not_dominated
    {cut₁ cut₂ : List Address} {a : Address}
    (ha : a ∈ cut₁)
    (hnd : ∀ b : Address, b ∈ cut₂ → ¬ PTree.isAncestorOf b a) :
    a ∈ stageAmbientCut cut₁ cut₂ := by
  exact (mem_stageAmbientCut_iff (cut₁ := cut₁) (cut₂ := cut₂) (a := a)).2
    (Or.inl ⟨ha, hnd⟩)

theorem mem_stageAmbientCut_right
    {cut₁ cut₂ : List Address} {a : Address}
    (ha : a ∈ cut₂) :
    a ∈ stageAmbientCut cut₁ cut₂ := by
  exact (mem_stageAmbientCut_iff (cut₁ := cut₁) (cut₂ := cut₂) (a := a)).2
    (Or.inr ha)

theorem stageAmbientCut_filter_mem_second_of_disjoint
    {cut₁ cut₂ : List Address}
    (hdisjoint : ∀ a ∈ cut₁, a ∉ cut₂) :
    (stageAmbientCut cut₁ cut₂).filter
        (fun a => decide (a ∈ cut₂)) =
      cut₂ := by
  classical
  unfold stageAmbientCut
  rw [List.filter_append]
  have hleft :
      (List.filter (fun a =>
          decide (∀ b : Address, b ∈ cut₂ → ¬ PTree.isAncestorOf b a))
          cut₁).filter (fun a => decide (a ∈ cut₂)) = [] := by
    apply List.eq_nil_iff_forall_not_mem.mpr
    intro a ha
    rcases List.mem_filter.1 ha with ⟨haLeft, ha₂⟩
    rcases List.mem_filter.1 haLeft with ⟨ha₁, _hsurvive⟩
    have ha₂Prop : a ∈ cut₂ := by
      simpa using ha₂
    exact hdisjoint a ha₁ ha₂Prop
  have hright :
      cut₂.filter (fun a => decide (a ∈ cut₂)) = cut₂ := by
    apply List.filter_eq_self.2
    intro a ha
    exact by simp [ha]
  simp [hleft, hright]

@[simp]
theorem stageAmbientCut_nil_left
    (cut₂ : List Address) :
    stageAmbientCut ([] : List Address) cut₂ = cut₂ := by
  classical
  simp [stageAmbientCut]

@[simp]
theorem stageAmbientCut_nil_right
    (cut₁ : List Address) :
    stageAmbientCut cut₁ ([] : List Address) = cut₁ := by
  classical
  simp [stageAmbientCut]

theorem stageAmbientCut_eq_append_of_no_right_dominates_left
    {cut₁ cut₂ : List Address}
    (hnd :
      ∀ a : Address, a ∈ cut₁ →
        ∀ b : Address, b ∈ cut₂ → ¬ PTree.isAncestorOf b a) :
    stageAmbientCut cut₁ cut₂ = cut₁ ++ cut₂ := by
  classical
  unfold stageAmbientCut
  have hfilter :
      cut₁.filter
          (fun a =>
            decide
              (∀ b : Address, b ∈ cut₂ → ¬ PTree.isAncestorOf b a)) =
        cut₁ := by
    induction cut₁ with
    | nil =>
        simp
    | cons a rest ih =>
        have ha :
            ∀ b : Address, b ∈ cut₂ → ¬ PTree.isAncestorOf b a :=
          hnd a (by simp)
        have hrest :
            rest.filter
                (fun a =>
                  decide
                    (∀ b : Address, b ∈ cut₂ → ¬ PTree.isAncestorOf b a)) =
              rest := by
          apply ih
          intro x hx b hb
          exact hnd x (by simp [hx]) b hb
        simp [ha, hrest]
        constructor
        · exact ha
        · intro x hx b hb
          exact hnd x (by simp [hx]) b hb
  rw [hfilter]

theorem not_isAncestorOf_root_of_ne_nil
    {a : Address} (ha : a ≠ []) :
    ¬ PTree.isAncestorOf a ([] : Address) := by
  intro h
  rcases h with ⟨c, hc⟩
  cases a with
  | nil =>
      exact ha rfl
  | cons i rest =>
      simp at hc

theorem isAncestorOf_append_single_of_ne
    {a addr : Address} {i : Nat}
    (hanc : PTree.isAncestorOf a (addr ++ [i]))
    (hne : a ≠ addr ++ [i]) :
    PTree.isAncestorOf a addr := by
  rcases hanc with ⟨c, hc⟩
  have hprefix : a <+: addr ++ [i] := ⟨c, hc.symm⟩
  have hcne : c ≠ [] := by
    intro hcNil
    apply hne
    subst c
    simpa using hc.symm
  have hlenC : 0 < c.length := by
    cases c with
    | nil =>
        exact False.elim (hcne rfl)
    | cons x xs =>
        simp
  have hlen : a.length ≤ addr.length := by
    have hlenEq :
        (addr ++ [i]).length = (a ++ c).length := by
      simpa [hc]
    simp at hlenEq
    omega
  have hprefixAddr : a <+: addr :=
    (List.isPrefix_append_of_length
      (l₁ := a) (l₂ := addr) (l₃ := [i]) hlen).1 hprefix
  rcases hprefixAddr with ⟨d, hd⟩
  exact ⟨d, hd.symm⟩

theorem PTree.remainderGo_append_stageAmbient_eq_go
    (cut₁ cut₂ : List Address) (addr : Address) (t : PTree)
    (hnotDominated :
      ∀ b : Address, b ∈ cut₂ → ¬ PTree.isAncestorOf b addr) :
    PTree.remainderGo (cut₁ ++ cut₂) addr t =
      PTree.remainderGo (stageAmbientCut cut₁ cut₂) addr t := by
  cases t with
  | leaf s =>
      simp [PTree.remainderGo]
  | node r s cs =>
      by_cases h₁ : addr ∈ cut₁
      · have h₂ : addr ∉ cut₂ := by
          intro h₂
          exact hnotDominated addr h₂ (PTree.isAncestorOf_refl addr)
        have happ : addr ∈ cut₁ ++ cut₂ := List.mem_append.2 (Or.inl h₁)
        have hstage : addr ∈ stageAmbientCut cut₁ cut₂ :=
          mem_stageAmbientCut_left_of_not_dominated
            (cut₁ := cut₁) (cut₂ := cut₂) h₁ hnotDominated
        simp [PTree.remainderGo, happ, hstage]
      · have h₂ : addr ∉ cut₂ := by
          intro h₂
          exact hnotDominated addr h₂ (PTree.isAncestorOf_refl addr)
        have happ : addr ∉ cut₁ ++ cut₂ := by
          intro h
          rcases List.mem_append.1 h with hleft | hright
          · exact h₁ hleft
          · exact h₂ hright
        have hstage : addr ∉ stageAmbientCut cut₁ cut₂ := by
          intro h
          rcases (mem_stageAmbientCut_iff
            (cut₁ := cut₁) (cut₂ := cut₂) (a := addr)).1 h with
            hleft | hright
          · exact h₁ hleft.1
          · exact h₂ hright
        simp [PTree.remainderGo, happ, hstage]
        apply list_mapIdx_congr_mem
        intro i child hchild
        by_cases hchild₂ : addr ++ [i] ∈ cut₂
        · have happChild :
              addr ++ [i] ∈ cut₁ ++ cut₂ :=
            List.mem_append.2 (Or.inr hchild₂)
          have hstageChild :
              addr ++ [i] ∈ stageAmbientCut cut₁ cut₂ :=
            mem_stageAmbientCut_right
              (cut₁ := cut₁) (cut₂ := cut₂) hchild₂
          cases child.1 <;> simp [PTree.remainderGo, happChild, hstageChild]
        · apply PTree.remainderGo_append_stageAmbient_eq_go
          intro b hb hbanc
          have hbne : b ≠ addr ++ [i] := by
            intro hbEq
            exact hchild₂ (by simpa [hbEq] using hb)
          have hbParent :
              PTree.isAncestorOf b addr :=
            isAncestorOf_append_single_of_ne
              (a := b) (addr := addr) (i := i)
              hbanc hbne
          exact hnotDominated b hb hbParent
termination_by t.size
decreasing_by
  have hlt : child.1.size < (PTree.node r s cs).size := by
    exact child_size_lt_parent (PTree.node r s cs) child.1 (by
      unfold IsImmediateSubtree PTree.children
      exact child.2)
  simpa [PTree.size] using hlt

theorem PTree.remainderGo_append_stageAmbient_eq_root
    (cut₁ cut₂ : List Address) (t : PTree)
    (hroot₂ : ([] : Address) ∉ cut₂) :
    PTree.remainderGo (cut₁ ++ cut₂) [] t =
      PTree.remainderGo (stageAmbientCut cut₁ cut₂) [] t := by
  apply PTree.remainderGo_append_stageAmbient_eq_go
  intro b hb hbroot
  exact not_isAncestorOf_root_of_ne_nil
    (a := b) (by
      intro hbNil
      subst b
      exact hroot₂ hb) hbroot

theorem stageAmbientCut_ne_nil_of_right_ne_nil
    {cut₁ cut₂ : List Address}
    (hcut₂ : cut₂ ≠ []) :
    stageAmbientCut cut₁ cut₂ ≠ [] := by
  intro hnil
  cases cut₂ with
  | nil =>
      exact hcut₂ rfl
  | cons a rest =>
      have ha : a ∈ stageAmbientCut cut₁ (a :: rest) :=
        mem_stageAmbientCut_right
          (cut₁ := cut₁) (cut₂ := a :: rest) (by simp)
      simpa [hnil] using ha

theorem root_not_mem_stageAmbientCut
    {cut₁ cut₂ : List Address}
    (hroot₁ : ([] : Address) ∉ cut₁)
    (hroot₂ : ([] : Address) ∉ cut₂) :
    ([] : Address) ∉ stageAmbientCut cut₁ cut₂ := by
  intro hroot
  rcases (mem_stageAmbientCut_iff
    (cut₁ := cut₁) (cut₂ := cut₂) (a := ([] : Address))).1 hroot with
    hleft | hright
  · exact hroot₁ hleft.1
  · exact hroot₂ hright

theorem internalCut_stageAmbientCut_of_right_internal
    {cut₁ cut₂ : List Address}
    (hroot₁ : ([] : Address) ∉ cut₁)
    (hcut₂ : InternalCut cut₂) :
    InternalCut (stageAmbientCut cut₁ cut₂) := by
  exact
    ⟨stageAmbientCut_ne_nil_of_right_ne_nil
        (cut₁ := cut₁) (cut₂ := cut₂) hcut₂.1,
      root_not_mem_stageAmbientCut
        (cut₁ := cut₁) (cut₂ := cut₂) hroot₁ hcut₂.2⟩

/--
Childwise normal form for staged ambient cuts at a node.

The first and second cuts are restricted to each premise subtree, staged there,
and then reattached under the premise index.  This is the address-level form
of coassociativity that remembers rule arity.
-/
def nodeChildwiseStageAmbientCut
    (cs : List PTree) (cut₁ cut₂ : List Address) : List Address :=
  prefixedChildCuts
    (cs.mapIdx (fun i _child =>
      stageAmbientCut
        (PTree.restrictCut cut₁ i)
        (PTree.restrictCut cut₂ i)))

theorem root_not_mem_nodeChildwiseStageAmbientCut
    (cs : List PTree) (cut₁ cut₂ : List Address) :
    ([] : Address) ∉ nodeChildwiseStageAmbientCut cs cut₁ cut₂ := by
  exact root_not_mem_prefixedChildCuts _

/--
Selector theorem for the childwise staged ambient cut: restricting back to a
child recovers the staged ambient cut of the two child restrictions.
-/
theorem restrictCut_nodeChildwiseStageAmbientCut
    (cs : List PTree) (cut₁ cut₂ : List Address)
    (i : Nat) (hi : i < cs.length) :
    PTree.restrictCut (nodeChildwiseStageAmbientCut cs cut₁ cut₂) i =
      stageAmbientCut
        (PTree.restrictCut cut₁ i)
        (PTree.restrictCut cut₂ i) := by
  unfold nodeChildwiseStageAmbientCut
  have h :=
    restrictCut_prefixedChildCuts
      (cs.mapIdx (fun i _child =>
        stageAmbientCut
          (PTree.restrictCut cut₁ i)
          (PTree.restrictCut cut₂ i)))
      i (by simpa [List.length_mapIdx] using hi)
  simpa [List.getElem_mapIdx] using h

theorem restrictCut_nodeChildwiseStageAmbientCut_ge
    (cs : List PTree) (cut₁ cut₂ : List Address)
    (i : Nat) (hge : cs.length ≤ i) :
    PTree.restrictCut (nodeChildwiseStageAmbientCut cs cut₁ cut₂) i = [] := by
  unfold nodeChildwiseStageAmbientCut
  exact restrictCut_prefixedChildCuts_ge
    (cs.mapIdx (fun i _child =>
      stageAmbientCut
        (PTree.restrictCut cut₁ i)
        (PTree.restrictCut cut₂ i)))
    i (by simpa [List.length_mapIdx] using hge)

/--
Membership in the childwise staged ambient cut is exactly membership in one
child-local staged ambient cut, reattached by the corresponding child index.
-/
theorem mem_nodeChildwiseStageAmbientCut_iff
    {cs : List PTree} {cut₁ cut₂ : List Address} {b : Address} :
    b ∈ nodeChildwiseStageAmbientCut cs cut₁ cut₂ ↔
      ∃ i : Nat, ∃ hi : i < cs.length, ∃ a : Address,
        a ∈ stageAmbientCut
          (PTree.restrictCut cut₁ i)
          (PTree.restrictCut cut₂ i) ∧
        b = i :: a := by
  unfold nodeChildwiseStageAmbientCut
  constructor
  · intro hb
    rcases (mem_prefixedChildCuts_iff.1 hb) with
      ⟨i, hi, a, ha, hbEq⟩
    refine ⟨i, by simpa [List.length_mapIdx] using hi, a, ?_, hbEq⟩
    simpa [List.getElem_mapIdx] using ha
  · rintro ⟨i, hi, a, ha, hbEq⟩
    apply mem_prefixedChildCuts_iff.2
    refine ⟨i, by simpa [List.length_mapIdx] using hi, a, ?_, hbEq⟩
    simpa [List.getElem_mapIdx] using ha

/-- Adding the same child index to both addresses preserves and reflects
ancestorhood. -/
theorem isAncestorOf_cons_cons_iff
    (i : Nat) (a b : Address) :
    PTree.isAncestorOf (i :: a) (i :: b) ↔
      PTree.isAncestorOf a b := by
  constructor
  · intro h
    rcases h with ⟨c, hc⟩
    exact ⟨c, (List.cons.inj hc).2⟩
  · intro h
    rcases h with ⟨c, hc⟩
    refine ⟨c, ?_⟩
    simpa [List.cons_append] using congrArg (fun x => i :: x) hc

/-- Distinct child indices cannot be in an ancestor relation. -/
theorem not_isAncestorOf_cons_cons_ne
    {i j : Nat} {a b : Address} (hij : i ≠ j) :
    ¬ PTree.isAncestorOf (i :: a) (j :: b) := by
  intro h
  rcases h with ⟨c, hc⟩
  exact hij (List.cons.inj hc).1.symm

theorem not_isAncestorOf_append_left_of_ne_nil
    {a c : Address}
    (hc : c ≠ []) :
    ¬ PTree.isAncestorOf (a ++ c) a := by
  rintro ⟨d, hd⟩
  cases c with
  | nil =>
      exact hc rfl
  | cons i rest =>
      have hlen := congrArg List.length hd
      simp [List.length_append] at hlen

/--
For a root-free parent cut, saying that no parent address dominates `i :: a`
is equivalent to saying that no address in the `i`th restricted child cut
dominates `a`.
-/
theorem forall_not_isAncestorOf_cons_iff_restrictCut
    {cut : List Address} (hroot : ([] : Address) ∉ cut)
    (i : Nat) (a : Address) :
    (∀ b : Address, b ∈ cut → ¬ PTree.isAncestorOf b (i :: a)) ↔
      ∀ b : Address, b ∈ PTree.restrictCut cut i →
        ¬ PTree.isAncestorOf b a := by
  constructor
  · intro h b hb hba
    have hparent : i :: b ∈ cut :=
      (PTree.mem_restrictCut_iff
        (cut := cut) (i := i) (addr := b)).1 hb
    exact h (i :: b) hparent
      ((isAncestorOf_cons_cons_iff i b a).2 hba)
  · intro h b hb hba
    cases b with
    | nil =>
        exact hroot hb
    | cons j rest =>
        by_cases hji : j = i
        · subst j
          have hrest : rest ∈ PTree.restrictCut cut i :=
            (PTree.mem_restrictCut_iff
              (cut := cut) (i := i) (addr := rest)).2 hb
          exact h rest hrest
            ((isAncestorOf_cons_cons_iff i rest a).1 hba)
        · exact
            not_isAncestorOf_cons_cons_ne
              (i := j) (j := i) (a := rest) (b := a) hji hba

/--
Subtree descent through a remainder.

If the previous-stage cut has no address at or above `a`, then the subtree
seen at `a` after pruning the ambient tree is precisely the original subtree
pruned by the prefix-restricted cut.  This is the local rooted-tree theorem
used by the nested ambient-detached component of coassociativity.
-/
theorem PTree.subtreeAt_remainderGo_of_forall_not_ancestor
    {cut : List Address} {a : Address} {t u : PTree}
    (hsub : PTree.subtreeAt t a = some u)
    (hnot :
      ∀ b : Address, b ∈ cut → ¬ PTree.isAncestorOf b a) :
    PTree.subtreeAt (PTree.remainderGo cut [] t) a =
      some (PTree.remainderGo (PTree.restrictCutAt cut a) [] u) := by
  induction a generalizing t cut u with
  | nil =>
      simp [PTree.subtreeAt] at hsub
      subst u
      have hroot : ([] : Address) ∉ cut := by
        intro hmem
        exact hnot [] hmem (PTree.isAncestorOf_refl [])
      cases t with
      | leaf s =>
          simpa [PTree.remainderGo, PTree.restrictCutAt] using
            PTree.subtreeAt_root
              (PTree.remainderGo cut [] (PTree.leaf s))
      | node r s cs =>
          simpa [PTree.restrictCutAt] using
            PTree.subtreeAt_root
              (PTree.remainderGo cut [] (PTree.node r s cs))
  | cons i rest ih =>
      cases t with
      | leaf s =>
          simp [PTree.subtreeAt] at hsub
      | node r s cs =>
          by_cases hi : i < cs.length
          · simp [PTree.subtreeAt, hi] at hsub
            have hroot : ([] : Address) ∉ cut := by
              intro hmem
              exact hnot [] hmem (PTree.root_isAncestorOf (i :: rest))
            have hnotChild :
                ∀ b : Address, b ∈ PTree.restrictCut cut i →
                  ¬ PTree.isAncestorOf b rest :=
              (forall_not_isAncestorOf_cons_iff_restrictCut
                (cut := cut) hroot i rest).1 hnot
            have hchild :
                PTree.subtreeAt
                    (PTree.remainderGo (PTree.restrictCut cut i) [] cs[i])
                    rest =
                  some
                    (PTree.remainderGo
                      (PTree.restrictCutAt (PTree.restrictCut cut i) rest)
                      [] u) :=
              ih (t := cs[i]) (cut := PTree.restrictCut cut i)
                (u := u) hsub hnotChild
            have hrem :
                PTree.remainderGo cut [] (PTree.node r s cs) =
                  PTree.node r s
                    (cs.attach.mapIdx (fun j child =>
                      PTree.remainderGo (PTree.restrictCut cut j) []
                        child.1)) := by
              exact PTree.remainderGo_node_root_not_mem
                (r := r) (s := s) (cs := cs) (cut := cut) hroot
            rw [hrem]
            simpa [PTree.subtreeAt, hi, PTree.restrictCutAt] using hchild
          · simp [PTree.subtreeAt, hi] at hsub

/--
Staging commutes with restriction to a child address, provided the
second-stage parent cut is root-free.
-/
theorem mem_stageAmbientCut_cons_iff_restrictCut
    {cut₁ cut₂ : List Address} (hroot₂ : ([] : Address) ∉ cut₂)
    (i : Nat) (a : Address) :
    i :: a ∈ stageAmbientCut cut₁ cut₂ ↔
      a ∈ stageAmbientCut
        (PTree.restrictCut cut₁ i)
        (PTree.restrictCut cut₂ i) := by
  constructor
  · intro h
    rcases (mem_stageAmbientCut_iff
      (cut₁ := cut₁) (cut₂ := cut₂) (a := i :: a)).1 h with
      hleft | hright
    · exact (mem_stageAmbientCut_iff
        (cut₁ := PTree.restrictCut cut₁ i)
        (cut₂ := PTree.restrictCut cut₂ i)
        (a := a)).2
        (Or.inl
          ⟨(PTree.mem_restrictCut_iff
              (cut := cut₁) (i := i) (addr := a)).2 hleft.1,
            (forall_not_isAncestorOf_cons_iff_restrictCut
              (cut := cut₂) hroot₂ i a).1 hleft.2⟩)
    · exact (mem_stageAmbientCut_iff
        (cut₁ := PTree.restrictCut cut₁ i)
        (cut₂ := PTree.restrictCut cut₂ i)
        (a := a)).2
        (Or.inr
          ((PTree.mem_restrictCut_iff
              (cut := cut₂) (i := i) (addr := a)).2 hright))
  · intro h
    rcases (mem_stageAmbientCut_iff
      (cut₁ := PTree.restrictCut cut₁ i)
      (cut₂ := PTree.restrictCut cut₂ i)
      (a := a)).1 h with
      hleft | hright
    · exact (mem_stageAmbientCut_iff
        (cut₁ := cut₁) (cut₂ := cut₂) (a := i :: a)).2
        (Or.inl
          ⟨(PTree.mem_restrictCut_iff
              (cut := cut₁) (i := i) (addr := a)).1 hleft.1,
            (forall_not_isAncestorOf_cons_iff_restrictCut
              (cut := cut₂) hroot₂ i a).2 hleft.2⟩)
    · exact (mem_stageAmbientCut_iff
        (cut₁ := cut₁) (cut₂ := cut₂) (a := i :: a)).2
        (Or.inr
          ((PTree.mem_restrictCut_iff
              (cut := cut₂) (i := i) (addr := a)).1 hright))

/--
Membership-level restriction commutes with staged ambient cuts.

This is the descent fact we actually need: after entering premise `i`, the
global staged cut has exactly the local staged-cut members.
-/
theorem mem_restrictCut_stageAmbientCut_iff
    {cut₁ cut₂ : List Address}
    (hroot₂ : ([] : Address) ∉ cut₂)
    (i : Nat) (a : Address) :
    a ∈ PTree.restrictCut (stageAmbientCut cut₁ cut₂) i ↔
      a ∈ stageAmbientCut
        (PTree.restrictCut cut₁ i)
        (PTree.restrictCut cut₂ i) := by
  rw [PTree.mem_restrictCut_iff]
  exact mem_stageAmbientCut_cons_iff_restrictCut
    (cut₁ := cut₁) (cut₂ := cut₂) hroot₂ i a

theorem mem_restrictCut_stageAmbientCut_iff_nodeChildwiseStageAmbientCut
    {cs : List PTree} {cut₁ cut₂ : List Address}
    (hroot₂ : ([] : Address) ∉ cut₂)
    (i : Nat) (hi : i < cs.length) (a : Address) :
    a ∈ PTree.restrictCut (stageAmbientCut cut₁ cut₂) i ↔
      a ∈ PTree.restrictCut (nodeChildwiseStageAmbientCut cs cut₁ cut₂) i := by
  rw [mem_restrictCut_stageAmbientCut_iff
    (cut₁ := cut₁) (cut₂ := cut₂) hroot₂ i a,
    restrictCut_nodeChildwiseStageAmbientCut cs cut₁ cut₂ i hi]

theorem mem_restrictCut_stageAmbientCut_iff_nodeChildwiseStageAmbientCut_of_internal_node_witness
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address}
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁)))
    (i : Nat) (hi : i < cs.length) (a : Address) :
    a ∈ PTree.restrictCut (stageAmbientCut cut₁ cut₂) i ↔
      a ∈ PTree.restrictCut (nodeChildwiseStageAmbientCut cs cut₁ cut₂) i := by
  have hroot₂ : ([] : Address) ∉ cut₂ :=
    ((mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₂).2.2
  exact mem_restrictCut_stageAmbientCut_iff_nodeChildwiseStageAmbientCut
    (cs := cs) (cut₁ := cut₁) (cut₂ := cut₂)
    hroot₂ i hi a

theorem mem_append_of_mem_stageAmbientCut
    {cut₁ cut₂ : List Address} {a : Address}
    (ha : a ∈ stageAmbientCut cut₁ cut₂) :
    a ∈ cut₁ ++ cut₂ := by
  rcases (mem_stageAmbientCut_iff
    (cut₁ := cut₁) (cut₂ := cut₂) (a := a)).1 ha with hleft | hright
  · exact List.mem_append.2 (Or.inl hleft.1)
  · exact List.mem_append.2 (Or.inr hright)

theorem stageAmbientCut_subset_append
    (cut₁ cut₂ : List Address) :
    ∀ a : Address, a ∈ stageAmbientCut cut₁ cut₂ → a ∈ cut₁ ++ cut₂ :=
  fun a ha => mem_append_of_mem_stageAmbientCut
    (cut₁ := cut₁) (cut₂ := cut₂) ha

theorem stageAmbientCut_sublist_append
    (cut₁ cut₂ : List Address) :
    List.Sublist (stageAmbientCut cut₁ cut₂) (cut₁ ++ cut₂) := by
  classical
  unfold stageAmbientCut
  exact (List.filter_sublist).append (List.Sublist.refl cut₂)

theorem stageAmbientCut_nodup_of_append_nodup
    {cut₁ cut₂ : List Address}
    (hnodup : (cut₁ ++ cut₂).Nodup) :
    (stageAmbientCut cut₁ cut₂).Nodup :=
  hnodup.sublist (stageAmbientCut_sublist_append cut₁ cut₂)

theorem stageAmbientCut_antichain_of_append_antichain
    {cut₁ cut₂ : List Address}
    (hanti :
      ∀ a, a ∈ cut₁ ++ cut₂ →
        ∀ b, b ∈ cut₁ ++ cut₂ →
          a ≠ b → ¬ PTree.comparable a b) :
    ∀ a, a ∈ stageAmbientCut cut₁ cut₂ →
      ∀ b, b ∈ stageAmbientCut cut₁ cut₂ →
        a ≠ b → ¬ PTree.comparable a b := by
  intro a ha b hb hne
  exact hanti a
    (mem_append_of_mem_stageAmbientCut
      (cut₁ := cut₁) (cut₂ := cut₂) ha)
    b
      (mem_append_of_mem_stageAmbientCut
        (cut₁ := cut₁) (cut₂ := cut₂) hb)
    hne

theorem append_antichain_of_parts
    {cut₁ cut₂ : List Address}
    (hanti₁ :
      ∀ a, a ∈ cut₁ →
        ∀ b, b ∈ cut₁ →
          a ≠ b → ¬ PTree.comparable a b)
    (hanti₂ :
      ∀ a, a ∈ cut₂ →
        ∀ b, b ∈ cut₂ →
          a ≠ b → ¬ PTree.comparable a b)
    (hcross :
      ∀ a, a ∈ cut₁ →
        ∀ b, b ∈ cut₂ →
          a ≠ b → ¬ PTree.comparable a b) :
    ∀ a, a ∈ cut₁ ++ cut₂ →
      ∀ b, b ∈ cut₁ ++ cut₂ →
        a ≠ b → ¬ PTree.comparable a b := by
  intro a ha b hb hne
  rcases List.mem_append.1 ha with ha₁ | ha₂
  · rcases List.mem_append.1 hb with hb₁ | hb₂
    · exact hanti₁ a ha₁ b hb₁ hne
    · exact hcross a ha₁ b hb₂ hne
  · rcases List.mem_append.1 hb with hb₁ | hb₂
    · intro hcomp
      exact hcross b hb₁ a ha₂ (fun hba => hne hba.symm)
        (PTree.comparable_symm hcomp)
    · exact hanti₂ a ha₂ b hb₂ hne

theorem append_nodup_of_parts_disjoint
    {cut₁ cut₂ : List Address}
    (hnodup₁ : cut₁.Nodup)
    (hnodup₂ : cut₂.Nodup)
    (hdisj : ∀ a : Address, a ∈ cut₁ → a ∉ cut₂) :
    (cut₁ ++ cut₂).Nodup := by
  induction cut₁ with
  | nil =>
      simpa using hnodup₂
  | cons a rest ih =>
      have hnotRest : a ∉ rest := by
        exact (List.nodup_cons.mp hnodup₁).1
      have hnodupRest : rest.Nodup := by
        exact (List.nodup_cons.mp hnodup₁).2
      have htail :
          (rest ++ cut₂).Nodup :=
        ih hnodupRest
          (by
            intro b hb
            exact hdisj b (by simp [hb]))
      have hnotTail : a ∉ rest ++ cut₂ := by
        intro ha
        rcases List.mem_append.1 ha with haRest | ha₂
        · exact hnotRest haRest
        · exact hdisj a (by simp) ha₂
      simpa [List.cons_append] using
        List.Nodup.cons hnotTail htail

theorem stageAmbientCut_nodup_of_parts_disjoint
    {cut₁ cut₂ : List Address}
    (hnodup₁ : cut₁.Nodup)
    (hnodup₂ : cut₂.Nodup)
    (hdisj : ∀ a : Address, a ∈ cut₁ → a ∉ cut₂) :
    (stageAmbientCut cut₁ cut₂).Nodup := by
  exact stageAmbientCut_nodup_of_append_nodup
    (cut₁ := cut₁) (cut₂ := cut₂)
    (append_nodup_of_parts_disjoint hnodup₁ hnodup₂ hdisj)

theorem stageAmbientCut_antichain_of_parts_survivor_cross
    {cut₁ cut₂ : List Address}
    (hanti₁ :
      ∀ a, a ∈ cut₁ →
        ∀ b, b ∈ cut₁ →
          a ≠ b → ¬ PTree.comparable a b)
    (hanti₂ :
      ∀ a, a ∈ cut₂ →
        ∀ b, b ∈ cut₂ →
          a ≠ b → ¬ PTree.comparable a b)
    (hcross :
      ∀ a, a ∈ cut₁ →
        (∀ c, c ∈ cut₂ → ¬ PTree.isAncestorOf c a) →
        ∀ b, b ∈ cut₂ →
          a ≠ b → ¬ PTree.comparable a b) :
    ∀ a, a ∈ stageAmbientCut cut₁ cut₂ →
      ∀ b, b ∈ stageAmbientCut cut₁ cut₂ →
        a ≠ b → ¬ PTree.comparable a b := by
  intro a ha b hb hne
  rcases (mem_stageAmbientCut_iff
    (cut₁ := cut₁) (cut₂ := cut₂) (a := a)).1 ha with
    haLeft | haRight
  · rcases (mem_stageAmbientCut_iff
      (cut₁ := cut₁) (cut₂ := cut₂) (a := b)).1 hb with
      hbLeft | hbRight
    · exact hanti₁ a haLeft.1 b hbLeft.1 hne
    · exact hcross a haLeft.1 haLeft.2 b hbRight hne
  · rcases (mem_stageAmbientCut_iff
      (cut₁ := cut₁) (cut₂ := cut₂) (a := b)).1 hb with
      hbLeft | hbRight
    · intro hcomp
      exact hcross b hbLeft.1 hbLeft.2 a haRight
        (fun hba => hne hba.symm)
        (PTree.comparable_symm hcomp)
    · exact hanti₂ a haRight b hbRight hne

/--
If the two staged cuts only use child indices below the node arity, then the
global staged ambient cut is membership-equivalent to the childwise staged
normal form.
-/
theorem mem_stageAmbientCut_iff_nodeChildwiseStageAmbientCut_of_bound
    {cs : List PTree} {cut₁ cut₂ : List Address} {b : Address}
    (hroot₁ : ([] : Address) ∉ cut₁)
    (hroot₂ : ([] : Address) ∉ cut₂)
    (hbound :
      ∀ i : Nat, ∀ a : Address,
        i :: a ∈ cut₁ ++ cut₂ → i < cs.length) :
    b ∈ stageAmbientCut cut₁ cut₂ ↔
      b ∈ nodeChildwiseStageAmbientCut cs cut₁ cut₂ := by
  constructor
  · intro hb
    cases b with
    | nil =>
        exact False.elim
          (root_not_mem_stageAmbientCut
            (cut₁ := cut₁) (cut₂ := cut₂) hroot₁ hroot₂ hb)
    | cons i a =>
        have hi : i < cs.length :=
          hbound i a
            (mem_append_of_mem_stageAmbientCut
              (cut₁ := cut₁) (cut₂ := cut₂) hb)
        exact (mem_nodeChildwiseStageAmbientCut_iff
          (cs := cs) (cut₁ := cut₁) (cut₂ := cut₂)
          (b := i :: a)).2
          ⟨i, hi, a,
            (mem_stageAmbientCut_cons_iff_restrictCut
              (cut₁ := cut₁) (cut₂ := cut₂) hroot₂ i a).1 hb,
            rfl⟩
  · intro hb
    rcases (mem_nodeChildwiseStageAmbientCut_iff
      (cs := cs) (cut₁ := cut₁) (cut₂ := cut₂) (b := b)).1 hb with
      ⟨i, _hi, a, ha, hbEq⟩
    subst b
    exact (mem_stageAmbientCut_cons_iff_restrictCut
      (cut₁ := cut₁) (cut₂ := cut₂) hroot₂ i a).2 ha

/--
Node-specialized childwise form of staged cuts.

The first cut is a root-free coalgebra cut of the original node, while the
second cut is a root-free coalgebra cut of the root-free remainder node.  Both
therefore descend through the same premise arity `cs.length`.
-/
theorem mem_stageAmbientCut_iff_nodeChildwiseStageAmbientCut_of_node_cuts
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address} {b : Address}
    (hcut₁ : cut₁ ∈ coalgebraAdmissibleCuts (PTree.node r s cs))
    (hroot₁ : ([] : Address) ∉ cut₁)
    (hcut₂ :
      cut₂ ∈ coalgebraAdmissibleCuts
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁)))
    (hroot₂ : ([] : Address) ∉ cut₂) :
    b ∈ stageAmbientCut cut₁ cut₂ ↔
      b ∈ nodeChildwiseStageAmbientCut cs cut₁ cut₂ := by
  apply mem_stageAmbientCut_iff_nodeChildwiseStageAmbientCut_of_bound
      (cs := cs) (cut₁ := cut₁) (cut₂ := cut₂)
      (b := b) hroot₁ hroot₂
  intro i a hmem
  rcases List.mem_append.1 hmem with h₁ | h₂
  · exact cons_mem_coalgebraAdmissibleCuts_node_index_lt
      (r := r) (s := s) (cs := cs) (cut := cut₁)
      hcut₁ h₁
  · have hi :
        i < (nodeRootFreeCutRemainderChildren cs cut₁).length :=
      cons_mem_coalgebraAdmissibleCuts_node_index_lt
        (r := r) (s := s)
        (cs := nodeRootFreeCutRemainderChildren cs cut₁)
        (cut := cut₂) hcut₂ h₂
    simpa [nodeRootFreeCutRemainderChildren_length] using hi

/--
Internal-sector version of the node-specialized childwise staged-cut theorem.
This is the exact address descent form used by the right internal/internal
witnesses.
-/
theorem mem_stageAmbientCut_iff_nodeChildwiseStageAmbientCut_of_internal_node_cuts
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address} {b : Address}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))) :
    b ∈ stageAmbientCut cut₁ cut₂ ↔
      b ∈ nodeChildwiseStageAmbientCut cs cut₁ cut₂ := by
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₁ with
    ⟨hcoal₁, hint₁⟩
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₂ with
    ⟨hcoal₂, hint₂⟩
  exact mem_stageAmbientCut_iff_nodeChildwiseStageAmbientCut_of_node_cuts
    (r := r) (s := s) (cs := cs)
    (cut₁ := cut₁) (cut₂ := cut₂) (b := b)
    hcoal₁ hint₁.2 hcoal₂ hint₂.2

/--
The ambient cut produced by a right internal/internal node witness is itself
an internal cut at the address level.
-/
theorem internalCut_stageAmbientCut_of_internal_node_witness
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))) :
    InternalCut (stageAmbientCut cut₁ cut₂) := by
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₁ with
    ⟨_hcoal₁, hint₁⟩
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₂ with
    ⟨_hcoal₂, hint₂⟩
  exact internalCut_stageAmbientCut_of_right_internal
    (cut₁ := cut₁) (cut₂ := cut₂) hint₁.2 hint₂

/--
The ambient cut of a right internal/internal node witness satisfies the
coalgebra node-address condition.  This proves the semantic part of
coalgebra-cut admissibility; the remaining raw admissibility/antichain part is
the separate tree-cut extension obligation.
-/
theorem isCoalgebraCut_stageAmbientCut_of_internal_node_witness
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))) :
    IsCoalgebraCut (PTree.node r s cs) (stageAmbientCut cut₁ cut₂) := by
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₁ with
    ⟨hcoal₁, hint₁⟩
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₂ with
    ⟨hcoal₂, hint₂⟩
  refine Or.inr (Or.inr ?_)
  intro a ha
  rcases (mem_stageAmbientCut_iff
    (cut₁ := cut₁) (cut₂ := cut₂) (a := a)).1 ha with
    hleft | hright
  · exact node_addresses_of_mem_coalgebraAdmissibleCuts_of_internal
      hcoal₁ hint₁ a hleft.1
  · have hrem :
        PTree.remainderGo cut₁ [] (PTree.node r s cs) =
          PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁) := by
      simpa [nodeRootFreeCutRemainderChildren] using
        PTree.remainderGo_node_root_not_mem
          (r := r) (s := s) (cs := cs)
          (cut := cut₁) hint₁.2
    have hcoal₂' :
        cut₂ ∈ coalgebraAdmissibleCuts
          (PTree.remainderGo cut₁ [] (PTree.node r s cs)) := by
      simpa [hrem] using hcoal₂
    exact node_addresses_of_mem_remainder_coalgebraAdmissibleCuts_of_internal
      (t := PTree.node r s cs) (cut₁ := cut₁) (cut₂ := cut₂)
      hcoal₂' hint₂ a hright

theorem validAddress_stageAmbientCut_of_internal_node_witness
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))) :
    ∀ a : Address, a ∈ stageAmbientCut cut₁ cut₂ →
      PTree.ValidAddress (PTree.node r s cs) a := by
  intro a ha
  rcases (mem_stageAmbientCut_iff
    (cut₁ := cut₁) (cut₂ := cut₂) (a := a)).1 ha with
    hleft | hright
  · rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₁ with
      ⟨hcoal₁, hint₁⟩
    exact validAddress_of_isNodeAddress
      (node_addresses_of_mem_coalgebraAdmissibleCuts_of_internal
        hcoal₁ hint₁ a hleft.1)
  · rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₁ with
      ⟨_hcoal₁, hint₁⟩
    rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₂ with
      ⟨hcoal₂, hint₂⟩
    have hrem :
        PTree.remainderGo cut₁ [] (PTree.node r s cs) =
          PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁) := by
      simpa [nodeRootFreeCutRemainderChildren] using
        PTree.remainderGo_node_root_not_mem
          (r := r) (s := s) (cs := cs)
          (cut := cut₁) hint₁.2
    have hcoal₂' :
        cut₂ ∈ coalgebraAdmissibleCuts
          (PTree.remainderGo cut₁ [] (PTree.node r s cs)) := by
      simpa [hrem] using hcoal₂
    exact validAddress_of_isNodeAddress
      (node_addresses_of_mem_remainder_coalgebraAdmissibleCuts_of_internal
        (t := PTree.node r s cs) (cut₁ := cut₁) (cut₂ := cut₂)
        hcoal₂' hint₂ a hright)

/--
The ambient cut produced by a right internal/internal node witness is bounded
by the premise arity of the node.
-/
theorem stageAmbientCut_node_witness_child_index_lt
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address} {i : Nat} {a : Address}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁)))
    (hmem : i :: a ∈ stageAmbientCut cut₁ cut₂) :
    i < cs.length := by
  have happ : i :: a ∈ cut₁ ++ cut₂ :=
    mem_append_of_mem_stageAmbientCut
      (cut₁ := cut₁) (cut₂ := cut₂) hmem
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₁ with
    ⟨hcoal₁, _hint₁⟩
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₂ with
    ⟨hcoal₂, _hint₂⟩
  rcases List.mem_append.1 happ with h₁ | h₂
  · exact cons_mem_coalgebraAdmissibleCuts_node_index_lt
      (r := r) (s := s) (cs := cs) (cut := cut₁)
      hcoal₁ h₁
  · have hi :
        i < (nodeRootFreeCutRemainderChildren cs cut₁).length :=
      cons_mem_coalgebraAdmissibleCuts_node_index_lt
        (r := r) (s := s)
        (cs := nodeRootFreeCutRemainderChildren cs cut₁)
        (cut := cut₂) hcoal₂ h₂
    simpa [nodeRootFreeCutRemainderChildren_length] using hi

theorem stageAmbientCut_mem_allAddresses_of_internal_node_witness
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address} :
    cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs) →
    cut₂ ∈ internalCoalgebraAdmissibleCuts
      (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁)) →
    ∀ a : Address, a ∈ stageAmbientCut cut₁ cut₂ →
      a ∈ PTree.allAddresses (PTree.node r s cs) := by
  intro hcut₁ hcut₂ a ha
  exact mem_allAddresses_of_validAddress
    (validAddress_stageAmbientCut_of_internal_node_witness
      (r := r) (s := s) (cs := cs)
      (cut₁ := cut₁) (cut₂ := cut₂)
      hcut₁ hcut₂ a ha)

/--
Local copy of the previous-cut leaf-collapse fact, placed before the
node-ambient admissibility lemmas so they can use it without forward
references.
-/
theorem exists_leaf_subtreeAt_remainderGo_of_mem_isAdmissibleCut_for_stage
    {t : PTree} {cut : List Address} {a : Address}
    (C : PTree.IsAdmissibleCut t)
    (ha : a ∈ C.nodes) :
    ∃ s : MultiSequent,
      PTree.subtreeAt (PTree.remainderGo C.nodes [] t) a =
        some (PTree.leaf s) := by
  induction a generalizing t cut with
  | nil =>
      cases t with
      | leaf s =>
          exact ⟨s, by simp [PTree.remainderGo, PTree.subtreeAt]⟩
      | node r s cs =>
          have hroot : ([] : Address) ∈ C.nodes := ha
          exact ⟨s, by simp [PTree.remainderGo, PTree.subtreeAt, hroot]⟩
  | cons i rest ih =>
      cases t with
      | leaf s =>
          have hvalid := C.valid (i :: rest) ha
          simp [PTree.ValidAddress, PTree.validAddress, PTree.subtreeAt] at hvalid
      | node r s cs =>
          have hroot : ([] : Address) ∉ C.nodes := by
            intro hnil
            exact C.antichain ([] : Address) hnil (i :: rest) ha
              (by simp)
              (Or.inl (PTree.root_isAncestorOf (i :: rest)))
          have hvalid := C.valid (i :: rest) ha
          have hi : i < cs.length := by
            by_contra hi
            simp [PTree.ValidAddress, PTree.validAddress,
              PTree.subtreeAt, hi] at hvalid
          have hrest : rest ∈ PTree.restrictCut C.nodes i := by
            exact (PTree.mem_restrictCut_iff
              (cut := C.nodes) (i := i) (addr := rest)).2 ha
          let Cchild : PTree.IsAdmissibleCut cs[i] :=
            PTree.isAdmissibleCut_restrictCut C i hi
          rcases ih
              (t := cs[i])
              (cut := PTree.restrictCut C.nodes i)
              Cchild
              (by
                change rest ∈ PTree.restrictCut C.nodes i
                exact hrest) with
            ⟨leafSeq, hleaf⟩
          refine ⟨leafSeq, ?_⟩
          have hrem :
              PTree.remainderGo C.nodes [] (PTree.node r s cs) =
                PTree.node r s
                  (cs.attach.mapIdx (fun j child =>
                    PTree.remainderGo (PTree.restrictCut C.nodes j) []
                      child.1)) := by
            exact PTree.remainderGo_node_root_not_mem
              (r := r) (s := s) (cs := cs) (cut := C.nodes) hroot
          rw [hrem]
          simpa [PTree.subtreeAt, hi, Cchild] using hleaf

theorem disjoint_previous_cut_second_internal_cut_for_stage
    {t : PTree} {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ coalgebraAdmissibleCuts t)
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.remainderGo cut₁ [] t)) :
    ∀ a : Address, a ∈ cut₁ → a ∉ cut₂ := by
  intro a ha₁ ha₂
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₂ with
    ⟨hcoal₂, hinternal₂⟩
  rcases exists_leaf_subtreeAt_remainderGo_of_mem_isAdmissibleCut_for_stage
      (t := t) (cut := cut₁) (a := a)
      (PTree.isAdmissibleCut_of_mem_allAdmissibleCuts
        ((mem_coalgebraAdmissibleCuts_iff).1 hcut₁).1)
      ha₁ with
    ⟨leafSeq, hleaf⟩
  have hnode :=
    node_addresses_of_mem_coalgebraAdmissibleCuts_of_internal
      hcoal₂ hinternal₂ a ha₂
  rcases hnode with ⟨r, s, cs, hsub⟩
  have hleaf' :
      PTree.subtreeAt (PTree.remainderGo cut₁ [] t) a =
        some (PTree.leaf leafSeq) := by
    simpa using hleaf
  rw [hleaf'] at hsub
  cases hsub

theorem not_isNodeAddress_below_leaf_for_stage
    {t : PTree} {a b : Address} {s : MultiSequent}
    (hleaf : PTree.subtreeAt t a = some (PTree.leaf s))
    (hab : PTree.isAncestorOf a b)
    (hne : b ≠ a) :
    ¬ IsNodeAddress t b := by
  intro hnode
  rcases hab with ⟨c, hbEq⟩
  cases c with
  | nil =>
      simp at hbEq
      exact hne hbEq
  | cons i rest =>
      rcases hnode with ⟨r, s', cs, hsub⟩
      have hnone :
          PTree.subtreeAt t (a ++ (i :: rest)) = none :=
        subtreeAt_eq_leaf_append_none
          t a (i :: rest) s hleaf (by simp)
      rw [hbEq] at hsub
      rw [hnone] at hsub
      cases hsub

theorem not_previous_cut_ancestor_of_second_internal_cut_for_stage
    {t : PTree} {cut₁ cut₂ : List Address} {a b : Address}
    (hcut₁ : cut₁ ∈ coalgebraAdmissibleCuts t)
    (ha₁ : a ∈ cut₁)
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.remainderGo cut₁ [] t))
    (hb₂ : b ∈ cut₂) :
    ¬ PTree.isAncestorOf a b := by
  intro hab
  have hneq : b ≠ a := by
    intro hba
    subst b
    exact disjoint_previous_cut_second_internal_cut_for_stage
      (t := t) (cut₁ := cut₁) (cut₂ := cut₂)
      hcut₁ hcut₂ a ha₁ hb₂
  rcases exists_leaf_subtreeAt_remainderGo_of_mem_isAdmissibleCut_for_stage
      (t := t) (cut := cut₁) (a := a)
      (PTree.isAdmissibleCut_of_mem_allAdmissibleCuts
        ((mem_coalgebraAdmissibleCuts_iff).1 hcut₁).1)
      ha₁ with
    ⟨leafSeq, hleaf⟩
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₂ with
    ⟨hcoal₂, hint₂⟩
  have hnode₂ : IsNodeAddress (PTree.remainderGo cut₁ [] t) b :=
    node_addresses_of_mem_coalgebraAdmissibleCuts_of_internal
      hcoal₂ hint₂ b hb₂
  exact not_isNodeAddress_below_leaf_for_stage
    (t := PTree.remainderGo cut₁ [] t)
    (a := a) (b := b) hleaf hab hneq hnode₂

theorem not_comparable_surviving_previous_cut_second_internal_cut_for_stage
    {t : PTree} {cut₁ cut₂ : List Address} {a b : Address}
    (hcut₁ : cut₁ ∈ coalgebraAdmissibleCuts t)
    (ha₁ : a ∈ cut₁)
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.remainderGo cut₁ [] t))
    (hsurvive : ∀ c : Address, c ∈ cut₂ → ¬ PTree.isAncestorOf c a)
    (hb₂ : b ∈ cut₂)
    (hne : a ≠ b) :
    ¬ PTree.comparable a b := by
  intro hcomp
  rcases hcomp with hab | hba
  · exact not_previous_cut_ancestor_of_second_internal_cut_for_stage
      (t := t) (cut₁ := cut₁) (cut₂ := cut₂)
      hcut₁ ha₁ hcut₂ hb₂ hab
  · exact hsurvive b hb₂ hba

/--
The staged ambient cut of a right internal/internal node witness is
duplicate-free.

This is no longer an abstract list fact: disjointness comes from the rooted
descent lemma saying that an internal second-stage cut cannot choose an address
already collapsed by the first-stage cut.
-/
theorem stageAmbientCut_nodup_of_internal_node_witness
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))) :
    (stageAmbientCut cut₁ cut₂).Nodup := by
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₁ with
    ⟨hcoal₁, hint₁⟩
  have hrem :
      PTree.remainderGo cut₁ [] (PTree.node r s cs) =
        PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁) := by
    simpa [nodeRootFreeCutRemainderChildren] using
      PTree.remainderGo_node_root_not_mem
        (r := r) (s := s) (cs := cs) (cut := cut₁) hint₁.2
  have hcut₂' :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.remainderGo cut₁ [] (PTree.node r s cs)) := by
    simpa [hrem] using hcut₂
  exact stageAmbientCut_nodup_of_parts_disjoint
    (cut₁ := cut₁) (cut₂ := cut₂)
    (nodup_of_mem_internalCoalgebraAdmissibleCuts hcut₁)
    (nodup_of_mem_internalCoalgebraAdmissibleCuts hcut₂)
    (disjoint_previous_cut_second_internal_cut_for_stage
      (t := PTree.node r s cs)
      (cut₁ := cut₁) (cut₂ := cut₂)
      hcoal₁ hcut₂')

/--
The staged ambient cut of a right internal/internal node witness is an
antichain.

The same-child cases are inherited from the two admissible cuts.  The
cross-child/cross-stage case is the proof-theoretic content: a surviving
first-stage address is not dominated by the second stage by definition of
`stageAmbientCut`, and it cannot dominate a second-stage internal address
because that address would lie below a leaf in the first remainder.
-/
theorem stageAmbientCut_antichain_of_internal_node_witness
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))) :
    ∀ a, a ∈ stageAmbientCut cut₁ cut₂ →
      ∀ b, b ∈ stageAmbientCut cut₁ cut₂ →
        a ≠ b → ¬ PTree.comparable a b := by
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₁ with
    ⟨hcoal₁, hint₁⟩
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₂ with
    ⟨hcoal₂, _hint₂⟩
  have hrem :
      PTree.remainderGo cut₁ [] (PTree.node r s cs) =
        PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁) := by
    simpa [nodeRootFreeCutRemainderChildren] using
      PTree.remainderGo_node_root_not_mem
        (r := r) (s := s) (cs := cs) (cut := cut₁) hint₁.2
  have hcut₂' :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.remainderGo cut₁ [] (PTree.node r s cs)) := by
    simpa [hrem] using hcut₂
  exact stageAmbientCut_antichain_of_parts_survivor_cross
    (cut₁ := cut₁) (cut₂ := cut₂)
    (antichain_of_mem_coalgebraAdmissibleCuts hcoal₁)
    (antichain_of_mem_coalgebraAdmissibleCuts hcoal₂)
    (by
      intro a ha₁ hsurvive b hb₂ hne
      exact not_comparable_surviving_previous_cut_second_internal_cut_for_stage
        (t := PTree.node r s cs)
        (cut₁ := cut₁) (cut₂ := cut₂)
        hcoal₁ ha₁ hcut₂' hsurvive hb₂ hne)

/--
Ambient cut associated to a right internal/internal node witness.

This is the corrected witness map: the left side is indexed by the staged
ambient cut, not by the first cut alone.
-/
def nodeAmbientCutOfRightWitness
    (cut₁ cut₂ : List Address) : List Address :=
  stageAmbientCut cut₁ cut₂

/--
Canonical ordered ambient cut for a node witness.

The staged cut carries the right membership predicate.  This version reorders
that predicate by the node's own address enumeration, making it a genuine
candidate for `PTree.allAdmissibleCuts` without changing the remainder.
-/
def nodeCanonicalAmbientCutOfRightWitness
    (r : RuleTag) (s : MultiSequent) (cs : List PTree)
    (cut₁ cut₂ : List Address) : List Address :=
  PTree.canonicalCut (PTree.node r s cs)
    (nodeAmbientCutOfRightWitness cut₁ cut₂)

theorem mem_nodeCanonicalAmbientCutOfRightWitness_iff
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address} {a : Address}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))) :
    a ∈ nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂ ↔
      a ∈ nodeAmbientCutOfRightWitness cut₁ cut₂ := by
  unfold nodeCanonicalAmbientCutOfRightWitness
  apply PTree.mem_canonicalCut_iff_of_forall_mem_allAddresses
  intro b hb
  exact stageAmbientCut_mem_allAddresses_of_internal_node_witness
    (r := r) (s := s) (cs := cs)
    (cut₁ := cut₁) (cut₂ := cut₂)
    hcut₁ hcut₂ b (by simpa [nodeAmbientCutOfRightWitness] using hb)

theorem nodeCanonicalAmbientCut_sublist_allAddresses
    (r : RuleTag) (s : MultiSequent) (cs : List PTree)
    (cut₁ cut₂ : List Address) :
    List.Sublist
      (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂)
      (PTree.allAddresses (PTree.node r s cs)) := by
  unfold nodeCanonicalAmbientCutOfRightWitness
  exact PTree.canonicalCut_sublist_allAddresses _ _

theorem nodeCanonicalAmbientCut_remainderGo_eq_stage
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))) :
    PTree.remainderGo
      (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂) []
      (PTree.node r s cs) =
      PTree.remainderGo (nodeAmbientCutOfRightWitness cut₁ cut₂) []
        (PTree.node r s cs) := by
  unfold nodeCanonicalAmbientCutOfRightWitness
  apply PTree.remainderGo_canonicalCut_eq
  intro a ha
  exact stageAmbientCut_mem_allAddresses_of_internal_node_witness
    (r := r) (s := s) (cs := cs)
    (cut₁ := cut₁) (cut₂ := cut₂)
    hcut₁ hcut₂ a (by simpa [nodeAmbientCutOfRightWitness] using ha)

theorem internalCut_nodeCanonicalAmbientCutOfRightWitness
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))) :
    InternalCut (nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂) := by
  have hint :
      InternalCut (nodeAmbientCutOfRightWitness cut₁ cut₂) :=
    by
      simpa [nodeAmbientCutOfRightWitness] using
        internalCut_stageAmbientCut_of_internal_node_witness
          (r := r) (s := s) (cs := cs)
          (cut₁ := cut₁) (cut₂ := cut₂) hcut₁ hcut₂
  constructor
  · intro hnil
    cases hstage : nodeAmbientCutOfRightWitness cut₁ cut₂ with
    | nil =>
        exact hint.1 hstage
    | cons a rest =>
        have haStage :
            a ∈ nodeAmbientCutOfRightWitness cut₁ cut₂ := by
          simp [hstage]
        have haCanon :
            a ∈ nodeCanonicalAmbientCutOfRightWitness r s cs cut₁ cut₂ :=
          (mem_nodeCanonicalAmbientCutOfRightWitness_iff
            (r := r) (s := s) (cs := cs)
            (cut₁ := cut₁) (cut₂ := cut₂)
            hcut₁ hcut₂).2 haStage
        simpa [hnil] using haCanon
  · intro hroot
    exact hint.2
      ((mem_nodeCanonicalAmbientCutOfRightWitness_iff
        (r := r) (s := s) (cs := cs)
        (cut₁ := cut₁) (cut₂ := cut₂)
        hcut₁ hcut₂).1 hroot)

