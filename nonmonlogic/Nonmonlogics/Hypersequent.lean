    (root_not_mem_restrictCutAt_of_second_internal
      (t := t) (cut₁ := cut₁) (cut₂ := cut₂) (b := b)
      hcut₁ hcut₂ hb₂)

theorem coalgebraTensorTermOfCutList_restrictCutAt_second_internal_fst
    {t : PTree} {cut₁ cut₂ : List Address} {b : Address} {u : PTree}
