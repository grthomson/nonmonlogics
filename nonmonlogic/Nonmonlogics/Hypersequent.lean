theorem hypersequentNormalizedHopfAxioms_direct_right_cancellation
    (K : Type) [CommRing K]
    [LeftDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))]
    [RightDistribClass
      (TensorProduct K (HypersequentAlgebra K) (HypersequentAlgebra K))] :
    LinearMap.mul' K (HypersequentAlgebra K) ∘ₗ
        LinearMap.rTensor (HypersequentAlgebra K)
          (hypersequentNormalizedHopfAxioms_direct K).antipode ∘ₗ
          hypersequentCoalgebraComulTensorLinearMap K =
