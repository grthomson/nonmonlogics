    simpa [addrs] using
      List.left_mem_of_mem_zip
        (xs := nodeRootFreeCutPrefixedRestrictions cs ambient)
        (ys := profile) (a := a) (b := cutA) hzipA
  have hbAddrs : b ∈ addrs := by
    simpa [addrs] using
      List.left_mem_of_mem_zip
        (xs := nodeRootFreeCutPrefixedRestrictions cs ambient)
        (ys := profile) (a := b) (b := cutB) hzipB
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hambient with
