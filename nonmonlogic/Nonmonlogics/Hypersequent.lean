theorem list_ne_nil_of_perm_ne_nil
    {α : Type _} {xs ys : List α}
    (hperm : List.Perm xs ys)
    (hxs : xs ≠ []) :
    ys ≠ [] := by
  intro hys
  cases xs with
  | nil =>
      exact hxs rfl
  | cons x xs =>
      have hx : x ∈ x :: xs := by simp
      have hy : x ∈ ys := (hperm.mem_iff).1 hx
      simpa [hys] using hy

theorem nodeRootFreeCutDetachedForest_nonempty_of_internal_node
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut : List Address}
    (hcut : cut ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs)) :
    nodeRootFreeCutDetachedForest cs cut ≠ [] := by
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut with
    ⟨hcoal, hint⟩
  have hraw :
      coalgebraDetachedForestOfCut (PTree.node r s cs) cut ≠ [] := by
    have hfilter :
        cut.filterMap (PTree.subtreeAt (PTree.node r s cs)) ≠ [] :=
      by
        cases cut with
        | nil =>
            exact False.elim (hint.1 rfl)
        | cons a rest =>
            have ha : a ∈ a :: rest := by simp
            rcases node_addresses_of_mem_coalgebraAdmissibleCuts_of_internal
                hcoal hint a ha with ⟨r', s', cs', hnode⟩
            simp [hnode]
    simpa [coalgebraDetachedForestOfCut, hint.1, hint.2] using hfilter
  exact list_ne_nil_of_perm_ne_nil
    (nodeRootFreeCut_detachedForest_perm
      (r := r) (s := s) (cs := cs)
      (cut := cut) hcoal hint.2)
    hraw

theorem coalgebraDetachedForestOfCut_nonempty_of_internal
    {t : PTree} {cut : List Address}
    (hcut : cut ∈ internalCoalgebraAdmissibleCuts t) :
    coalgebraDetachedForestOfCut t cut ≠ [] := by
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut with
    ⟨hcoal, hint⟩
  have hfilter :
      cut.filterMap (PTree.subtreeAt t) ≠ [] :=
    by
      cases cut with
      | nil =>
          exact False.elim (hint.1 rfl)
      | cons a rest =>
          have ha : a ∈ a :: rest := by simp
          rcases node_addresses_of_mem_coalgebraAdmissibleCuts_of_internal
              hcoal hint a ha with ⟨r, s, cs, hnode⟩
          simp [hnode]
  simpa [coalgebraDetachedForestOfCut, hint.1, hint.2] using hfilter

/--
Every tree detached by a proper internal coalgebra cut is a genuine proper
subtree of the original tree, hence strictly smaller.
-/
theorem coalgebraDetachedForestOfCut_mem_size_lt_of_internal
    {t u : PTree} {cut : List Address}
    (hcut : cut ∈ internalCoalgebraAdmissibleCuts t)
    (hu : u ∈ coalgebraDetachedForestOfCut t cut) :
    u.size < t.size := by
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut with
    ⟨_hcoal, hint⟩
  have huFilter :
      u ∈ cut.filterMap (PTree.subtreeAt t) := by
    simpa [coalgebraDetachedForestOfCut, hint.1, hint.2] using hu
  rcases List.mem_filterMap.1 huFilter with ⟨a, ha, hsub⟩
  exact PTree.subtreeAt_size_lt_of_ne_root
    (t := t) (u := u) (a := a)
    (by
      intro haNil
      exact hint.2 (by simpa [haNil] using ha))
    hsub

/--
Conditional split membership for the ambient witness.

The remaining hard forest equation is isolated as a permutation saying that
the ambient detached forest is the concatenation of the first detached forest
and the second detached forest inside the first remainder.  Once that
permutation and the first-coordinate tensor-term equation are available, the
proper split membership is immediate from the multiplicative forest coproduct.
-/
theorem nodeAmbientSplit_mem_proper_of_detached_append_perm
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address}
    (hfirstNonempty : nodeRootFreeCutDetachedForest cs cut₁ ≠ [])
    (hsecondNonempty :
      coalgebraDetachedForestOfCut
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))
        cut₂ ≠ [])
    (hfst :
      (coalgebraTensorTermOfCutList
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))
        cut₂).1 =
        HQ.ofForest
          (coalgebraDetachedForestOfCut
            (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))
            cut₂))
    (hperm :
      List.Perm
        (nodeRootFreeCutDetachedForest cs
          (nodeAmbientCutOfRightWitness cut₁ cut₂))
        (nodeRootFreeCutDetachedForest cs cut₁ ++
          coalgebraDetachedForestOfCut
            (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))
            cut₂)) :
    nodeAmbientSplitOfRightWitness r s cs cut₁ cut₂ ∈
      coalgebraForestProperSplittingTensorSupport
        (nodeRootFreeCutDetachedForest cs
          (nodeAmbientCutOfRightWitness cut₁ cut₂)) := by
  let f₁ := nodeRootFreeCutDetachedForest cs cut₁
  let f₂ :=
    coalgebraDetachedForestOfCut
      (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))
      cut₂
  have hmemAppend :
      (HQ.ofForest f₁, HQ.ofForest f₂) ∈
        coalgebraForestProperSplittingTensorSupport (f₁ ++ f₂) :=
    coalgebraForestProperSplittingTensorSupport_contains_prefix_suffix
      (f := f₁) (g := f₂)
      (by
        dsimp [f₁]
        exact hfirstNonempty)
      (by
        dsimp [f₂]
        exact hsecondNonempty)
  have htransport :
      (HQ.ofForest f₁, HQ.ofForest f₂) ∈
        coalgebraForestProperSplittingTensorSupport
          (nodeRootFreeCutDetachedForest cs
            (nodeAmbientCutOfRightWitness cut₁ cut₂)) := by
    exact ((coalgebraForestProperSplittingTensorSupport_perm_of_forest_perm
      hperm).mem_iff).2 hmemAppend
  simpa [nodeAmbientSplitOfRightWitness, f₁, f₂, hfst] using htransport

theorem nodeAmbientSplit_mem_proper_of_canonical_detached_append_perm
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address}
    (hfirstNonempty : nodeRootFreeCutDetachedForest cs cut₁ ≠ [])
    (hsecondNonempty :
