/-!
## A packaged Hopf target for the normalized GL/CK route

This is the normalized companion to the splitting-target package below: once
coassociativity, comultiplicativity, and antipode cancellation are supplied,
the target exposes the actual Mathlib `Coalgebra`, `Bialgebra`, and
`HopfAlgebra` instances together with the concrete normalized maps.
-/

/-- Complete theorem target for the normalized GL/CK Hopf algebra. -/
structure HypersequentNormalizedHopfTarget where
  bialgebraAxioms : HypersequentNormalizedBialgebraAxioms R
  hopfAxioms : HypersequentNormalizedHopfAxioms R bialgebraAxioms

namespace HypersequentNormalizedHopfTarget

/-- The coalgebra supplied by a completed normalized Hopf target. -/
noncomputable def toCoalgebra
    (H : HypersequentNormalizedHopfTarget R) :
    Coalgebra R (HypersequentAlgebra R) :=
  hypersequentNormalizedCoalgebra R
    (hypersequentNormalizedBialgebraAxioms_coalgebra R H.bialgebraAxioms)

/-- The bialgebra supplied by a completed normalized Hopf target. -/
noncomputable def toBialgebra
    (H : HypersequentNormalizedHopfTarget R) :
    Bialgebra R (HypersequentAlgebra R) :=
  hypersequentNormalizedBialgebra R H.bialgebraAxioms

/-- The Hopf algebra supplied by a completed normalized Hopf target. -/
noncomputable def toHopfAlgebra
    (H : HypersequentNormalizedHopfTarget R) :
    HopfAlgebra R (HypersequentAlgebra R) :=
  hypersequentNormalizedHopfAlgebra R H.bialgebraAxioms H.hopfAxioms

/-- The normalized comultiplication of the target. -/
def comul
    (_H : HypersequentNormalizedHopfTarget R) :
    HypersequentAlgebra R →ₗ[R]
      TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R) :=
  hypersequentCoalgebraComulTensorLinearMap R

/-- The normalized counit of the target. -/
def counit
    (_H : HypersequentNormalizedHopfTarget R) :
    HypersequentAlgebra R →ₗ[R] R :=
  (hypersequentCounitAlgHom R).toLinearMap

/-- The antipode supplied by the target. -/
def antipode
    (H : HypersequentNormalizedHopfTarget R) :
    HypersequentAlgebra R →ₗ[R] HypersequentAlgebra R :=
  H.hopfAxioms.antipode

@[simp]
theorem comul_apply
    (H : HypersequentNormalizedHopfTarget R)
    (x : HypersequentAlgebra R) :
    (HypersequentNormalizedHopfTarget.comul R H) x =
      hypersequentCoalgebraComulTensorLinearMap R x := rfl

@[simp]
theorem counit_apply
    (H : HypersequentNormalizedHopfTarget R)
    (x : HypersequentAlgebra R) :
    (HypersequentNormalizedHopfTarget.counit R H) x =
      (hypersequentCounitAlgHom R).toLinearMap x := rfl

@[simp]
theorem antipode_apply
    (H : HypersequentNormalizedHopfTarget R)
    (x : HypersequentAlgebra R) :
    (HypersequentNormalizedHopfTarget.antipode R H) x =
      H.hopfAxioms.antipode x := rfl

theorem coassoc
    (H : HypersequentNormalizedHopfTarget R) :
    HypersequentNormalizedCoalgebraCoassoc R :=
  H.bialgebraAxioms.coassoc

theorem rightCounit
    (H : HypersequentNormalizedHopfTarget R) :
    HypersequentNormalizedCoalgebraRightCounit R :=
  H.bialgebraAxioms.rightCounit

theorem leftCounit
    (H : HypersequentNormalizedHopfTarget R) :
    HypersequentNormalizedCoalgebraLeftCounit R :=
  H.bialgebraAxioms.leftCounit

theorem comul_mul
    (H : HypersequentNormalizedHopfTarget R) :
    HypersequentNormalizedComulMul R :=
  H.bialgebraAxioms.comul_mul

theorem antipode_left_cancellation
    (H : HypersequentNormalizedHopfTarget R) :
    LinearMap.mul' R (HypersequentAlgebra R) ∘ₗ
        LinearMap.lTensor (HypersequentAlgebra R)
          (HypersequentNormalizedHopfTarget.antipode R H) ∘ₗ
          hypersequentCoalgebraComulTensorLinearMap R =
      Algebra.linearMap R (HypersequentAlgebra R) ∘ₗ
        (hypersequentCounitAlgHom R).toLinearMap :=
  H.hopfAxioms.left_cancellation

theorem antipode_right_cancellation
    (H : HypersequentNormalizedHopfTarget R) :
    LinearMap.mul' R (HypersequentAlgebra R) ∘ₗ
        LinearMap.rTensor (HypersequentAlgebra R)
          (HypersequentNormalizedHopfTarget.antipode R H) ∘ₗ
          hypersequentCoalgebraComulTensorLinearMap R =
      Algebra.linearMap R (HypersequentAlgebra R) ∘ₗ
        (hypersequentCounitAlgHom R).toLinearMap :=
  H.hopfAxioms.right_cancellation

/--
Build the full normalized Hopf target from a normalized bialgebra package and
basis-level antipode cancellation checks.
-/
noncomputable def ofBasisAntipode
    (hBialg : HypersequentNormalizedBialgebraAxioms R)
    (S : HypersequentAlgebra R →ₗ[R] HypersequentAlgebra R)
    (hS : HypersequentNormalizedHopfBasisAxioms R hBialg S) :
    HypersequentNormalizedHopfTarget R where
  bialgebraAxioms := hBialg
  hopfAxioms := hypersequentNormalizedHopfAxioms_of_basis R hBialg S hS

/--
Build the full normalized Hopf target directly from the three remaining pieces
of mathematics:

* basis-level normalized coassociativity;
* multiplicativity of the normalized coproduct;
* basis-level antipode cancellation.

This is the shortest end-to-end packaging route for the normalized GL/CK
construction once the admissible-cut combinatorics are complete.
-/
noncomputable def ofCoassocComulMulBasisAntipode
    (hcoassoc :
      ∀ G : Hypersequent,
        ((TensorProduct.assoc R
            (HypersequentAlgebra R)
            (HypersequentAlgebra R)
            (HypersequentAlgebra R)).toLinearMap ∘ₗ
            LinearMap.rTensor (HypersequentAlgebra R)
              (hypersequentCoalgebraComulTensorLinearMap R) ∘ₗ
              hypersequentCoalgebraComulTensorLinearMap R)
          (hseqMonomial R G) =
        (LinearMap.lTensor (HypersequentAlgebra R)
            (hypersequentCoalgebraComulTensorLinearMap R) ∘ₗ
          hypersequentCoalgebraComulTensorLinearMap R)
          (hseqMonomial R G))
    (hMul : HypersequentNormalizedComulMul R)
    (S : HypersequentAlgebra R →ₗ[R] HypersequentAlgebra R)
    (hS :
      HypersequentNormalizedHopfBasisAxioms R
        (hypersequentNormalizedBialgebraAxioms_of_coassoc_and_comulMul
          R hcoassoc hMul) S) :
    HypersequentNormalizedHopfTarget R :=
  ofBasisAntipode R
    (hypersequentNormalizedBialgebraAxioms_of_coassoc_and_comulMul
      R hcoassoc hMul)
    S hS

noncomputable def ofDecompositionBasisAntipode
    [LeftDistribClass
      (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))]
    [RightDistribClass
      (TensorProduct R (HypersequentAlgebra R) (HypersequentAlgebra R))]
    (hcompat : HypersequentNormalizedStageAlgebraCompatibility R)
    (S : HypersequentAlgebra R →ₗ[R] HypersequentAlgebra R)
    (hS :
      HypersequentNormalizedHopfBasisAxioms R
        (hypersequentNormalizedBialgebraAxioms_of_decomposition
          (R := R) hcompat) S) :
    HypersequentNormalizedHopfTarget R :=
  ofBasisAntipode R
    (hypersequentNormalizedBialgebraAxioms_of_decomposition
      (R := R) hcompat)
    S hS

end HypersequentNormalizedHopfTarget

namespace HypersequentNormalizedHopfCompletionData

/--
View Hopf-completion data as the packaged normalized Hopf target.

This bridge is intentionally placed after `HypersequentNormalizedHopfTarget`:
the completion object is the compact dependency bundle, while the target is
