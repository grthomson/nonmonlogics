/--
Witness-projection count balance is equivalent to the support-level
node-normal count balance.
-/
theorem NodeNormalInternalInternalNatCountBalanced_iff_witness_count
    (r : RuleTag) (s : MultiSequent) (cs : List PTree) :
    NodeNormalInternalInternalNatCountBalanced r s cs ↔
      ∀ p : HypersequentTripleBasis,
        @List.count HypersequentTripleBasis instBEqOfDecidableEq p
            ((nodeRightInternalInternalNormalWitnesses r s cs).map
              (nodeRightInternalInternalNormalWitnessTriple r s cs)) =
          @List.count HypersequentTripleBasis instBEqOfDecidableEq p
            ((nodeLeftInternalInternalNormalWitnesses r s cs).map
              (nodeLeftInternalInternalNormalWitnessTriple r s cs)) := by
  constructor
  · intro h p
    rw [← nodeRightInternalInternalNormalSupport_eq_witness_map,
      ← nodeLeftInternalInternalNormalSupport_eq_witness_map]
    exact h p
  · intro h p
    rw [nodeRightInternalInternalNormalSupport_eq_witness_map,
      nodeLeftInternalInternalNormalSupport_eq_witness_map]
    exact h p

theorem NodeNormalInternalInternalNatCountBalanced_iff_profile_witness_count
    (r : RuleTag) (s : MultiSequent) (cs : List PTree) :
    NodeNormalInternalInternalNatCountBalanced r s cs ↔
      ∀ p : HypersequentTripleBasis,
        @List.count HypersequentTripleBasis instBEqOfDecidableEq p
            ((nodeRightInternalInternalNormalWitnesses r s cs).map
              (nodeRightInternalInternalNormalWitnessTriple r s cs)) =
          @List.count HypersequentTripleBasis instBEqOfDecidableEq p
            ((nodeLeftInternalInternalNormalProfileWitnesses r s cs).map
              (nodeLeftInternalInternalNormalProfileWitnessTriple r s cs)) := by
  constructor
  · intro h p
    rw [← nodeRightInternalInternalNormalSupport_eq_witness_map,
      ← nodeLeftInternalInternalNormalSupport_eq_profile_witness_map]
    exact h p
  · intro h p
    rw [nodeRightInternalInternalNormalSupport_eq_witness_map,
      nodeLeftInternalInternalNormalSupport_eq_profile_witness_map]
    exact h p

/--
Final count-balance reduction in antichain-refinement form.

After rewriting each right witness triple through
`nodeRightWitnessToLeftProfileWitness`, the remaining theorem says exactly
that this refinement map enumerates the left profile witnesses with the same
triple multiplicities.
-/
theorem NodeNormalInternalInternalNatCountBalanced_iff_toLeftProfile_count
    (r : RuleTag) (s : MultiSequent) (cs : List PTree) :
    NodeNormalInternalInternalNatCountBalanced r s cs ↔
      ∀ p : HypersequentTripleBasis,
        @List.count HypersequentTripleBasis instBEqOfDecidableEq p
            ((nodeRightInternalInternalNormalWitnesses r s cs).map
              (fun w =>
                nodeLeftInternalInternalNormalProfileWitnessTriple r s cs
                  (nodeRightWitnessToLeftProfileWitness r s cs w))) =
          @List.count HypersequentTripleBasis instBEqOfDecidableEq p
            ((nodeLeftInternalInternalNormalProfileWitnesses r s cs).map
              (nodeLeftInternalInternalNormalProfileWitnessTriple r s cs)) := by
  rw [NodeNormalInternalInternalNatCountBalanced_iff_profile_witness_count]
  constructor
  · intro h p
    rw [← nodeRightWitnessTriple_map_eq_toLeftProfileWitnessTriple_map]
    exact h p
  · intro h p
    rw [nodeRightWitnessTriple_map_eq_toLeftProfileWitnessTriple_map]
    exact h p

theorem NodeNormalInternalInternalNatCountBalanced_iff_fullyCanonicalRecovered_count
    (r : RuleTag) (s : MultiSequent) (cs : List PTree) :
    NodeNormalInternalInternalNatCountBalanced r s cs ↔
      ∀ p : HypersequentTripleBasis,
        @List.count HypersequentTripleBasis instBEqOfDecidableEq p
            ((nodeRightInternalInternalNormalWitnesses r s cs).map
              (fun w =>
                nodeRightInternalInternalNormalWitnessTriple r s cs
                  (nodeLeftProfileWitnessFullyCanonicalRightWitness r s cs
                    (nodeRightWitnessToLeftProfileWitness r s cs w)))) =
          @List.count HypersequentTripleBasis instBEqOfDecidableEq p
            ((nodeLeftInternalInternalNormalProfileWitnesses r s cs).map
              (nodeLeftInternalInternalNormalProfileWitnessTriple r s cs)) := by
  rw [NodeNormalInternalInternalNatCountBalanced_iff_profile_witness_count]
  constructor
  · intro h p
    rw [← nodeRightWitnessTriple_map_eq_fullyCanonicalRecovered_map]
    exact h p
  · intro h p
    rw [nodeRightWitnessTriple_map_eq_fullyCanonicalRecovered_map]
    exact h p

theorem nodeLeftProfileWitness_zip_perm_fullyCanonicalRightWitness
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {w : List Address × List (List Address)}
    (hw : w ∈ nodeLeftInternalInternalNormalProfileWitnesses r s cs) :
    List.Perm
      (List.zip (nodeRootFreeCutDetachedForest cs w.1) w.2)
      (List.zip
        (nodeRootFreeCutDetachedForest cs
          (nodeCanonicalAmbientCutOfRightWitness r s cs
            (nodeLeftProfileWitnessCanonicalFirstCut r s cs w)
            (nodeLeftProfileWitnessCanonicalSecondCut r s cs w)))
        (nodeRightWitnessAmbientProfile r s cs
          (nodeLeftProfileWitnessCanonicalFirstCut r s cs w)
          (nodeLeftProfileWitnessCanonicalSecondCut r s cs w))) := by
  rw [
    nodeCanonicalAmbientCut_fullyCanonicalLeftProfileWitness_eq_ambient
      (r := r) (s := s) (cs := cs) (w := w) hw,
    nodeRightWitnessAmbientProfile_eq_leftProfileWitnessProfile
      (r := r) (s := s) (cs := cs) (w := w) hw]

theorem nodeLeftProfileWitness_tensor_eq_fullyCanonicalRightWitness
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {w : List Address × List (List Address)}
    (hw : w ∈ nodeLeftInternalInternalNormalProfileWitnesses r s cs) :
    coalgebraForestTensorTermOfProfile
        (nodeRootFreeCutDetachedForest cs w.1) w.2 =
      (HQ.ofForest
        (nodeRootFreeCutDetachedForest cs
          (nodeLeftProfileWitnessCanonicalFirstCut r s cs w)),
        (coalgebraTensorTermOfCutList
          (PTree.node r s
            (nodeRootFreeCutRemainderChildren cs
              (nodeLeftProfileWitnessCanonicalFirstCut r s cs w)))
          (nodeLeftProfileWitnessCanonicalSecondCut r s cs w)).1) := by
  rcases (mem_nodeLeftInternalInternalNormalProfileWitnesses_iff
      (r := r) (s := s) (cs := cs) (w := w)).1 hw with
    ⟨ambient, hambient, profile, hprofile, rfl⟩
  have hfirst :
      nodeLeftProfileWitnessCanonicalFirstCut r s cs (ambient, profile) ∈
        internalCoalgebraAdmissibleCuts (PTree.node r s cs) :=
    nodeLeftProfileWitnessCanonicalFirstCut_mem_internalCoalgebraAdmissibleCuts
      (r := r) (s := s) (cs := cs) (w := (ambient, profile)) hw
  have hsecond :
      nodeLeftProfileWitnessCanonicalSecondCut r s cs (ambient, profile) ∈
        internalCoalgebraAdmissibleCuts
          (PTree.node r s
            (nodeRootFreeCutRemainderChildren cs
              (nodeLeftProfileWitnessCanonicalFirstCut r s cs (ambient, profile)))) :=
    nodeLeftProfileWitnessCanonicalSecondCut_mem_internalCoalgebraAdmissibleCuts
      (r := r) (s := s) (cs := cs) (w := (ambient, profile)) hw
  have hlenLeft :
      profile.length =
        (nodeRootFreeCutDetachedForest cs ambient).length :=
    coalgebraForestProperCutProfiles_length_eq hprofile
  have hlenRight :
      (nodeRightWitnessAmbientProfile r s cs
          (nodeLeftProfileWitnessCanonicalFirstCut r s cs (ambient, profile))
          (nodeLeftProfileWitnessCanonicalSecondCut r s cs (ambient, profile))).length =
        (nodeRootFreeCutDetachedForest cs
          (nodeCanonicalAmbientCutOfRightWitness r s cs
            (nodeLeftProfileWitnessCanonicalFirstCut r s cs (ambient, profile))
            (nodeLeftProfileWitnessCanonicalSecondCut r s cs (ambient, profile)))).length :=
    nodeRightWitnessAmbientProfile_length_eq_detachedForest
      (r := r) (s := s) (cs := cs)
      (cut₁ := nodeLeftProfileWitnessCanonicalFirstCut r s cs (ambient, profile))
      (cut₂ := nodeLeftProfileWitnessCanonicalSecondCut r s cs (ambient, profile))
      hfirst hsecond
  have hprofileEq :
      coalgebraForestTensorTermOfProfile
          (nodeRootFreeCutDetachedForest cs ambient) profile =
        coalgebraForestTensorTermOfProfile
          (nodeRootFreeCutDetachedForest cs
            (nodeCanonicalAmbientCutOfRightWitness r s cs
              (nodeLeftProfileWitnessCanonicalFirstCut r s cs (ambient, profile))
              (nodeLeftProfileWitnessCanonicalSecondCut r s cs (ambient, profile))))
          (nodeRightWitnessAmbientProfile r s cs
            (nodeLeftProfileWitnessCanonicalFirstCut r s cs (ambient, profile))
            (nodeLeftProfileWitnessCanonicalSecondCut r s cs (ambient, profile))) :=
    coalgebraForestTensorTermOfProfile_eq_of_zip_perm
      hlenLeft hlenRight
      (nodeLeftProfileWitness_zip_perm_fullyCanonicalRightWitness
        (r := r) (s := s) (cs := cs) (w := (ambient, profile)) hw)
  rw [hprofileEq]
  exact
    nodeRightWitnessAmbientProfile_tensor_eq
      (r := r) (s := s) (cs := cs)
      (cut₁ := nodeLeftProfileWitnessCanonicalFirstCut r s cs (ambient, profile))
      (cut₂ := nodeLeftProfileWitnessCanonicalSecondCut r s cs (ambient, profile))
      hfirst hsecond

theorem nodeLeftProfileWitnessTriple_eq_fullyCanonicalRightWitnessTriple
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {w : List Address × List (List Address)}
    (hw : w ∈ nodeLeftInternalInternalNormalProfileWitnesses r s cs) :
    nodeLeftInternalInternalNormalProfileWitnessTriple r s cs w =
      nodeRightInternalInternalNormalWitnessTriple r s cs
        (nodeLeftProfileWitnessFullyCanonicalRightWitness r s cs w) := by
  exact
    nodeLeftProfileWitnessTriple_eq_fullyCanonicalRightWitnessTriple_of_tensor
      (r := r) (s := s) (cs := cs) (w := w) hw
      (nodeLeftProfileWitness_tensor_eq_fullyCanonicalRightWitness
        (r := r) (s := s) (cs := cs) (w := w) hw)

theorem nodeRightWitnessToLeftProfileWitness_fullyCanonicalRightWitness_eq
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {w : List Address × List (List Address)}
    (hw : w ∈ nodeLeftInternalInternalNormalProfileWitnesses r s cs) :
    nodeRightWitnessToLeftProfileWitness r s cs
        (nodeLeftProfileWitnessFullyCanonicalRightWitness r s cs w) = w := by
  cases w with
  | mk ambient profile =>
      simp [nodeRightWitnessToLeftProfileWitness,
        nodeLeftProfileWitnessFullyCanonicalRightWitness,
        nodeCanonicalAmbientCut_fullyCanonicalLeftProfileWitness_eq_ambient
          (r := r) (s := s) (cs := cs) (w := (ambient, profile)) hw,
        nodeRightWitnessAmbientProfile_eq_leftProfileWitnessProfile
          (r := r) (s := s) (cs := cs) (w := (ambient, profile)) hw]

theorem nodeLeftProfileWitnessFullyCanonicalRightWitness_toLeftProfileWitness_eq
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))) :
    nodeLeftProfileWitnessFullyCanonicalRightWitness r s cs
        (nodeRightWitnessToLeftProfileWitness r s cs (cut₁, cut₂)) =
      (cut₁, cut₂) := by
  classical
  let w := nodeRightWitnessToLeftProfileWitness r s cs (cut₁, cut₂)
  have hw : w ∈ nodeLeftInternalInternalNormalProfileWitnesses r s cs := by
    simpa [w] using
      nodeRightWitnessToLeftProfileWitness_mem
        (r := r) (s := s) (cs := cs)
        (cut₁ := cut₁) (cut₂ := cut₂) hcut₁ hcut₂
  have hrawFirst :
      (nodeLeftProfileWitnessFirstCut cs w).Perm cut₁ := by
    simpa [w] using
      nodeRightWitnessAmbientProfile_firstCut_perm
        (r := r) (s := s) (cs := cs)
        (cut₁ := cut₁) (cut₂ := cut₂) hcut₁ hcut₂
  have hcanonFirstPerm :
      (nodeLeftProfileWitnessCanonicalFirstCut r s cs w).Perm cut₁ := by
    exact
      ((nodeLeftProfileWitnessFirstCut_perm_canonical
        (r := r) (s := s) (cs := cs) (w := w) hw).symm).trans hrawFirst
  have hcanonFirstMem :
      nodeLeftProfileWitnessCanonicalFirstCut r s cs w ∈
        internalCoalgebraAdmissibleCuts (PTree.node r s cs) :=
    nodeLeftProfileWitnessCanonicalFirstCut_mem_internalCoalgebraAdmissibleCuts
      (r := r) (s := s) (cs := cs) (w := w) hw
  have hcanonFirstSub :
      List.Sublist (nodeLeftProfileWitnessCanonicalFirstCut r s cs w)
        (PTree.allAddresses (PTree.node r s cs)) :=
    PTree.cut_sublist_allAddresses_of_mem_allAdmissibleCuts
      ((mem_coalgebraAdmissibleCuts_iff).1
        ((mem_internalCoalgebraAdmissibleCuts_iff).1 hcanonFirstMem).1).1
  have hcut₁Sub :
      List.Sublist cut₁ (PTree.allAddresses (PTree.node r s cs)) :=
    PTree.cut_sublist_allAddresses_of_mem_allAdmissibleCuts
      ((mem_coalgebraAdmissibleCuts_iff).1
        ((mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₁).1).1
  have hfirstEq :
      nodeLeftProfileWitnessCanonicalFirstCut r s cs w = cut₁ :=
    List.eq_of_perm_of_sublist_of_sublist_nodup
      hcanonFirstPerm hcanonFirstSub hcut₁Sub
      (PTree.allAddresses_nodup (PTree.node r s cs))
  have hrawSecond :
      (nodeLeftProfileWitnessSecondCut cs w).Perm cut₂ := by
    simpa [w] using
      nodeRightWitnessAmbientProfile_secondCut_perm
        (r := r) (s := s) (cs := cs)
        (cut₁ := cut₁) (cut₂ := cut₂) hcut₁ hcut₂
  have hcanonSecondPerm :
      (nodeLeftProfileWitnessCanonicalSecondCut r s cs w).Perm cut₂ := by
    exact
      ((nodeLeftProfileWitnessSecondCut_perm_canonicalSecondCut
        (r := r) (s := s) (cs := cs) (w := w) hw).symm).trans hrawSecond
  have hcanonSecondMem :
      nodeLeftProfileWitnessCanonicalSecondCut r s cs w ∈
        internalCoalgebraAdmissibleCuts
          (PTree.node r s
            (nodeRootFreeCutRemainderChildren cs
              (nodeLeftProfileWitnessCanonicalFirstCut r s cs w))) :=
    nodeLeftProfileWitnessCanonicalSecondCut_mem_internalCoalgebraAdmissibleCuts
      (r := r) (s := s) (cs := cs) (w := w) hw
  have hcut₂Canon :
      cut₂ ∈
        internalCoalgebraAdmissibleCuts
          (PTree.node r s
            (nodeRootFreeCutRemainderChildren cs
              (nodeLeftProfileWitnessCanonicalFirstCut r s cs w))) := by
    simpa [hfirstEq] using hcut₂
  have hcanonSecondSub :
      List.Sublist (nodeLeftProfileWitnessCanonicalSecondCut r s cs w)
        (PTree.allAddresses
          (PTree.node r s
            (nodeRootFreeCutRemainderChildren cs
              (nodeLeftProfileWitnessCanonicalFirstCut r s cs w)))) :=
    PTree.cut_sublist_allAddresses_of_mem_allAdmissibleCuts
      ((mem_coalgebraAdmissibleCuts_iff).1
        ((mem_internalCoalgebraAdmissibleCuts_iff).1 hcanonSecondMem).1).1
  have hcut₂Sub :
      List.Sublist cut₂
        (PTree.allAddresses
          (PTree.node r s
            (nodeRootFreeCutRemainderChildren cs
              (nodeLeftProfileWitnessCanonicalFirstCut r s cs w)))) :=
    PTree.cut_sublist_allAddresses_of_mem_allAdmissibleCuts
      ((mem_coalgebraAdmissibleCuts_iff).1
        ((mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₂Canon).1).1
  have hsecondEq :
      nodeLeftProfileWitnessCanonicalSecondCut r s cs w = cut₂ :=
    List.eq_of_perm_of_sublist_of_sublist_nodup
      hcanonSecondPerm hcanonSecondSub hcut₂Sub
      (PTree.allAddresses_nodup
        (PTree.node r s
          (nodeRootFreeCutRemainderChildren cs
            (nodeLeftProfileWitnessCanonicalFirstCut r s cs w))))
  simp [nodeLeftProfileWitnessFullyCanonicalRightWitness, w, hfirstEq, hsecondEq]

theorem mem_nodeRightToLeftProfileWitnessMap_iff_leftProfileWitnesses
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {w : List Address × List (List Address)} :
    w ∈
        (nodeRightInternalInternalNormalWitnesses r s cs).map
          (nodeRightWitnessToLeftProfileWitness r s cs) ↔
      w ∈ nodeLeftInternalInternalNormalProfileWitnesses r s cs := by
  constructor
  · intro hw
    rcases List.mem_map.1 hw with ⟨v, hv, rfl⟩
    rcases (mem_nodeRightInternalInternalNormalWitnesses_iff
        (r := r) (s := s) (cs := cs) (w := v)).1 hv with
      ⟨cut₁, hcut₁, cut₂, hcut₂, rfl⟩
    exact nodeRightWitnessToLeftProfileWitness_mem
      (r := r) (s := s) (cs := cs)
      (cut₁ := cut₁) (cut₂ := cut₂) hcut₁ hcut₂
  · intro hw
    exact List.mem_map.2
      ⟨nodeLeftProfileWitnessFullyCanonicalRightWitness r s cs w,
        nodeLeftProfileWitnessFullyCanonicalRightWitness_mem
          (r := r) (s := s) (cs := cs) (w := w) hw,
        nodeRightWitnessToLeftProfileWitness_fullyCanonicalRightWitness_eq
          (r := r) (s := s) (cs := cs) (w := w) hw⟩

theorem nodeRightToLeftProfileWitnessMap_perm_leftProfileWitnesses
    (r : RuleTag) (s : MultiSequent) (cs : List PTree) :
    List.Perm
      ((nodeRightInternalInternalNormalWitnesses r s cs).map
        (nodeRightWitnessToLeftProfileWitness r s cs))
      (nodeLeftInternalInternalNormalProfileWitnesses r s cs) := by
  classical
  have hright :
      (nodeRightInternalInternalNormalWitnesses r s cs).Nodup :=
    nodeRightInternalInternalNormalWitnesses_nodup r s cs
  have hmap :
      ((nodeRightInternalInternalNormalWitnesses r s cs).map
        (nodeRightWitnessToLeftProfileWitness r s cs)).Nodup := by
    apply List.Nodup.map_on
      (l := nodeRightInternalInternalNormalWitnesses r s cs)
      (f := nodeRightWitnessToLeftProfileWitness r s cs)
    · intro x hx y hy hxy
      rcases (mem_nodeRightInternalInternalNormalWitnesses_iff
          (r := r) (s := s) (cs := cs) (w := x)).1 hx with
        ⟨cut₁, hcut₁, cut₂, hcut₂, rfl⟩
      rcases (mem_nodeRightInternalInternalNormalWitnesses_iff
          (r := r) (s := s) (cs := cs) (w := y)).1 hy with
        ⟨cut₁', hcut₁', cut₂', hcut₂', rfl⟩
      calc
        (cut₁, cut₂)
            =
              nodeLeftProfileWitnessFullyCanonicalRightWitness r s cs
                (nodeRightWitnessToLeftProfileWitness r s cs
                  (cut₁, cut₂)) := by
                exact
                  (nodeLeftProfileWitnessFullyCanonicalRightWitness_toLeftProfileWitness_eq
                    (r := r) (s := s) (cs := cs)
                    (cut₁ := cut₁) (cut₂ := cut₂) hcut₁ hcut₂).symm
        _ =
              nodeLeftProfileWitnessFullyCanonicalRightWitness r s cs
                (nodeRightWitnessToLeftProfileWitness r s cs
                  (cut₁', cut₂')) := by
                rw [hxy]
        _ = (cut₁', cut₂') := by
                exact
                  nodeLeftProfileWitnessFullyCanonicalRightWitness_toLeftProfileWitness_eq
                    (r := r) (s := s) (cs := cs)
                    (cut₁ := cut₁') (cut₂ := cut₂') hcut₁' hcut₂'
    · exact hright
  have hleft :
      (nodeLeftInternalInternalNormalProfileWitnesses r s cs).Nodup :=
    nodeLeftInternalInternalNormalProfileWitnesses_nodup r s cs
  exact
    (List.perm_ext_iff_of_nodup hmap hleft).2
      (fun w =>
        mem_nodeRightToLeftProfileWitnessMap_iff_leftProfileWitnesses
          (r := r) (s := s) (cs := cs) (w := w))

theorem nodeFullyCanonicalRecoveredTripleMap_perm_leftProfileTripleMap
    (r : RuleTag) (s : MultiSequent) (cs : List PTree) :
    List.Perm
      ((nodeRightInternalInternalNormalWitnesses r s cs).map
        (fun w =>
          nodeRightInternalInternalNormalWitnessTriple r s cs
            (nodeLeftProfileWitnessFullyCanonicalRightWitness r s cs
              (nodeRightWitnessToLeftProfileWitness r s cs w))))
      ((nodeLeftInternalInternalNormalProfileWitnesses r s cs).map
        (nodeLeftInternalInternalNormalProfileWitnessTriple r s cs)) := by
  let F : (List Address × List (List Address)) → HypersequentTripleBasis :=
    fun w =>
      nodeRightInternalInternalNormalWitnessTriple r s cs
        (nodeLeftProfileWitnessFullyCanonicalRightWitness r s cs w)
  have hbij :
      List.Perm
        (((nodeRightInternalInternalNormalWitnesses r s cs).map
          (nodeRightWitnessToLeftProfileWitness r s cs)).map F)
        ((nodeLeftInternalInternalNormalProfileWitnesses r s cs).map F) :=
    (nodeRightToLeftProfileWitnessMap_perm_leftProfileWitnesses r s cs).map F
  have hleft :
      (nodeLeftInternalInternalNormalProfileWitnesses r s cs).map F =
        (nodeLeftInternalInternalNormalProfileWitnesses r s cs).map
          (nodeLeftInternalInternalNormalProfileWitnessTriple r s cs) := by
    apply List.map_congr_left
    intro w hw
    exact
      (nodeLeftProfileWitnessTriple_eq_fullyCanonicalRightWitnessTriple
        (r := r) (s := s) (cs := cs) (w := w) hw).symm
  rw [hleft] at hbij
  simpa [F, List.map_map, Function.comp_def] using hbij

/--
The `natCount` balance theorem is exactly strong enough to close the
node-normal support permutation.
-/
theorem coalgebraInternalInternalExtensionPerm_node_normal_of_natCount_balance
    (r : RuleTag) (s : MultiSequent) (cs : List PTree)
    (hcount : NodeNormalInternalInternalNatCountBalanced r s cs) :
    List.Perm
      (nodeRightInternalInternalNormalSupport r s cs)
      (nodeLeftInternalInternalNormalSupport r s cs) := by
  exact list_perm_of_natCount_balance
    (nodeRightInternalInternalNormalSupport r s cs)
    (nodeLeftInternalInternalNormalSupport r s cs)
    (by
      intro p
      exact hcount p)

/--
Reduced form of the remaining internal/internal theorem.

After the support normalizations, coassociativity is now concentrated in this
finite multiplicity statement.  The intended bijection sends a right witness
`(cut₁, cut₂)` to the ambient cut `stageAmbientCut cut₁ cut₂`, with
`disjoint_previous_cut_second_internal_cut` providing the no-recutting
condition that makes the map injective on internal coalgebra cuts.
-/
theorem coalgebraInternalInternalExtensionPerm_node_normal_count_balance
    (r : RuleTag) (s : MultiSequent) (cs : List PTree) :
    NodeNormalInternalInternalNatCountBalanced r s cs := by
  rw [NodeNormalInternalInternalNatCountBalanced_iff_fullyCanonicalRecovered_count]
  intro p
  rw [List.count_eq_count_of_lawfulBEq p,
    List.count_eq_count_of_lawfulBEq p]
  exact
    (nodeFullyCanonicalRecoveredTripleMap_perm_leftProfileTripleMap r s cs).count_eq p

/--
Normalized node-local internal/internal extension permutation.

After the root-free node normal forms, this is the concentrated remaining
mathematics: the childwise nested-remainder cuts enumerate exactly the proper
splittings of the childwise detached forest.
-/
theorem coalgebraInternalInternalExtensionPerm_node_normal
    (r : RuleTag) (s : MultiSequent) (cs : List PTree) :
    List.Perm
      (nodeRightInternalInternalNormalSupport r s cs)
      (nodeLeftInternalInternalNormalSupport r s cs) := by
  exact coalgebraInternalInternalExtensionPerm_node_normal_of_natCount_balance
    r s cs
    (coalgebraInternalInternalExtensionPerm_node_normal_count_balance r s cs)

/--
Node-local internal/internal extension permutation.

This follows from the normalized childwise statement plus the proved root-free
normal forms for both staged sectors.
-/
theorem coalgebraInternalInternalExtensionPerm_node
    (r : RuleTag) (s : MultiSequent) (cs : List PTree) :
    List.Perm
      (coalgebraRightInternalInternalTripleSupport (PTree.node r s cs))
      (coalgebraLeftInternalInternalTripleSupport (PTree.node r s cs)) := by
  rw [coalgebraRightInternalInternalTripleSupport_node_rootFree]
  exact (coalgebraInternalInternalExtensionPerm_node_normal r s cs).trans
    (coalgebraLeftInternalInternalTripleSupport_node_rootFree_perm r s cs).symm

/--
The internal/internal extension bijection, stated at exactly the support level
needed by normalized coassociativity.

This is the remaining genuine cut-extension theorem: second cuts of the
remainder after an internal first cut enumerate the same triples as proper
splittings of the detached forest.
-/
theorem coalgebraInternalInternalExtensionPerm
    (t : PTree) :
    List.Perm
      (coalgebraRightInternalInternalTripleSupport t)
      (coalgebraLeftInternalInternalTripleSupport t) := by
  cases t with
  | leaf s =>
      exact coalgebraInternalInternalExtensionPerm_leaf s
  | node r s cs =>
      exact coalgebraInternalInternalExtensionPerm_node r s cs

/--
Assembly check for normalized coassociativity at support level.

Once the forest boundary/proper-sector split and the internal/internal
extension bijection are available, the staged right and left support lists are
permutations of the same seven sectors:
empty-empty, empty-root, root-unit, internal identity, internal second-empty,
internal second-root, and internal/internal.
-/
theorem coalgebraCoassoc_tree_support_perm_of_internal_extension
    (hforest : HypersequentNormalizedForestBoundaryProperPerm)
    (hext :
      ∀ t : PTree,
        List.Perm
          (coalgebraRightInternalInternalTripleSupport t)
          (coalgebraLeftInternalInternalTripleSupport t))
    (t : PTree) :
    List.Perm
      (coalgebraRightStageTripleSupport t)
      (coalgebraLeftStageTripleSupport t) := by
  classical
  let E : List HypersequentTripleBasis := [(0, 0, HQ.singleton t)]
  let ER : List HypersequentTripleBasis := [(0, HQ.singleton t, 0)]
  let RU : List HypersequentTripleBasis := [(HQ.singleton t, 0, 0)]
  let I : List HypersequentTripleBasis :=
    coalgebraInternalIdentityTripleSupport t
  let SE : List HypersequentTripleBasis :=
    coalgebraInternalSecondEmptyTripleSupport t
  let SR : List HypersequentTripleBasis :=
    coalgebraInternalSecondRootTripleSupport t
  let II : List HypersequentTripleBasis :=
    coalgebraLeftInternalInternalTripleSupport t
  have hRstage :=
    coalgebraRightStageTripleSupport_perm_empty_root_internal t
  have hRE :
      List.Perm
        (coalgebraRightEmptyFirstTripleSupport t)
        (E ++ (ER ++ I)) := by
    simpa [E, ER, I] using
      coalgebraRightEmptyFirstTripleSupport_perm_boundary_internal t
  have hRR :
      List.Perm
        (coalgebraRightRootFirstTripleSupport t)
        RU := by
    simpa [RU] using
      coalgebraRightRootFirstTripleSupport_perm_boundary t
  have hRI :
      List.Perm
        (coalgebraRightInternalFirstTripleSupport t)
        (SE ++ (SR ++ II)) := by
    have hbase :=
      coalgebraRightInternalFirstTripleSupport_perm_boundary_internal t
    have hbase' :
        List.Perm
          (coalgebraRightInternalFirstTripleSupport t)
          (SE ++
            (SR ++ coalgebraRightInternalInternalTripleSupport t)) := by
      simpa [SE, SR] using hbase
    have hreplace :
        List.Perm
          (SE ++
            (SR ++ coalgebraRightInternalInternalTripleSupport t))
          (SE ++ (SR ++ II)) :=
      List.Perm.append_left SE
        (List.Perm.append_left SR
          (by simpa [II] using hext t))
    exact hbase'.trans hreplace
  have hRparts :
      List.Perm
        (coalgebraRightEmptyFirstTripleSupport t ++
          (coalgebraRightRootFirstTripleSupport t ++
            coalgebraRightInternalFirstTripleSupport t))
        ((E ++ (ER ++ I)) ++ (RU ++ (SE ++ (SR ++ II)))) :=
    hRE.append (hRR.append hRI)
  have hRcanon :
      List.Perm
        (coalgebraRightStageTripleSupport t)
        (E ++ (ER ++ (I ++ (RU ++ (SE ++ (SR ++ II)))))) := by
    refine hRstage.trans (hRparts.trans ?_)
    simp [List.append_assoc]
  have hLstage :=
    coalgebraLeftStageTripleSupport_perm_empty_root_internal t
  have hLE :
      List.Perm
        (coalgebraLeftEmptyFirstTripleSupport t)
        E := by
    simpa [E] using
      coalgebraLeftEmptyFirstTripleSupport_perm_boundary t
  have hLR :
      List.Perm
        (coalgebraLeftRootFirstTripleSupport t)
        (ER ++ (RU ++ SR)) := by
    simpa [ER, RU, SR] using
      coalgebraLeftRootFirstTripleSupport_perm_boundary_internal t
  have hLI :
      List.Perm
        (coalgebraLeftInternalFirstTripleSupport t)
        (I ++ (SE ++ II)) := by
    simpa [I, SE, II] using
      coalgebraLeftInternalFirstTripleSupport_perm_boundary_internal
        hforest t
  have hLparts :
      List.Perm
        (coalgebraLeftEmptyFirstTripleSupport t ++
          (coalgebraLeftRootFirstTripleSupport t ++
            coalgebraLeftInternalFirstTripleSupport t))
        (E ++ ((ER ++ (RU ++ SR)) ++ (I ++ (SE ++ II)))) :=
    hLE.append (hLR.append hLI)
  have hblocks :
      List.Perm
        (E ++ ((ER ++ (RU ++ SR)) ++ (I ++ (SE ++ II))))
        (E ++ (ER ++ (I ++ (RU ++ (SE ++ (SR ++ II)))))) := by
    simpa [List.append_assoc] using
      List.Perm.append_left E
        (List.Perm.append_left ER
          (List.Perm.five_block_internal_stage RU SR I SE II))
  have hLcanon :
      List.Perm
        (coalgebraLeftStageTripleSupport t)
        (E ++ (ER ++ (I ++ (RU ++ (SE ++ (SR ++ II)))))) :=
    hLstage.trans (hLparts.trans hblocks)
  exact hRcanon.trans hLcanon.symm

theorem coalgebraCoassoc_tree_support_of_internal_extension
    (hforest : HypersequentNormalizedForestBoundaryProperPerm)
    (hext :
      ∀ t : PTree,
        List.Perm
          (coalgebraRightInternalInternalTripleSupport t)
          (coalgebraLeftInternalInternalTripleSupport t))
    (t : PTree) :
    coalgebraRightStageTripleElement R t =
      coalgebraLeftStageTripleElement R t := by
  unfold coalgebraRightStageTripleElement coalgebraLeftStageTripleElement
  exact List.sum_map_eq_of_perm
    (coalgebraCoassoc_tree_support_perm_of_internal_extension
      hforest hext t)
    (hypersequentTripleBasisTmul (R := R))

theorem hypersequent_add_eq_zero_iff
    (G H : Hypersequent) :
    G + H = 0 ↔ G = 0 ∧ H = 0 := by
  simpa [hypersequentCounitSupport] using
    hypersequentCounitSupport_add_iff G H

theorem ofForest_ne_zero_of_ne_nil
    {f : Forest}
    (hf : f ≠ []) :
    HQ.ofForest f ≠ 0 := by
  cases f with
  | nil =>
      exact False.elim (hf rfl)
  | cons t ts =>
      exact ofForest_ne_zero_of_mem (f := t :: ts) (u := t) (by simp)

theorem coalgebraRightInternalInternalTripleSupport_first_ne_zero_of_mem
    {t : PTree} {p : HypersequentTripleBasis}
    (hp : p ∈ coalgebraRightInternalInternalTripleSupport t) :
    p.1 ≠ 0 := by
  rcases (mem_coalgebraRightInternalInternalTripleSupport_iff).1 hp with
    ⟨cut₁, hcut₁, cut₂, _hcut₂, rfl⟩
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₁ with
    ⟨hcoal₁, hinternal₁⟩
  rw [coalgebraRightStageTripleOfCuts_of_ne_nil_of_root_not_mem
    (t := t) (cut₁ := cut₁) (cut₂ := cut₂)
    hinternal₁.1 hinternal₁.2]
  exact ofForest_ne_zero_of_ne_nil
    (coalgebraDetachedForest_nonempty_of_internal
      (t := t) (cut := cut₁) hcoal₁ hinternal₁)

theorem coalgebraRightInternalInternalTripleSupport_second_ne_zero_of_mem
    {t : PTree} {p : HypersequentTripleBasis}
    (hp : p ∈ coalgebraRightInternalInternalTripleSupport t) :
    p.2.1 ≠ 0 := by
  rcases (mem_coalgebraRightInternalInternalTripleSupport_iff).1 hp with
    ⟨cut₁, hcut₁, cut₂, hcut₂, rfl⟩
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₁ with
    ⟨_hcoal₁, hinternal₁⟩
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₂ with
    ⟨hcoal₂, hinternal₂⟩
  rw [coalgebraRightStageTripleOfCuts_of_ne_nil_of_root_not_mem
    (t := t) (cut₁ := cut₁) (cut₂ := cut₂)
    hinternal₁.1 hinternal₁.2]
  have hterm :
      coalgebraTensorTermOfCutList (PTree.remainderGo cut₁ [] t) cut₂ =
        (HQ.ofForest (cut₂.filterMap
            (PTree.subtreeAt (PTree.remainderGo cut₁ [] t))),
          HQ.singleton (PTree.remainderGo cut₂ []
            (PTree.remainderGo cut₁ [] t))) :=
    coalgebraTensorTermOfCutList_of_ne_nil_of_root_not_mem
      (t := PTree.remainderGo cut₁ [] t) (cut := cut₂)
      hinternal₂.1 hinternal₂.2
  have hne :
      HQ.ofForest (cut₂.filterMap
          (PTree.subtreeAt (PTree.remainderGo cut₁ [] t))) ≠ 0 :=
    ofForest_ne_zero_of_ne_nil
      (coalgebraDetachedForest_nonempty_of_internal
        (t := PTree.remainderGo cut₁ [] t) (cut := cut₂)
        hcoal₂ hinternal₂)
  simpa [hterm] using hne

theorem coalgebraRightInternalInternalTripleSupport_third_ne_zero_of_mem
    {t : PTree} {p : HypersequentTripleBasis}
    (hp : p ∈ coalgebraRightInternalInternalTripleSupport t) :
    p.2.2 ≠ 0 := by
  rcases (mem_coalgebraRightInternalInternalTripleSupport_iff).1 hp with
    ⟨cut₁, hcut₁, cut₂, hcut₂, rfl⟩
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₁ with
    ⟨_hcoal₁, hinternal₁⟩
  rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₂ with
    ⟨_hcoal₂, hinternal₂⟩
  rw [coalgebraRightStageTripleOfCuts_of_ne_nil_of_root_not_mem
    (t := t) (cut₁ := cut₁) (cut₂ := cut₂)
    hinternal₁.1 hinternal₁.2]
  have hterm :
      coalgebraTensorTermOfCutList (PTree.remainderGo cut₁ [] t) cut₂ =
        (HQ.ofForest (cut₂.filterMap
            (PTree.subtreeAt (PTree.remainderGo cut₁ [] t))),
          HQ.singleton (PTree.remainderGo cut₂ []
            (PTree.remainderGo cut₁ [] t))) :=
    coalgebraTensorTermOfCutList_of_ne_nil_of_root_not_mem
      (t := PTree.remainderGo cut₁ [] t) (cut := cut₂)
      hinternal₂.1 hinternal₂.2
  have hne :
      HQ.singleton (PTree.remainderGo cut₂ []
          (PTree.remainderGo cut₁ [] t)) ≠ 0 :=
    singleton_ne_zero (PTree.remainderGo cut₂ []
      (PTree.remainderGo cut₁ [] t))
  simpa [hterm] using hne

theorem coalgebraLeftInternalInternalTripleSupport_third_ne_zero_of_mem
    {t : PTree} {p : HypersequentTripleBasis}
