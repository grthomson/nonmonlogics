  rcases (mem_nodeRightInternalInternalNormalWitnesses_iff
    (r := r) (s := s) (cs := cs) (w := w)).1 hw with
    ⟨cut₁, hcut₁, cut₂, hcut₂, rfl⟩
  exact nodeRightWitnessToLeftProfileWitness_mem
    (r := r) (s := s) (cs := cs)
    (cut₁ := cut₁) (cut₂ := cut₂) hcut₁ hcut₂

/--
The image of the right witness list under antichain refinement lands inside
the left profile witness list, at the level of raw witness membership.
-/
theorem mem_nodeLeftProfileWitnesses_of_mem_rightToLeftProfileMap
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
