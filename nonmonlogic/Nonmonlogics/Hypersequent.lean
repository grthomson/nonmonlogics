/--
Right internal/internal witness triples depend only on the two staged
antichains, up to permutation.  This is the key adapter between the list-coded
profile witnesses and the proof-theoretic antichain refinement picture.
-/
theorem nodeRightInternalInternalNormalWitnessTriple_eq_of_perm
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₁' cut₂ cut₂' : List Address}
    (hcut₁ :
      cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (hcut₁' :
      cut₁' ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (hperm₁ : cut₁.Perm cut₁')
    (hperm₂ : cut₂.Perm cut₂') :
    nodeRightInternalInternalNormalWitnessTriple r s cs (cut₁, cut₂) =
      nodeRightInternalInternalNormalWitnessTriple r s cs (cut₁', cut₂') := by
  have hdet :
      HQ.ofForest (nodeRootFreeCutDetachedForest cs cut₁) =
        HQ.ofForest (nodeRootFreeCutDetachedForest cs cut₁') :=
    nodeRootFreeCutDetachedHypersequent_eq_of_perm_internal
      (r := r) (s := s) (cs := cs)
      (cut₁ := cut₁) (cut₂ := cut₁') hcut₁ hcut₁' hperm₁
  have hnode :
      PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁) =
        PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁') :=
    nodeRootFreeCutRemainderNode_eq_of_perm_internal
      (r := r) (s := s) (cs := cs)
      (cut₁ := cut₁) (cut₂ := cut₁') hcut₁ hcut₁' hperm₁
  have hq :
      coalgebraTensorTermOfCutList
          (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁)) cut₂ =
        coalgebraTensorTermOfCutList
          (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁')) cut₂' := by
    rw [hnode]
    exact coalgebraTensorTermOfCutList_eq_of_perm hperm₂
  unfold nodeRightInternalInternalNormalWitnessTriple
  simp [hdet, hq]

theorem nodeRightWitness_fullyCanonical_recovered_triple_eq
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {cut₁ cut₂ : List Address}
    (hcut₁ : cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs))
    (hcut₂ :
      cut₂ ∈ internalCoalgebraAdmissibleCuts
        (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁))) :
    nodeRightInternalInternalNormalWitnessTriple r s cs
        (nodeLeftProfileWitnessFullyCanonicalRightWitness r s cs
          (nodeRightWitnessToLeftProfileWitness r s cs (cut₁, cut₂))) =
      nodeRightInternalInternalNormalWitnessTriple r s cs (cut₁, cut₂) := by
  let w := nodeRightWitnessToLeftProfileWitness r s cs (cut₁, cut₂)
  have hw : w ∈ nodeLeftInternalInternalNormalProfileWitnesses r s cs := by
    simpa [w] using
      nodeRightWitnessToLeftProfileWitness_mem
        (r := r) (s := s) (cs := cs)
        (cut₁ := cut₁) (cut₂ := cut₂) hcut₁ hcut₂
  have hcut₁Canon :
      nodeLeftProfileWitnessCanonicalFirstCut r s cs w ∈
        internalCoalgebraAdmissibleCuts (PTree.node r s cs) :=
    nodeLeftProfileWitnessCanonicalFirstCut_mem_internalCoalgebraAdmissibleCuts
      (r := r) (s := s) (cs := cs) (w := w) hw
  have hrawFirst :
      (nodeLeftProfileWitnessFirstCut cs w).Perm cut₁ := by
    simpa [w] using
      nodeRightWitnessAmbientProfile_firstCut_perm
        (r := r) (s := s) (cs := cs)
        (cut₁ := cut₁) (cut₂ := cut₂) hcut₁ hcut₂
  have hcanonFirst :
      (nodeLeftProfileWitnessCanonicalFirstCut r s cs w).Perm cut₁ := by
    exact
      ((nodeLeftProfileWitnessFirstCut_perm_canonical
        (r := r) (s := s) (cs := cs) (w := w) hw).symm).trans
        (by simpa [nodeLeftProfileWitnessCanonicalFirstCut] using hrawFirst)
  have hrawSecond :
      (nodeLeftProfileWitnessSecondCut cs w).Perm cut₂ := by
    simpa [w] using
      nodeRightWitnessAmbientProfile_secondCut_perm
        (r := r) (s := s) (cs := cs)
        (cut₁ := cut₁) (cut₂ := cut₂) hcut₁ hcut₂
  have hcanonSecond :
      (nodeLeftProfileWitnessCanonicalSecondCut r s cs w).Perm cut₂ := by
    exact
      (nodeLeftProfileWitnessSecondCut_perm_canonicalSecondCut
        (r := r) (s := s) (cs := cs) (w := w) hw).symm.trans hrawSecond
  simpa [w, nodeLeftProfileWitnessFullyCanonicalRightWitness] using
    nodeRightInternalInternalNormalWitnessTriple_eq_of_perm
      (r := r) (s := s) (cs := cs)
      (cut₁ := nodeLeftProfileWitnessCanonicalFirstCut r s cs w)
      (cut₁' := cut₁)
      (cut₂ := nodeLeftProfileWitnessCanonicalSecondCut r s cs w)
      (cut₂' := cut₂)
      hcut₁Canon hcut₁ hcanonFirst hcanonSecond

theorem nodeRightWitnessTriple_map_eq_fullyCanonicalRecovered_map
    (r : RuleTag) (s : MultiSequent) (cs : List PTree) :
    (nodeRightInternalInternalNormalWitnesses r s cs).map
        (nodeRightInternalInternalNormalWitnessTriple r s cs) =
      (nodeRightInternalInternalNormalWitnesses r s cs).map
        (fun w =>
          nodeRightInternalInternalNormalWitnessTriple r s cs
            (nodeLeftProfileWitnessFullyCanonicalRightWitness r s cs
              (nodeRightWitnessToLeftProfileWitness r s cs w))) := by
  apply List.map_congr_left
  intro w hw
  rcases (mem_nodeRightInternalInternalNormalWitnesses_iff
      (r := r) (s := s) (cs := cs) (w := w)).1 hw with
    ⟨cut₁, hcut₁, cut₂, hcut₂, rfl⟩
  exact
    (nodeRightWitness_fullyCanonical_recovered_triple_eq
      (r := r) (s := s) (cs := cs)
      (cut₁ := cut₁) (cut₂ := cut₂) hcut₁ hcut₂).symm

theorem mem_leftProfileWitnessTriple_map_of_mem_rightWitnessMap
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {p : HypersequentTripleBasis}
    (hp :
      p ∈ (nodeRightInternalInternalNormalWitnesses r s cs).map
        (nodeRightInternalInternalNormalWitnessTriple r s cs)) :
    p ∈ (nodeLeftInternalInternalNormalProfileWitnesses r s cs).map
      (nodeLeftInternalInternalNormalProfileWitnessTriple r s cs) := by
  rcases List.mem_map.1 hp with ⟨w, hw, hEq⟩
  subst p
  exact mem_leftProfileWitnessTriple_map_of_mem_rightWitnessTriple
    (r := r) (s := s) (cs := cs) hw

/--
Pointwise, the right witness list and its image under the antichain-refinement
map produce the same triple atoms.  This removes one layer from the remaining
count-balance proof: the only remaining counting issue is whether the
refinement map covers the left profile witnesses with the correct
multiplicity.
-/
theorem nodeRightWitnessTriple_map_eq_toLeftProfileWitnessTriple_map
    (r : RuleTag) (s : MultiSequent) (cs : List PTree) :
    (nodeRightInternalInternalNormalWitnesses r s cs).map
        (nodeRightInternalInternalNormalWitnessTriple r s cs) =
      (nodeRightInternalInternalNormalWitnesses r s cs).map
        (fun w =>
          nodeLeftInternalInternalNormalProfileWitnessTriple r s cs
            (nodeRightWitnessToLeftProfileWitness r s cs w)) := by
  apply List.map_congr_left
  intro w hw
  rcases (mem_nodeRightInternalInternalNormalWitnesses_iff
    (r := r) (s := s) (cs := cs) (w := w)).1 hw with
    ⟨cut₁, hcut₁, cut₂, hcut₂, rfl⟩
  exact nodeRightWitnessTriple_eq_leftProfileWitnessTriple
    (r := r) (s := s) (cs := cs)
    (cut₁ := cut₁) (cut₂ := cut₂) hcut₁ hcut₂

/--
The antichain-refinement map sends every right witness to a valid left profile
witness.  This is the membership half of the CK/GL extension bijection.
-/
theorem nodeRightWitnessToLeftProfileWitness_map_mem
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {w : List Address × List Address}
    (hw : w ∈ nodeRightInternalInternalNormalWitnesses r s cs) :
    nodeRightWitnessToLeftProfileWitness r s cs w ∈
