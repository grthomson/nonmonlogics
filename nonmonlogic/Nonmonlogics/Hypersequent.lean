  · exact nodeCanonicalAmbientCut_sublist_allAddresses r s cs cut₁ cut₂
  · exact hnodup
  · intro a ha
    have haStage :
        a ∈ nodeAmbientCutOfRightWitness cut₁ cut₂ :=
      (mem_nodeCanonicalAmbientCutOfRightWitness_iff
        (r := r) (s := s) (cs := cs)
