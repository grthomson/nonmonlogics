theorem nodeRightNormalSupport_subset_left_of_dominated_address_perm
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    (haddr :
      ∀ cut₁ cut₂ : List Address,
        cut₁ ∈ internalCoalgebraAdmissibleCuts (PTree.node r s cs) →
        cut₂ ∈ internalCoalgebraAdmissibleCuts
          (PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁)) →
        List.Perm
          (firstStageDominatedBySecondAddresses cut₁ cut₂)
          (firstStageInsideSecondAddresses cut₁ cut₂))
    {p : HypersequentTripleBasis}
    (hp : p ∈ nodeRightInternalInternalNormalSupport r s cs) :
    p ∈ nodeLeftInternalInternalNormalSupport r s cs := by
  apply nodeRightNormalSupport_subset_left_of_dominated_perm
      (r := r) (s := s) (cs := cs)
  · intro cut₁ cut₂ hcut₁ hcut₂
    rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₁ with
      ⟨hcoal₁, hint₁⟩
    have hfirstRem :
        PTree.remainderGo cut₁ [] (PTree.node r s cs) =
          PTree.node r s (nodeRootFreeCutRemainderChildren cs cut₁) := by
      simpa [nodeRootFreeCutRemainderChildren] using
        PTree.remainderGo_node_root_not_mem
          (r := r) (s := s) (cs := cs) (cut := cut₁) hint₁.2
    have hcut₂Rem :
        cut₂ ∈ internalCoalgebraAdmissibleCuts
          (PTree.remainderGo cut₁ [] (PTree.node r s cs)) := by
      simpa [hfirstRem] using hcut₂
    rcases (mem_internalCoalgebraAdmissibleCuts_iff).1 hcut₂Rem with
      ⟨hcoal₂, hint₂⟩
    have hvalid₂ :
        ∀ b : Address, b ∈ cut₂ →
          ∃ u, PTree.subtreeAt (PTree.node r s cs) b = some u := by
      intro b hb
      rcases node_addresses_of_mem_remainder_coalgebraAdmissibleCuts_of_internal
          (t := PTree.node r s cs) (cut₁ := cut₁) (cut₂ := cut₂)
          hcoal₂ hint₂ b hb with
        ⟨r', s', cs', hsub⟩
      exact ⟨PTree.node r' s' cs', hsub⟩
    exact firstStageDominatedBySecondForest_perm_inside_of_address_perm
      (t := PTree.node r s cs) (cut₁ := cut₁) (cut₂ := cut₂)
      hvalid₂ (haddr cut₁ cut₂ hcut₁ hcut₂)
  · exact hp

