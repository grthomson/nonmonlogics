theorem canonical_nodeLeftProfileWitnessFirstCut_mem_internalCoalgebraAdmissibleCuts
    {r : RuleTag} {s : MultiSequent} {cs : List PTree}
    {w : List Address × List (List Address)}
    (hw : w ∈ nodeLeftInternalInternalNormalProfileWitnesses r s cs)
    (hne : nodeLeftProfileWitnessFirstCut cs w ≠ [])
    (hanti :
      ∀ a, a ∈ nodeLeftProfileWitnessFirstCut cs w →
        ∀ b, b ∈ nodeLeftProfileWitnessFirstCut cs w →
          a ≠ b → ¬ PTree.comparable a b) :
    PTree.canonicalCut (PTree.node r s cs)
        (nodeLeftProfileWitnessFirstCut cs w) ∈
      internalCoalgebraAdmissibleCuts (PTree.node r s cs) := by
  let firstCut := nodeLeftProfileWitnessFirstCut cs w
  let t := PTree.node r s cs
  have hraw :
      PTree.canonicalCut t firstCut ∈ PTree.allAdmissibleCuts t := by
    apply PTree.mem_allAdmissibleCuts_of_sublist_valid_antichain
    · exact PTree.canonicalCut_sublist_allAddresses t firstCut
    · exact PTree.canonicalCut_nodup_of_allAddresses_nodup
        (PTree.allAddresses_nodup t)
    · intro a ha
      exact validAddress_of_mem_nodeLeftProfileWitnessFirstCut
        (r := r) (s := s) (cs := cs) (w := w) hw
        (by
          have hafirst : a ∈ firstCut :=
            (PTree.mem_canonicalCut_iff.1 ha).2
          simpa [firstCut] using hafirst)
    · intro a ha b hb hneab
      exact hanti a (PTree.mem_canonicalCut_iff.1 ha).2
        b (PTree.mem_canonicalCut_iff.1 hb).2 hneab
  have hcoal :
      IsCoalgebraCut t (PTree.canonicalCut t firstCut) := by
    by_cases hnil : PTree.canonicalCut t firstCut = []
    · exact Or.inl hnil
    · by_cases hroot : ([] : Address) ∈ PTree.canonicalCut t firstCut
      · exact Or.inr (Or.inl hroot)
      · exact Or.inr (Or.inr (by
          intro a ha
          have hafirst : a ∈ firstCut := (PTree.mem_canonicalCut_iff.1 ha).2
          exact isNodeAddress_of_mem_nodeLeftProfileWitnessFirstCut
            (r := r) (s := s) (cs := cs) (w := w) hw
            (by simpa [firstCut] using hafirst)))
  have hnotRoot :
      ([] : Address) ∉ PTree.canonicalCut t firstCut := by
    intro hroot
    exact root_not_mem_nodeLeftProfileWitnessFirstCut
      (r := r) (s := s) (cs := cs) (w := w) hw
      (by
        have hmem : ([] : Address) ∈ firstCut :=
          (PTree.mem_canonicalCut_iff.1 hroot).2
        simpa [firstCut] using hmem)
  have hnotNil :
      PTree.canonicalCut t firstCut ≠ [] := by
    intro hcanonNil
    cases hfirst : firstCut with
    | nil =>
        exact hne (by simpa [firstCut] using hfirst)
    | cons a rest =>
        have haFirst : a ∈ firstCut := by
          simpa [hfirst]
        have haAll : a ∈ PTree.allAddresses t := by
          exact mem_allAddresses_of_mem_nodeLeftProfileWitnessFirstCut
            (r := r) (s := s) (cs := cs) (w := w) hw
            (by simpa [firstCut] using haFirst)
        have haCanon :
            a ∈ PTree.canonicalCut t firstCut :=
          PTree.mem_canonicalCut_iff.2 ⟨haAll, haFirst⟩
        simpa [hcanonNil] using haCanon
  exact (mem_internalCoalgebraAdmissibleCuts_iff).2
    ⟨(mem_coalgebraAdmissibleCuts_iff).2 ⟨hraw, hcoal⟩,
      ⟨hnotNil, hnotRoot⟩⟩

