          (nodeRootFreeCutDetachedForest cs cut₁)
          (firstStageOutsideSecondForest (PTree.node r s cs) cut₁ cut₂ ++
            firstStageInsideSecondForest (PTree.node r s cs) cut₁ cut₂))
    {p : HypersequentTripleBasis}
    (hp : p ∈ nodeRightInternalInternalNormalSupport r s cs) :
