theorem filter_not_fst_then_snd_zero_eq_total_root
    {f : Forest}
    (hf : f ≠ []) :
    ((coalgebraForestSplittingTensorSupport f).filter
        (fun p => !(decide (p.1 = 0)))).filter
        (fun p => decide (p.2 = 0)) =
      [(HQ.ofForest f, 0)] := by
  classical
  let xs := coalgebraForestSplittingTensorSupport f
  have hcomm :
      (xs.filter (fun p => !(decide (p.1 = 0)))).filter
          (fun p => decide (p.2 = 0)) =
        (xs.filter (fun p => decide (p.2 = 0))).filter
          (fun p => !(decide (p.1 = 0))) := by
    rw [List.filter_filter, List.filter_filter]
    apply List.filter_congr
    intro p _hp
    by_cases h₁ : p.1 = 0 <;> by_cases h₂ : p.2 = 0 <;>
      simp [h₁, h₂, Bool.and_comm]
  rw [hcomm]
  rw [show xs.filter (fun p => decide (p.2 = 0)) =
      [(HQ.ofForest f, 0)] by
        simpa [xs] using
          coalgebraForestSplittingTensorSupport_filter_snd_zero f]
  simp [ofForest_ne_zero_of_ne_nil hf]

theorem filter_not_fst_then_not_snd_eq_proper
    (f : Forest) :
    ((coalgebraForestSplittingTensorSupport f).filter
        (fun p => !(decide (p.1 = 0)))).filter
        (fun p => !(decide (p.2 = 0))) =
      coalgebraForestProperSplittingTensorSupport f := by
  classical
  unfold coalgebraForestProperSplittingTensorSupport
  rw [List.filter_filter]
  apply List.filter_congr
  intro p _hp
  by_cases h₁ : p.1 = 0 <;> by_cases h₂ : p.2 = 0 <;>
    simp [h₁, h₂]

theorem hypersequentNormalizedForestBoundaryProperPerm :
    HypersequentNormalizedForestBoundaryProperPerm := by
  classical
  intro f hf
  let xs := coalgebraForestSplittingTensorSupport f
  have hperm :
      List.Perm xs
        (xs.filter (fun p => decide (p.1 = 0)) ++
          ((xs.filter (fun p => !(decide (p.1 = 0)))).filter
            (fun p => decide (p.2 = 0)) ++
          (xs.filter (fun p => !(decide (p.1 = 0)))).filter
            (fun p => !(decide (p.2 = 0))))) :=
    List.perm_filter_append_filter_filter_append_filter_filter_not
      xs
      (fun p => decide (p.1 = 0))
      (fun p => decide (p.2 = 0))
  refine hperm.trans ?_
  rw [show xs.filter (fun p => decide (p.1 = 0)) =
      [(0, HQ.ofForest f)] by
        simpa [xs] using
          coalgebraForestSplittingTensorSupport_filter_fst_zero f]
  rw [show (xs.filter (fun p => !(decide (p.1 = 0)))).filter
      (fun p => decide (p.2 = 0)) =
      [(HQ.ofForest f, 0)] by
        simpa [xs] using
          filter_not_fst_then_snd_zero_eq_total_root (f := f) hf]
  rw [show (xs.filter (fun p => !(decide (p.1 = 0)))).filter
      (fun p => !(decide (p.2 = 0))) =
      coalgebraForestProperSplittingTensorSupport f by
        simpa [xs] using
          filter_not_fst_then_not_snd_eq_proper f]

/--
Node-level internal/internal support permutation target.  This isolates the
extension-bijection part of coassociativity after all boundary sectors have
been named explicitly.
-/
def HypersequentNormalizedNodeInternalExtensionPerm : Prop :=
  ∀ r : RuleTag, ∀ s : MultiSequent, ∀ cs : List PTree,
    List.Perm
      (coalgebraRightInternalInternalTripleSupport (PTree.node r s cs))
      (coalgebraLeftInternalInternalTripleSupport (PTree.node r s cs))

/--
Descent-step version of the node internal-extension target.

At a rule node, the proof may use the internal-extension theorem for every
immediate premise subtree.  This is the proof-theoretic induction principle
that matches rooted NMMS derivations: base/primitive leaves terminate, and
logical rules descend through their premise arity.
-/
def HypersequentNormalizedInternalExtensionDescentStep : Prop :=
  ∀ r : RuleTag, ∀ s : MultiSequent, ∀ cs : List PTree,
    (∀ i : Nat, ∀ hi : i < cs.length,
      List.Perm
        (coalgebraRightInternalInternalTripleSupport cs[i])
        (coalgebraLeftInternalInternalTripleSupport cs[i])) →
    List.Perm
      (coalgebraRightInternalInternalTripleSupport (PTree.node r s cs))
      (coalgebraLeftInternalInternalTripleSupport (PTree.node r s cs))

/--
Ambient/staged descent obligation for the internal/internal extension theorem.

This is the correct node-local target: a right witness is a pair
`(cut₁, cut₂)`, and its corresponding left witness is indexed by the ambient
cut obtained by staging `cut₂` over `cut₁`, not by the original `cut₁`.
The premise-subtree induction hypotheses should be used to prove this
node-normal permutation.
-/
def HypersequentNormalizedInternalExtensionAmbientDescentStep : Prop :=
  ∀ r : RuleTag, ∀ s : MultiSequent, ∀ cs : List PTree,
    (∀ i : Nat, ∀ hi : i < cs.length,
      List.Perm
        (coalgebraRightInternalInternalTripleSupport cs[i])
        (coalgebraLeftInternalInternalTripleSupport cs[i])) →
    List.Perm
      (nodeRightInternalInternalNormalSupport r s cs)
      (nodeLeftInternalInternalNormalSupport r s cs)

/--
Ambient node-normal descent implies node descent by the already-proved
root-free normal forms.
-/
theorem internalExtensionDescentStep_of_ambient_descent
    (hambient : HypersequentNormalizedInternalExtensionAmbientDescentStep) :
    HypersequentNormalizedInternalExtensionDescentStep := by
  intro r s cs ih
  rw [coalgebraRightInternalInternalTripleSupport_node_rootFree]
  exact
    (hambient r s cs ih).trans
      (coalgebraLeftInternalInternalTripleSupport_node_rootFree_perm
        r s cs).symm

/--
The rooted descent route for the internal/internal extension theorem.

This avoids naive induction on the nested `PTree` type.  The only mathematical
obligation is now the node descent step: prove the node permutation assuming
it for each premise subtree.
-/
theorem coalgebraInternalInternalExtensionPerm_of_descent_step
    (hstep : HypersequentNormalizedInternalExtensionDescentStep)
    (t : PTree) :
    List.Perm
      (coalgebraRightInternalInternalTripleSupport t)
      (coalgebraLeftInternalInternalTripleSupport t) := by
  exact
    (PTree_size_induction
      (motive := fun t =>
        List.Perm
          (coalgebraRightInternalInternalTripleSupport t)
          (coalgebraLeftInternalInternalTripleSupport t))
      (by
        intro t ih
        cases t with
        | leaf s =>
            exact coalgebraInternalInternalExtensionPerm_leaf s
        | node r s cs =>
            exact hstep r s cs
              (fun i hi =>
                ih cs[i] (node_getElem_size_lt_parent
                  (r := r) (s := s) (cs := cs) hi)))) t

theorem hypersequentNormalizedNodeInternalExtensionPerm_of_descent_step
    (hstep : HypersequentNormalizedInternalExtensionDescentStep) :
    HypersequentNormalizedNodeInternalExtensionPerm := by
  intro r s cs
  exact coalgebraInternalInternalExtensionPerm_of_descent_step
    hstep (PTree.node r s cs)

theorem hypersequentNormalizedNodeInternalExtensionPerm_of_ambient_descent
    (hambient : HypersequentNormalizedInternalExtensionAmbientDescentStep) :
    HypersequentNormalizedNodeInternalExtensionPerm :=
  hypersequentNormalizedNodeInternalExtensionPerm_of_descent_step
    (internalExtensionDescentStep_of_ambient_descent hambient)

theorem hypersequentNormalizedNodeInternalExtensionPerm :
    HypersequentNormalizedNodeInternalExtensionPerm :=
  coalgebraInternalInternalExtensionPerm_node

theorem hypersequentNormalizedNodeInternalExtensionPerm_iff_tree :
    HypersequentNormalizedNodeInternalExtensionPerm ↔
      ∀ t : PTree,
        List.Perm
          (coalgebraRightInternalInternalTripleSupport t)
          (coalgebraLeftInternalInternalTripleSupport t) := by
  constructor
  · intro hnode t
    cases t with
    | leaf s =>
        exact coalgebraInternalInternalExtensionPerm_leaf s
    | node r s cs =>
        exact hnode r s cs
  · intro htree r s cs
    exact htree (PTree.node r s cs)

theorem coalgebraInternalInternalExtensionPerm_of_node
    (hnode : HypersequentNormalizedNodeInternalExtensionPerm)
    (t : PTree) :
    List.Perm
      (coalgebraRightInternalInternalTripleSupport t)
      (coalgebraLeftInternalInternalTripleSupport t) :=
  (hypersequentNormalizedNodeInternalExtensionPerm_iff_tree).1 hnode t

